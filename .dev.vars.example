# Copy to .dev.vars (which is gitignored) for local development.
# `wrangler pages dev` picks these up automatically.

XAI_API_KEY=xai-...
ADMIN_USER=ben
ADMIN_PASSWORD=replace-me-with-something-long
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=ben-h-c/clad-web
GITHUB_BRANCH=main

# Bearer token the agent runner uses to call /api/agent/* (separate from the
# basic-auth console login). Use a long random string; set the same value in
# runner/.env. In production set via `wrangler secret put AGENT_TOKEN`.
AGENT_TOKEN=replace-with-a-long-random-string

# The YouTube Data API key is NOT set here — it lives only in runner/.env
# (the runner runs on the Mac, not in the Worker).

# ---------------------------------------------------------------------------
# Optional, per feature. src/env.d.ts is the authoritative binding list; each
# feature stays inert until its secrets are set. Uncomment what you need.
# ---------------------------------------------------------------------------

# Reader accounts (Better Auth on D1)
#BETTER_AUTH_SECRET=generate-a-long-random-string
#BETTER_AUTH_URL=http://localhost:4321

# Social sign-in (web + native iOS)
#GOOGLE_CLIENT_ID=...
#GOOGLE_CLIENT_SECRET=...
#GOOGLE_IOS_CLIENT_ID=...
#APPLE_CLIENT_ID=...
#APPLE_CLIENT_SECRET=...
#APPLE_APP_BUNDLE_ID=com.bencody.cladfacts
#TWITTER_CLIENT_ID=...
#TWITTER_CLIENT_SECRET=...

# Transactional email (verification, newsletter) — Resend
#RESEND_API_KEY=re_...

# Stripe (Premium supporter tier; checkout stays "Coming soon" until set)
#STRIPE_SECRET_KEY=sk_test_...
#STRIPE_PRICE_MONTHLY=price_...
#STRIPE_PRICE_ANNUAL=price_...
#STRIPE_WEBHOOK_SECRET=whsec_...
#PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# iOS push (APNs) — APNS_KEY is the full .p8 contents (the only real secret)
#APNS_KEY=...
#APNS_KEY_ID=...
#APNS_TEAM_ID=...
#APNS_BUNDLE_ID=com.bencody.cladfacts

# Apple In-App Purchase (App Store Server API)
#APPLE_IAP_KEY=...
#APPLE_IAP_KEY_ID=...
#APPLE_IAP_ISSUER_ID=...

# Deploy-time only — post-deploy zone cache purge (README "Purge on deploy")
#CLOUDFLARE_ZONE_ID=...
#CLOUDFLARE_API_TOKEN=...   # scoped to Zone → Cache Purge only

# App Store surfaces (smart banner, footer badge, home promo). Build-time
# flag, read via import.meta.env — set it in the BUILD environment (or .env),
# not just .dev.vars. Leave unset until the listing is publicly visible.
#PUBLIC_APP_STORE_LIVE=true
