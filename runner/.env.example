# Copy to runner/.env (gitignored). The runner reads these at startup.

# Where the deployed Worker lives (prod). For local testing use http://localhost:8787
WORKER_BASE_URL=https://cladfacts.com

# Must match the AGENT_TOKEN set on the Worker (wrangler secret put AGENT_TOKEN).
AGENT_TOKEN=replace-with-the-same-long-random-string

# xAI key used to generate reports (same key as the Worker's XAI_API_KEY).
XAI_API_KEY=xai-...

# YouTube Data API v3 key (Google Cloud → enable "YouTube Data API v3" → create API key).
YOUTUBE_API_KEY=AIza...

# Absolute path to yt-dlp (brew install yt-dlp). PM2 runs with a minimal PATH.
YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
