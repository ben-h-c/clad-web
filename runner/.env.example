# Copy to runner/.env for local runs (gitignored). In a cloud container, set
# these as the platform's environment variables instead of a .env file.

# Where the deployed Worker lives (prod). For local testing use http://localhost:8787
WORKER_BASE_URL=https://cladfacts.com

# Must match the AGENT_TOKEN set on the Worker (wrangler secret put AGENT_TOKEN).
AGENT_TOKEN=replace-with-the-same-long-random-string

# xAI key used to generate reports (same key as the Worker's XAI_API_KEY).
XAI_API_KEY=xai-...

# YouTube Data API v3 key (Google Cloud → enable "YouTube Data API v3" → create API key).
# Used for outlet scanning AND video metadata (channel/title) — no yt-dlp.
YOUTUBE_API_KEY=AIza...

# Hosted transcript API (replaces yt-dlp, so the runner needs no residential IP).
# Point this at your provider's YouTube-transcript endpoint and key.
TRANSCRIPT_API_URL=https://api.supadata.ai/v1/youtube/transcript
TRANSCRIPT_API_KEY=replace-with-provider-key
# Header to send the key in. Default x-api-key; set to "Authorization" to send
# it as "Bearer <key>" instead.
TRANSCRIPT_API_KEY_HEADER=x-api-key
