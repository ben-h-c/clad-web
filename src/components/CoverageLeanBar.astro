---
/**
 * Overall coverage lean strip — homepage (between Front Page and calendar)
 * and News Trends. Single box only; no "By the Numbers" section wrapper.
 */
import { gradeToGpa, gpaToGrade, leanScoreOf } from "~/lib/topics";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  class?: string;
}
const { posts } = Astro.props;
const wrapClass = ["coverage-lean", Astro.props.class].filter(Boolean).join(" ");

const mean = (ns: number[]) => (ns.length ? ns.reduce((a, b) => a + b, 0) / ns.length : null);
const allLeans = posts.map((p) => leanScoreOf(p.data)).filter((n): n is number => n !== null);
const split = { left: 0, center: 0, right: 0 };
for (const s of allLeans) {
  if (s < -15) split.left++;
  else if (s > 15) split.right++;
  else split.center++;
}
const splitTotal = allLeans.length || 1;
const pct = (n: number) => Math.round((n / splitTotal) * 100);
const overallGpa = mean(
  posts.map((p) => gradeToGpa(p.data.letterGrade)).filter((n): n is number => n !== null)
);
---
{
  /*
   * Homepage (class home-lean): scroll-linked "passing glance" — stays compact
   * until the card is near the vertical center of the viewport, then eases to
   * full prominence. Driven by --lean-focus (0…1). Reduced-motion: static.
   */
}
<aside
  class={wrapClass}
  aria-label="Overall coverage lean"
  data-lean-scroll={wrapClass.includes("home-lean") ? "" : undefined}
  style={wrapClass.includes("home-lean") ? "--lean-focus:0" : undefined}
>
  <h2 class="coverage-lean__title small-caps">Overall coverage lean</h2>
  <div
    class="split-bar"
    role="img"
    aria-label={`Left ${pct(split.left)}%, Center ${pct(split.center)}%, Right ${pct(split.right)}%`}
  >
    <span class="split-bar__seg split--left" style={`width:${pct(split.left)}%`}></span>
    <span class="split-bar__seg split--center" style={`width:${pct(split.center)}%`}></span>
    <span class="split-bar__seg split--right" style={`width:${pct(split.right)}%`}></span>
  </div>
  <div class="split-legend coverage-lean__legend">
    <span><i class="dot split--left"></i> Left {pct(split.left)}%</span>
    <span><i class="dot split--center"></i> Center {pct(split.center)}%</span>
    <span><i class="dot split--right"></i> Right {pct(split.right)}%</span>
  </div>
  <p class="coverage-lean__note">
    {splitTotal.toLocaleString("en-US")} graded reports
    {overallGpa !== null && (
      <>
        {" · "}avg grade <strong>{gpaToGrade(overallGpa)}</strong>
      </>
    )}
  </p>
</aside>

{
  wrapClass.includes("home-lean") && (
    <script>
      // Module scope — only attach scroll listeners once per page session.
      let leanScrollBound = false;

      function leanEls(): HTMLElement[] {
        return [...document.querySelectorAll<HTMLElement>("[data-lean-scroll]")];
      }

      function wireLeanScroll() {
        const reduce =
          typeof matchMedia === "function" &&
          matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (reduce) {
          leanEls().forEach((el) => el.style.setProperty("--lean-focus", "1"));
          return;
        }

        let ticking = false;

        const smoothstep = (t: number) => {
          const x = Math.max(0, Math.min(1, t));
          return x * x * (3 - 2 * x);
        };

        const update = () => {
          ticking = false;
          const vh = window.innerHeight || 1;
          const viewMid = vh * 0.5;
          // Falloff: quiet near edges, peak when card center ≈ viewport mid.
          const range = vh * 0.42;

          leanEls().forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.bottom < -80 || r.top > vh + 80) {
              el.style.setProperty("--lean-focus", "0");
              return;
            }
            const elMid = r.top + r.height * 0.5;
            const dist = Math.abs(elMid - viewMid);
            const focus = smoothstep(1 - dist / range);
            el.style.setProperty("--lean-focus", focus.toFixed(4));
          });
        };

        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(update);
        };

        if (!leanScrollBound) {
          leanScrollBound = true;
          window.addEventListener("scroll", onScroll, { passive: true });
          window.addEventListener("resize", onScroll, { passive: true });
          document.addEventListener("astro:page-load", () => requestAnimationFrame(update));
        }
        update();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", wireLeanScroll);
      } else {
        wireLeanScroll();
      }
    </script>
  )
}
