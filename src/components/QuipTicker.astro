---
import type { QuipData } from "~/lib/agents";

interface Props {
  data: QuipData | null;
}
const { data } = Astro.props;

// Fallback so the strip is never empty before the quip-writer first runs.
// Tone guard: light and human, never mocking the news, facts, or the product
// itself (see BANNED_QUIP_PATTERNS in src/lib/agents.ts).
const FALLBACK = [
  "Drink some water. The news will still be here.",
  "Breaking: you are doing great, actually.",
  "Reminder: primary sources beat hot takes.",
  "Stretch. Blink. Carry on.",
  "Nobody is thinking about you as much as you fear. Refreshing, right?",
  "Read the correction. It's usually the most honest sentence in the paper.",
  "Hot take: a walk outside pairs well with a well-sourced story.",
];
// Cap hard: a handful of quips, rendered ONCE — this strip is decoration, not
// content, and must never be the first meaningful text crawlers/readers hit.
const base = data?.quips?.length ? data.quips : [];
const quips = (base.length >= 8 ? base : [...base, ...FALLBACK]).slice(0, 10);
---
<!-- Decorative marquee: one DOM copy, aria-hidden; CSS drives the loop and
     prefers-reduced-motion pauses it (see .quips rules in global.css). -->
<section class="quips" aria-hidden="true">
  <div class="quips__viewport">
    <div class="quips__track" style={`--n:${quips.length}`}>
      {quips.map((q) => (
        <span class="quips__item">
          <span class="quips__star">✦</span>
          {q}
        </span>
      ))}
    </div>
  </div>
</section>
