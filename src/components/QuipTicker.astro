---
import type { QuipData } from "~/lib/agents";

interface Props {
  data: QuipData | null;
}
const { data } = Astro.props;

// Fallback so the strip is never empty before the quip-writer first runs.
const FALLBACK = [
  "Go touch some grass, none of this really matters to you.",
  "You will not remember this headline in a week.",
  "Breaking: you are doing great, actually.",
  "The algorithm is not your friend. Neither is the ticker above this one.",
  "Drink some water. The news will still be here.",
  "Nobody is thinking about you as much as you fear. Refreshing, right?",
  "Hot take: log off and go outside for a bit.",
];
// Cap the pool so the home page doesn't ship an unbounded (2x-looped) list.
// If the (already-filtered) pool runs thin, top up with FALLBACK so the
// marquee stays dense.
const base = data?.quips?.length ? data.quips : [];
const quips = (base.length >= 8 ? base : [...base, ...FALLBACK]).slice(0, 30);
// Repeat so the marquee loops seamlessly (animation shifts by 50%).
const loop = [...quips, ...quips];
---
<section class="quips" aria-label="For fun">
  <div class="quips__viewport">
    <div class="quips__track" style={`--n:${quips.length}`}>
      {loop.map((q, i) => (
        <span class="quips__item" aria-hidden={i >= quips.length ? "true" : undefined}>
          <span class="quips__star" aria-hidden="true">✦</span>
          {q}
        </span>
      ))}
    </div>
  </div>
</section>
