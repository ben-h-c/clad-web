---
import { env } from "cloudflare:workers";
import { listDrafts, openFlagCount } from "~/lib/agents";

interface Props {
  current: string;
}
const { current } = Astro.props;

let pending = 0;
try {
  pending = (await listDrafts(env.AGENTS)).length;
} catch {
  pending = 0;
}
let flags = 0;
try {
  flags = await openFlagCount(env.AGENTS);
} catch {
  flags = 0;
}

const links = [
  { key: "queue", label: `Pending Queue${pending ? ` (${pending})` : ""}`, href: "/admin/queue/" },
  { key: "intake", label: "Add URLs", href: "/admin/intake/" },
  { key: "posts", label: "Posts", href: "/admin/posts/" },
  { key: "users", label: "Users", href: "/admin/users/" },
  { key: "digest", label: "Email", href: "/admin/digest/" },
  { key: "flags", label: `Reader Flags${flags ? ` (${flags})` : ""}`, href: "/admin/flags/" },
  { key: "comments", label: "Reader Comments", href: "/admin/comments/" },
  { key: "agents", label: "Agents", href: "/admin/agents/" },
  { key: "categories", label: "Categories", href: "/admin/categories/" },
  { key: "compliance", label: "Compliance", href: "/admin/compliance/" },
  { key: "results", label: "Race results", href: "/admin/results/" },
  { key: "stats", label: "Stats", href: "/admin/stats/" },
  { key: "health", label: "Health", href: "/admin/health/" },
];
const currentLabel = links.find((l) => l.key === current)?.label ?? "Console";
---
<nav class="admin-nav" aria-label="Admin console">
  <details class="admin-nav__menu">
    <summary>☰ {currentLabel}</summary>
    <ul class="admin-nav__list">
      {links.map((l) => (
        <li>
          {l.key === current ? (
            <span class="admin-nav__current">{l.label}</span>
          ) : (
            <a href={l.href}>{l.label}</a>
          )}
        </li>
      ))}
    </ul>
  </details>
  <a class="admin-nav__site" href="/" target="_blank" rel="noopener">View site ↗</a>
</nav>
<script is:inline>
  (() => {
    const nav = document.querySelector(".admin-nav");
    if (!nav) return;
    const menu = nav.querySelector("details");
    const list = nav.querySelector(".admin-nav__list") || nav.querySelector("ul");
    const summary = menu && menu.querySelector("summary");
    if (!menu || !list || !summary) return;

    const placeList = () => {
      if (!menu.open) return;
      const r = summary.getBoundingClientRect();
      // Prefer below the button; flip up if near the bottom of the viewport.
      const gap = 4;
      const maxH = Math.min(window.innerHeight * 0.7, 28 * 16);
      let top = r.bottom + gap;
      const spaceBelow = window.innerHeight - r.bottom - gap;
      if (spaceBelow < 8 * 16 && r.top > spaceBelow) {
        // Open upward
        list.style.maxHeight = Math.min(maxH, r.top - gap) + "px";
        top = Math.max(gap, r.top - gap - Math.min(list.scrollHeight || maxH, maxH));
      } else {
        list.style.maxHeight = Math.min(maxH, Math.max(120, spaceBelow)) + "px";
      }
      list.style.top = top + "px";
      list.style.left = Math.max(8, Math.min(r.left, window.innerWidth - 16 - 240)) + "px";
      list.style.minWidth = Math.max(r.width, 15 * 16) + "px";
    };

    const syncOpen = () => {
      document.documentElement.classList.toggle("admin-nav-open", !!menu.open);
      if (menu.open) {
        // Double-rAF so layout is ready after open.
        requestAnimationFrame(() => {
          placeList();
          requestAnimationFrame(placeList);
        });
      }
    };

    menu.addEventListener("toggle", syncOpen);
    window.addEventListener("resize", () => {
      if (menu.open) placeList();
    });
    window.addEventListener(
      "scroll",
      () => {
        if (menu.open) placeList();
      },
      true
    );

    document.addEventListener("click", (e) => {
      if (menu.open && !menu.contains(e.target) && !list.contains(e.target)) {
        menu.open = false;
        syncOpen();
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.open) {
        menu.open = false;
        syncOpen();
      }
    });

    syncOpen();
  })();
</script>
