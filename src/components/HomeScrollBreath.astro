---
/**
 * Homepage scroll driver for the coverage lean strip.
 *
 * Directional latch (not a symmetric center peak):
 *  · Scroll down — expands as the strip approaches, then stays fully open
 *    while it rides up and off the top of the screen.
 *  · Scroll up — same the other way: expands on approach, stays open until
 *    it fully leaves the bottom of the screen.
 *
 * One passive scroll listener + rAF. Values are quantized; @property CSS
 * transitions interpolate between steps.
 */
---
<script>
  let bound = false;
  let ticking = false;
  let lastLean = -1;
  let lastText = -1;
  let leanEl: HTMLElement | null = null;

  /** Last scrollY used to infer direction. */
  let lastScrollY = typeof window !== "undefined" ? window.scrollY || 0 : 0;
  /** 1 = down the page, -1 = up the page. */
  let scrollDir = 1;
  /**
   * Once the strip has opened enough while scrolling a direction, stay fully
   * open until it fully exits the far edge of that direction.
   *  0 = not latched
   *  1 = latched while scrolling down (hold until fully above viewport)
   * -1 = latched while scrolling up (hold until fully below viewport)
   */
  let latch = 0;

  const STEPS = 20;
  const LATCH_AT = 0.55; // raw focus needed to lock open
  const quantize = (v: number) => Math.round(Math.max(0, Math.min(1, v)) * STEPS) / STEPS;

  const smoothstep = (t: number) => {
    const x = Math.max(0, Math.min(1, t));
    return x * x * (3 - 2 * x);
  };

  const setRoot = (name: string, value: number, last: number): number => {
    const q = quantize(value);
    if (q === last) return last;
    document.documentElement.style.setProperty(name, String(q));
    return q;
  };

  const update = () => {
    ticking = false;
    const root = document.documentElement;
    const reduce =
      typeof matchMedia === "function" && matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduce) {
      root.style.setProperty("--home-lean-focus", "1");
      root.style.setProperty("--home-lean-text", "1");
      return;
    }

    if (!leanEl) leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");

    const y = window.scrollY || 0;
    const dy = y - lastScrollY;
    if (Math.abs(dy) > 0.5) {
      scrollDir = dy > 0 ? 1 : -1;
    }
    lastScrollY = y;

    const vh = window.innerHeight || 1;
    const viewMid = vh * 0.5;
    const range = vh * 0.45;

    let raw = 0;
    let fullyAbove = true;
    let fullyBelow = true;

    if (leanEl) {
      const r = leanEl.getBoundingClientRect();
      // Small slack so sub-pixel edges don't flicker the latch.
      fullyAbove = r.bottom < 4;
      fullyBelow = r.top > vh - 4;
      if (!fullyAbove && !fullyBelow) {
        const elMid = r.top + r.height * 0.5;
        raw = smoothstep(1 - Math.abs(elMid - viewMid) / range);
      }
    } else {
      fullyAbove = fullyBelow = true;
      raw = 0;
    }

    // Clear latch only after the strip fully leaves in the latched direction.
    if (latch === 1 && fullyAbove) latch = 0;
    if (latch === -1 && fullyBelow) latch = 0;

    // Arm latch once the strip has opened enough in the current scroll direction.
    if (!latch && raw >= LATCH_AT) {
      latch = scrollDir >= 0 ? 1 : -1;
    }

    // While latched, stay fully expanded regardless of center distance.
    // Otherwise use the live approach curve (opening as you scroll onto it).
    let leanFocus = 0;
    if (latch !== 0) {
      leanFocus = 1;
    } else if (!fullyAbove && !fullyBelow) {
      leanFocus = raw;
    }

    // Labels follow focus, with a slight lag on the way open only when unlatched.
    const leanText =
      latch !== 0 ? 1 : smoothstep((leanFocus - 0.12) / 0.72);

    lastLean = setRoot("--home-lean-focus", leanFocus, lastLean);
    lastText = setRoot("--home-lean-text", leanText, lastText);
  };

  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  };

  const boot = () => {
    leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");
    lastScrollY = window.scrollY || 0;
    latch = 0;
    if (!bound) {
      bound = true;
      window.addEventListener("scroll", onScroll, { passive: true, capture: false });
      window.addEventListener("resize", onScroll, { passive: true });
      document.addEventListener("astro:page-load", () => {
        leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");
        lastScrollY = window.scrollY || 0;
        latch = 0;
        lastLean = lastText = -1;
        requestAnimationFrame(update);
      });
    }
    lastLean = lastText = -1;
    update();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
</script>
