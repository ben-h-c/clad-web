---
/**
 * Homepage scroll driver for the coverage lean strip.
 *
 * Directional latch without layout collapse jumps:
 *  · Scroll down — opens on approach, stays open through the top edge and
 *    while off-screen above (never collapses content above the viewport).
 *  · Scroll up — opens on approach, stays open until fully below; collapse
 *    only happens below the fold so the screen doesn’t jump.
 *
 * Visual open/close uses opacity + transform only (no margin/max-height thrash).
 */
---
<script>
  let bound = false;
  let ticking = false;
  let lastLean = -1;
  let lastText = -1;
  let leanEl: HTMLElement | null = null;

  let lastScrollY = typeof window !== "undefined" ? window.scrollY || 0 : 0;
  /** 1 = down the page, -1 = up the page. */
  let scrollDir = 1;
  /**
   *  0 = free (follow approach curve)
   *  1 = hold open after scrolling down (even when fully above)
   * -1 = hold open after scrolling up (until fully below, then release)
   */
  let latch = 0;
  /** Last applied focus — never drop it while the strip is fully above. */
  let appliedFocus = 0;

  const STEPS = 16;
  const LATCH_AT = 0.5;
  const quantize = (v: number) => Math.round(Math.max(0, Math.min(1, v)) * STEPS) / STEPS;

  const smoothstep = (t: number) => {
    const x = Math.max(0, Math.min(1, t));
    return x * x * (3 - 2 * x);
  };

  const setRoot = (name: string, value: number, last: number): number => {
    const q = quantize(value);
    if (q === last) return last;
    document.documentElement.style.setProperty(name, String(q));
    return q;
  };

  const update = () => {
    ticking = false;
    const root = document.documentElement;
    const reduce =
      typeof matchMedia === "function" && matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduce) {
      root.style.setProperty("--home-lean-focus", "1");
      root.style.setProperty("--home-lean-text", "1");
      return;
    }

    if (!leanEl) leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");

    const y = window.scrollY || 0;
    const dy = y - lastScrollY;
    if (Math.abs(dy) > 0.5) scrollDir = dy > 0 ? 1 : -1;
    lastScrollY = y;

    const vh = window.innerHeight || 1;
    const viewMid = vh * 0.5;
    const range = vh * 0.5;

    let raw = 0;
    let fullyAbove = true;
    let fullyBelow = true;

    if (leanEl) {
      const r = leanEl.getBoundingClientRect();
      fullyAbove = r.bottom < 2;
      fullyBelow = r.top > vh - 2;
      if (!fullyAbove && !fullyBelow) {
        const elMid = r.top + r.height * 0.5;
        raw = smoothstep(1 - Math.abs(elMid - viewMid) / range);
      }
    }

    // Arm latch when the strip has opened enough.
    if (!latch && raw >= LATCH_AT) {
      latch = scrollDir >= 0 ? 1 : -1;
    }

    // Release rules that avoid shrinking content above the viewport:
    //  · down-latch: release only after scrolling back up past the strip
    //    (strip ends fully below us) — height change is below the fold.
    //  · up-latch: release when scrolling down past the strip off the top,
    //    but KEEP applied focus frozen while fullyAbove so height doesn’t
    //    collapse above the fold mid-scroll.
    if (latch === 1 && scrollDir < 0 && fullyBelow) {
      latch = 0;
    }
    if (latch === -1 && scrollDir > 0 && fullyAbove) {
      latch = 0;
      // Don’t force focus to 0 yet while still fullyAbove — freeze below.
    }

    let leanFocus = 0;
    if (latch !== 0) {
      leanFocus = 1;
    } else if (!fullyAbove && !fullyBelow) {
      leanFocus = raw;
    } else if (fullyAbove) {
      // Off the top: freeze last applied value (never animate closed above fold).
      leanFocus = appliedFocus > 0.05 ? appliedFocus : 0;
    } else {
      // Fully below: safe to close.
      leanFocus = 0;
    }

    // Hard freeze: never decrease focus while the strip is fully above.
    if (fullyAbove && leanFocus < appliedFocus) {
      leanFocus = appliedFocus;
    }

    appliedFocus = leanFocus;

    const leanText = leanFocus >= 0.92 ? 1 : smoothstep((leanFocus - 0.08) / 0.75);

    lastLean = setRoot("--home-lean-focus", leanFocus, lastLean);
    lastText = setRoot("--home-lean-text", leanText, lastText);
  };

  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  };

  const boot = () => {
    leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");
    lastScrollY = window.scrollY || 0;
    latch = 0;
    appliedFocus = 0;
    if (!bound) {
      bound = true;
      window.addEventListener("scroll", onScroll, { passive: true, capture: false });
      window.addEventListener("resize", onScroll, { passive: true });
      document.addEventListener("astro:page-load", () => {
        leanEl = document.querySelector<HTMLElement>("[data-lean-scroll]");
        lastScrollY = window.scrollY || 0;
        latch = 0;
        appliedFocus = 0;
        lastLean = lastText = -1;
        requestAnimationFrame(update);
      });
    }
    lastLean = lastText = -1;
    update();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
</script>
