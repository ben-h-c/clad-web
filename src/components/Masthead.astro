---
import { dateline } from "~/lib/dateline";
import { getSessionUser } from "~/lib/user-data";

interface Props {
  date?: Date;
  /** SSR theme for correct theme-toggle aria-pressed on first paint (dark default). */
  theme?: "dark" | "light";
}
const { date = new Date(), theme = "dark" } = Astro.props;

// In the console, keep the masthead within /admin (the logo and nav shouldn't
// bounce the editor out to the public site — AdminNav handles that on purpose).
const isAdmin = Astro.url.pathname.startsWith("/admin");
const homeHref = isAdmin ? "/admin/" : "/";

// Resolve session on the server so signed-in users never flash/see "Sign in".
let signedIn = false;
let accountLabel = "Account";
if (!isAdmin) {
  try {
    const user = await getSessionUser(Astro.request.headers);
    if (user) {
      signedIn = true;
      accountLabel = (user.name || user.email || "Account").trim().slice(0, 28) || "Account";
    }
  } catch {
    signedIn = false;
  }
}
const accountHref = signedIn ? "/account/" : "/login/";
const accountText = signedIn ? "Account" : "Sign in";
const menuAccountText = signedIn ? accountLabel : "Sign in";
---

<header class="masthead" data-signed-in={signedIn ? "1" : "0"}>
  {/* Fixed stack: chrome row + volume/date row */}
  <div class="masthead__fixed">
    <div class="masthead__bar">
      {!isAdmin ? (
        <details class="masthead__menu">
          <summary aria-label="Menu" title="Menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <span class="masthead__menu-label small-caps">Menu</span>
          </summary>
          <nav aria-label="Site">
            <ul class="masthead__menu-list">
              <li class="masthead__popular">
                <p class="masthead__popular-label small-caps">Popular</p>
                <ul class="masthead__popular-list">
                  <li><a href="/bracket/">Ballot board</a></li>
                  <li><a href="/bracket/votes/">Community votes</a></li>
                  <li><a href="/quiz/">Morning quiz</a></li>
                  <li><a href="/elections/map/">Election map</a></li>
                </ul>
              </li>
              <li>
                <details class="masthead__submenu">
                  <summary>Read</summary>
                  <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/discover/">Discover</a></li>
                    <li><a href="/good-news/">Good News</a></li>
                    <li><a href="/trends/">News Trends</a></li>
                    <li><a href="/recent/">Latest reports</a></li>
                    <li><a href="/search/">Search</a></li>
                  </ul>
                </details>
              </li>
              <li>
                <details class="masthead__submenu">
                  <summary>Midterms 2026</summary>
                  <ul>
                    <li><a href="/elections/map/">Interactive map</a></li>
                    <li><a href="/bracket/">Ballot board</a></li>
                    <li><a href="/bracket/votes/">Community votes</a></li>
                    <li><a href="/politicians/">Politicians</a></li>
                  </ul>
                </details>
              </li>
              <li>
                <details class="masthead__submenu">
                  <summary>Play &amp; grades</summary>
                  <ul>
                    <li><a href="/quiz/">Morning Quiz</a></li>
                    <li><a href="/week/">Week in Grades</a></li>
                    <li><a href="/bias/">Check your bias</a></li>
                  </ul>
                </details>
              </li>
              <li>
                <details class="masthead__submenu">
                  <summary>Learn</summary>
                  <ul>
                    <li><a href="/learn/">New to the news?</a></li>
                    <li><a href="/learn/first-vote/">First-time voter</a></li>
                    <li><a href="/students/">Students</a></li>
                    <li><a href="/how-it-works/">How it works</a></li>
                  </ul>
                </details>
              </li>
              <li>
                <details class="masthead__submenu">
                  <summary>More</summary>
                  <ul>
                    <li><a href="/newsletter/">Newsletter</a></li>
                    <li><a href="/press/">Press</a></li>
                    <li><a href="/archive/">Archive</a></li>
                    <li><a href="/about/">About Clad</a></li>
                    <li><a href="/about/#contact">Contact</a></li>
                  </ul>
                </details>
              </li>
              <li class="masthead__menu-account">
                <a id="menu-account" href={accountHref}>{menuAccountText}</a>
              </li>
            </ul>
          </nav>
        </details>
      ) : (
        <span class="masthead__bar-spacer" aria-hidden="true"></span>
      )}
      <p class="masthead__title"><a href={homeHref}>CLAD</a></p>
      {!isAdmin ? (
        <div class="masthead__chrome" role="group" aria-label="Account and display">
          <a class="masthead__account small-caps" id="masthead-account" href={accountHref}>{accountText}</a>
          <button
            type="button"
            class="masthead__theme"
            id="theme-toggle"
            aria-label="Toggle light or dark reading"
            title="Toggle light or dark reading"
            aria-pressed={theme === "dark" ? "true" : "false"}
          >◐</button>
          <a class="masthead__search" href="/search/" aria-label="Search" title="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
            </svg>
          </a>
        </div>
      ) : (
        <span class="masthead__bar-spacer" aria-hidden="true"></span>
      )}
    </div>
    <div class="masthead__meta">
      <span class="date">{dateline(date)}</span>
    </div>
  </div>
  <div class="masthead__identity">
    <p class="masthead__tagline small-caps">Grading Content &amp; Exposing Bias</p>
    <div class="rule rule--double" aria-hidden="true"></div>
  </div>
</header>
{!isAdmin && (
  <script is:inline>
    (() => {
      const menu = document.querySelector(".masthead__menu");
      const syncMenuOpen = () => {
        document.documentElement.classList.toggle("masthead-menu-open", !!(menu && menu.open));
      };
      if (menu) {
        menu.addEventListener("toggle", syncMenuOpen);
        syncMenuOpen();
      }
      document.addEventListener("click", (e) => {
        if (menu && menu.open && !menu.contains(e.target)) {
          menu.open = false;
          syncMenuOpen();
        }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && menu && menu.open) {
          menu.open = false;
          syncMenuOpen();
        }
      });
    })();
    // Only one submenu open at a time (accordion).
    document.querySelectorAll(".masthead__submenu").forEach((sub) => {
      sub.addEventListener("toggle", () => {
        if (!sub.open) return;
        document.querySelectorAll(".masthead__submenu").forEach((other) => {
          if (other !== sub) other.open = false;
        });
      });
    });
    // Client backup only if SSR missed a session (cookie race / bfcache).
    // Theme toggle is wired globally in BaseLayout (capture phase).
    const root = document.querySelector(".masthead");
    if (root && root.getAttribute("data-signed-in") !== "1") {
      fetch("/api/auth/get-session", { headers: { accept: "application/json" }, credentials: "same-origin" })
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const user = d && d.user;
          if (!user) return;
          const acct = document.getElementById("masthead-account");
          if (acct) { acct.textContent = "Account"; acct.href = "/account/"; }
          const m = document.getElementById("menu-account");
          if (m) { m.textContent = user.name || user.email || "Account"; m.href = "/account/"; }
          root.setAttribute("data-signed-in", "1");
        })
        .catch(() => {});
    }
  </script>
)}
