---
import { getCollection } from "astro:content";
import { dateline, volume } from "~/lib/dateline";

interface Props {
  date?: Date;
}
const { date = new Date() } = Astro.props;
const vol = volume(date);
const issue = Math.floor((Date.now() - Date.UTC(2026, 0, 1)) / 86_400_000);

let count = 0;
try {
  count = (await getCollection("posts", (p) => !p.data.draft)).length;
} catch {
  count = 0;
}

// In the console, keep the masthead within /admin (the logo and nav shouldn't
// bounce the editor out to the public site — AdminNav handles that on purpose).
const isAdmin = Astro.url.pathname.startsWith("/admin");
const homeHref = isAdmin ? "/admin/" : "/";
---

<header class="masthead">
  {!isAdmin && (
    <details class="masthead__menu">
      <summary aria-label="Menu" title="Menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <span class="masthead__menu-label small-caps">Menu</span>
      </summary>
      <ul class="masthead__menu-list">
        <li><a href="/">Home</a></li>
        <li><a href="/search/">Search</a></li>
        <li><a href="/about/">About Clad</a></li>
        <li><a href="/about/#contact">Contact</a></li>
        <li><a id="menu-account" href="/login/">Sign in</a></li>
      </ul>
    </details>
  )}
  {!isAdmin && (
    <a class="masthead__search" href="/search/" aria-label="Search" title="Search">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
      </svg>
    </a>
  )}
  {!isAdmin && (
    <a class="masthead__account small-caps" id="masthead-account" href="/login/">Sign in</a>
  )}
  <h1 class="masthead__title"><a href={homeHref} style="color:inherit;text-decoration:none">Clad</a></h1>
  <p class="masthead__tagline small-caps">Grading Content &amp; Exposing Bias</p>
  <div class="rule rule--double" aria-hidden="true"></div>
  <div class="masthead__meta">
    <span class="edition">Vol. {vol} · No. {issue} · {count} {count === 1 ? "Report" : "Reports"}</span>
    <span class="date">{dateline(date)}</span>
  </div>
</header>
{!isAdmin && (
  <script is:inline>
    document.addEventListener("click", (e) => {
      const menu = document.querySelector(".masthead__menu");
      if (menu && menu.open && !menu.contains(e.target)) menu.open = false;
    });
    // Reflect signed-in state (static pages can't know it server-side).
    fetch("/api/auth/get-session", { headers: { accept: "application/json" } })
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        const user = d && d.user;
        if (!user) return;
        const acct = document.getElementById("masthead-account");
        if (acct) { acct.textContent = "Account"; acct.href = "/account/"; }
        const m = document.getElementById("menu-account");
        if (m) { m.textContent = user.name || user.email || "Account"; m.href = "/account/"; }
      })
      .catch(() => {});
  </script>
)}
