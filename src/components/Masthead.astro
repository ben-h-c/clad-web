---
import { getCollection } from "astro:content";
import { dateline, volume, issueNumber } from "~/lib/dateline";

interface Props {
  date?: Date;
}
const { date = new Date() } = Astro.props;
const vol = volume(date);
const issue = issueNumber(date);

let count = 0;
try {
  count = (await getCollection("posts", (p) => !p.data.draft)).length;
} catch {
  count = 0;
}

// In the console, keep the masthead within /admin (the logo and nav shouldn't
// bounce the editor out to the public site — AdminNav handles that on purpose).
const isAdmin = Astro.url.pathname.startsWith("/admin");
const homeHref = isAdmin ? "/admin/" : "/";
---

<header class="masthead">
  {!isAdmin && (
    <details class="masthead__menu">
      <summary aria-label="Menu" title="Menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <span class="masthead__menu-label small-caps">Menu</span>
      </summary>
      <nav aria-label="Site">
        <ul class="masthead__menu-list">
          <li>
            <details class="masthead__submenu">
              <summary>Read</summary>
              <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/discover/">Discover</a></li>
                <li><a href="/good-news/">Good News</a></li>
                <li><a href="/trends/">News Trends</a></li>
                <li><a href="/recent/">Latest reports</a></li>
                <li><a href="/search/">Search</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details class="masthead__submenu">
              <summary>Midterms 2026</summary>
              <ul>
                <li><a href="/bracket/">Race board</a></li>
                <li><a href="/bracket/coverage/">Coverage tournament</a></li>
                <li><a href="/politicians/">Politicians</a></li>
                <li><a href="/bracket/card/">Share card image</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details class="masthead__submenu">
              <summary>Play &amp; grades</summary>
              <ul>
                <li><a href="/quiz/">Morning Quiz</a></li>
                <li><a href="/week/">Week in Grades</a></li>
                <li><a href="/bias/">Check your bias</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details class="masthead__submenu">
              <summary>Learn</summary>
              <ul>
                <li><a href="/learn/">New to the news?</a></li>
                <li><a href="/learn/first-vote/">First-time voter</a></li>
                <li><a href="/students/">Students</a></li>
                <li><a href="/how-it-works/">How it works</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details class="masthead__submenu">
              <summary>More</summary>
              <ul>
                <li><a href="/newsletter/">Newsletter</a></li>
                <li><a href="/press/">Press</a></li>
                <li><a href="/archive/">Archive</a></li>
                <li><a href="/about/">About Clad</a></li>
                <li><a href="/about/#contact">Contact</a></li>
              </ul>
            </details>
          </li>
          <li class="masthead__menu-account">
            <a id="menu-account" href="/login/">Sign in</a>
          </li>
        </ul>
      </nav>
    </details>
  )}
  {!isAdmin && (
    <a class="masthead__search" href="/search/" aria-label="Search" title="Search">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
      </svg>
    </a>
  )}
  {!isAdmin && (
    <button type="button" class="masthead__theme" id="theme-toggle" aria-label="Toggle light or dark reading" title="Toggle light or dark reading">◐</button>
  )}
  {!isAdmin && (
    <a class="masthead__account small-caps" id="masthead-account" href="/login/">Sign in</a>
  )}
  <p class="masthead__title"><a href={homeHref} style="color:inherit;text-decoration:none">Clad</a></p>
  <p class="masthead__tagline small-caps">Grading Content &amp; Exposing Bias</p>
  <div class="rule rule--double" aria-hidden="true"></div>
  <div class="masthead__meta">
    <span class="edition">Vol. {vol} · No. {issue} · {count} {count === 1 ? "Report" : "Reports"}</span>
    <span class="date">{dateline(date)}</span>
  </div>
</header>
{!isAdmin && (
  <script is:inline>
    document.addEventListener("click", (e) => {
      const menu = document.querySelector(".masthead__menu");
      if (menu && menu.open && !menu.contains(e.target)) menu.open = false;
    });
    // Only one submenu open at a time (accordion).
    document.querySelectorAll(".masthead__submenu").forEach((sub) => {
      sub.addEventListener("toggle", () => {
        if (!sub.open) return;
        document.querySelectorAll(".masthead__submenu").forEach((other) => {
          if (other !== sub) other.open = false;
        });
      });
    });
    // Manual light/dark toggle; persists across visits. Light is the default,
    // so an unset theme counts as light (we do not follow the OS preference).
    const themeBtn = document.getElementById("theme-toggle");
    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const root = document.documentElement;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        try { localStorage.setItem("clad_theme", next); } catch {}
        const tc = document.querySelector('meta[name="theme-color"]');
        if (tc) tc.setAttribute("content", next === "dark" ? "#181612" : "#f5edd9");
      });
    }
    // Reflect signed-in state (static pages can't know it server-side).
    fetch("/api/auth/get-session", { headers: { accept: "application/json" } })
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        const user = d && d.user;
        if (!user) return;
        const acct = document.getElementById("masthead-account");
        if (acct) { acct.textContent = "Account"; acct.href = "/account/"; }
        const m = document.getElementById("menu-account");
        if (m) { m.textContent = user.name || user.email || "Account"; m.href = "/account/"; }
      })
      .catch(() => {});
  </script>
)}
