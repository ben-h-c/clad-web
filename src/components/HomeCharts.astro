---
import { gradeToGpa, gpaToGrade, leanScoreOf, type TopicAgg } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";
import type { SentimentMap } from "~/lib/agents";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  topics: TopicAgg[];
  // Social-media sentiment map (KV, scanner-scored); {} hides the reception
  // card and column.
  sentiments?: SentimentMap;
}
const { posts, topics, sentiments = {} } = Astro.props;

const mean = (ns: number[]) => (ns.length ? ns.reduce((a, b) => a + b, 0) / ns.length : null);
function leanLabel(s: number | null): string {
  if (s === null) return "—";
  return Math.abs(s) < 5 ? "Center" : `${Math.abs(Math.round(s))}% ${s > 0 ? "Right" : "Left"}`;
}
function sentiLabel(s: number | null): string {
  if (s === null) return "—";
  return Math.abs(s) < 10 ? "Mixed" : `${Math.abs(Math.round(s))}% ${s > 0 ? "Positive" : "Negative"}`;
}
// Grade band drives the bar colour: A/B = ink, C = muted, D/F = red.
function gradeTier(gpa: number): "good" | "mid" | "bad" {
  if (gpa >= 7) return "good"; // B- and up
  if (gpa >= 4) return "mid"; // C- to C+
  return "bad";
}

// ---- aggregate by media network (established outlets, >=4 graded reports) ----
type Net = { name: string; count: number; lean: number | null; gpa: number | null; senti: number | null };
const byNet = new Map<string, { leans: number[]; gpas: number[]; sentis: number[] }>();
for (const p of posts) {
  const name = p.data.sourceTitle;
  if (!name || !isNewsOutlet(name)) continue;
  if (!byNet.has(name)) byNet.set(name, { leans: [], gpas: [], sentis: [] });
  const e = byNet.get(name)!;
  const l = leanScoreOf(p.data);
  if (l !== null) e.leans.push(l);
  const g = gradeToGpa(p.data.letterGrade);
  if (g !== null) e.gpas.push(g);
  const s = sentiments[p.id]?.score;
  if (typeof s === "number") e.sentis.push(s);
}
const networks: Net[] = [...byNet.entries()]
  .map(([name, e]) => ({
    name,
    count: Math.max(e.leans.length, e.gpas.length),
    lean: mean(e.leans),
    gpa: mean(e.gpas),
    senti: mean(e.sentis),
  }))
  .filter((n) => n.count >= 4);

const biasByNet = [...networks].filter((n) => n.lean !== null).sort((a, b) => a.lean! - b.lean!);
const gradeByNet = [...networks].filter((n) => n.gpa !== null).sort((a, b) => b.gpa! - a.gpa!);
const sentiByNet = [...networks].filter((n) => n.senti !== null).sort((a, b) => b.senti! - a.senti!);

// ---- overall coverage lean split ----
const allLeans = posts.map((p) => leanScoreOf(p.data)).filter((n): n is number => n !== null);
const split = { left: 0, center: 0, right: 0 };
for (const s of allLeans) {
  if (s < -15) split.left++;
  else if (s > 15) split.right++;
  else split.center++;
}
const splitTotal = allLeans.length || 1;
const pct = (n: number) => Math.round((n / splitTotal) * 100);
const overallGpa = mean(posts.map((p) => gradeToGpa(p.data.letterGrade)).filter((n): n is number => n !== null));

// ---- top issues right now (already recency/popularity-ranked) ----
const topIssues = topics.slice(0, 10);
---
<section class="charts">
  <div class="feed__head">
    <h2 class="feed__title">By the Numbers</h2>
    <button type="button" class="charts-expand-all" aria-expanded="false">
      <span class="charts-expand-all__txt">Expand all</span> <span aria-hidden="true">▾</span>
    </button>
  </div>
  <div class="rule rule--double" aria-hidden="true"></div>

  <div class="charts__scroll">
    <button type="button" class="hero-arrow hero-arrow--left" aria-label="Scroll left" hidden>‹</button>
  <div class="charts__grid">
    <!-- Overall coverage -->
    <div class="chart-card">
      <h3 class="chart-card__title small-caps">Overall coverage lean</h3>
      <div class="chart-card__body">
        <div class="split-bar" role="img" aria-label={`Left ${pct(split.left)}%, Center ${pct(split.center)}%, Right ${pct(split.right)}%`}>
          <span class="split-bar__seg split--left" style={`width:${pct(split.left)}%`}></span>
          <span class="split-bar__seg split--center" style={`width:${pct(split.center)}%`}></span>
          <span class="split-bar__seg split--right" style={`width:${pct(split.right)}%`}></span>
        </div>
        <div class="split-legend">
          <span><i class="dot split--left"></i> Left {pct(split.left)}%</span>
          <span><i class="dot split--center"></i> Center {pct(split.center)}%</span>
          <span><i class="dot split--right"></i> Right {pct(split.right)}%</span>
        </div>
        <p class="chart-card__note">
          Across {splitTotal} graded reports · average grade{" "}
          <strong>{overallGpa !== null ? gpaToGrade(overallGpa) : "—"}</strong>
        </p>
      </div>
      <button type="button" class="chart-expand" aria-expanded="false"><span class="chart-expand__txt">Expand</span> <span aria-hidden="true">▾</span></button>
    </div>

    <!-- One bucket for all network breakdowns — collapsed by default -->
    <details class="chart-card chart-card--wide chart-card--network-bucket">
      <summary class="chart-card__summary">
        <span class="chart-card__summary-text">
          <h3 class="chart-card__title small-caps">By network</h3>
          <span class="chart-card__lede">
            Political bias, average grade{sentiByNet.length > 0 ? ", and social reception" : ""} by outlet
          </span>
        </span>
        <span class="chart-card__toggle">
          <span class="chart-card__toggle-txt">Show</span>
          <span aria-hidden="true">▾</span>
        </span>
      </summary>
      <div class="charts-network-stack">
        <div class="chart-panel">
          <h4 class="chart-panel__title small-caps">Political bias by network</h4>
          <div class="chart-rows">
            {biasByNet.map((n) => (
              <div class="chart-row">
                <span class="chart-row__label" title={n.name}>{n.name}</span>
                <div class="bias-track">
                  <span class="bias-center" aria-hidden="true"></span>
                  <span
                    class={`bias-bar ${n.lean! >= 0 ? "is-right" : "is-left"}`}
                    style={`width:${Math.min(50, Math.abs(n.lean!) / 2)}%; ${n.lean! >= 0 ? "left:50%" : "right:50%"}`}
                  ></span>
                </div>
                <span class="chart-row__val">{leanLabel(n.lean)}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="chart-panel">
          <h4 class="chart-panel__title small-caps">Average grade by network</h4>
          <div class="chart-rows">
            {gradeByNet.map((n) => (
              <div class="chart-row">
                <span class="chart-row__label" title={n.name}>{n.name}</span>
                <div class="grade-track">
                  <span class={`grade-bar grade--${gradeTier(n.gpa!)}`} style={`width:${(n.gpa! / 12) * 100}%`}></span>
                </div>
                <span class="chart-row__val">{gpaToGrade(n.gpa!)}</span>
              </div>
            ))}
          </div>
        </div>
        {sentiByNet.length > 0 && (
          <div class="chart-panel">
            <h4 class="chart-panel__title small-caps">Social reception by network</h4>
            <div class="chart-rows">
              {sentiByNet.map((n) => (
                <div class="chart-row">
                  <span class="chart-row__label" title={n.name}>{n.name}</span>
                  <div class="bias-track">
                    <span class="bias-center" aria-hidden="true"></span>
                    <span
                      class={`bias-bar ${n.senti! >= 0 ? "is-pos" : "is-neg"}`}
                      style={`width:${Math.min(50, Math.abs(n.senti!) / 2)}%; ${n.senti! >= 0 ? "left:50%" : "right:50%"}`}
                    ></span>
                  </div>
                  <span class="chart-row__val">{sentiLabel(n.senti)}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </details>

    <!-- Top issues -->
    <div class="chart-card chart-card--wide">
      <h3 class="chart-card__title small-caps">Top issues right now</h3>
      <div class="chart-card__body">
        <ul class="issue-rows">
          {topIssues.map((t) => (
            <li class="issue-row">
              <a class="issue-row__name" href={`/topics/${t.slug}/`}>{t.display}</a>
              <span class="issue-row__count">
                {t.todayCount > 0
                  ? `${t.todayCount} today`
                  : t.recentCount > 0
                    ? `${t.recentCount} recent`
                    : `${t.count} ${t.count === 1 ? "report" : "reports"}`}
              </span>
              <span class={`issue-row__lean ${t.avgLean === null ? "" : t.avgLean > 5 ? "is-right" : t.avgLean < -5 ? "is-left" : "is-center"}`}>
                {leanLabel(t.avgLean)}
              </span>
              <span class={`issue-row__senti ${t.avgSentiment === null ? "" : t.avgSentiment >= 10 ? "is-pos" : t.avgSentiment <= -10 ? "is-neg" : "is-center"}`}>
                {sentiLabel(t.avgSentiment)}
              </span>
              <span class="issue-row__grade">{t.avgGrade ?? "—"}</span>
            </li>
          ))}
        </ul>
      </div>
      <button type="button" class="chart-expand" aria-expanded="false"><span class="chart-expand__txt">Expand</span> <span aria-hidden="true">▾</span></button>
    </div>
  </div>
    <button type="button" class="hero-arrow hero-arrow--right" aria-label="Scroll right">›</button>
  </div>
</section>

<script is:inline>
  (() => {
    const section = document.querySelector(".charts");
    if (!section) return;

    /* ---- horizontal scroll arrows (desktop strip) ---- */
    const wrap = section.querySelector(".charts__scroll");
    const strip = wrap && wrap.querySelector(".charts__grid");
    const left = wrap && wrap.querySelector(".hero-arrow--left");
    const right = wrap && wrap.querySelector(".hero-arrow--right");
    const updateArrows = () => {
      if (!strip || !left || !right) return;
      const max = strip.scrollWidth - strip.clientWidth;
      if (max <= 4) { left.hidden = true; right.hidden = true; return; }
      left.hidden = strip.scrollLeft <= 2;
      right.hidden = strip.scrollLeft >= max - 2;
    };
    if (strip && left && right) {
      const step = () => Math.max(280, strip.clientWidth * 0.85);
      left.addEventListener("click", () => strip.scrollBy({ left: -step(), behavior: "smooth" }));
      right.addEventListener("click", () => strip.scrollBy({ left: step(), behavior: "smooth" }));
      strip.addEventListener("scroll", updateArrows, { passive: true });
    }

    /* ---- collapse / expand (always-visible cards + one network bucket) ---- */
    const cards = [...section.querySelectorAll(".chart-card:not(.chart-card--network-bucket)")];
    const networkBucket = section.querySelector("details.chart-card--network-bucket");
    const setCard = (card, expand) => {
      card.classList.toggle("is-expanded", expand);
      const b = card.querySelector(".chart-expand");
      if (b) {
        b.setAttribute("aria-expanded", String(expand));
        const t = b.querySelector(".chart-expand__txt");
        if (t) t.textContent = expand ? "Collapse" : "Expand";
      }
    };
    // Measure (while not clipped) whether each body overflows the compact box;
    // clip + show an expand button only for those. Short cards stay as-is.
    const COLLAPSE_PX = 8.5 * 16;
    const syncFits = () => {
      cards.forEach((card) => {
        const body = card.querySelector(".chart-card__body");
        const b = card.querySelector(".chart-expand");
        if (!body) return;
        const tall = body.scrollHeight > COLLAPSE_PX + 6;
        card.classList.toggle("is-clipped", tall);
        if (b) b.classList.toggle("is-hidden", !tall);
      });
    };
    cards.forEach((card) => {
      const b = card.querySelector(".chart-expand");
      if (b) b.addEventListener("click", () => { setCard(card, !card.classList.contains("is-expanded")); syncFits(); updateArrows(); });
    });

    const allBtn = section.querySelector(".charts-expand-all");
    const syncBucketLabel = () => {
      if (!networkBucket) return;
      const t = networkBucket.querySelector(".chart-card__toggle-txt");
      if (t) t.textContent = networkBucket.open ? "Hide" : "Show";
    };
    const syncAllBtn = () => {
      if (!allBtn) return;
      const open = !!(networkBucket && networkBucket.open);
      allBtn.setAttribute("aria-expanded", String(open));
      const t = allBtn.querySelector(".charts-expand-all__txt");
      if (t) t.textContent = open ? "Collapse all" : "Expand all";
    };
    if (networkBucket) {
      networkBucket.addEventListener("toggle", () => {
        syncBucketLabel();
        syncAllBtn();
        updateArrows();
      });
    }

    if (allBtn) {
      allBtn.addEventListener("click", () => {
        const expand = allBtn.getAttribute("aria-expanded") !== "true";
        allBtn.setAttribute("aria-expanded", String(expand));
        const t = allBtn.querySelector(".charts-expand-all__txt");
        if (t) t.textContent = expand ? "Collapse all" : "Expand all";
        cards.forEach((card) => setCard(card, expand));
        if (networkBucket) networkBucket.open = expand;
        syncBucketLabel();
        syncFits();
        updateArrows();
      });
    }

    const init = () => { syncBucketLabel(); syncFits(); updateArrows(); };
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
    else init();
    window.addEventListener("load", init);
    window.addEventListener("resize", () => { syncFits(); updateArrows(); });
  })();
</script>
