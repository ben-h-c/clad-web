---
import { gradeToGpa, gpaToGrade, leanScoreOf, type TopicAgg } from "~/lib/topics";
import type { SentimentMap } from "~/lib/agents";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  topics: TopicAgg[];
  // Kept for API compatibility with index.astro (network charts live on /trends/).
  sentiments?: SentimentMap;
}
const { posts, topics } = Astro.props;

const mean = (ns: number[]) => (ns.length ? ns.reduce((a, b) => a + b, 0) / ns.length : null);
function leanLabel(s: number | null): string {
  if (s === null) return "—";
  return Math.abs(s) < 5 ? "Center" : `${Math.abs(Math.round(s))}% ${s > 0 ? "Right" : "Left"}`;
}
function sentiLabel(s: number | null): string {
  if (s === null) return "—";
  return Math.abs(s) < 10 ? "Mixed" : `${Math.abs(Math.round(s))}% ${s > 0 ? "Positive" : "Negative"}`;
}

// ---- overall coverage lean split ----
const allLeans = posts.map((p) => leanScoreOf(p.data)).filter((n): n is number => n !== null);
const split = { left: 0, center: 0, right: 0 };
for (const s of allLeans) {
  if (s < -15) split.left++;
  else if (s > 15) split.right++;
  else split.center++;
}
const splitTotal = allLeans.length || 1;
const pct = (n: number) => Math.round((n / splitTotal) * 100);
const overallGpa = mean(posts.map((p) => gradeToGpa(p.data.letterGrade)).filter((n): n is number => n !== null));

// ---- top issues right now (already recency/popularity-ranked) ----
const topIssues = topics.slice(0, 10);
---
{/* iOS app only — public website uses CoverageLeanBar + TopIssuesGrid instead. */}
<section class="charts home-app-only" data-home-charts>
  <div class="feed__head">
    <h2 class="feed__title">By the Numbers</h2>
    <a class="charts-more" href="/trends/">Full News Trends →</a>
  </div>
  <div class="rule rule--double" aria-hidden="true"></div>

  <div class="charts__scroll">
    <button type="button" class="hero-arrow hero-arrow--left" aria-label="Scroll left" hidden>‹</button>
  <div class="charts__grid">
    <!-- Overall coverage -->
    <div class="chart-card">
      <h3 class="chart-card__title small-caps">Overall coverage lean</h3>
      <div class="chart-card__body">
        <div class="split-bar" role="img" aria-label={`Left ${pct(split.left)}%, Center ${pct(split.center)}%, Right ${pct(split.right)}%`}>
          <span class="split-bar__seg split--left" style={`width:${pct(split.left)}%`}></span>
          <span class="split-bar__seg split--center" style={`width:${pct(split.center)}%`}></span>
          <span class="split-bar__seg split--right" style={`width:${pct(split.right)}%`}></span>
        </div>
        <div class="split-legend">
          <span><i class="dot split--left"></i> Left {pct(split.left)}%</span>
          <span><i class="dot split--center"></i> Center {pct(split.center)}%</span>
          <span><i class="dot split--right"></i> Right {pct(split.right)}%</span>
        </div>
        <p class="chart-card__note">
          Across {splitTotal} graded reports · average grade{" "}
          <strong>{overallGpa !== null ? gpaToGrade(overallGpa) : "—"}</strong>
        </p>
      </div>
      <button type="button" class="chart-expand" aria-expanded="false"><span class="chart-expand__txt">Expand</span> <span aria-hidden="true">▾</span></button>
    </div>

    <!-- Top issues -->
    <div class="chart-card chart-card--wide">
      <h3 class="chart-card__title small-caps">Top issues right now</h3>
      <div class="chart-card__body">
        <ul class="issue-rows">
          {topIssues.map((t) => (
            <li class="issue-row">
              <div class="issue-row__head">
                <a class="issue-row__name" href={`/topics/${t.slug}/`}>{t.display}</a>
                <span class="issue-row__grade">{t.avgGrade ?? "—"}</span>
              </div>
              <div class="issue-row__stats">
                <span class="issue-row__count">
                  {t.todayCount > 0
                    ? `${t.todayCount} today`
                    : t.recentCount > 0
                      ? `${t.recentCount} recent`
                      : `${t.count} ${t.count === 1 ? "report" : "reports"}`}
                </span>
                <span class={`issue-row__lean ${t.avgLean === null ? "" : t.avgLean > 5 ? "is-right" : t.avgLean < -5 ? "is-left" : "is-center"}`}>
                  {leanLabel(t.avgLean)}
                </span>
                <span class={`issue-row__senti ${t.avgSentiment === null ? "" : t.avgSentiment >= 10 ? "is-pos" : t.avgSentiment <= -10 ? "is-neg" : "is-center"}`}>
                  {sentiLabel(t.avgSentiment)}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <button type="button" class="chart-expand" aria-expanded="false"><span class="chart-expand__txt">Expand</span> <span aria-hidden="true">▾</span></button>
    </div>
  </div>
    <button type="button" class="hero-arrow hero-arrow--right" aria-label="Scroll right">›</button>
  </div>
</section>

<script is:inline>
  (() => {
    const section = document.querySelector(".charts");
    if (!section) return;

    /* ---- horizontal scroll arrows (desktop strip) ---- */
    const wrap = section.querySelector(".charts__scroll");
    const strip = wrap && wrap.querySelector(".charts__grid");
    const left = wrap && wrap.querySelector(".hero-arrow--left");
    const right = wrap && wrap.querySelector(".hero-arrow--right");
    const updateArrows = () => {
      if (!strip || !left || !right) return;
      const max = strip.scrollWidth - strip.clientWidth;
      if (max <= 4) { left.hidden = true; right.hidden = true; return; }
      left.hidden = strip.scrollLeft <= 2;
      right.hidden = strip.scrollLeft >= max - 2;
    };
    if (strip && left && right) {
      const step = () => Math.max(280, strip.clientWidth * 0.85);
      left.addEventListener("click", () => strip.scrollBy({ left: -step(), behavior: "smooth" }));
      right.addEventListener("click", () => strip.scrollBy({ left: step(), behavior: "smooth" }));
      strip.addEventListener("scroll", updateArrows, { passive: true });
    }

    /* ---- per-card collapse / expand ---- */
    const cards = [...section.querySelectorAll(".chart-card")];
    const setCard = (card, expand) => {
      card.classList.toggle("is-expanded", expand);
      const b = card.querySelector(".chart-expand");
      if (b) {
        b.setAttribute("aria-expanded", String(expand));
        const t = b.querySelector(".chart-expand__txt");
        if (t) t.textContent = expand ? "Collapse" : "Expand";
      }
    };
    const COLLAPSE_PX = 8.5 * 16;
    const syncFits = () => {
      cards.forEach((card) => {
        const body = card.querySelector(".chart-card__body");
        const b = card.querySelector(".chart-expand");
        if (!body) return;
        const tall = body.scrollHeight > COLLAPSE_PX + 6;
        card.classList.toggle("is-clipped", tall);
        if (b) b.classList.toggle("is-hidden", !tall);
      });
    };
    cards.forEach((card) => {
      const b = card.querySelector(".chart-expand");
      if (b) b.addEventListener("click", () => { setCard(card, !card.classList.contains("is-expanded")); syncFits(); updateArrows(); });
    });

    const init = () => { syncFits(); updateArrows(); };
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
    else init();
    window.addEventListener("load", init);
    window.addEventListener("resize", () => { syncFits(); updateArrows(); });
  })();
</script>
