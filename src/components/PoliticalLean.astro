---
interface Props {
  // Preferred: signed -100 (left) .. +100 (right). Falls back to the legacy
  // enum when an older post has no numeric score.
  score?: number;
  lean?: string;
  size?: "badge" | "header";
}
const { score, lean, size = "badge" } = Astro.props;

const ENUM_TO_SCORE: Record<string, number> = {
  left: -80, "center-left": -40, center: 0, "center-right": 40, right: 80, none: 0,
};

const raw = typeof score === "number" ? score : lean ? ENUM_TO_SCORE[lean] ?? 0 : 0;
const s = Math.max(-100, Math.min(100, Math.round(raw)));
const mag = Math.abs(s);

const label =
  mag < 5 ? "Centered" : `${mag}% ${s > 0 ? "Right" : "Left"}-leaning`;

// marker position on a 0..100 track (left → right)
const pos = (s + 100) / 2;
---
<div class={`lean lean--${size}`}>
  <span class="small-caps lean__label">Political Lean</span>
  <span class="lean__value">{label}</span>
  <div class="lean__scale" aria-hidden="true">
    <span class="lean__scale-end">L</span>
    <div class="lean__track">
      <span class="lean__center"></span>
      <span class="lean__marker" style={`left:${pos}%`}></span>
    </div>
    <span class="lean__scale-end">R</span>
  </div>
</div>
