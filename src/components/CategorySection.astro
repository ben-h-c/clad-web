---
import ReportCard from "~/components/ReportCard.astro";
import { sectionSlug } from "~/lib/sections";
import type { CollectionEntry } from "astro:content";

interface Props {
  section: string;
  posts: CollectionEntry<"posts">[];
  limit?: number;
}
const { section, posts, limit = 6 } = Astro.props;
const shown = posts.slice(0, limit);
const hasMore = posts.length > limit;
---
{shown.length > 0 && (
  <section class="category">
    <div class="category__head">
      <h2 class="category__title">{section}</h2>
      <a class="category__more" href={`/sections/${sectionSlug(section)}/`}>
        More in {section} →
      </a>
    </div>
    <div class="rule rule--double" aria-hidden="true"></div>
    <div class="card-grid">
      {shown.map((p) => <ReportCard post={p} />)}
    </div>
    {hasMore && (
      <p class="category__foot">
        <a href={`/sections/${sectionSlug(section)}/`}>See all {posts.length} in {section} →</a>
      </p>
    )}
  </section>
)}
