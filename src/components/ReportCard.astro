---
import Verdict from "~/components/Verdict.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import { shortDate } from "~/lib/dateline";
import { displayableThumb } from "~/lib/imagePolicy";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "card" | "bar";
  /** Hide grade + political-lean (free/anonymous readers). */
  locked?: boolean;
  /** Today's free sample — render fully unlocked with a badge + leak-checker marker. */
  sample?: boolean;
  /**
   * Hero-strip mode: in the iOS app, compact card + hold-to-preview popup.
   * On the public website these still render as full cards (CSS/JS gated to
   * html.clad-app).
   */
  peek?: boolean;
}
const { post, variant = "card", locked = false, sample = false, peek = false } = Astro.props;
const showLocked = locked && !sample;
const d = post.data;
const isBroadcast = d.type === "broadcast";
const source = d.sourceTitle ?? (() => {
  try {
    return new URL(d.sourceUrl).hostname.replace(/^www\./, "");
  } catch {
    return d.sourceUrl;
  }
})();
const thumb = displayableThumb(d.thumbnail);
// hqdefault onerror fallback applies only when the displayed image is itself a
// YouTube still (maxres 404s for some videos). Owned /generated/ art must never
// fall back to a video still — that's the imagery-policy escape hatch closing.
const isYtStill = !!thumb && /^https:\/\/(img\.youtube\.com|i\.ytimg\.com)\//.test(thumb);
const hq = d.videoId && isYtStill
  ? `https://img.youtube.com/vi/${d.videoId}/hqdefault.jpg`
  : null;

// Lean as a compact "% direction" label.
const ENUM_TO_SCORE: Record<string, number> = {
  left: -80, "center-left": -40, center: 0, "center-right": 40, right: 80, none: 0,
};
const leanScore = typeof d.leanScore === "number"
  ? d.leanScore
  : d.politicalLean ? ENUM_TO_SCORE[d.politicalLean] ?? 0 : null;

// Card text: explain WHY it was graded (fall back to summary for legacy posts).
// Locked readers never see the grade rationale — always the neutral summary.
const blurb = (!showLocked && isBroadcast && d.gradeRationale) ? d.gradeRationale : d.summary;

const cardClass = [
  "report-card",
  `report-card--${variant}`,
  peek ? "report-card--peek" : "",
].filter(Boolean).join(" ");
---
<article
  class={cardClass}
  data-sample-unlocked={sample ? "true" : undefined}
  data-peek={peek ? "true" : undefined}
  aria-expanded={peek ? "false" : undefined}
>
  <a class="report-card__link" href={`/posts/${post.id}/`} draggable="false">
    {thumb && (
      <div class="report-card__thumb">
        <img
          src={thumb}
          alt={`Video: ${d.headline}`}
          width="320"
          height="180"
          loading="lazy"
          decoding="async"
          onerror={hq ? `this.onerror=null;this.src='${hq}'` : undefined}
        />
      </div>
    )}
    <div class="report-card__body">
      {sample && <span class="sample-badge small-caps report-card__detail">Today's free sample</span>}

      {/* Compact grade chip — visible only while peeked (collapsed). */}
      {peek && !showLocked && isBroadcast && d.letterGrade && (
        <div class="report-card__peek-row" aria-hidden="true">
          <LetterGrade grade={d.letterGrade} size="badge" />
          {leanScore !== null && (
            <span class="report-card__peek-lean">
              {leanScore === 0 ? "Center" : leanScore < 0 ? `${Math.abs(leanScore)}% L` : `${leanScore}% R`}
            </span>
          )}
        </div>
      )}
      {peek && showLocked && (
        <div class="report-card__peek-row report-card__peek-row--locked" aria-hidden="true">
          <span class="report-card__peek-lock">🔒</span>
        </div>
      )}
      {peek && !showLocked && !isBroadcast && d.verdict && (
        <div class="report-card__peek-row" aria-hidden="true">
          <Verdict verdict={d.verdict} />
        </div>
      )}

      {/* Full scoreband / verdict — expanded detail (or always when not peek). */}
      <div class="report-card__detail">
        {showLocked ? (
          <div class="scoreband scoreband--locked" aria-hidden="true">
            <span class="grade-lock">🔒 Grade &amp; lean — free with account</span>
          </div>
        ) : isBroadcast && d.letterGrade ? (
          <div class="scoreband">
            <div class="scoreband__grade">
              <LetterGrade grade={d.letterGrade} size="card" />
              <span class="scoreband__cap small-caps">Grade</span>
            </div>
            {leanScore !== null && (
              <div class="scoreband__bias">
                <PoliticalLean score={leanScore} />
              </div>
            )}
          </div>
        ) : d.verdict ? (
          <div class="report-card__titlerow"><Verdict verdict={d.verdict} /></div>
        ) : null}
      </div>

      <h3 class="report-card__headline">{d.headline}</h3>
      <p class="report-card__meta">{shortDate(d.publishedAt)}</p>
      {blurb && <p class="report-card__summary report-card__detail">{blurb}</p>}
    </div>
  </a>
  <p class="report-card__source report-card__detail">
    {isBroadcast && <span aria-hidden="true">▶ </span>}Source:{" "}
    <a href={d.sourceUrl} rel="noopener noreferrer" target="_blank">{source}</a>
  </p>
  {peek && (
    <p class="report-card__hold-hint small-caps" aria-hidden="true">Hold to preview</p>
  )}
</article>
