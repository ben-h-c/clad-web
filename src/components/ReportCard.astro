---
import Verdict from "~/components/Verdict.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import { shortDate } from "~/lib/dateline";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const d = post.data;
const isBroadcast = d.type === "broadcast";
const source = d.sourceTitle ?? (() => {
  try {
    return new URL(d.sourceUrl).hostname.replace(/^www\./, "");
  } catch {
    return d.sourceUrl;
  }
})();
const hq = d.videoId
  ? `https://img.youtube.com/vi/${d.videoId}/hqdefault.jpg`
  : null;

const LEAN_LABELS: Record<string, string> = {
  left: "Leans Left",
  "center-left": "Center-Left",
  center: "Centered",
  "center-right": "Center-Right",
  right: "Leans Right",
  none: "No Bias",
};
const leanLabel = d.politicalLean ? LEAN_LABELS[d.politicalLean] : null;
---
<article class="report-card">
  <a class="report-card__link" href={`/posts/${post.id}/`}>
    {d.thumbnail && (
      <div class="report-card__thumb">
        <img
          src={d.thumbnail}
          alt=""
          width="320"
          height="180"
          loading="lazy"
          decoding="async"
          onerror={hq ? `this.onerror=null;this.src='${hq}'` : undefined}
        />
      </div>
    )}
    <div class="report-card__body">
      <div class="report-card__titlerow">
        {isBroadcast && d.letterGrade ? (
          <span class="grade-tag">
            <span class="grade-tag__label small-caps">Grade</span>
            <LetterGrade grade={d.letterGrade} />
          </span>
        ) : d.verdict ? (
          <Verdict verdict={d.verdict} />
        ) : null}
        <h3 class="report-card__headline">{d.headline}</h3>
      </div>
      <p class="report-card__meta">
        {shortDate(d.publishedAt)}{leanLabel ? ` · ${leanLabel}` : ""}
      </p>
      <p class="report-card__summary">{d.summary}</p>
    </div>
  </a>
  <p class="report-card__source">
    {isBroadcast ? "▶ " : ""}Source:{" "}
    <a href={d.sourceUrl} rel="noopener noreferrer" target="_blank">{source}</a>
  </p>
</article>
