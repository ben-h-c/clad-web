---
import ReportCard from "~/components/ReportCard.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}
const { posts } = Astro.props;
---
{posts.length > 0 && (
  <section class="hero">
    <div class="hero__head">
      <h2 class="small-caps">Front Page</h2>
    </div>
    <div class="hero-strip" aria-label="Featured reports">
      {posts.map((p) => (
        <div class="hero-strip__item">
          <ReportCard post={p} />
        </div>
      ))}
    </div>
  </section>
)}
