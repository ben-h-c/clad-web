---
import ReportCard from "~/components/ReportCard.astro";
import BreakingGroupCard from "~/components/BreakingGroupCard.astro";
import type { CollectionEntry } from "astro:content";

type Item =
  | { kind: "post"; post: CollectionEntry<"posts"> }
  | { kind: "group"; slug: string; title: string; topic?: string; members: CollectionEntry<"posts">[] };

interface Props {
  items: Item[];
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <section class="hero hero--breaking">
    <div class="hero__head">
      <h2 class="small-caps">Breaking News</h2>
    </div>
    <div class="hero-strip-wrap">
      <button type="button" class="hero-arrow hero-arrow--left" aria-label="Scroll left" hidden>‹</button>
      <div class="hero-strip" aria-label="Breaking News reports">
        {items.map((it) => (
          <div class="hero-strip__item">
            {it.kind === "group" ? (
              <BreakingGroupCard slug={it.slug} title={it.title} topic={it.topic} members={it.members} />
            ) : (
              <ReportCard post={it.post} />
            )}
          </div>
        ))}
      </div>
      <button type="button" class="hero-arrow hero-arrow--right" aria-label="Scroll right">›</button>
    </div>
  </section>
)}
