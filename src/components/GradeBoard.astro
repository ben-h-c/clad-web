---
import type { CollectionEntry } from "astro:content";
import LetterGrade from "~/components/LetterGrade.astro";
import { leanScoreOf } from "~/lib/topics";

interface Props {
  top: CollectionEntry<"posts">[];
  bottom: CollectionEntry<"posts">[];
}
const { top, bottom } = Astro.props;

function sourceOf(d: CollectionEntry<"posts">["data"]): string {
  if (d.sourceTitle) return d.sourceTitle;
  try {
    return new URL(d.sourceUrl).hostname.replace(/^www\./, "");
  } catch {
    return "";
  }
}

function leanOf(d: CollectionEntry<"posts">["data"]): { label: string; dir: string } | null {
  const s = leanScoreOf(d);
  if (s === null) return null;
  if (Math.abs(s) < 5) return { label: "Center", dir: "center" };
  return { label: `${Math.abs(s)}% ${s > 0 ? "Right" : "Left"}`, dir: s > 0 ? "right" : "left" };
}

const columns = [
  { key: "top", label: "Highest Graded", posts: top },
  { key: "bottom", label: "Lowest Graded", posts: bottom },
];
---
<section class="gradeboard">
  <div class="feed__head">
    <h2 class="feed__title">Best &amp; Worst Graded</h2>
    <a class="category__more" href="/search/">See all →</a>
  </div>
  <div class="rule rule--double" aria-hidden="true"></div>
  <div class="gradeboard__cols">
    {columns.map((col) => (
      <div class={`gradeboard__col gradeboard__col--${col.key}`}>
        <h3 class="gradeboard__sub small-caps">{col.label}</h3>
        <ol class="gradeboard__list">
          {col.posts.map((p, i) => (
            <li class="gradeboard__item">
              <span class="gradeboard__rank">{i + 1}</span>
              {p.data.letterGrade && <LetterGrade grade={p.data.letterGrade} size="card" />}
              <a class="gradeboard__link" href={`/posts/${p.id}/`}>
                <span class="gradeboard__headline">{p.data.headline}</span>
                <span class="gradeboard__sub-meta">
                  {sourceOf(p.data) && (
                    <span class="gradeboard__source small-caps">{sourceOf(p.data)}</span>
                  )}
                  {leanOf(p.data) && (
                    <span class={`gradeboard__lean gradeboard__lean--${leanOf(p.data)!.dir}`}>
                      {leanOf(p.data)!.label}
                    </span>
                  )}
                </span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    ))}
  </div>
</section>
