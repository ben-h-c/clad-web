---
// First-visit onboarding overlay. Opens from the "How it works" footer link
// (and, when AUTO_OPEN is on, once per visitor via localStorage).
//
// Screenshot-driven: most steps show a real capture of the live site inside a
// browser frame (public/onboarding/*.png), with a slow Ken Burns zoom and an
// animated caption. Generate/refresh those images with:
//   npm run shots          (see scripts/captureOnboarding.mjs)
// If an image is missing the frame degrades to a neutral skeleton — it never
// shows a broken-image icon — so the tour is safe to ship before the captures
// land. The two conceptual steps (Why / Account) stay as CSS art.
---
<div class="tour" id="tour" hidden aria-hidden="true">
  <div class="tour__backdrop" data-tour-skip></div>
  <div class="tour__dialog" role="dialog" aria-modal="true" aria-labelledby="tour-title">
    <button type="button" class="tour__close" data-tour-skip aria-label="Close intro">×</button>
    <div class="tour__progress" aria-hidden="true"><span class="tour__bar" id="tour-bar"></span></div>

    <div class="tour__viewport" id="tour-viewport">
      <!-- 1 — Welcome -->
      <section class="tour__step" data-step="0">
        <div class="tour__art tour__art--shot">
          <div class="shot">
            <div class="shot__chrome" aria-hidden="true">
              <span></span><span></span><span></span>
              <b class="shot__url">cladfacts.com</b>
            </div>
            <div class="shot__frame">
              <img class="shot__img" src="/onboarding/home.png" alt="The CladFacts front page" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="shot__cap">Today's front page</span>
            </div>
          </div>
        </div>
        <p class="tour__kicker">Welcome to</p>
        <h2 class="tour__heading" id="tour-title">CladFacts</h2>
        <p class="tour__text">
          We read the news so you can trust it. Our AI analyzes news articles and
          TV segments, then grades each one for <strong>factual quality</strong>
          and rates its <strong>political lean</strong> — and every verdict is
          hand-reviewed before it's published.
        </p>
      </section>

      <!-- 2 — Why -->
      <section class="tour__step" data-step="1" hidden>
        <div class="tour__art">
          <div class="mk-why">
            <div class="mk-why__row"><span class="bad">✕ Hidden bias</span><b>→</b><span class="fix">✓ Lean rated</span></div>
            <div class="mk-why__row"><span class="bad">✕ No sources</span><b>→</b><span class="fix">✓ Sources cited</span></div>
            <div class="mk-why__row"><span class="bad">✕ Missing context</span><b>→</b><span class="fix">✓ Context added</span></div>
          </div>
        </div>
        <p class="tour__kicker">Why we built it</p>
        <h2 class="tour__heading">The news has blind spots</h2>
        <p class="tour__text">
          Coverage can carry <strong>hidden bias</strong>, skip the
          <strong>sources</strong> behind its claims, or strip away the
          <strong>context</strong> you need to judge a story. CladFacts exists to
          close those gaps — rating the lean, grading the facts, citing the
          sources, and restoring the context — so you see the full picture, not a
          slanted slice.
        </p>
      </section>

      <!-- 3 — Breaking News -->
      <section class="tour__step" data-step="2" hidden>
        <div class="tour__art tour__art--shot">
          <div class="shot">
            <div class="shot__chrome" aria-hidden="true">
              <span></span><span></span><span></span>
              <b class="shot__url">cladfacts.com</b>
            </div>
            <div class="shot__frame">
              <img class="shot__img" src="/onboarding/breaking.png" alt="The Breaking News strip" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="shot__cap">Ranked by impact</span>
            </div>
          </div>
        </div>
        <p class="tour__kicker">Breaking News</p>
        <h2 class="tour__heading">The biggest stories, ranked by impact</h2>
        <p class="tour__text">
          The top strip surfaces what matters most right now. When several outlets
          cover the same event, we group them so you see the whole picture — not
          the same story five times.
        </p>
      </section>

      <!-- 4 — Front Page -->
      <section class="tour__step" data-step="3" hidden>
        <div class="tour__art tour__art--shot">
          <div class="shot">
            <div class="shot__chrome" aria-hidden="true">
              <span></span><span></span><span></span>
              <b class="shot__url">cladfacts.com</b>
            </div>
            <div class="shot__frame">
              <img class="shot__img" src="/onboarding/frontpage.png" alt="The Front Page of graded reports" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="shot__cap">Talk shows, graded</span>
            </div>
          </div>
        </div>
        <p class="tour__kicker">Front Page</p>
        <h2 class="tour__heading">Talk shows, fact-checked</h2>
        <p class="tour__text">
          Roundtables and commentary — Fox &amp; Friends, The View, Bill Maher,
          Jon Stewart and more — get the same grade and lean treatment as hard
          news, so you can weigh the talk against the facts.
        </p>
      </section>

      <!-- 5 — Grades & lean -->
      <section class="tour__step" data-step="4" hidden>
        <div class="tour__art tour__art--shot">
          <div class="shot">
            <div class="shot__chrome" aria-hidden="true">
              <span></span><span></span><span></span>
              <b class="shot__url">cladfacts.com/posts/…</b>
            </div>
            <div class="shot__frame">
              <img class="shot__img" src="/onboarding/report.png" alt="A report showing its grade, lean and sources" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="shot__cap">Grade + lean, explained</span>
            </div>
          </div>
        </div>
        <p class="tour__kicker">How we score</p>
        <h2 class="tour__heading">A letter grade and a lean — with reasons</h2>
        <p class="tour__text">
          The <strong>grade</strong> (A+ to F) reflects factual accuracy and
          sourcing. The <strong>lean</strong> shows how far left or right the
          framing tilts. Each report explains <em>why</em> it got its grade and
          lean — and you can flag any you disagree with.
        </p>
      </section>

      <!-- 6 — Charts & topics -->
      <section class="tour__step" data-step="5" hidden>
        <div class="tour__art tour__art--shot">
          <div class="shot">
            <div class="shot__chrome" aria-hidden="true">
              <span></span><span></span><span></span>
              <b class="shot__url">cladfacts.com/trends</b>
            </div>
            <div class="shot__frame">
              <img class="shot__img" src="/onboarding/trends.png" alt="Charts breaking down bias and grades by network" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="shot__cap">Bias by network</span>
            </div>
          </div>
        </div>
        <p class="tour__kicker">By the Numbers</p>
        <h2 class="tour__heading">See the patterns</h2>
        <p class="tour__text">
          Charts break down bias and grading by network, and the Topics section
          groups coverage by issue so you can compare how different outlets handle
          the same story.
        </p>
      </section>

      <!-- 7 — Account -->
      <section class="tour__step" data-step="6" hidden>
        <div class="tour__art">
          <div class="mk-logo">Clad</div>
        </div>
        <p class="tour__kicker">Make it yours</p>
        <h2 class="tour__heading">Create a free account</h2>
        <p class="tour__text">
          Save articles to read later, follow the topics you care about, and opt
          in to alerts and our newsletter. Always free to browse — no account
          required.
        </p>
        <div class="tour__cta">
          <a class="auth-submit" href="/register/" data-tour-skip>Create account</a>
          <button type="button" class="auth-submit secondary" data-tour-skip>Browse the site</button>
        </div>
      </section>
    </div>

    <div class="tour__timer" id="tour-timer" hidden aria-hidden="true"><span id="tour-timerbar"></span></div>

    <div class="tour__footer">
      <button type="button" class="tour__skip" data-tour-skip>Skip intro</button>
      <div class="tour__dots" id="tour-dots" aria-hidden="true"></div>
      <div class="tour__nav">
        <span class="tour__count" id="tour-count" aria-hidden="true"></span>
        <button type="button" class="tour__back" id="tour-back" hidden>Back</button>
        <button type="button" class="tour__next" id="tour-next">Next</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const KEY = "clad_tour_v1";
    const AUTO_MS = 7000; // per-slide auto-advance dwell
    const tour = document.getElementById("tour");
    if (!tour) return;
    const steps = Array.from(tour.querySelectorAll(".tour__step"));
    const dotsWrap = document.getElementById("tour-dots");
    const viewport = document.getElementById("tour-viewport");
    const dialog = tour.querySelector(".tour__dialog");
    const back = document.getElementById("tour-back");
    const next = document.getElementById("tour-next");
    const bar = document.getElementById("tour-bar");
    const count = document.getElementById("tour-count");
    const timer = document.getElementById("tour-timer");
    const timerBar = document.getElementById("tour-timerbar");
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let auto = false; // auto-advance; on while opened, cancelled on interaction

    // Build dots.
    const dots = steps.map((_, n) => {
      const d = document.createElement("span");
      d.className = "tour__dot";
      d.addEventListener("click", () => goManual(n));
      dotsWrap.append(d);
      return d;
    });

    const stopAuto = () => {
      auto = false;
      timer.hidden = true;
      timer.classList.remove("is-timing", "is-paused");
    };
    const armTimer = () => {
      timer.classList.remove("is-timing", "is-paused");
      if (!auto || i === steps.length - 1) {
        timer.hidden = true;
        return;
      }
      timer.hidden = false;
      timer.style.setProperty("--tour-dur", AUTO_MS + "ms");
      void timerBar.offsetWidth; // reflow → restart the fill animation
      timer.classList.add("is-timing");
    };
    timerBar.addEventListener("animationend", () => {
      if (auto && i < steps.length - 1) go(i + 1);
    });

    const render = () => {
      steps.forEach((s, n) => {
        s.hidden = n !== i;
        s.classList.toggle("is-active", n === i);
      });
      // Restart the active step's entrance animation (remove → reflow → add).
      const active = steps[i];
      active.classList.remove("play");
      void active.offsetWidth;
      active.classList.add("play");

      dots.forEach((d, n) => d.classList.toggle("is-on", n === i));
      back.hidden = i === 0;
      next.textContent = i === steps.length - 1 ? "Finish" : "Next";
      bar.style.width = ((i + 1) / steps.length) * 100 + "%";
      count.textContent = i + 1 + " / " + steps.length;
      armTimer();
    };
    const go = (n) => { i = Math.max(0, Math.min(steps.length - 1, n)); render(); };
    // Any deliberate navigation cancels auto-advance for the session.
    const goManual = (n) => { stopAuto(); go(n); };

    const open = () => {
      tour.hidden = false;
      tour.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      auto = !reduce; // gentle auto-advance as an attraction; off if reduced-motion
      go(0);
    };
    const close = () => {
      stopAuto();
      tour.hidden = true;
      tour.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      try { localStorage.setItem(KEY, "1"); } catch {}
    };

    next.addEventListener("click", () => (i === steps.length - 1 ? close() : goManual(i + 1)));
    back.addEventListener("click", () => goManual(i - 1));
    tour.querySelectorAll("[data-tour-skip]").forEach((el) =>
      el.addEventListener("click", (e) => {
        // Let the "Create account" link navigate; still mark as seen.
        if (el.tagName !== "A") e.preventDefault();
        close();
      })
    );
    document.addEventListener("keydown", (e) => {
      if (tour.hidden) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowRight") next.click();
      else if (e.key === "ArrowLeft" && i > 0) back.click();
    });

    // Pause auto-advance while the pointer rests on the card.
    dialog.addEventListener("pointerenter", () => { if (auto) timer.classList.add("is-paused"); });
    dialog.addEventListener("pointerleave", () => { if (auto) timer.classList.remove("is-paused"); });

    // Swipe / drag between slides (mouse + touch). A click that doesn't move
    // past the threshold falls through, so links and buttons still work.
    let startX = 0, dragging = false, moved = 0;
    viewport.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      dragging = true; startX = e.clientX; moved = 0;
    });
    viewport.addEventListener("pointermove", (e) => {
      if (dragging) moved = e.clientX - startX;
    });
    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(moved) > 60) {
        stopAuto();
        if (moved < 0 && i < steps.length - 1) go(i + 1);
        else if (moved > 0 && i > 0) go(i - 1);
      }
      moved = 0;
    };
    viewport.addEventListener("pointerup", endDrag);
    viewport.addEventListener("pointercancel", endDrag);

    // Re-open from the footer link, anywhere.
    document.getElementById("how-it-works")?.addEventListener("click", (e) => {
      e.preventDefault();
      open();
    });

    // TEMP: first-visit auto-open is disabled. Flip to true once the onboarding
    // screenshots are in public/onboarding/. The "How it works" footer link
    // still opens the tour manually.
    const AUTO_OPEN = false;
    const path = location.pathname;
    const suppressed = /^\/(admin|login|register|account|verified)(\/|$)/.test(path);
    let seen = true;
    try { seen = !!localStorage.getItem(KEY); } catch {}
    if (AUTO_OPEN && !seen && !suppressed) open();
  })();
</script>
