---
// First-visit onboarding overlay. Auto-opens once per visitor (localStorage),
// and can be re-opened anytime via the "How it works" footer link. Each step
// shows a real screenshot of the matching screen (public/tour/*.png), captured
// at iPhone width, so the demo previews the actual app.
---
<div class="tour" id="tour" hidden aria-hidden="true">
  <div class="tour__backdrop" data-tour-skip></div>
  <div class="tour__dialog" role="dialog" aria-modal="true" aria-labelledby="tour-title">
    <button type="button" class="tour__close" data-tour-skip aria-label="Close intro">×</button>
    <div class="tour__progress" aria-hidden="true"><span class="tour__bar" id="tour-bar"></span></div>

    <div class="tour__viewport">
      <!-- 1 — The feed -->
      <section class="tour__step" data-step="0">
        <div class="tour__art tour__art--shot">
          <img class="tour__shot" src="/tour/1-feed.png" width="393" height="852"
               alt="CladFacts home feed: report cards each showing a letter grade and a political-lean rating" />
        </div>
        <p class="tour__kicker">The feed</p>
        <h2 class="tour__heading" id="tour-title">Every story, graded at a glance</h2>
        <p class="tour__text">
          The homepage is a live feed of the day's coverage. Each report carries a
          <strong>letter grade</strong> for factual quality and a
          <strong>political-lean</strong> rating — so you can see what's solid and
          which way it tilts before you even click.
        </p>
      </section>

      <!-- 2 — Inside a report -->
      <section class="tour__step" data-step="1" hidden>
        <div class="tour__art tour__art--shot">
          <img class="tour__shot" src="/tour/2-report.png" width="393" height="852" loading="lazy"
               alt="A graded report showing an A-minus grade, a factuality score of 85, a political-lean slider, and the reasons for the grade" />
        </div>
        <p class="tour__kicker">Inside a report</p>
        <h2 class="tour__heading">A grade, a lean, and the reasons</h2>
        <p class="tour__text">
          Open any report to see its <strong>factuality score</strong>, where it
          falls left-to-right, and plain-English notes on <em>why</em> it earned
          that grade and lean. Disagree with a call? Flag it for review.
        </p>
      </section>

      <!-- 3 — By the Numbers -->
      <section class="tour__step" data-step="2" hidden>
        <div class="tour__art tour__art--shot">
          <img class="tour__shot" src="/tour/3-bias.png" width="393" height="852" loading="lazy"
               alt="By the Numbers charts: overall coverage lean, political bias by network, and average grade by network" />
        </div>
        <p class="tour__kicker">By the Numbers</p>
        <h2 class="tour__heading">See the bias across the news</h2>
        <p class="tour__text">
          Charts break down the <strong>overall coverage lean</strong> and rate
          the political tilt and average grade of each network — so you can compare
          how different outlets handle the same news.
        </p>
      </section>

      <!-- 4 — Search & filter -->
      <section class="tour__step" data-step="3" hidden>
        <div class="tour__art tour__art--shot">
          <img class="tour__shot" src="/tour/4-search.png" width="393" height="852" loading="lazy"
               alt="The search screen with a query box and filters for outlet, grade, political bias, and date" />
        </div>
        <p class="tour__kicker">Search &amp; filter</p>
        <h2 class="tour__heading">Find coverage, your way</h2>
        <p class="tour__text">
          Search by topic, headline, or network, then filter by
          <strong>outlet, date, grade, and political lean</strong> to pull exactly
          the coverage you're looking for.
        </p>
      </section>

      <!-- 5 — Account -->
      <section class="tour__step" data-step="4" hidden>
        <div class="tour__art tour__art--shot">
          <img class="tour__shot" src="/tour/5-account.png" width="393" height="852" loading="lazy"
               alt="The create-account screen for a free CladFacts account" />
        </div>
        <p class="tour__kicker">Make it yours</p>
        <h2 class="tour__heading">Create a free account</h2>
        <p class="tour__text">
          Save reports, follow the topics you care about, and turn on alerts. Your
          first 7 days are <strong>full access</strong> — every grade, lean, the
          bias charts, and search — no card required.
        </p>
        <div class="tour__cta">
          <a class="auth-submit" href="/register/" data-tour-skip>Create account</a>
          <button type="button" class="auth-submit secondary" data-tour-skip>Browse the site</button>
        </div>
      </section>
    </div>

    <div class="tour__footer">
      <button type="button" class="tour__skip" data-tour-skip>Skip</button>
      <div class="tour__dots" id="tour-dots" aria-hidden="true"></div>
      <div class="tour__nav">
        <span class="tour__count" id="tour-count" aria-hidden="true"></span>
        <button type="button" class="tour__back" id="tour-back" hidden>Back</button>
        <button type="button" class="tour__next" id="tour-next">Next</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Screenshot steps: replace the mockup frame with a framed phone shot. */
  .tour__art--shot {
    height: auto;
    border: none;
    background: transparent;
    padding: 0;
    margin: 0 auto 1.2rem;
  }
  .tour__shot {
    display: block;
    height: min(38vh, 300px);
    width: auto;
    max-width: 100%;
    margin: 0 auto;
    border-radius: 12px;
    border: 1px solid var(--rule);
    box-shadow: 0 10px 30px rgba(20, 16, 10, 0.22);
    background: var(--paper);
  }
  @media (max-width: 30rem) {
    .tour__shot { height: min(34vh, 260px); }
  }
</style>

<script is:inline>
  (() => {
    const KEY = "clad_tour_v1";
    const tour = document.getElementById("tour");
    if (!tour) return;
    const steps = Array.from(tour.querySelectorAll(".tour__step"));
    const dotsWrap = document.getElementById("tour-dots");
    const back = document.getElementById("tour-back");
    const next = document.getElementById("tour-next");
    const bar = document.getElementById("tour-bar");
    const count = document.getElementById("tour-count");
    let i = 0;

    // Build dots.
    const dots = steps.map((_, n) => {
      const d = document.createElement("span");
      d.className = "tour__dot";
      d.addEventListener("click", () => go(n));
      dotsWrap.append(d);
      return d;
    });

    const render = () => {
      steps.forEach((s, n) => {
        s.hidden = n !== i;
        s.classList.toggle("is-active", n === i);
      });
      // Restart the active step's entrance animation (remove → reflow → add).
      const active = steps[i];
      active.classList.remove("play");
      void active.offsetWidth;
      active.classList.add("play");

      dots.forEach((d, n) => d.classList.toggle("is-on", n === i));
      back.hidden = i === 0;
      next.textContent = i === steps.length - 1 ? "Finish" : "Next";
      bar.style.width = ((i + 1) / steps.length) * 100 + "%";
      count.textContent = i + 1 + " / " + steps.length;
    };
    const go = (n) => { i = Math.max(0, Math.min(steps.length - 1, n)); render(); };

    const open = () => {
      tour.hidden = false;
      tour.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      go(0);
    };
    const close = () => {
      tour.hidden = true;
      tour.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      try { localStorage.setItem(KEY, "1"); } catch {}
    };

    next.addEventListener("click", () => (i === steps.length - 1 ? close() : go(i + 1)));
    back.addEventListener("click", () => go(i - 1));
    tour.querySelectorAll("[data-tour-skip]").forEach((el) =>
      el.addEventListener("click", (e) => {
        // Let the "Create account" link navigate; still mark as seen.
        if (el.tagName !== "A") e.preventDefault();
        close();
      })
    );
    document.addEventListener("keydown", (e) => {
      if (tour.hidden) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowRight") next.click();
      else if (e.key === "ArrowLeft" && i > 0) back.click();
    });

    // Re-open from the footer link, anywhere.
    document.getElementById("how-it-works")?.addEventListener("click", (e) => {
      e.preventDefault();
      open();
    });

    // First-visit auto-open is enabled. Set AUTO_OPEN = false to disable it
    // (the "How it works" footer link still opens the tour manually either way).
    const AUTO_OPEN = true;
    // Auto-open on first visit — but not on admin/auth utility pages.
    const path = location.pathname;
    const suppressed = /^\/(admin|login|register|account|verified)(\/|$)/.test(path);
    let seen = true;
    try { seen = !!localStorage.getItem(KEY); } catch {}
    if (AUTO_OPEN && !seen && !suppressed) open();
  })();
</script>
