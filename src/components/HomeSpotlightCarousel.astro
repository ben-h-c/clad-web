---
/**
 * Top-of-home spotlight carousel of hot/popular site sections.
 * Arrows (desktop web) + swipe; optional dismiss (localStorage).
 * Visible by default — only hidden after the user closes it.
 */
import type { HomePromo } from "~/lib/homePromos";

interface Props {
  promos: HomePromo[];
  class?: string;
}
const promos = Astro.props.promos ?? [];
const wrapClass = ["home-spotlight", Astro.props.class].filter(Boolean).join(" ");
const multi = promos.length > 1;
/** Bump to re-show for everyone after a product change / bug. */
const DISMISS_KEY = "clad_spotlight_v2";
---
{promos.length > 0 && (
  <section
    class={wrapClass}
    data-home-spotlight
    data-spotlight-key={DISMISS_KEY}
    aria-roledescription="carousel"
    aria-label="Featured on CladFacts"
  >
    <div class="home-spotlight__frame">
      {multi && (
        <button
          type="button"
          class="home-spotlight__arrow home-spotlight__arrow--prev"
          data-spotlight-prev
          aria-label="Previous highlight"
        >
          ‹
        </button>
      )}

      <div class="home-spotlight__viewport" data-spotlight-viewport>
        <ul class="home-spotlight__track" data-spotlight-track>
          {promos.map((p, i) => (
            <li
              class:list={["home-spotlight__slide", i === 0 && "is-active"]}
              data-spotlight-slide
              data-index={i}
              aria-hidden={i === 0 ? "false" : "true"}
              aria-label={`${i + 1} of ${promos.length}`}
            >
              {/* Whole card is the hit target — no separate CTA buttons. */}
              <a
                class:list={["home-promo", "home-promo--spotlight", "home-promo--spotlight-link", p.variant && `home-promo--${p.variant}`]}
                href={p.href}
              >
                <div class="home-promo__text">
                  <p class="home-promo__kicker small-caps">{p.kicker}</p>
                  <p class="home-promo__title">{p.title}</p>
                  <p class="home-promo__body">{p.body}</p>
                </div>
                <span class="home-spotlight__go" aria-hidden="true">→</span>
                <span class="visually-hidden">{p.cta}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {multi && (
        <button
          type="button"
          class="home-spotlight__arrow home-spotlight__arrow--next"
          data-spotlight-next
          aria-label="Next highlight"
        >
          ›
        </button>
      )}

      <button
        type="button"
        class="home-spotlight__close"
        data-spotlight-close
        aria-label="Hide featured highlights"
        title="Close"
      >
        ×
      </button>
    </div>

    {multi && (
      <div class="home-spotlight__dots" data-spotlight-dots role="tablist" aria-label="Choose highlight">
        {promos.map((p, i) => (
          <button
            type="button"
            class:list={["home-spotlight__dot", i === 0 && "is-on"]}
            data-spotlight-dot={i}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`${p.kicker}: ${p.title}`}
          />
        ))}
      </div>
    )}
  </section>
)}

<script is:inline>
  (() => {
    if (window.__homeSpotlight) return;
    window.__homeSpotlight = true;

    // Clear older dismiss keys so a prior close during the hidden-by-default bug
    // doesn't keep the bar gone forever.
    try {
      localStorage.removeItem("clad_spotlight_v1");
    } catch (_) {}

    const wire = (root) => {
      if (!root || root.dataset.spotlightWired === "1") return;
      root.dataset.spotlightWired = "1";

      const key = root.getAttribute("data-spotlight-key") || "clad_spotlight_v2";
      try {
        if (localStorage.getItem(key)) {
          root.hidden = true;
          return;
        }
      } catch (_) {}
      // Always show unless explicitly dismissed (do not start hidden in HTML).
      root.hidden = false;

      const closeBtn = root.querySelector("[data-spotlight-close]");
      closeBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        root.hidden = true;
        try {
          localStorage.setItem(key, "1");
        } catch (_) {}
      });

      const track = root.querySelector("[data-spotlight-track]");
      const slides = [...root.querySelectorAll("[data-spotlight-slide]")];
      const dots = [...root.querySelectorAll("[data-spotlight-dot]")];
      const prev = root.querySelector("[data-spotlight-prev]");
      const next = root.querySelector("[data-spotlight-next]");
      if (!track || slides.length < 2) return;

      let i = 0;
      let touchX = null;

      const go = (n) => {
        i = ((n % slides.length) + slides.length) % slides.length;
        slides.forEach((s, k) => {
          const on = k === i;
          s.classList.toggle("is-active", on);
          s.setAttribute("aria-hidden", on ? "false" : "true");
        });
        dots.forEach((d, k) => {
          const on = k === i;
          d.classList.toggle("is-on", on);
          d.setAttribute("aria-selected", on ? "true" : "false");
        });
        track.style.transform = `translate3d(${-i * 100}%, 0, 0)`;
      };

      prev?.addEventListener("click", () => go(i - 1));
      next?.addEventListener("click", () => go(i + 1));
      dots.forEach((d) => {
        d.addEventListener("click", () => {
          const n = Number(d.getAttribute("data-spotlight-dot"));
          if (Number.isFinite(n)) go(n);
        });
      });

      root.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          go(i - 1);
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          go(i + 1);
        } else if (e.key === "Escape") {
          closeBtn?.click();
        }
      });

      const vp = root.querySelector("[data-spotlight-viewport]");
      if (vp) {
        let touchY = null;
        vp.addEventListener(
          "touchstart",
          (e) => {
            const t = e.changedTouches[0];
            touchX = t?.clientX ?? null;
            touchY = t?.clientY ?? null;
          },
          { passive: true }
        );
        vp.addEventListener(
          "touchend",
          (e) => {
            if (touchX == null) return;
            const t = e.changedTouches[0];
            const x = t?.clientX;
            const y = t?.clientY;
            const dx = x == null ? 0 : x - touchX;
            const dy = y == null || touchY == null ? 0 : y - touchY;
            touchX = null;
            touchY = null;
            // Ignore mostly-vertical gestures so page scroll isn't stolen.
            if (Math.abs(dx) < 48 || Math.abs(dx) < Math.abs(dy) * 1.25) return;
            if (dx < 0) go(i + 1);
            else go(i - 1);
          },
          { passive: true }
        );
      }

      go(0);
    };

    const init = () => {
      document.querySelectorAll("[data-home-spotlight]").forEach(wire);
    };
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
    else init();
  })();
</script>
