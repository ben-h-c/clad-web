---
/**
 * Home / list topic card — media tile when a still exists (image + bottom scrim +
 * overlaid type), plain elevated card as fallback.
 */
import { displayableThumb } from "~/lib/imagePolicy";
import LetterGrade from "~/components/LetterGrade.astro";
import type { TopicAgg } from "~/lib/topics";

interface Props {
  topic: TopicAgg;
  locked?: boolean;
}
const { topic, locked = false } = Astro.props;

const thumb = displayableThumb(topic.thumbnail);

const metaParts: string[] = [];
if (topic.todayCount > 0) {
  metaParts.push(`${topic.todayCount} today`);
  metaParts.push(`${topic.count} ${topic.count === 1 ? "report" : "reports"}`);
} else if (topic.recentCount > 0) {
  metaParts.push(`${topic.recentCount} recent`);
  metaParts.push(`${topic.count} ${topic.count === 1 ? "report" : "reports"}`);
} else {
  metaParts.push(`${topic.count} ${topic.count === 1 ? "report" : "reports"}`);
}
const meta = metaParts.join(" · ");

const leanScore =
  !locked && typeof topic.avgLean === "number" ? topic.avgLean : null;
const leanMag = leanScore === null ? 0 : Math.abs(leanScore);
const leanLabel =
  leanScore === null
    ? null
    : leanMag < 5
      ? "Centered"
      : `${leanMag}% ${leanScore > 0 ? "Right" : "Left"}`;
const leanPos = leanScore === null ? 50 : (Math.max(-100, Math.min(100, leanScore)) + 100) / 2;
const leanSide =
  leanScore === null ? "center" : leanMag < 5 ? "center" : leanScore < 0 ? "left" : "right";

const rowClass = [
  "topic-row",
  thumb ? "topic-row--media" : "topic-row--plain",
].join(" ");
---
<a class={rowClass} href={`/topics/${topic.slug}/`}>
  {thumb ? (
    <>
      <span class="topic-row__bg" aria-hidden="true">
        <img
          src={thumb}
          alt=""
          loading="lazy"
          decoding="async"
          width="640"
          height="360"
          onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
        />
      </span>
      <span class="topic-row__scrim" aria-hidden="true"></span>
    </>
  ) : null}

  <span class="topic-row__content">
    <span class="topic-row__name">{topic.display}</span>
    <span class="topic-row__meta">{meta}</span>

    {leanLabel && (
      <span class={`topic-row__lean topic-row__lean--${leanSide}`} aria-label={`Political lean ${leanLabel}`}>
        <span class="topic-row__lean-label small-caps">Political lean</span>
        <span class="topic-row__lean-value">{leanLabel}</span>
        <span class="topic-row__lean-track" aria-hidden="true">
          <span class="topic-row__lean-end">L</span>
          <span class="topic-row__lean-bar">
            <span class="topic-row__lean-center"></span>
            <span class="topic-row__lean-marker" style={`left:${leanPos}%`}></span>
          </span>
          <span class="topic-row__lean-end">R</span>
        </span>
      </span>
    )}
    {locked && (
      <span class="topic-row__lean topic-row__lean--locked">
        <span class="topic-row__lean-label small-caps">Political lean</span>
        <span class="topic-row__lean-value">Unlock free</span>
      </span>
    )}
  </span>

  {!locked && topic.avgGrade && (
    <span class="topic-row__grade">
      <LetterGrade grade={topic.avgGrade} size="card" />
    </span>
  )}
  {locked && (
    <span class="topic-row__grade grade-lock">
      <span class="grade-lock-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Grade unlocks with a free CladFacts account</span>
    </span>
  )}
</a>
