---
interface Props {
  grade: string;
  size?: "badge" | "card" | "hero";
}
const { grade, size = "badge" } = Astro.props;

// Soft pastel tiers: A = sage, B = amber, C = mid, D/F = rose.
const tier = grade.charAt(0).toUpperCase();
const tierClass =
  tier === "A"
    ? "grade--good"
    : tier === "B"
    ? "grade--b"
    : tier === "C"
    ? "grade--mid"
    : "grade--bad";
---
<span class={`letter-grade letter-grade--${size} ${tierClass}`}>{grade}</span>
