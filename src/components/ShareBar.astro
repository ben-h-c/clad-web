---
interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;

const enc = encodeURIComponent;
const xHref = `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}`;
const fbHref = `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}`;
const smsHref = `sms:?&body=${enc(`${title} ${url}`)}`;
const redditHref = `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}`;
const mailHref = `mailto:?subject=${enc(title)}&body=${enc(`${title}\n\n${url}`)}`;
---
<div class="sharebar" data-url={url} data-title={title}>
  <span class="sharebar__label small-caps">Share</span>

  <button type="button" class="sharebar__btn sharebar__native" hidden aria-label="Share">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="18" cy="5" r="3"></circle>
      <circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <line x1="8.6" y1="10.5" x2="15.4" y2="6.5"></line>
      <line x1="8.6" y1="13.5" x2="15.4" y2="17.5"></line>
    </svg>
    <span>Share</span>
  </button>

  <a class="sharebar__btn" href={smsHref} aria-label="Share via text message">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.5 8.5 0 0 1-12.4 7.5L3 21l2-5.6A8.5 8.5 0 1 1 21 11.5z"></path>
    </svg>
    <span>Text</span>
  </a>

  <a class="sharebar__btn" href={xHref} target="_blank" rel="noopener" aria-label="Share on X">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231 5.447-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"></path>
    </svg>
    <span>X</span>
  </a>

  <a class="sharebar__btn" href={fbHref} target="_blank" rel="noopener" aria-label="Share on Facebook">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.89h2.78l-.44 2.9h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"></path>
    </svg>
    <span>Facebook</span>
  </a>

  <a class="sharebar__btn" href={redditHref} target="_blank" rel="noopener" aria-label="Share on Reddit">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="12" cy="14.5" rx="8.5" ry="5.5"></ellipse>
      <circle cx="8.5" cy="13.5" r="1" fill="currentColor" stroke="none"></circle>
      <circle cx="15.5" cy="13.5" r="1" fill="currentColor" stroke="none"></circle>
      <path d="M9.5 17c1.5 1 3.5 1 5 0"></path>
      <path d="M12 9l1-5 4 1"></path>
      <circle cx="17.5" cy="5.5" r="1.4"></circle>
      <circle cx="4.5" cy="10" r="1.6"></circle>
      <circle cx="19.5" cy="10" r="1.6"></circle>
    </svg>
    <span>Reddit</span>
  </a>

  <button type="button" class="sharebar__btn sharebar__tiktok" aria-label="Share on TikTok — copies a ready-made caption and opens TikTok">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"></path>
    </svg>
    <span class="sharebar__tiktok-label">TikTok</span>
  </button>

  <a class="sharebar__btn" href={mailHref} aria-label="Share by email">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2"></rect>
      <path d="m22 7-10 6L2 7"></path>
    </svg>
    <span>Email</span>
  </a>

  <button type="button" class="sharebar__btn sharebar__copy" aria-label="Copy link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.7 1.7"></path>
      <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.7-1.7"></path>
    </svg>
    <span class="sharebar__copy-label">Copy link</span>
  </button>
</div>

<script is:inline>
  document.querySelectorAll(".sharebar").forEach((bar) => {
    const url = bar.getAttribute("data-url") || location.href;
    const title = bar.getAttribute("data-title") || document.title;

    const native = bar.querySelector(".sharebar__native");
    if (native && navigator.share) {
      native.hidden = false;
      native.addEventListener("click", () => {
        navigator.share({ title, url }).catch(() => {});
      });
    }

    // TikTok has no link-share intent like X/Facebook — the working flow is:
    // put a ready-made caption on the clipboard, then open TikTok's creation
    // surface (the app takes over on phones).
    const tiktok = bar.querySelector(".sharebar__tiktok");
    if (tiktok) {
      tiktok.addEventListener("click", async () => {
        const label = tiktok.querySelector(".sharebar__tiktok-label");
        try {
          await navigator.clipboard.writeText(`${title} ${url}`);
          if (label) {
            label.textContent = "Caption copied!";
            setTimeout(() => (label.textContent = "TikTok"), 2200);
          }
        } catch {
          // Clipboard denied — still open TikTok; the reader can copy manually.
        }
        window.open("https://www.tiktok.com/upload", "_blank", "noopener");
      });
    }

    const copy = bar.querySelector(".sharebar__copy");
    if (copy) {
      copy.addEventListener("click", async () => {
        const label = copy.querySelector(".sharebar__copy-label");
        try {
          await navigator.clipboard.writeText(url);
          if (label) {
            const prev = label.textContent;
            label.textContent = "Copied!";
            setTimeout(() => (label.textContent = prev), 1600);
          }
        } catch {
          if (label) label.textContent = "Copy failed";
        }
      });
    }
  });
</script>
