---
/**
 * Horizontal “Today” media-hero strip — desk highlight + daily calendar +
 * fresh graded reports. Infinite loop scroll (no hard stop at the ends).
 */
import type { HomeFeatureItem } from "~/lib/homeFeatures";
import { todayIsoNy } from "~/lib/calendarEvents";

interface Props {
  items: HomeFeatureItem[];
  class?: string;
  title?: string;
}
const { items, title = "Today" } = Astro.props;
const today = todayIsoNy();
const multi = items.length > 1;
const wrapClass = ["home-features", Astro.props.class].filter(Boolean).join(" ");
---
{items.length > 0 && (
  <section class={wrapClass} aria-label={title} data-home-features>
    <div class="feed__head home-features__head">
      <h2 class="feed__title" id="home-features-title">{title}</h2>
      <a class="category__more" href={`/day/${today}/`}>Full day →</a>
    </div>
    <div class="rule rule--double" aria-hidden="true"></div>

    <div class="home-features__wrap" data-home-features-wrap>
      {multi && (
        <button type="button" class="hero-arrow hero-arrow--left" data-hf-prev aria-label="Previous highlights">‹</button>
      )}
      <div
        class="home-features__strip"
        aria-labelledby="home-features-title"
        data-home-features-strip
        data-loop={multi ? "1" : "0"}
      >
        {items.map((h, i) => {
          const image = h.image || null;
          const slideClass = [
            "media-hero",
            "home-feature",
            "home-features__slide",
            image ? "media-hero--has-image" : "media-hero--plain",
            h.variant && `home-feature--${h.variant}`,
            h.variant && `media-hero--${h.variant}`,
          ]
            .filter(Boolean)
            .join(" ");
          return (
            <article
              class={`home-features__item ${slideClass}`}
              data-home-feature={h.id}
              data-hf-slide
              aria-label={`${i + 1} of ${items.length}: ${h.title}`}
            >
              {image && (
                <div class="media-hero__bg" aria-hidden="true">
                  <img
                    src={image}
                    alt=""
                    width="960"
                    height="540"
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </div>
              )}
              <div class="media-hero__scrim" aria-hidden="true"></div>
              <div class="media-hero__content home-feature__inner">
                <div class="home-feature__text">
                  <p class="home-feature__kicker media-hero__kicker small-caps">{h.kicker}</p>
                  <h3 class="home-feature__title media-hero__title">{h.title}</h3>
                  {h.body && <p class="home-feature__body media-hero__body">{h.body}</p>}
                </div>
                <div class="home-feature__actions media-hero__actions">
                  <a class="home-feature__cta media-hero__cta" href={h.href}>{h.cta}</a>
                  {h.secondaryHref && h.secondaryCta && (
                    <a class="home-feature__secondary media-hero__secondary" href={h.secondaryHref}>
                      {h.secondaryCta}
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>
      {multi && (
        <button type="button" class="hero-arrow hero-arrow--right" data-hf-next aria-label="Next highlights">›</button>
      )}
    </div>
    {multi && (
      <p class="home-features__hint small-caps" aria-hidden="true">
        Swipe · loops · {items.length} stories today
      </p>
    )}
  </section>
)}

{multi && (
  <script is:inline>
    (() => {
      const root = document.querySelector("[data-home-features]");
      if (!root || root.dataset.loopBound === "1") return;
      root.dataset.loopBound = "1";

      const strip = root.querySelector("[data-home-features-strip]");
      const prev = root.querySelector("[data-hf-prev]");
      const next = root.querySelector("[data-hf-next]");
      if (!strip || strip.dataset.loop !== "1") return;

      const originals = Array.from(strip.querySelectorAll("[data-hf-slide]"));
      if (originals.length < 2) return;

      // Duplicate the set once for seamless wrap (start mid-set).
      const frag = document.createDocumentFragment();
      originals.forEach((el) => {
        const clone = el.cloneNode(true);
        clone.setAttribute("aria-hidden", "true");
        // Avoid duplicate eager images fighting bandwidth
        clone.querySelectorAll("img[loading=eager]").forEach((img) => {
          img.setAttribute("loading", "lazy");
        });
        frag.appendChild(clone);
      });
      strip.appendChild(frag);

      let setWidth = 0;
      let jumping = false;
      const reduce = () =>
        matchMedia("(prefers-reduced-motion: reduce)").matches;

      const measure = () => {
        const slides = strip.querySelectorAll("[data-hf-slide]");
        const n = originals.length;
        if (slides.length < n * 2) return;
        const first = slides[0];
        const mid = slides[n];
        if (!first || !mid) return;
        setWidth = mid.offsetLeft - first.offsetLeft;
      };

      /** When scrolled into the clone half, snap back by one set (seamless loop). */
      const jumpIfNeeded = () => {
        if (!setWidth || jumping) return;
        const x = strip.scrollLeft;
        if (x >= setWidth - 1) {
          jumping = true;
          strip.scrollLeft = x - setWidth;
          jumping = false;
        }
      };

      const step = () =>
        Math.max(260, Math.min(setWidth || 400, strip.clientWidth * 0.85));

      const go = (dir) => {
        measure();
        if (!setWidth) return;
        const behavior = reduce() ? "auto" : "smooth";
        // From the start, left needs a silent hop into the clone set first
        if (dir < 0 && strip.scrollLeft <= 6) {
          jumping = true;
          strip.scrollLeft = setWidth + strip.scrollLeft;
          jumping = false;
        }
        strip.scrollBy({ left: dir * step(), behavior });
        window.setTimeout(jumpIfNeeded, reduce() ? 0 : 450);
      };

      prev && prev.addEventListener("click", () => go(-1));
      next && next.addEventListener("click", () => go(1));

      strip.addEventListener(
        "scroll",
        () => {
          if (jumping) return;
          if (strip._hfRaf) return;
          strip._hfRaf = requestAnimationFrame(() => {
            strip._hfRaf = 0;
            jumpIfNeeded();
          });
        },
        { passive: true }
      );

      // Touch: when user flings past the end of the first set, wrap
      strip.addEventListener(
        "scrollend",
        () => {
          jumpIfNeeded();
        },
        { passive: true }
      );

      if (prev) prev.hidden = false;
      if (next) next.hidden = false;

      const boot = () => {
        measure();
        if (setWidth > 0) strip.scrollLeft = 0;
      };
      requestAnimationFrame(() => {
        boot();
        requestAnimationFrame(boot);
      });
      window.addEventListener("resize", () => {
        const frac = setWidth ? (strip.scrollLeft % setWidth) / setWidth : 0;
        measure();
        if (setWidth) strip.scrollLeft = frac * setWidth;
      });

      strip.querySelectorAll("img").forEach((img) => {
        if (!img.complete) img.addEventListener("load", measure, { once: true });
      });
    })();
  </script>
)}
