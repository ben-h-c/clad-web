---
/**
 * Homepage teaser for Human Spotlight — photo + lede + link into full article.
 */
import type { HumanSpotlightStore } from "~/lib/agents";
import {
  spotlightDateKey,
  teaserFromArticle,
  personInitials,
  spotlightDisplayImage,
} from "~/lib/humanSpotlight";

interface Props {
  payload?: HumanSpotlightStore | null;
  class?: string;
}

const todayKey = spotlightDateKey();
const raw = Astro.props.payload;
const show =
  raw &&
  raw.dateKey === todayKey &&
  raw.person &&
  typeof raw.person.name === "string" &&
  raw.person.name.trim() &&
  typeof raw.person.article === "string" &&
  raw.person.article.trim().length > 40;

const person = show ? raw!.person : null;
const display = person ? spotlightDisplayImage(person) : null;
const teaser = person ? teaserFromArticle(person.article, 220) : "";
const initials = person ? personInitials(person.name) : "";
const href = "/human-spotlight/";

const wrapClass = ["human-spot", Astro.props.class].filter(Boolean).join(" ");
---
{show && person && (
  <section class={wrapClass} aria-labelledby="human-spot-title" id="human-spotlight">
    <div class="feed__head">
      <h2 class="feed__title" id="human-spot-title">Human Spotlight</h2>
      <a class="category__more" href={href}>Today’s story →</a>
    </div>
    <div class="rule rule--double" aria-hidden="true"></div>

    <a class="human-spot__teaser" href={href}>
      <div
        class:list={["human-spot__photo", display?.kind === "youtube" && "human-spot__photo--video"]}
        aria-hidden={display ? "true" : undefined}
      >
        {display ? (
          <img
            src={display.src}
            alt=""
            width="200"
            height="200"
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span class="human-spot__initials" aria-hidden="true">{initials}</span>
        )}
      </div>
      <div class="human-spot__intro">
        {(person.field || person.location) && (
          <p class="human-spot__meta small-caps">
            {[person.field, person.location].filter(Boolean).join(" · ")}
            {" · "}
            {raw!.dateLabel}
          </p>
        )}
        {!(person.field || person.location) && (
          <p class="human-spot__meta small-caps">{raw!.dateLabel}</p>
        )}
        <h3 class="human-spot__name">{person.name}</h3>
        <p class="human-spot__achievement">{person.achievement}</p>
        {teaser && <p class="human-spot__lede">{teaser}</p>}
        <span class="human-spot__cta">Read the full story →</span>
      </div>
    </a>
  </section>
)}
