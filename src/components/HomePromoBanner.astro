---
/**
 * Dismissible home spotlights from ~/lib/homePromos.
 * Close hides for this page view only — refresh or a new visit shows them again.
 */
import { activeHomePromos, type HomePromo } from "~/lib/homePromos";

interface Props {
  /** Override for tests; defaults to active promos now. */
  promos?: HomePromo[];
}
const promos = Astro.props.promos ?? activeHomePromos();
---
{promos.length > 0 && (
  <div class="home-promos" data-home-promos>
    {promos.map((p) => (
      <aside
        class:list={["home-promo", p.variant && `home-promo--${p.variant}`]}
        data-promo-id={p.id}
      >
        <div class="home-promo__text">
          <p class="home-promo__kicker small-caps">{p.kicker}</p>
          <p class="home-promo__title">{p.title}</p>
          <p class="home-promo__body">{p.body}</p>
        </div>
        <div class="home-promo__actions">
          <a class="home-promo__cta" href={p.href}>{p.cta}</a>
          {p.secondaryHref && p.secondaryCta && (
            <a class="home-promo__secondary" href={p.secondaryHref}>{p.secondaryCta}</a>
          )}
        </div>
        <button
          type="button"
          class="home-promo__close"
          data-promo-dismiss
          aria-label={`Dismiss ${p.kicker} highlight`}
        >×</button>
      </aside>
    ))}
  </div>
  <script is:inline>
    (() => {
      // Clear any old permanent dismiss flags from earlier builds.
      try {
        Object.keys(localStorage)
          .filter((k) => k.startsWith("clad_promo_"))
          .forEach((k) => localStorage.removeItem(k));
      } catch {}
      document.querySelectorAll("[data-home-promos] [data-promo-dismiss]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const el = btn.closest("[data-promo-id]");
          if (el) el.hidden = true;
        });
      });
    })();
  </script>
)}
