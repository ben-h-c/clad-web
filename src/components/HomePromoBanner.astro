---
/**
 * Dismissible home spotlight(s). Pass a single promo or a list.
 * Close hides for this page view only — refresh shows them again.
 * Script binds once per page even if this component is mounted multiple times.
 */
import {
  activeHomePromos,
  homePromosForPage,
  type HomePromo,
  type HomePromoContext,
} from "~/lib/homePromos";

interface Props {
  /** Explicit promo(s) to render. */
  promos?: HomePromo[];
  /** Single promo convenience prop. */
  promo?: HomePromo | null;
  /** Live context when building the list here (legacy). */
  context?: HomePromoContext;
  /** Extra class on the wrapper (e.g. mid-page spacing). */
  class?: string;
}
const list: HomePromo[] =
  Astro.props.promo != null
    ? [Astro.props.promo]
    : Astro.props.promos ??
      (Astro.props.context ? homePromosForPage(Astro.props.context) : activeHomePromos());
const wrapClass = ["home-promos", Astro.props.class].filter(Boolean).join(" ");
---
{list.length > 0 && (
  <div class={wrapClass} data-home-promos>
    {list.map((p) => (
      <aside
        class:list={["home-promo", p.variant && `home-promo--${p.variant}`]}
        data-promo-id={p.id}
      >
        <div class="home-promo__text">
          <p class="home-promo__kicker small-caps">{p.kicker}</p>
          <p class="home-promo__title">{p.title}</p>
          <p class="home-promo__body">{p.body}</p>
        </div>
        <div class="home-promo__actions">
          <a class="home-promo__cta" href={p.href}>{p.cta}</a>
          {p.secondaryHref && p.secondaryCta && (
            <a class="home-promo__secondary" href={p.secondaryHref}>{p.secondaryCta}</a>
          )}
        </div>
        <button
          type="button"
          class="home-promo__close"
          data-promo-dismiss
          aria-label={`Dismiss ${p.kicker} highlight`}
        >×</button>
      </aside>
    ))}
  </div>
)}
