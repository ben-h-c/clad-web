---
import { PRICE, TRIAL_DAYS } from "~/lib/access";

interface Props {
  signedIn: boolean;
}
const { signedIn } = Astro.props;
---
<section class="paywall">
  <p class="small-caps paywall__eyebrow">CladFacts Premium</p>
  <h2 class="paywall__title">Grades, bias charts &amp; the full picture</h2>
  <p class="paywall__lede">
    Letter grades, political-lean ratings, the By-the-Numbers charts, the
    Best &amp; Worst Graded boards, and the News Trends dashboard are part
    of Premium.{signedIn ? "" : ` Your first ${TRIAL_DAYS} days are free.`}
  </p>
  <div class="paywall__cta">
    <a class="auth-submit" href="/upgrade/">See plans — {PRICE.monthly}/mo</a>
    {!signedIn && <a class="auth-submit secondary" href="/register/">Start free week</a>}
  </div>
  <button type="button" class="auth-submit js-app-purchase">Go Premium</button>
  <p class="paywall__legal" data-app-hide>
    CladFacts Premium — auto-renewing subscription, {PRICE.monthly}/mo or
    {" "}{PRICE.annual}/yr until cancelled.
    {" "}<a href="/terms/">Terms of Use</a> · <a href="/privacy/">Privacy Policy</a>
  </p>
</section>
