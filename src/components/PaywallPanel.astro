---
/**
 * Registration wall for anonymous readers.
 * Premium / billing CTAs only when showBillingPromo() is true.
 */
import { showBillingPromo, PRICE } from "~/lib/access";
import { registerHref, loginHref } from "~/lib/safeNext";

interface Props {
  signedIn: boolean;
  /** Where to send the user after register/login (e.g. current path). */
  returnTo?: string;
}
const { signedIn, returnTo } = Astro.props;
const reg = returnTo ? registerHref(returnTo) : "/register/";
const log = returnTo ? loginHref(returnTo) : "/login/";
const billing = showBillingPromo();
---
<section class="paywall">
  <p class="small-caps paywall__eyebrow">Free account · no card</p>
  <h2 class="paywall__title">See every grade — free with an account.</h2>
  <p class="paywall__lede">
    Letter grades, lean scores, charts, midterms tools, and Reader Reactions
    unlock the moment you sign up. No card required.
  </p>
  <ul class="paywall__perks">
    <li>Grades on every report</li>
    <li>Lean scores &amp; charts</li>
    <li>Quiz · midterms ballot · newsletter</li>
  </ul>
  <div class="paywall__cta">
    <a class="auth-submit" href={reg}>Create free account</a>
    {billing && (
      <a class="auth-submit secondary" href="/upgrade/">Premium from {PRICE.monthly}/mo</a>
    )}
  </div>
  {!signedIn && (
    <p class="paywall__signin">Already have an account? <a href={log}>Sign in</a>.</p>
  )}
  {billing && (
    <>
      <button type="button" class="auth-submit js-app-purchase">Go Premium</button>
      <p class="paywall__legal" data-app-hide>
        CladFacts Premium — auto-renewing supporter subscription, {PRICE.monthly}/mo or
        {" "}{PRICE.annual}/yr until cancelled.
        {" "}<a href="/terms/">Terms of Use</a> · <a href="/privacy/">Privacy Policy</a>
      </p>
    </>
  )}
</section>
