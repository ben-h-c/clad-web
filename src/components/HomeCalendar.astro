---
/**
 * Interactive home calendar — the graded record plus a short "Coming up" list.
 *
 * Month grid: each day encodes average grade (wash), report count, and lean
 * ribbon. Encoding switch recolours by grade / lean / volume.
 *
 * Coming up: daybook events for the next three calendar days (today + 2),
 * always visible under the grid — no separate Ahead tab.
 *
 * GATING: grade and lean are Premium values. When `locked`, buildDaySummaries
 * emits nulls, the grade/lean encodings are withheld, and the calendar falls
 * back to volume — which doubles as the sign-in prompt.
 */
import {
  buildCalendarEvents,
  kindLabel,
  todayIsoNy,
  type CalendarEvent,
} from "~/lib/calendarEvents";
import type { CalendarDaySummary } from "~/lib/calendarDays";
import type { RaceDef } from "~/lib/races";

interface Props {
  races?: RaceDef[];
  live?: CalendarEvent[] | null;
  extra?: CalendarEvent[];
  /** Per-day aggregates of the graded record. */
  days?: CalendarDaySummary[];
  /** Earliest / latest day carrying reports — bounds the month nav. */
  first?: string | null;
  last?: string | null;
  /** True for anonymous / restricted readers: no grade or lean values. */
  locked?: boolean;
  class?: string;
}

const events = buildCalendarEvents({
  races: Astro.props.races,
  live: Astro.props.live,
  extra: Astro.props.extra,
});
const days = Astro.props.days ?? [];
const locked = Astro.props.locked ?? true;
const today = todayIsoNy();
const defaultMonth = today.slice(0, 7);
const wrapClass = ["home-cal", Astro.props.class].filter(Boolean).join(" ");

// Nav bounds: the record on one side, the furthest scheduled event on the
// other, so paging can't wander into empty centuries.
const eventDates = events.map((e) => e.date).filter(Boolean).sort();
const firstDay = Astro.props.first ?? (days.length ? days[0].date : null);
const lastDay = Astro.props.last ?? (days.length ? days[days.length - 1].date : null);
const minMonth = [firstDay, eventDates[0]].filter(Boolean).sort()[0]?.slice(0, 7) ?? defaultMonth;
const maxMonth =
  [lastDay, eventDates[eventDates.length - 1], today].filter(Boolean).sort().pop()?.slice(0, 7) ??
  defaultMonth;

const clientEvents = events.map((e) => ({
  id: e.id,
  date: e.date,
  title: e.title,
  body: e.body ?? "",
  kind: e.kind,
  kindLabel: kindLabel(e.kind),
  state: e.state ?? "",
  links: e.links ?? [],
}));

---
<section
  class={wrapClass}
  data-home-cal
  data-today={today}
  data-month={defaultMonth}
  data-min-month={minMonth}
  data-max-month={maxMonth}
  data-locked={locked ? "1" : "0"}
  aria-label="Calendar"
>
  <div class="home-cal__panel">
    <div class="home-cal__toolbar">
      <button type="button" class="home-cal__nav" data-cal-prev aria-label="Previous month">‹</button>
      <div class="home-cal__month-wrap">
        <h3 class="home-cal__month" data-cal-month-label></h3>
        <button type="button" class="home-cal__today" data-cal-today hidden>Today</button>
      </div>
      <button type="button" class="home-cal__nav" data-cal-next aria-label="Next month">›</button>
    </div>

    <div class="home-cal__encodings" role="group" aria-label="Colour the month by">
      {!locked && (
        <>
          <button type="button" class="home-cal__enc" data-cal-enc="grade" aria-pressed="false">Grade</button>
          <button type="button" class="home-cal__enc is-on" data-cal-enc="lean" aria-pressed="true">Lean</button>
        </>
      )}
      <button
        type="button"
        class={`home-cal__enc${locked ? " is-on" : ""}`}
        data-cal-enc="volume"
        aria-pressed={locked ? "true" : "false"}
      >Volume</button>
    </div>

    <div
      class="home-cal__swipe"
      data-cal-swipe
      tabindex="0"
      role="application"
      aria-label="News calendar. Swipe or use arrows to change months."
    >
      <div class="home-cal__weekdays" aria-hidden="true">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>
      <div class="home-cal__grid" data-cal-grid></div>
    </div>

    <div class="home-cal__legend" data-cal-legend></div>

    {locked && (
      <p class="home-cal__locked-note">
        Showing how much ran each day. <a href="/register/">Create a free account</a> to colour the
        record by grade and coverage lean.
      </p>
    )}

    {/* Always-visible daybook peek: events on today through today+2. */}
    <div class="home-cal__coming" data-cal-coming>
      <h3 class="home-cal__coming-title">Coming up</h3>
      <div class="home-cal__agenda" data-cal-agenda></div>
    </div>
  </div>

  <dialog class="home-cal__dialog" data-cal-dialog aria-labelledby="home-cal-dialog-title">
    <div class="home-cal__dialog-inner">
      <header class="home-cal__dialog-head">
        <h3 class="home-cal__dialog-title" id="home-cal-dialog-title" data-cal-dialog-title>Day</h3>
        <button type="button" class="home-cal__dialog-close" data-cal-dialog-close aria-label="Close">×</button>
      </header>
      {/* Scorecard / day summary pins under the title; stories scroll below. */}
      <div class="home-cal__dialog-pin" data-cal-dialog-pin></div>
      <div class="home-cal__dialog-body" data-cal-dialog-body></div>
    </div>
  </dialog>

  <script type="application/json" data-cal-events set:html={JSON.stringify(clientEvents)} />
  <script type="application/json" data-cal-days set:html={JSON.stringify(days)} />
</section>

<script>
  type CalEvent = {
    id: string;
    date: string;
    title: string;
    body: string;
    kind: string;
    kindLabel: string;
    state: string;
    links: { label: string; href: string }[];
  };
  type DayReport = {
    slug: string;
    title: string;
    outlet: string;
    grade: string | null;
    lean: number | null;
    thumb: string | null;
  };
  type DaySummary = {
    date: string;
    n: number;
    grade: string | null;
    gpa: number | null;
    lean: [number, number, number] | null;
    avgLean: number | null;
    top: DayReport[];
  };

  function initHomeCalendar(root: HTMLElement) {
    if (root.dataset.calReady === "1") return;
    root.dataset.calReady = "1";

    function readJson<T>(sel: string): T[] {
      try {
        return JSON.parse(root.querySelector(sel)?.textContent || "[]") as T[];
      } catch {
        return [];
      }
    }

    const events = readJson<CalEvent>("[data-cal-events]");
    const days = readJson<DaySummary>("[data-cal-days]");

    const byDate = new Map<string, CalEvent[]>();
    for (const e of events) {
      const list = byDate.get(e.date) ?? [];
      list.push(e);
      byDate.set(e.date, list);
    }
    const dayByDate = new Map<string, DaySummary>(days.map((d) => [d.date, d]));
    const maxN = days.reduce((m, d) => (d.n > m ? d.n : m), 0) || 1;

    const today = root.dataset.today || "";
    const locked = root.dataset.locked === "1";
    const minMonth = root.dataset.minMonth || "";
    const maxMonth = root.dataset.maxMonth || "";
    let month = root.dataset.month || today.slice(0, 7);
    // Lean is the default encoding: it is the read most people come for, and
    // it stays legible on days where grades cluster. Restricted readers have
    // no lean values, so they fall back to volume. Must match the button that
    // renders with `is-on` above.
    let enc: "grade" | "lean" | "volume" = locked ? "volume" : "lean";

    const labelEl = root.querySelector("[data-cal-month-label]");
    const gridEl = root.querySelector("[data-cal-grid]");
    const legendEl = root.querySelector("[data-cal-legend]");
    const agendaEl = root.querySelector("[data-cal-agenda]");
    const swipeEl = root.querySelector("[data-cal-swipe]") as HTMLElement | null;
    const prevBtn = root.querySelector("[data-cal-prev]") as HTMLButtonElement | null;
    const nextBtn = root.querySelector("[data-cal-next]") as HTMLButtonElement | null;
    const todayBtn = root.querySelector("[data-cal-today]") as HTMLButtonElement | null;
    const dialog = root.querySelector("[data-cal-dialog]") as HTMLDialogElement | null;
    const dialogTitle = root.querySelector("[data-cal-dialog-title]");
    const dialogPin = root.querySelector("[data-cal-dialog-pin]") as HTMLElement | null;
    const dialogBody = root.querySelector("[data-cal-dialog-body]") as HTMLElement | null;
    let lastTrigger: HTMLElement | null = null;
    let selectedDate: string | null = null;

    const MONTHS = [
      "January", "February", "March", "April", "May", "June",
      "July", "August", "September", "October", "November", "December",
    ];

    function escapeHtml(s: string): string {
      return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function shiftMonth(ym: string, delta: number): string {
      const [y, m] = ym.split("-").map(Number);
      const d = new Date(Date.UTC(y, m - 1 + delta, 1));
      return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
    }
    function monthLabel(ym: string): string {
      const [y, m] = ym.split("-").map(Number);
      return `${MONTHS[(m || 1) - 1] || ""} ${y || ""}`.trim();
    }
    function daysInMonth(ym: string): number {
      const [y, m] = ym.split("-").map(Number);
      return new Date(Date.UTC(y, m, 0)).getUTCDate();
    }
    function firstWeekday(ym: string): number {
      const [y, m] = ym.split("-").map(Number);
      return new Date(Date.UTC(y, m - 1, 1)).getUTCDay();
    }
    function prettyDate(date: string): string {
      const [y, m, d] = date.split("-").map(Number);
      return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString("en-US", {
        weekday: "long", month: "long", day: "numeric", year: "numeric", timeZone: "UTC",
      });
    }

    /**
     * Grade band → CSS class suffix. lib/topics scores grades on a 0–12 scale
     * (F=0 … A+=12), NOT a 4.0 GPA — the thresholds below are the midpoints
     * between letter bands on that scale.
     */
    function gradeBand(gpa: number | null): string {
      if (gpa == null) return "none";
      if (gpa >= 9.5) return "a"; // A- and up
      if (gpa >= 6.5) return "b"; // B- … B+
      if (gpa >= 3.5) return "c"; // C- … C+
      return "d"; // D+ and below
    }

    /** Letter → colour band for per-story grade pills (A/B/C/D+F). */
    function gradeBandFromLetter(letter: string | null | undefined): string {
      if (!letter) return "none";
      const t = letter.charAt(0).toUpperCase();
      if (t === "A") return "a";
      if (t === "B") return "b";
      if (t === "C") return "c";
      if (t === "D" || t === "F") return "d";
      return "none";
    }

    function leanLabel(score: number | null): string {
      if (score == null) return "";
      const mag = Math.abs(score);
      if (mag < 5) return "Centered";
      return `${mag}% ${score > 0 ? "Right" : "Left"}-leaning`;
    }

    function leanSpectrumHtml(score: number, compact = false): string {
      const s = Math.max(-100, Math.min(100, Math.round(score)));
      const pos = (s + 100) / 2;
      if (compact) {
        return (
          `<div class="home-cal__story-lean" aria-label="${escapeHtml(leanLabel(s))}">` +
          `<span class="home-cal__story-lean-end">L</span>` +
          `<span class="home-cal__story-lean-track" aria-hidden="true">` +
          `<span class="home-cal__story-lean-center"></span>` +
          `<span class="home-cal__story-lean-marker" style="left:${pos}%"></span>` +
          `</span>` +
          `<span class="home-cal__story-lean-end">R</span>` +
          `<span class="home-cal__story-lean-txt">${escapeHtml(leanLabel(s))}</span>` +
          `</div>`
        );
      }
      return (
        `<div class="home-cal__spectrum">` +
        `<span class="home-cal__spectrum-label small-caps">Political lean</span>` +
        `<span class="home-cal__spectrum-value">${escapeHtml(leanLabel(s))}</span>` +
        `<div class="home-cal__spectrum-scale" aria-hidden="true">` +
        `<span class="home-cal__spectrum-end home-cal__spectrum-end--l">L</span>` +
        `<div class="home-cal__spectrum-track">` +
        `<span class="home-cal__spectrum-center"></span>` +
        `<span class="home-cal__spectrum-marker" style="left:${pos}%"></span>` +
        `</div>` +
        `<span class="home-cal__spectrum-end home-cal__spectrum-end--r">R</span>` +
        `</div></div>`
      );
    }

    function storyCardHtml(r: DayReport): string {
      const band = gradeBandFromLetter(r.grade);
      const thumb = r.thumb
        ? `<span class="home-cal__story-thumb" aria-hidden="true">` +
          `<img src="${escapeHtml(r.thumb)}" alt="" width="96" height="54" loading="lazy" decoding="async" referrerpolicy="no-referrer">` +
          `</span>`
        : `<span class="home-cal__story-thumb home-cal__story-thumb--empty" aria-hidden="true"></span>`;
      const pill = r.grade
        ? `<span class="home-cal__pill home-cal__pill--${band}">${escapeHtml(r.grade)}</span>`
        : "";
      const lean = r.lean != null ? leanSpectrumHtml(r.lean, true) : "";
      return (
        `<li class="home-cal__story">` +
        `<a class="home-cal__story-link" href="/posts/${encodeURIComponent(r.slug)}/">` +
        thumb +
        `<span class="home-cal__story-main">` +
        `<span class="home-cal__story-top">` +
        pill +
        (r.outlet ? `<span class="home-cal__outlet">${escapeHtml(r.outlet)}</span>` : "") +
        `</span>` +
        `<span class="home-cal__story-title">${escapeHtml(r.title)}</span>` +
        lean +
        `</span></a></li>`
      );
    }

    function splitBarHtml(lean: [number, number, number]): string {
      const [l, c, r] = lean;
      return (
        `<div class="home-cal__leanbar" role="img" aria-label="Coverage split: ${l}% left, ${c}% center, ${r}% right">` +
        `<i class="home-cal__ribbon--l" style="flex:0 0 ${l}%"></i>` +
        `<i class="home-cal__ribbon--c" style="flex:0 0 ${c}%"></i>` +
        `<i class="home-cal__ribbon--r" style="flex:0 0 ${r}%"></i>` +
        `</div>` +
        `<p class="home-cal__leankey"><span class="home-cal__leankey-l">${l}% left</span> · ` +
        `<span class="home-cal__leankey-c">${c}% center</span> · ` +
        `<span class="home-cal__leankey-r">${r}% right</span></p>`
      );
    }

    function cellFace(sum: DaySummary | undefined): string {
      if (!sum) return "";
      let wash = "";
      let mark = "";
      if (enc === "grade" && sum.gpa != null) {
        wash = `<span class="home-cal__wash home-cal__wash--${gradeBand(sum.gpa)}"></span>`;
        mark = `<span class="home-cal__cellgrade home-cal__cellgrade--${gradeBand(sum.gpa)}">${escapeHtml(sum.grade || "")}</span>`;
      } else if (enc === "lean" && sum.lean) {
        const [l, c, r] = sum.lean;
        const band = c >= 60 ? "center" : l > r ? "left" : "right";
        wash = `<span class="home-cal__wash home-cal__wash--${band}"></span>`;
        mark = `<span class="home-cal__cellnum">${c}%C</span>`;
      } else {
        const t = Math.min(1, sum.n / maxN);
        wash = `<span class="home-cal__wash home-cal__wash--vol" style="opacity:${(0.12 + t * 0.6).toFixed(2)}"></span>`;
        mark = `<span class="home-cal__cellnum">${sum.n}</span>`;
      }
      const ribbon = sum.lean
        ? `<span class="home-cal__ribbon" aria-hidden="true">` +
          `<i class="home-cal__ribbon--l" style="flex:0 0 ${sum.lean[0]}%"></i>` +
          `<i class="home-cal__ribbon--c" style="flex:0 0 ${sum.lean[1]}%"></i>` +
          `<i class="home-cal__ribbon--r" style="flex:0 0 ${sum.lean[2]}%"></i>` +
          `</span>`
        : "";
      return `${wash}<span class="home-cal__count">${sum.n}</span>${mark}${ribbon}`;
    }

    function render() {
      if (!gridEl || !labelEl) return;
      labelEl.textContent = monthLabel(month);
      root.dataset.month = month;
      if (prevBtn) prevBtn.disabled = !!minMonth && month <= minMonth;
      if (nextBtn) nextBtn.disabled = !!maxMonth && month >= maxMonth;
      if (todayBtn) {
        const todayMonth = today.slice(0, 7);
        todayBtn.hidden = !todayMonth || month === todayMonth;
      }

      const dim = daysInMonth(month);
      const start = firstWeekday(month);
      const cells: string[] = [];
      for (let i = 0; i < start; i++) {
        cells.push(`<div class="home-cal__cell home-cal__cell--pad" aria-hidden="true"></div>`);
      }

      for (let day = 1; day <= dim; day++) {
        const date = `${month}-${String(day).padStart(2, "0")}`;
        const sum = dayByDate.get(date);
        const dayEvents = byDate.get(date) ?? [];
        const has = !!sum || dayEvents.length > 0;
        const isToday = date === today;
        const isSelected = date === selectedDate;
        const dots =
          !sum && dayEvents.length
            ? `<span class="home-cal__marks">${[...new Set(dayEvents.map((e) => e.kind))]
                .slice(0, 3)
                .map((k) => `<span class="home-cal__dot home-cal__dot--${k}"></span>`)
                .join("")}</span>`
            : "";
        const bits = [`${monthLabel(month)} ${day}`];
        if (sum) {
          bits.push(`${sum.n} report${sum.n === 1 ? "" : "s"}`);
          if (sum.grade) bits.push(`average ${sum.grade}`);
          if (sum.avgLean != null) bits.push(leanLabel(sum.avgLean));
        } else if (dayEvents.length) {
          bits.push(`${dayEvents.length} event${dayEvents.length === 1 ? "" : "s"}`);
        }
        const cls = [
          "home-cal__cell",
          has ? "home-cal__cell--event" : "",
          isToday ? "home-cal__cell--today" : "",
          isSelected ? "home-cal__cell--selected" : "",
        ]
          .filter(Boolean)
          .join(" ");
        cells.push(
          `<button type="button" class="${cls}" data-cal-day="${date}" ${has ? "" : "disabled "}` +
            `aria-label="${escapeHtml(bits.join(", "))}"` +
            `${isSelected ? ' aria-current="true"' : ""}>` +
            `<span class="home-cal__daynum">${day}</span>${sum ? cellFace(sum) : dots}` +
            `</button>`
        );
      }

      const total = start + dim;
      const trail = total % 7 === 0 ? 0 : 7 - (total % 7);
      for (let i = 0; i < trail; i++) {
        cells.push(`<div class="home-cal__cell home-cal__cell--pad" aria-hidden="true"></div>`);
      }
      // Subtle re-paint so encoding switches and month changes feel live.
      gridEl.classList.remove("is-animating");
      // Force reflow so the animation restarts when month/encoding changes.
      void (gridEl as HTMLElement).offsetWidth;
      gridEl.classList.add("is-animating");
      gridEl.innerHTML = cells.join("");
      renderLegend();
    }

    function renderLegend() {
      if (!legendEl) return;
      let html = "";
      if (enc === "grade") {
        html =
          [["a", "A / A−"], ["b", "B"], ["c", "C"], ["d", "D / F"]]
            .map(
              ([k, l]) =>
                `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--${k}"></i>${l}</span>`
            )
            .join("") + `<span class="home-cal__keynote">Colour = the day's average grade · figure = reports</span>`;
      } else if (enc === "lean") {
        html =
          `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--left"></i>Left</span>` +
          `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--center"></i>Center</span>` +
          `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--right"></i>Right</span>` +
          `<span class="home-cal__keynote">Ribbon = share of the day's coverage by lean</span>`;
      } else {
        html =
          `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--vol" style="opacity:.18"></i>Lighter day</span>` +
          `<span class="home-cal__key"><i class="home-cal__swatch home-cal__wash--vol" style="opacity:.72"></i>Heavier day</span>` +
          `<span class="home-cal__keynote">Shading = how many reports ran that day</span>`;
      }
      legendEl.innerHTML = html;
    }

    function openDay(date: string) {
      if (!dialog || !dialogTitle || !dialogBody) return;
      const sum = dayByDate.get(date);
      const dayEvents = byDate.get(date) ?? [];
      if (!sum && !dayEvents.length) return;
      selectedDate = date;
      // Highlight the opened cell without a full re-render of washes.
      gridEl?.querySelectorAll(".home-cal__cell--selected").forEach((el) => {
        el.classList.remove("home-cal__cell--selected");
        el.removeAttribute("aria-current");
      });
      const cell = gridEl?.querySelector(`[data-cal-day="${date}"]`);
      cell?.classList.add("home-cal__cell--selected");
      cell?.setAttribute("aria-current", "true");

      dialogTitle.textContent = prettyDate(date);

      // Pin: day scorecard stays fixed under the title.
      // Scroll: story cards, daybook events, and "open full day" link.
      const pinParts: string[] = [];
      const scrollParts: string[] = [];

      if (sum) {
        const scoreBits = [`<span><b>${sum.n}</b> report${sum.n === 1 ? "" : "s"}</span>`];
        if (sum.grade) scoreBits.push(`<span>average <b>${escapeHtml(sum.grade)}</b></span>`);
        pinParts.push(
          `<div class="home-cal__scorecard">` +
            `<div class="home-cal__score">` +
            (sum.grade
              ? `<span class="home-cal__scoregrade home-cal__cellgrade--${gradeBand(sum.gpa)}">${escapeHtml(sum.grade)}</span>`
              : `<span class="home-cal__scoregrade home-cal__scoregrade--muted">${sum.n}</span>`) +
            `<div class="home-cal__scorebits">` +
            (sum.grade ? `<span class="small-caps">Day average</span>` : "") +
            scoreBits.join("") +
            `</div></div>` +
            (sum.avgLean != null ? leanSpectrumHtml(sum.avgLean) : "") +
            (sum.lean
              ? `<div class="home-cal__splitblock">` +
                `<span class="home-cal__splitlabel small-caps">Coverage split</span>` +
                splitBarHtml(sum.lean) +
                `</div>`
              : locked
                ? `<p class="home-cal__locked-inline"><a href="/register/">Create a free account</a> to unlock grade and lean for this day.</p>`
                : "") +
            `</div>`
        );
        if (sum.top.length) {
          scrollParts.push(
            `<ul class="home-cal__daylist">` + sum.top.map((r) => storyCardHtml(r)).join("") + `</ul>`
          );
        }
        if (sum.n > sum.top.length) {
          scrollParts.push(
            `<p class="home-cal__more"><a href="/day/${date}/">Open the full day — all ${sum.n} reports →</a></p>`
          );
        } else {
          scrollParts.push(`<p class="home-cal__more"><a href="/day/${date}/">Open the full day →</a></p>`);
        }
      }

      if (dayEvents.length) {
        scrollParts.push(
          dayEvents
            .map((e) => {
              const links = (e.links || [])
                .filter((l) => {
                  const h = String(l.href || "");
                  return h.startsWith("/") && !h.startsWith("//") && !h.includes("://");
                })
                .map(
                  (l) => `<a class="home-cal__link" href="${escapeHtml(l.href)}">${escapeHtml(l.label)} →</a>`
                )
                .join("");
              return (
                `<article class="home-cal__event home-cal__event--${escapeHtml(e.kind)}">` +
                `<p class="home-cal__event-kicker small-caps">${escapeHtml(e.kindLabel)}${e.state ? ` · ${escapeHtml(e.state)}` : ""}</p>` +
                `<h4 class="home-cal__event-title">${escapeHtml(e.title)}</h4>` +
                (e.body ? `<p class="home-cal__event-body">${escapeHtml(e.body)}</p>` : "") +
                (links ? `<div class="home-cal__event-links">${links}</div>` : "") +
                `</article>`
              );
            })
            .join("")
        );
      }

      if (dialogPin) {
        dialogPin.innerHTML = pinParts.join("");
        dialogPin.hidden = pinParts.length === 0;
      }
      dialogBody.innerHTML = scrollParts.join("");
      // Always start a fresh day at the top of the scroll pane.
      dialogBody.scrollTop = 0;
      if (typeof dialog.showModal === "function") dialog.showModal();
      else dialog.setAttribute("open", "");
      requestAnimationFrame(() => {
        dialogBody.scrollTop = 0;
      });
    }

    /** Civil date + n days without timezone drift (UTC day math on ISO parts). */
    function shiftIso(date: string, deltaDays: number): string {
      const [y, m, d] = date.split("-").map(Number);
      return new Date(Date.UTC(y, (m || 1) - 1, (d || 1) + deltaDays)).toISOString().slice(0, 10);
    }

    /** Events on today through the next two days (three calendar days). */
    function renderComingUp() {
      if (!agendaEl) return;
      const end = shiftIso(today, 2);
      const coming = events
        .filter((e) => e.date >= today && e.date <= end)
        .sort((a, b) => a.date.localeCompare(b.date) || a.title.localeCompare(b.title));

      function card(e: CalEvent): string {
        const [y, m, d] = e.date.split("-").map(Number);
        const dt = new Date(Date.UTC(y, m - 1, d));
        const mon = dt.toLocaleDateString("en-US", { month: "short", timeZone: "UTC" });
        const wd = dt.toLocaleDateString("en-US", { weekday: "short", timeZone: "UTC" });
        const isToday = e.date === today;
        const links = (e.links || [])
          .filter((l) => {
            const h = String(l.href || "");
            return h.startsWith("/") && !h.startsWith("//") && !h.includes("://");
          })
          .map((l) => `<a class="home-cal__link" href="${escapeHtml(l.href)}">${escapeHtml(l.label)} →</a>`)
          .join("");
        return (
          `<article class="home-cal__ev${isToday ? " is-today" : ""}">` +
          `<div class="home-cal__evwhen"><span class="home-cal__evmon">${mon}</span>` +
          `<span class="home-cal__evday">${d}</span><span class="home-cal__evwd">${wd}</span></div>` +
          `<div class="home-cal__evbody">` +
          `<p class="home-cal__event-kicker small-caps">${escapeHtml(e.kindLabel)}${e.state ? ` · ${escapeHtml(e.state)}` : ""}${isToday ? " · Today" : ""}</p>` +
          `<h4 class="home-cal__event-title">${escapeHtml(e.title)}</h4>` +
          (e.body ? `<p class="home-cal__event-body">${escapeHtml(e.body)}</p>` : "") +
          (links ? `<div class="home-cal__event-links">${links}</div>` : "") +
          `</div></article>`
        );
      }

      if (!coming.length) {
        agendaEl.innerHTML = `<p class="home-cal__empty">Nothing scheduled in the next three days.</p>`;
        return;
      }
      agendaEl.innerHTML = coming.map(card).join("");
    }

    function closeDialog() {
      if (!dialog) return;
      if (typeof dialog.close === "function") dialog.close();
      else dialog.removeAttribute("open");
    }

    prevBtn?.addEventListener("click", () => {
      if (minMonth && month <= minMonth) return;
      month = shiftMonth(month, -1);
      render();
    });
    nextBtn?.addEventListener("click", () => {
      if (maxMonth && month >= maxMonth) return;
      month = shiftMonth(month, 1);
      render();
    });
    todayBtn?.addEventListener("click", () => {
      const target = today.slice(0, 7);
      if (!target) return;
      month = target;
      render();
      // Nudge attention to today after jumping back.
      requestAnimationFrame(() => {
        gridEl?.querySelector(".home-cal__cell--today")?.classList.add("is-pulse");
        setTimeout(() => gridEl?.querySelector(".is-pulse")?.classList.remove("is-pulse"), 700);
      });
    });

    root.querySelectorAll<HTMLElement>("[data-cal-enc]").forEach((b) => {
      b.addEventListener("click", () => {
        const next = b.dataset.calEnc as typeof enc;
        if (!next || next === enc) return;
        enc = next;
        root.querySelectorAll<HTMLElement>("[data-cal-enc]").forEach((x) => {
          const on = x === b;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", String(on));
        });
        render();
      });
    });

    gridEl?.addEventListener("click", (ev) => {
      const t = (ev.target as HTMLElement).closest("[data-cal-day]") as HTMLElement | null;
      if (!t || t.hasAttribute("disabled")) return;
      lastTrigger = t;
      const date = t.dataset.calDay;
      if (date) openDay(date);
    });

    root.querySelector("[data-cal-dialog-close]")?.addEventListener("click", closeDialog);
    dialog?.addEventListener("click", (ev) => {
      if (ev.target === dialog) closeDialog();
    });
    // Return focus to the day that opened the dialog (native <dialog> traps
    // focus but does not restore it when closed by backdrop or ESC).
    dialog?.addEventListener("close", () => {
      selectedDate = null;
      gridEl?.querySelectorAll(".home-cal__cell--selected").forEach((el) => {
        el.classList.remove("home-cal__cell--selected");
        el.removeAttribute("aria-current");
      });
      lastTrigger?.focus?.();
      lastTrigger = null;
    });

    let touchX = 0;
    let touchY = 0;
    let tracking = false;
    swipeEl?.addEventListener(
      "touchstart",
      (ev) => {
        const t = ev.changedTouches[0];
        if (!t) return;
        touchX = t.clientX;
        touchY = t.clientY;
        tracking = true;
      },
      { passive: true }
    );
    swipeEl?.addEventListener(
      "touchend",
      (ev) => {
        if (!tracking) return;
        tracking = false;
        const t = ev.changedTouches[0];
        if (!t) return;
        const dx = t.clientX - touchX;
        const dy = t.clientY - touchY;
        if (Math.abs(dx) < 56 || Math.abs(dx) < Math.abs(dy) * 1.35) return;
        const dir = dx < 0 ? 1 : -1;
        const target = shiftMonth(month, dir);
        if (dir < 0 && minMonth && month <= minMonth) return;
        if (dir > 0 && maxMonth && month >= maxMonth) return;
        month = target;
        render();
      },
      { passive: true }
    );

    swipeEl?.addEventListener("keydown", (ev) => {
      if (ev.key === "ArrowLeft") {
        ev.preventDefault();
        if (minMonth && month <= minMonth) return;
        month = shiftMonth(month, -1);
        render();
      } else if (ev.key === "ArrowRight") {
        ev.preventDefault();
        if (maxMonth && month >= maxMonth) return;
        month = shiftMonth(month, 1);
        render();
      }
    });

    render();
    renderComingUp();
  }

  function boot() {
    document.querySelectorAll<HTMLElement>("[data-home-cal]").forEach(initHomeCalendar);
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
  document.addEventListener("astro:page-load", boot);
</script>
