---
/**
 * One soft, dismissible tip bar for first-time visitors who skipped the tour.
 * Appears once per tip id (localStorage). Never stacks with the tour modal.
 * Second tip (explore-analytics-v1) arms only after the first tip is dismissed.
 * Mount site-wide from BaseLayout (non-admin).
 */
---
<aside class="site-tip" id="site-tip" hidden data-tip-id="explore-midterms-quiz-v1">
  <p class="site-tip__msg">
    <span class="site-tip__kicker small-caps">Try this</span>
    <span class="site-tip__text">
      New here? Fill a <a href="/bracket/">midterms ballot</a>, take the
      <a href="/quiz/">morning quiz</a>, or <a href="/register/">create a free account</a> to unlock grades.
    </span>
  </p>
  <div class="site-tip__actions">
    <a class="site-tip__cta" href="/bracket/">Ballot board</a>
    <button type="button" class="site-tip__dismiss" id="site-tip-dismiss" aria-label="Dismiss tip">×</button>
  </div>
</aside>
<script is:inline>
  (() => {
    const el = document.getElementById("site-tip");
    if (!el) return;
    const TIPS = [
      {
        id: "explore-midterms-quiz-v1",
        kicker: "Try this",
        textHtml:
          'New here? Fill a <a href="/bracket/">midterms ballot</a>, take the ' +
          '<a href="/quiz/">morning quiz</a>, or <a href="/register/">create a free account</a> to unlock grades.',
        ctaHref: "/bracket/",
        ctaLabel: "Ballot board",
      },
      {
        id: "explore-analytics-v1",
        // Arms only once the first tip's localStorage flag is set (never stack).
        requires: "explore-midterms-quiz-v1",
        kicker: "Try this",
        textHtml:
          'Curious how the news leans? Check your <a href="/bias/">bias</a>, see the ' +
          '<a href="/week/">Week in Grades</a>, or track the <a href="/trends/">trend line</a>.',
        ctaHref: "/bias/",
        ctaLabel: "Check your bias",
      },
    ];
    const path = location.pathname || "/";
    if (/^\/(login|register|admin|verified|account|reset-password)/.test(path)) return;

    const key = (id) => "clad_tip_" + id;
    let tip = null;
    try {
      for (const t of TIPS) {
        if (localStorage.getItem(key(t.id))) continue;
        if (t.requires && !localStorage.getItem(key(t.requires))) continue;
        // If tour is still pending on home, let the tour own first attention.
        if (
          path === "/" &&
          !localStorage.getItem("clad_tour_v3") &&
          !localStorage.getItem("clad_tour_v2")
        ) {
          return;
        }
        tip = t;
        break;
      }
    } catch {
      return;
    }
    if (!tip) return;

    el.setAttribute("data-tip-id", tip.id);
    const kicker = el.querySelector(".site-tip__kicker");
    const text = el.querySelector(".site-tip__text");
    const cta = el.querySelector(".site-tip__cta");
    if (kicker) kicker.textContent = tip.kicker;
    if (text) text.innerHTML = tip.textHtml;
    if (cta) {
      cta.setAttribute("href", tip.ctaHref);
      cta.textContent = tip.ctaLabel;
    }

    const KEY = key(tip.id);
    setTimeout(() => {
      try {
        if (localStorage.getItem(KEY)) return;
      } catch {}
      el.hidden = false;
    }, 2200);

    const dismiss = () => {
      el.hidden = true;
      try {
        localStorage.setItem(KEY, "1");
      } catch {}
    };
    document.getElementById("site-tip-dismiss")?.addEventListener("click", dismiss);
    el.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        try {
          localStorage.setItem(KEY, "1");
        } catch {}
      });
    });
  })();
</script>
