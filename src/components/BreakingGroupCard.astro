---
/**
 * Developing-story group card for Breaking News — media overlay when a still
 * exists (same language as report / topic media tiles).
 */
import { displayableThumb } from "~/lib/imagePolicy";
import LetterGrade from "~/components/LetterGrade.astro";
import { gradeToGpa, gpaToGrade, leanScoreOf } from "~/lib/topics";
import type { CollectionEntry } from "astro:content";

interface Props {
  slug: string;
  title: string;
  topic?: string;
  members: CollectionEntry<"posts">[];
  locked?: boolean;
  peek?: boolean;
}
const { slug, title, topic, members, locked = false, peek = true } = Astro.props;

const gpas = members.map((p) => gradeToGpa(p.data.letterGrade)).filter((n): n is number => n != null);
const leans = members.map((p) => leanScoreOf(p.data)).filter((n): n is number => n != null);
const avgGrade = gpas.length ? gpaToGrade(gpas.reduce((a, b) => a + b, 0) / gpas.length) : null;
const avgLean = leans.length ? Math.round(leans.reduce((a, b) => a + b, 0) / leans.length) : null;

const lead = members[0];
const reasoning = lead?.data.summary || "";

const byNew = [...members].sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const thumb = displayableThumb(byNew.find((p) => p.data.thumbnail)?.data.thumbnail);
const hqFallback =
  thumb && /^https:\/\/(img\.youtube\.com|i\.ytimg\.com)\//.test(thumb)
    ? byNew.find((p) => p.data.videoId)?.data.videoId
    : undefined;

const leanCompact =
  avgLean === null
    ? null
    : avgLean === 0
      ? "Center"
      : avgLean < 0
        ? `${Math.abs(avgLean)}% L`
        : `${Math.abs(avgLean)}% R`;

const useMedia = !!thumb;
const cardClass = [
  "report-card",
  "report-card--card",
  "report-card--group",
  useMedia ? "report-card--media" : "",
  peek ? "report-card--peek" : "",
].filter(Boolean).join(" ");
---
<article
  class={cardClass}
  data-peek={peek ? "true" : undefined}
  aria-expanded={peek ? "false" : undefined}
>
  <a class="report-card__link" href={`/breaking/${slug}/`} draggable="false">
    {useMedia ? (
      <>
        <div class="report-card__media-bg" aria-hidden="true">
          <img
            src={thumb!}
            alt=""
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
            onerror={hqFallback ? `this.onerror=null;this.src='https://img.youtube.com/vi/${hqFallback}/hqdefault.jpg'` : undefined}
          />
        </div>
        <div class="report-card__media-scrim" aria-hidden="true"></div>
        <div class="report-card__media-body">
          <span class="report-card__grouptag report-card__grouptag--media small-caps">
            {members.length} reports
          </span>
          <div class="report-card__media-chips">
            {locked ? (
              <span class="report-card__chip report-card__chip--lock grade-lock">Unlock free</span>
            ) : avgGrade ? (
              <>
                <span class="report-card__chip report-card__chip--grade">
                  <LetterGrade grade={avgGrade} size="badge" />
                </span>
                {leanCompact && (
                  <span class="report-card__chip report-card__chip--lean">{leanCompact}</span>
                )}
              </>
            ) : null}
          </div>
          <p class="report-card__kicker report-card__kicker--media small-caps">
            Developing{topic ? ` · ${topic}` : ""}
          </p>
          <h3 class="report-card__headline">{title}</h3>
          {reasoning && <p class="report-card__summary">{reasoning}</p>}
        </div>
      </>
    ) : (
      <div class="report-card__body">
        <p class="report-card__kicker small-caps">
          Developing{topic ? ` · ${topic}` : ""} · {members.length} reports
        </p>
        <h3 class="report-card__headline">{title}</h3>
        {reasoning && <p class="report-card__summary report-card__detail">{reasoning}</p>}
      </div>
    )}
  </a>
  {peek && (
    <p class="report-card__hold-hint small-caps" aria-hidden="true">Hold for preview</p>
  )}
</article>
