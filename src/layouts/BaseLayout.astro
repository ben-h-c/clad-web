---
import "~/styles/global.css";
import Masthead from "~/components/Masthead.astro";
import OnboardingTour from "~/components/OnboardingTour.astro";
import SiteTips from "~/components/SiteTips.astro";
import ThemeCoachmark from "~/components/ThemeCoachmark.astro";
import { APP_STORE_URL, APP_STORE_LIVE } from "~/lib/app-store";
import { FOOTER_PRODUCT_LINKS } from "~/lib/explore";
import { getSessionUser, getPrefs, type ThemePref } from "~/lib/user-data";
import { showBillingPromo } from "~/lib/access";

interface Props {
  title: string;
  description?: string;
  /** Social-preview overrides. Default to the page title/description. */
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  /** Keep this page out of search indexes (auth/utility pages). */
  noindex?: boolean;
  /** Extra JSON-LD object(s) to emit in <head> (e.g. NewsArticle). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Mount the onboarding tour on this page (home only). */
  tour?: boolean;
}

const {
  title,
  description = "CladFacts — fact-checked headlines, edited like a 1920s broadsheet.",
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  noindex = false,
  jsonLd,
  tour = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://cladfacts.com");
// Canonical URLs always carry a trailing slash (except file-like paths), so
// /foo and /foo/ never compete in search indexes.
const path = Astro.url.pathname;
const normalizedPath =
  /\.[a-z0-9]+$/i.test(path) || path === "/" || path.endsWith("/") ? path : path + "/";
const canonical = new URL(normalizedPath, site).href;
const metaDescription = description.replace(/\s+/g, " ").trim();
const shareTitle = ogTitle ?? title;
const shareDescription = (ogDescription ?? description).replace(/\s+/g, " ").trim();
// Resolve the share image to an absolute URL (relative paths -> site origin).
// Pages without their own image fall back to a branded card so link previews
// (X/Twitter, etc.) always show a large image.
const shareImage = new URL(ogImage ?? "/og/brand.png", site).href;

// Signed-in account theme (light/dark) — applied before paint to avoid flash.
// Guests use localStorage (masthead toggle); if unset, dark is the default.
let accountTheme: ThemePref | null = null;
if (!path.startsWith("/admin")) {
  try {
    const u = await getSessionUser(Astro.request.headers);
    if (u) {
      const prefs = await getPrefs(u.id);
      accountTheme = prefs.theme === "light" ? "light" : "dark";
    }
  } catch {
    accountTheme = null;
  }
}
// SSR default dark so first paint matches FOUC script for guests without localStorage.
const htmlTheme = accountTheme ?? "dark";
const themeColor = htmlTheme === "dark" ? "#181612" : "#3a3026";

// Site-wide structured data: the publisher + a searchable website. Page-specific
// schema (e.g. NewsArticle) is passed in via the jsonLd prop.
const SITE_URL = site.origin;
const orgLd = {
  "@context": "https://schema.org",
  "@type": "NewsMediaOrganization",
  name: "CladFacts",
  alternateName: "Clad",
  legalName: "CladFacts LLC",
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  description: "AI-assisted fact-checking that grades news for accuracy and rates its political bias.",
  publishingPrinciples: `${SITE_URL}/how-it-works/`,
  factCheckingPolicy: `${SITE_URL}/methodology/`,
  correctionsPolicy: `${SITE_URL}/corrections/`,
  // sameAs grows as handles are reserved; App Store is live (id6781372681).
  sameAs: [
    "https://apps.apple.com/app/id6781372681",
  ],
  founder: {
    "@type": "Person",
    name: "Ben Cody",
    url: `${SITE_URL}/about/#editor`,
  },
};
const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "CladFacts",
  alternateName: "Clad",
  url: SITE_URL,
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE_URL}/search/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
const ldBlocks = [orgLd, siteLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
const billingOn = showBillingPromo();
---
<!doctype html>
<html
  lang="en"
  data-theme={htmlTheme}
  data-account-theme={accountTheme ? "1" : "0"}
  data-billing={billingOn ? "1" : "0"}
>
  <head>
    <meta charset="utf-8" />
    <!-- The iOS app injects window.__cladNative at document start. Flag the
         document as in-app so CSS can hide the web/Stripe purchase surfaces
         and reveal the app-only "Go Premium" button, which routes to the
         native StoreKit paywall via the cladPurchase bridge (Apple IAP).
         Purchase surfaces stay inert while data-billing="0". -->
    <script is:inline>
      if (window.__cladNative) {
        document.documentElement.classList.add('clad-app');
        document.addEventListener('click', function (e) {
          if (document.documentElement.getAttribute('data-billing') !== '1') return;
          var b = e.target.closest && e.target.closest('.js-app-purchase');
          if (b && window.webkit && window.webkit.messageHandlers && window.webkit.messageHandlers.cladPurchase) {
            e.preventDefault();
            window.webkit.messageHandlers.cladPurchase.postMessage({});
          }
        });
      }
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content={themeColor} />
    <!-- Theme before first paint + global toggle handler (capture phase so it
         always wins over menu chrome stacking / other click handlers). -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        function applyTheme(next) {
          var dark = next === "dark";
          if (dark) {
            root.setAttribute("data-theme", "dark");
            root.classList.add("theme-dark");
          } else {
            root.setAttribute("data-theme", "light");
            root.classList.remove("theme-dark");
          }
          try { localStorage.setItem("clad_theme", dark ? "dark" : "light"); } catch (e) {}
          var tc = document.querySelector('meta[name="theme-color"]');
          if (tc) tc.setAttribute("content", dark ? "#181612" : "#3a3026");
          root.style.colorScheme = dark ? "dark" : "light";
          var btn = document.getElementById("theme-toggle");
          if (btn) {
            btn.setAttribute("aria-pressed", dark ? "true" : "false");
            btn.title = dark ? "Switch to light reading" : "Switch to dark reading";
            btn.setAttribute("aria-label", dark ? "Switch to light reading" : "Switch to dark reading");
          }
        }
        window.__cladApplyTheme = applyTheme;
        try {
          var fromAccount = root.getAttribute("data-account-theme") === "1";
          var t = root.getAttribute("data-theme");
          if (fromAccount && (t === "dark" || t === "light")) {
            applyTheme(t);
          } else {
            t = localStorage.getItem("clad_theme");
            // Explicit toggle/account choice wins; otherwise default to dark.
            if (t === "dark" || t === "light") applyTheme(t);
            else applyTheme("dark");
          }
        } catch (e) {
          applyTheme("dark");
        }
        // Capture phase so masthead title / menu listeners cannot steal the click.
        document.addEventListener(
          "click",
          function (e) {
            var btn = e.target && e.target.closest && e.target.closest("#theme-toggle");
            if (!btn) return;
            e.preventDefault();
            e.stopPropagation();
            var cur = root.getAttribute("data-theme") === "dark" || root.classList.contains("theme-dark");
            var next = cur ? "light" : "dark";
            applyTheme(next);
            var mast = document.querySelector(".masthead");
            if (mast && mast.getAttribute("data-signed-in") === "1") {
              fetch("/api/me/preferences", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                credentials: "same-origin",
                body: JSON.stringify({ theme: next }),
              }).catch(function () {});
            }
          },
          true
        );
      })();
    </script>
    <meta name="google-site-verification" content="OYUpYStZyOvXegnN47Cnf17Ay6-ZtZSQtGrTjwBW5Zs" />
    <meta name="description" content={metaDescription} />
    {/* Large image previews in Google Discover/Top Stories; per-post OG
        images are 1200×630 and grade-free for restricted readers. */}
    <meta name="robots" content={noindex ? "noindex,follow" : "max-image-preview:large"} />
    {/* iOS Safari smart app banner — the native install prompt for the
        CladFacts app (same listing as the footer badge). app-argument deep
        links the app to the page being viewed. Gated on APP_STORE_LIVE so we
        never advertise a listing that isn't publicly up yet. */}
    {APP_STORE_LIVE && (
      <meta name="apple-itunes-app" content={`app-id=6781372681, app-argument=${Astro.url.href}`} />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="CladFacts — latest reports" href="/rss.xml" />
    <link rel="preconnect" href="https://img.youtube.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <title>{title}</title>

    <!-- Open Graph / social link previews -->
    <meta property="og:site_name" content="CladFacts" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={shareTitle} />
    <meta property="og:description" content={shareDescription} />
    {shareImage && <meta property="og:image" content={shareImage} />}
    {shareImage && <meta property="og:image:secure_url" content={shareImage} />}
    {shareImage && <meta property="og:image:type" content="image/png" />}
    {shareImage && <meta property="og:image:width" content="1200" />}
    {shareImage && <meta property="og:image:height" content="630" />}
    {shareImage && <meta property="og:image:alt" content={shareTitle} />}

    <meta name="twitter:card" content={shareImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={shareTitle} />
    <meta name="twitter:description" content={shareDescription} />
    {shareImage && <meta name="twitter:image" content={shareImage} />}
    {shareImage && <meta name="twitter:image:alt" content={shareTitle} />}

    {ldBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {/* Living stage behind the broadsheet — motion, color, depth (decorative). */}
    <div class="living-bg" aria-hidden="true">
      <span class="living-bg__orb living-bg__orb--a"></span>
      <span class="living-bg__orb living-bg__orb--b"></span>
      <span class="living-bg__orb living-bg__orb--c"></span>
      <span class="living-bg__orb living-bg__orb--d"></span>
      <span class="living-bg__spark living-bg__spark--1"></span>
      <span class="living-bg__spark living-bg__spark--2"></span>
      <span class="living-bg__spark living-bg__spark--3"></span>
      <span class="living-bg__spark living-bg__spark--4"></span>
      <span class="living-bg__spark living-bg__spark--5"></span>
      <span class="living-bg__grid"></span>
    </div>
    {Astro.url.pathname.startsWith("/posts/") && (
      <>
        <div class="read-progress" aria-hidden="true"><span class="read-progress__bar" id="read-progress-bar"></span></div>
        <script is:inline>
          (() => {
            var bar = document.getElementById("read-progress-bar");
            if (!bar || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
            var ticking = false;
            var update = () => {
              ticking = false;
              var doc = document.documentElement;
              var max = doc.scrollHeight - innerHeight;
              bar.style.width = (max > 0 ? Math.min(100, (scrollY / max) * 100) : 0) + "%";
            };
            addEventListener("scroll", () => {
              if (!ticking) { ticking = true; requestAnimationFrame(update); }
            }, { passive: true });
            update();
          })();
        </script>
      </>
    )}
    <div class="shell">
      <Masthead />
      <main id="main">
        <slot />
      </main>
      <footer class="colophon">
        <nav class="colophon__explore" aria-label="Explore Clad">
          {FOOTER_PRODUCT_LINKS.map((l, i) => (
            <>
              {i > 0 && <span class="colophon__dot" aria-hidden="true">·</span>}
              <a href={l.href}>{l.label}</a>
            </>
          ))}
        </nav>
        <p>
          Clad — AI-assisted reporting; every verdict is hand-reviewed.
          <a href="/about/">About</a>
          ·
          <a href="/how-it-works/">How it works</a>
          ·
          <a href="/newsletter/">Newsletter</a>
          ·
          <a href="/register/">Free account</a>
          {APP_STORE_LIVE && (
            <>
              {" · "}
              <a href="/app/">iPhone app</a>
            </>
          )}
          ·
          <a href="/privacy/">Privacy</a>
          ·
          <a href="/terms/">Terms</a>
        </p>
        {APP_STORE_LIVE && (
        <a
          class="appstore-badge"
          data-app-hide
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener"
          aria-label="Download CladFacts on the App Store"
        >
          <svg class="appstore-badge__logo" viewBox="0 0 384 512" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
            />
          </svg>
          <span class="appstore-badge__text">
            <span class="appstore-badge__small">Download on the</span>
            <span class="appstore-badge__big">App Store</span>
          </span>
        </a>
        )}
        <p>
          Reports are editorial commentary and analysis based on publicly
          available material, presented under fair use. Verdicts assess the
          evidence, not any person.
        </p>
        <p>© {new Date().getFullYear()} CladFacts LLC. All rights reserved.</p>
      </footer>
    </div>
    {!path.startsWith("/admin") && <SiteTips />}
    {!path.startsWith("/admin") && <ThemeCoachmark />}
    {tour && <OnboardingTour />}
  </body>
</html>
