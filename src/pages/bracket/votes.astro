---
/**
 * Anonymous community ballot dashboard.
 * Counts locked ballots only — never exposes who voted for whom.
 * Includes a US map colored by community lean (vs editorial election map).
 */
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getShareTags } from "~/lib/agents";
import { DEFAULT_ELECTION_ID, getElection } from "~/lib/elections";
import { OG_VERSIONS } from "~/lib/ogCard";
import { getCommunityVotes, type CommunityRaceTally } from "~/lib/picks";
import { buildCommunityVoteMap, COMMUNITY_FILL_LABELS } from "~/lib/communityMap";
import { buildStateForecasts } from "~/lib/electionForecast";
import { getElectionForecastLive } from "~/lib/agents";
import { US_MAP_VIEWBOX, US_STATE_PATHS } from "~/lib/usMapPaths";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "public, max-age=30, s-maxage=60");

const election = getElection(DEFAULT_ELECTION_ID)!;
const summary = await getCommunityVotes(election.id);
const races = summary?.races ?? [];
const lockedBallots = summary?.lockedBallots ?? 0;
const totalPicks = summary?.totalPicks ?? 0;
const cmap = buildCommunityVoteMap(races);
const forecastLive = await getElectionForecastLive(env.AGENTS);
const FORECAST_ASOF = buildStateForecasts(forecastLive).asOf;

const sort = Astro.url.searchParams.get("sort") || "votes";
const chamber = Astro.url.searchParams.get("chamber") || "";

function closeness(r: CommunityRaceTally) {
  return Math.abs(r.aPct - 50);
}

let view = [...races];
if (chamber === "senate" || chamber === "governor") {
  view = view.filter((r) => r.chamber === chamber);
}
if (sort === "close") {
  view.sort((a, b) => closeness(a) - closeness(b) || b.total - a.total);
} else if (sort === "office") {
  view.sort((a, b) => a.office.localeCompare(b.office));
} else if (sort === "marquee") {
  view.sort(
    (a, b) =>
      (a.tier === "marquee" ? 0 : a.tier === "watch" ? 1 : 2) -
        (b.tier === "marquee" ? 0 : b.tier === "watch" ? 1 : 2) ||
      b.total - a.total
  );
} else {
  // votes (default)
  view.sort((a, b) => b.total - a.total || closeness(a) - closeness(b));
}

const withVotes = races.filter((r) => r.total > 0);
const closest = [...withVotes].sort((a, b) => closeness(a) - closeness(b))[0] ?? null;
const mostVotes = [...withVotes].sort((a, b) => b.total - a.total)[0] ?? null;
const blowout = [...withVotes].sort((a, b) => Math.abs(b.aPct - b.bPct) - Math.abs(a.aPct - a.bPct))[0] ?? null;

const aLead = races.filter((r) => r.leader === "a").length;
const bLead = races.filter((r) => r.leader === "b").length;
const ties = races.filter((r) => r.leader === "tie").length;

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/bracket/votes/`;

// KV tagline (share-tag-writer) with a computed, grade-free fallback.
const shareTags = (await getShareTags(env.AGENTS))?.tags ?? {};

function sortHref(s: string) {
  const u = new URL(Astro.url);
  u.searchParams.set("sort", s);
  return u.pathname + u.search;
}
function chamberHref(c: string | null) {
  const u = new URL(Astro.url);
  if (!c) u.searchParams.delete("chamber");
  else u.searchParams.set("chamber", c);
  return u.pathname + u.search;
}
function partyTag(p: string | null) {
  return p ? ` (${p})` : "";
}
---
<BaseLayout
  title="Community ballots — Midterms 2026 — CladFacts"
  description="Anonymous tallies of locked CladFacts midterms ballots — who the community picked in each race."
  ogTitle="CladFacts community ballots"
  ogDescription={`${lockedBallots} locked ballots · anonymous race-by-race tallies for 2026 midterms.`}
  ogImage={`${origin}/og/bracket-votes.png?v=${OG_VERSIONS.bracketVotes}`}
>
  <article class="static-page votes-dash" data-page="votes-dashboard">
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Community</p>
    <h1 class="static-page__title">Community ballots</h1>
    <p class="upgrade__lede">
      How Clad readers locked their picks — race by race. Totals only; every ballot is
      <strong>100% anonymous</strong> (we never show who picked whom).
    </p>

    <nav class="bracket-modes" aria-label="Midterms modes">
      <a href="/bracket/">Ballot board</a>
      <a class="bracket-modes__on" href="/bracket/votes/" aria-current="page">Community votes</a>
      <a href="/elections/map/">Interactive map</a>
      <a href="/politicians/">Politicians</a>
    </nav>

    <div class="votes-hero" aria-label="Summary">
      <div class="votes-stat">
        <span class="votes-stat__n">{lockedBallots.toLocaleString("en-US")}</span>
        <span class="votes-stat__l small-caps">Locked ballots</span>
      </div>
      <div class="votes-stat">
        <span class="votes-stat__n">{totalPicks.toLocaleString("en-US")}</span>
        <span class="votes-stat__l small-caps">Race picks</span>
      </div>
      <div class="votes-stat">
        <span class="votes-stat__n">{withVotes.length}/{races.length}</span>
        <span class="votes-stat__l small-caps">Races with votes</span>
      </div>
      <div class="votes-stat">
        <span class="votes-stat__n">{aLead}–{bLead}{ties ? ` · ${ties} tie` : ""}</span>
        <span class="votes-stat__l small-caps">Side A lead · Side B lead</span>
      </div>
    </div>

    {lockedBallots === 0 ? (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          No locked ballots yet. Fill your picks on the ballot board, then
          <strong> lock in</strong> to join the anonymous tally — and to share your sheet.
        </span>
        <a class="paywall-banner__cta" href="/bracket/">Go to ballot board</a>
      </p>
    ) : (
      <>
        <ShareBar
          url="https://cladfacts.com/bracket/votes/"
          title="How readers are calling the 2026 midterms"
          hook={shareTags.votes ??
            (closest && closest.total >= 2
              ? `${lockedBallots.toLocaleString("en-US")} locked ballots. Closest race: ${closest.office}, ${closest.aPct}–${closest.bPct}. Not polls — picks.`
              : `${lockedBallots.toLocaleString("en-US")} locked ballots, tallied race by race. Not polls — picks.`)}
        />

        <div class="votes-highlights">
          {mostVotes && mostVotes.total > 0 && (
            <a class="votes-hl" href={`/bracket/votes/${mostVotes.raceId}/`}>
              <span class="small-caps votes-hl__k">Most picks</span>
              <strong>{mostVotes.office}</strong>
              <span class="votes-hl__m">{mostVotes.total} votes · {mostVotes.aPct}/{mostVotes.bPct}</span>
            </a>
          )}
          {closest && closest.total >= 2 && (
            <a class="votes-hl" href={`/bracket/votes/${closest.raceId}/`}>
              <span class="small-caps votes-hl__k">Closest race</span>
              <strong>{closest.office}</strong>
              <span class="votes-hl__m">{closest.aPct}% – {closest.bPct}%</span>
            </a>
          )}
          {blowout && blowout.total >= 2 && Math.abs(blowout.aPct - blowout.bPct) >= 20 && (
            <a class="votes-hl" href={`/bracket/votes/${blowout.raceId}/`}>
              <span class="small-caps votes-hl__k">Biggest lean</span>
              <strong>{blowout.office}</strong>
              <span class="votes-hl__m">
                {(blowout.aPct >= blowout.bPct ? blowout.aName : blowout.bName)} leads
              </span>
            </a>
          )}
        </div>

        {/* Community lean map — same US base as /elections/map, colored by locked picks */}
        <section class="votes-map" id="votes-map" aria-label="Community votes map">
          <div class="votes-map__head">
            <h2 class="static-page__sub" style="margin:0">Community map</h2>
            <p class="votes-map__lede">
              Where locked Clad ballots lean by state — same geography as the
              <a href="/elections/map/">election map</a>, but colored by
              <strong> reader picks</strong>, not editorial outlook.
              {cmap.statesWithVotes > 0 && (
                <>
                  {" "}
                  {cmap.statesWithVotes} states with votes · outlook as of {FORECAST_ASOF}.
                </>
              )}
            </p>
          </div>

          <div class="votes-map__toolbar" role="toolbar" aria-label="Community map layer">
            <span class="small-caps votes-toolbar__label">Layer</span>
            <div class="votes-map__seg" role="group">
              <button type="button" class="votes-map__seg-btn votes-map__seg-btn--on" data-cv-layer="all">All races</button>
              <button type="button" class="votes-map__seg-btn" data-cv-layer="senate">Senate</button>
              <button type="button" class="votes-map__seg-btn" data-cv-layer="governor">Governor</button>
            </div>
          </div>

          <div class="votes-map__shell">
            <div class="votes-map__col">
              <div class="votes-map__wrap">
                <div class="votes-map__legend" aria-label="Community lean legend">
                  <span class="votes-map__leg votes-map__leg--solid-d">Solid D</span>
                  <span class="votes-map__leg votes-map__leg--likely-d">Likely D</span>
                  <span class="votes-map__leg votes-map__leg--lean-d">Lean D</span>
                  <span class="votes-map__leg votes-map__leg--tossup">Close</span>
                  <span class="votes-map__leg votes-map__leg--lean-r">Lean R</span>
                  <span class="votes-map__leg votes-map__leg--likely-r">Likely R</span>
                  <span class="votes-map__leg votes-map__leg--solid-r">Solid R</span>
                  <span class="votes-map__leg votes-map__leg--empty">No picks</span>
                </div>
                <p class="votes-map__hint small-caps" id="cv-map-hint">Tap a state for community picks vs outlook</p>
                <svg
                  class="votes-map__svg"
                  viewBox={US_MAP_VIEWBOX}
                  role="img"
                  aria-labelledby="cv-map-title cv-map-desc"
                  id="cv-map-svg"
                >
                  <title id="cv-map-title">Community ballot lean by state</title>
                  <desc id="cv-map-desc">
                    U.S. map colored by how locked CladFacts ballots lean in each state.
                  </desc>
                  <g class="votes-map__states">
                    {cmap.states.map((s) => (
                      <path
                        id={`cv-st-${s.code}`}
                        class={`votes-map__state votes-map__fill--${s.fill}`}
                        d={US_STATE_PATHS[s.code]}
                        data-code={s.code}
                        tabindex="0"
                        role="button"
                        aria-label={`${s.name}: ${s.glance}`}
                      />
                    ))}
                  </g>
                </svg>
              </div>
              <p class="votes-map__note">
                Colors use locked-ballot share by party (Cook-style bands for glanceability).
                Compare with the editorial outlook on the
                <a href="/elections/map/">election map</a> — this is readers, not forecasts.
              </p>
            </div>

            <aside class="votes-map__panel" id="cv-map-panel" aria-live="polite">
              <div id="cv-map-empty">
                <h3 class="votes-map__panel-title">Pick a state</h3>
                <p>
                  See how the community locked picks for that state’s races, and whether
                  that leans with or against the editorial 2026 outlook.
                </p>
                <p class="votes-map__panel-cta">
                  <a href="/bracket/">Fill your ballot →</a>
                </p>
              </div>
              <div id="cv-map-detail" hidden>
                <button type="button" class="votes-map__close" id="cv-map-close" aria-label="Close">×</button>
                <p class="small-caps votes-map__eyebrow" id="cv-detail-code"></p>
                <h3 class="votes-map__panel-title" id="cv-detail-name"></h3>
                <p id="cv-detail-glance"></p>
                <p class="votes-map__compare" id="cv-detail-compare"></p>
                <div id="cv-detail-races"></div>
              </div>
            </aside>
          </div>
        </section>

        <script is:inline define:vars={{ cvMapData: Object.fromEntries(cmap.states.map((s) => [s.code, s])), fillLabels: COMMUNITY_FILL_LABELS }}>
          (() => {
            const DATA = cvMapData;
            const LABELS = fillLabels;
            let layer = "all";
            let selected = null;

            const svg = document.getElementById("cv-map-svg");
            const empty = document.getElementById("cv-map-empty");
            const detail = document.getElementById("cv-map-detail");
            const closeBtn = document.getElementById("cv-map-close");

            function esc(s) {
              return String(s ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
            }

            function partyWord(p) {
              return p === "D" ? "Democratic" : p === "R" ? "Republican" : "—";
            }

            function ratingWord(r) {
              const map = {
                "solid-d": "Solid Dem", "likely-d": "Likely Dem", "lean-d": "Lean Dem",
                tossup: "Toss-up", "lean-r": "Lean GOP", "likely-r": "Likely GOP",
                "solid-r": "Solid GOP", "no-race": "No race", empty: "No picks",
              };
              return map[r] || r;
            }

            function layerOutlook(st) {
              if (layer === "senate") return st.outlook.senate;
              if (layer === "governor") return st.outlook.governor;
              return st.outlook.control;
            }

            function applyColors() {
              document.querySelectorAll(".votes-map__state").forEach((path) => {
                const code = path.getAttribute("data-code");
                const st = DATA[code];
                if (!st) return;
                [...path.classList].forEach((c) => {
                  if (c.startsWith("votes-map__fill--")) path.classList.remove(c);
                });
                const fill = (st.fillByLayer && st.fillByLayer[layer]) || st.fill;
                path.classList.add("votes-map__fill--" + fill);
                const glance = (st.glanceByLayer && st.glanceByLayer[layer]) || st.glance;
                path.setAttribute("aria-label", st.name + ": " + glance);
              });
              if (selected && DATA[selected]) paintDetail(DATA[selected]);
            }

            function paintDetail(st) {
              if (!detail || !empty) return;
              empty.hidden = true;
              detail.hidden = false;
              const glance = (st.glanceByLayer && st.glanceByLayer[layer]) || st.glance;
              const fill = (st.fillByLayer && st.fillByLayer[layer]) || st.fill;
              const fo = layerOutlook(st);
              const agree = st.agreesByLayer ? st.agreesByLayer[layer] : null;

              document.getElementById("cv-detail-code").textContent = st.code;
              document.getElementById("cv-detail-name").textContent = st.name;
              document.getElementById("cv-detail-glance").textContent = glance;

              let compare = "Editorial outlook (" + (layer === "all" ? "state control" : layer) + "): " +
                ratingWord(fo.rating);
              if (fo.current && fo.current !== "N") compare += " · holds " + partyWord(fo.current);
              if (agree === true) compare += " · community agrees";
              else if (agree === false) compare += " · community differs";
              else if (fill === "empty") compare += " · no community sample yet";
              document.getElementById("cv-detail-compare").textContent = compare;

              const races = (st.races || []).filter((r) => {
                if (layer === "senate") return r.chamber === "senate";
                if (layer === "governor") return r.chamber === "governor";
                return true;
              });
              const box = document.getElementById("cv-detail-races");
              if (!races.length) {
                box.innerHTML = "<p class=\"votes-map__muted\">No featured races for this layer.</p>";
                return;
              }
              box.innerHTML = races
                .map((r) => {
                  const lead =
                    r.leader === "a" ? r.aName : r.leader === "b" ? r.bName : "Split";
                  return (
                    "<a class=\"votes-map__race\" href=\"" + esc(r.href) + "\">" +
                    "<strong>" + esc(r.office) + "</strong>" +
                    "<span>" + esc(r.aName) + " " + r.aPct + "% · " + esc(r.bName) + " " + r.bPct + "%</span>" +
                    "<span class=\"votes-map__race-lead\">" +
                    (r.total ? esc(lead) + " · " + r.total + " votes" : "No votes yet") +
                    "</span></a>"
                  );
                })
                .join("");
            }

            function selectState(code) {
              selected = code;
              document.querySelectorAll(".votes-map__state--selected").forEach((el) => {
                el.classList.remove("votes-map__state--selected");
              });
              const path = document.getElementById("cv-st-" + code);
              if (path) path.classList.add("votes-map__state--selected");
              if (DATA[code]) paintDetail(DATA[code]);
            }

            function clearSelect() {
              selected = null;
              document.querySelectorAll(".votes-map__state--selected").forEach((el) => {
                el.classList.remove("votes-map__state--selected");
              });
              if (empty) empty.hidden = false;
              if (detail) detail.hidden = true;
            }

            document.querySelectorAll("[data-cv-layer]").forEach((btn) => {
              btn.addEventListener("click", () => {
                layer = btn.getAttribute("data-cv-layer") || "all";
                document.querySelectorAll("[data-cv-layer]").forEach((b) => {
                  b.classList.toggle("votes-map__seg-btn--on", b === btn);
                });
                applyColors();
              });
            });

            if (svg) {
              svg.addEventListener("click", (e) => {
                const t = e.target.closest(".votes-map__state");
                if (t) selectState(t.getAttribute("data-code"));
              });
              svg.addEventListener("keydown", (e) => {
                if (e.key !== "Enter" && e.key !== " ") return;
                const t = e.target.closest(".votes-map__state");
                if (t) {
                  e.preventDefault();
                  selectState(t.getAttribute("data-code"));
                }
              });
            }
            if (closeBtn) closeBtn.addEventListener("click", clearSelect);
            applyColors();
          })();
        </script>

        <div class="votes-toolbar">
          <div class="votes-toolbar__group" role="group" aria-label="Sort">
            <span class="small-caps votes-toolbar__label">Sort</span>
            {(
              [
                ["votes", "Most votes"],
                ["close", "Closest"],
                ["marquee", "Marquee"],
                ["office", "A–Z"],
              ] as const
            ).map(([s, label]) => (
              <a class:list={["ballot-chip", sort === s && "ballot-chip--on"]} href={sortHref(s)}>{label}</a>
            ))}
          </div>
          <div class="votes-toolbar__group" role="group" aria-label="Filter">
            <span class="small-caps votes-toolbar__label">Filter</span>
            <a class:list={["ballot-chip", !chamber && "ballot-chip--on"]} href={chamberHref(null)}>All</a>
            <a class:list={["ballot-chip", chamber === "senate" && "ballot-chip--on"]} href={chamberHref("senate")}>Senate</a>
            <a class:list={["ballot-chip", chamber === "governor" && "ballot-chip--on"]} href={chamberHref("governor")}>Governors</a>
          </div>
        </div>

        <ul class="votes-list" id="votes-list">
          {view.map((r) => (
            <li>
              <a
                class="votes-row"
                href={`/bracket/votes/${r.raceId}/`}
                data-race={r.raceId}
                data-a={r.aPct}
                data-b={r.bPct}
                data-total={r.total}
              >
                <header class="votes-row__head">
                  <span class="votes-row__office">{r.office}</span>
                  <span class="votes-row__meta small-caps">
                    {r.tier} · {r.state} · {r.total} {r.total === 1 ? "vote" : "votes"}
                  </span>
                  {r.winnerName && (
                    <span class="votes-row__called small-caps">Called · {r.winnerName}</span>
                  )}
                </header>
                <div class="votes-row__names">
                  <span class:list={["votes-row__side", r.leader === "a" && "is-lead"]}>
                    {r.aName}{partyTag(r.aParty)}
                    <strong>{r.aPct}%</strong>
                    <span class="votes-row__count">{r.aCount}</span>
                  </span>
                  <span class="votes-row__vs" aria-hidden="true">vs</span>
                  <span class:list={["votes-row__side", r.leader === "b" && "is-lead"]}>
                    {r.bName}{partyTag(r.bParty)}
                    <strong>{r.bPct}%</strong>
                    <span class="votes-row__count">{r.bCount}</span>
                  </span>
                </div>
                <div
                  class="votes-bar"
                  role="img"
                  aria-label={`${r.aName} ${r.aPct} percent, ${r.bName} ${r.bPct} percent`}
                >
                  <span class="votes-bar__a" style={`width:${r.total ? r.aPct : 50}%`}></span>
                  <span class="votes-bar__b" style={`width:${r.total ? r.bPct : 50}%`}></span>
                </div>
                <span class="votes-row__more">Details →</span>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    <p class="static-page__note">
      Only <strong>locked</strong> ballots count here so draft picks cannot skew the board.
      Your identity is never attached to a pick in this view.
      {" "}
      <a href="/bracket/">Fill or lock your ballot →</a>
    </p>
  </article>
</BaseLayout>

<style>
  .votes-hero {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 1rem 0 1.25rem;
  }
  @media (max-width: 720px) {
    .votes-hero { grid-template-columns: 1fr 1fr; }
  }
  .votes-stat {
    border: 1px solid var(--ink, #1a140d);
    padding: 0.75rem 0.85rem;
    text-align: center;
  }
  .votes-stat__n {
    display: block;
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    font-size: 1.45rem;
    line-height: 1.15;
  }
  .votes-stat__l {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.68rem;
    opacity: 0.7;
  }
  .votes-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 720px) {
    .votes-highlights { grid-template-columns: 1fr; }
  }
  .votes-hl {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 0.85rem;
    border: 2px solid var(--ink, #1a140d);
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
  }
  .votes-hl:hover { background: color-mix(in srgb, var(--ink, #1a140d) 8%, transparent); }
  .votes-hl__k { opacity: 0.65; font-size: 0.68rem; }
  .votes-hl__m { font-size: 0.88rem; opacity: 0.85; }
  .votes-toolbar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .votes-toolbar__group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }
  .votes-toolbar__label { margin-right: 0.2rem; opacity: 0.65; }
  .ballot-chip {
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border: 1px solid var(--rule, #cfc3ad);
    text-decoration: none;
    color: inherit;
  }
  .ballot-chip--on {
    border-color: var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    font-weight: 700;
  }
  .votes-list {
    list-style: none;
    margin: 0;
