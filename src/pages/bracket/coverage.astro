---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import { getAccess } from "~/lib/access";
import { buildCoverageBracket, roundLabel, type BracketMatchup } from "~/lib/bracket";
import type { PoliticianAgg } from "~/lib/politicians";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const reveal = access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const board = buildCoverageBracket(all, reveal);

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const ogImage = `${origin}/og/bracket-coverage.png`;

const byRound = {
  r16: board.matchups.filter((m) => m.round === "r16"),
  qf: board.matchups.filter((m) => m.round === "qf"),
  sf: board.matchups.filter((m) => m.round === "sf"),
  final: board.matchups.filter((m) => m.round === "final"),
};

function slotLine(m: BracketMatchup, side: "a" | "b") {
  const s = m[side];
  const p = s.politician as PoliticianAgg | null;
  if (!p) {
    return {
      seed: "—",
      name: "TBD",
      slug: "",
      href: null as string | null,
      meta: "",
      lead: false,
      avgGrade: null as string | null,
      avgLean: null as number | null,
      pol: null as PoliticianAgg | null,
    };
  }
  const lead = m.leaderSlug === p.slug;
  const meta = reveal
    ? `${p.appearances.length} reports` + (p.avgFactuality != null ? ` · ${p.avgFactuality}/100` : "")
    : `${p.appearances.length} reports`;
  return {
    seed: s.seed ? String(s.seed) : "—",
    name: p.name,
    slug: p.slug,
    href: `/politicians/${p.slug}/`,
    meta,
    lead,
    avgGrade: p.avgGrade,
    avgLean: p.avgLean,
    pol: p,
  };
}
---
<BaseLayout
  title={`${board.title} — CladFacts`}
  description={board.subtitle}
  ogTitle={board.title}
  ogDescription="March Madness for midterm coverage volume — top figures by graded reports on CladFacts."
  ogImage={ogImage}
>
  <article class="static-page bracket-page">
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Coverage tournament</p>
    <h1 class="static-page__title">{board.title}</h1>
    <p class="upgrade__lede">{board.subtitle}</p>

    <nav class="bracket-modes" aria-label="Bracket modes">
      <a href="/bracket/">Race board</a>
      <a class="bracket-modes__on" href="/bracket/coverage/" aria-current="page">Coverage tournament</a>
      <a href="/politicians/">All politicians</a>
    </nav>

    {!reveal && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          Guests see the field and report counts. Sign in free to reveal who leads each
          matchup by coverage grade (volume + average factuality) — not polls.
        </span>
        <a class="paywall-banner__cta" href="/register/">Create free account</a>
      </p>
    )}

    {reveal && board.champion && (
      <div class="bracket-champ">
        <PoliticianAvatar slug={board.champion.slug} name={board.champion.name} size="md" />
        <div class="bracket-champ__body">
          <span class="small-caps">Coverage champion (live)</span>
          <a href={`/politicians/${board.champion.slug}/`}>{board.champion.name}</a>
          <span class="bracket-champ__meta">
            {board.champion.appearances.length} reports
          </span>
          <div class="scoreband bracket-champ__scores">
            {board.champion.avgGrade && (
              <div class="scoreband__grade">
                <LetterGrade grade={board.champion.avgGrade} size="card" />
                <span class="scoreband__cap small-caps">Avg grade</span>
              </div>
            )}
            {board.champion.avgLean != null && (
              <div class="scoreband__bias">
                <PoliticalLean score={board.champion.avgLean} />
              </div>
            )}
          </div>
        </div>
      </div>
    )}

    {board.field.length < 4 ? (
      <p class="dateline">Not enough graded coverage yet to fill a tournament field.</p>
    ) : (
      <div class="bracket-board">
        {(["r16", "qf", "sf", "final"] as const).map((round) =>
          byRound[round].length === 0 ? null : (
            <section class={`bracket-col bracket-col--${round}`}>
              <h2 class="bracket-col__title">{roundLabel(round)}</h2>
              <ul class="bracket-list">
                {byRound[round].map((m) => {
                  const a = slotLine(m, "a");
                  const b = slotLine(m, "b");
                  return (
                    <li class="bracket-match">
                      <p class="bracket-match__region small-caps">{m.region}</p>
                      <div class:list={["bracket-slot", { "bracket-slot--lead": a.lead }]}>
                        <span class="bracket-slot__seed">{a.seed}</span>
                        {a.slug ? <PoliticianAvatar slug={a.slug} name={a.name} size="sm" /> : <span class="bracket-slot__ph" />}
                        <div class="bracket-slot__main">
                          {a.href ? <a class="bracket-slot__name" href={a.href}>{a.name}</a> : <span class="bracket-slot__name">{a.name}</span>}
                          <span class="bracket-slot__meta">{a.meta}</span>
                          {reveal && (a.avgGrade || a.avgLean != null) && (
                            <div class="scoreband bracket-slot__scores">
                              {a.avgGrade && (
                                <div class="scoreband__grade">
                                  <LetterGrade grade={a.avgGrade} size="badge" />
                                  <span class="scoreband__cap small-caps">Avg</span>
                                </div>
                              )}
                              {a.avgLean != null && (
                                <div class="scoreband__bias">
                                  <PoliticalLean score={a.avgLean} />
                                </div>
                              )}
                            </div>
                          )}
                        </div>
                      </div>
                      <div class="bracket-slot__vs">vs</div>
                      <div class:list={["bracket-slot", { "bracket-slot--lead": b.lead }]}>
                        <span class="bracket-slot__seed">{b.seed}</span>
                        {b.slug ? <PoliticianAvatar slug={b.slug} name={b.name} size="sm" /> : <span class="bracket-slot__ph" />}
                        <div class="bracket-slot__main">
                          {b.href ? <a class="bracket-slot__name" href={b.href}>{b.name}</a> : <span class="bracket-slot__name">{b.name}</span>}
                          <span class="bracket-slot__meta">{b.meta}</span>
                          {reveal && (b.avgGrade || b.avgLean != null) && (
                            <div class="scoreband bracket-slot__scores">
                              {b.avgGrade && (
                                <div class="scoreband__grade">
                                  <LetterGrade grade={b.avgGrade} size="badge" />
                                  <span class="scoreband__cap small-caps">Avg</span>
                                </div>
                              )}
                              {b.avgLean != null && (
                                <div class="scoreband__bias">
                                  <PoliticalLean score={b.avgLean} />
                                </div>
                              )}
                            </div>
                          )}
                        </div>
                      </div>
                      {reveal && m.leaderReason && <p class="bracket-match__why">{m.leaderReason}</p>}
                    </li>
                  );
                })}
              </ul>
            </section>
          )
        )}
      </div>
    )}

    <p class="static-page__note">
      Prefer fixed races? See the <a href="/bracket/">race board</a>.
    </p>
  </article>
</BaseLayout>

<style>
  .bracket-modes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0.75rem 0 1.25rem;
  }
  .bracket-modes a { color: inherit; }
  .bracket-modes__on {
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .bracket-champ {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.1rem;
    align-items: flex-start;
    margin: 1rem 0;
    padding: 0.9rem 1.1rem;
    border: 3px double var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
  }
  .bracket-champ__body {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .bracket-champ a {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.35rem;
    font-weight: 700;
    color: inherit;
    text-decoration: none;
  }
  .bracket-champ a:hover { text-decoration: underline; }
  .bracket-champ__scores {
    margin: 0.45rem 0 0;
  }
  .bracket-champ__meta { opacity: 0.8; font-size: 0.92rem; }
  .bracket-board {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }
  @media (max-width: 960px) {
    .bracket-board { grid-template-columns: 1fr; }
  }
  .bracket-col__title {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .bracket-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bracket-match {
    border: 1px solid var(--ink, #1a140d);
    padding: 0.65rem 0.75rem;
  }
  .bracket-match__region {
    margin: 0 0 0.4rem;
    opacity: 0.65;
    font-size: 0.72rem;
  }
  .bracket-slot {
    display: grid;
    grid-template-columns: 1.5rem auto minmax(0, 1fr);
    column-gap: 0.45rem;
    align-items: start;
    padding: 0.35rem 0.25rem;
  }
  .bracket-slot--lead {
    background: color-mix(in srgb, var(--ink, #1a140d) 8%, transparent);
    outline: 1.5px solid var(--ink, #1a140d);
  }
  .bracket-slot__seed {
    font-weight: 700;
    opacity: 0.55;
    font-size: 0.85rem;
    padding-top: 0.35rem;
  }
  .bracket-slot__ph {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px dashed var(--rule, #cfc3ad);
  }
  .bracket-slot__main { min-width: 0; }
  .bracket-slot__name {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    font-size: 0.98rem;
    display: block;
    line-height: 1.2;
  }
  .bracket-slot__meta { font-size: 0.78rem; opacity: 0.75; display: block; margin-top: 0.15rem; }
  .bracket-slot__scores {
    margin: 0.35rem 0 0;
    gap: 0.35rem 0.55rem;
  }
  .bracket-slot__scores.scoreband { margin-bottom: 0; }
  .bracket-slot__vs {
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.45;
    margin: 0.15rem 0;
  }
  .bracket-match__why {
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    opacity: 0.75;
  }
</style>
