---
import BaseLayout from "~/layouts/BaseLayout.astro";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
// Cache-bust query so the preview always hits a fresh card after deploys.
const cardSrc = `${origin}/og/bracket.png?v=${Date.now().toString(36)}`;
const pageUrl = `${origin}/bracket/`;
const downloadName = "clad-midterms-2026-race-board.png";
---
<BaseLayout
  title="Midterms 2026 share card — CladFacts"
  description="Download or share the CladFacts Midterms 2026 race board card — coverage grades, not polls."
  ogTitle="Midterms 2026 Race Board"
  ogDescription="Class II Senate and midterm governors — coverage grades, not polls."
  ogImage={`${origin}/og/bracket.png`}
  noindex={true}
>
  <article class="static-page card-page">
    <p class="small-caps upgrade__eyebrow">Share card</p>
    <h1 class="static-page__title">Midterms 2026 race board</h1>
    <p class="upgrade__lede">
      Save this image for Bluesky, X, Instagram, texts, or group chats.
      It is the same card social apps load when someone shares
      <a href="/bracket/">cladfacts.com/bracket</a>.
    </p>

    <div class="card-page__actions">
      <a class="card-page__btn" href={cardSrc} download={downloadName}>Download PNG</a>
      <a class="card-page__btn card-page__btn--ghost" href={cardSrc} target="_blank" rel="noopener">Open full size</a>
      <button type="button" class="card-page__btn card-page__btn--ghost" id="card-copy" data-url={pageUrl}>
        Copy board link
      </button>
      <a class="card-page__btn card-page__btn--ghost" href="/bracket/">Back to race board</a>
    </div>
    <p class="card-page__status" id="card-copy-status" hidden></p>

    <figure class="card-page__figure">
      <img
        class="card-page__img"
        src={cardSrc}
        width="1200"
        height="630"
        alt="CladFacts Midterms 2026 race board share card — Class II Senate and midterm governors, coverage grades not polls"
        loading="eager"
        decoding="async"
      />
      <figcaption class="card-page__cap">1200 × 630 · public (no grades / no leaders)</figcaption>
    </figure>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.getElementById("card-copy");
    const status = document.getElementById("card-copy-status");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-url") || "https://cladfacts.com/bracket/";
      try {
        await navigator.clipboard.writeText(url);
        if (status) { status.hidden = false; status.textContent = "Board link copied."; }
      } catch {
        if (status) { status.hidden = false; status.textContent = url; }
      }
    });
  })();
</script>

<style>
  .card-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 1.25rem;
  }
  .card-page__btn {
    appearance: none;
    font: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    text-decoration: none;
    cursor: pointer;
  }
  .card-page__btn--ghost {
    background: transparent;
    color: inherit;
  }
  .card-page__status {
    font-size: 0.9rem;
    opacity: 0.85;
    margin: -0.5rem 0 1rem;
  }
  .card-page__figure {
    margin: 0;
    border: 1px solid var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
    padding: 0.75rem;
  }
  .card-page__img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 1200px;
    margin: 0 auto;
    background: var(--paper, #f5edd9);
  }
  .card-page__cap {
    margin: 0.55rem 0 0;
    font-size: 0.82rem;
    opacity: 0.7;
    text-align: center;
  }
</style>
