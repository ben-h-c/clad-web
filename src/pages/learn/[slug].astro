---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { CLAIM_TAGS, getLearnPage, GRADE_BANDS, LEARN_PAGES } from "~/lib/campus";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const page = getLearnPage(slug);
if (!page) return new Response("Not found", { status: 404 });

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/learn/${page.slug}/`;
const ogImage = `${origin}/og/learn/${page.slug}.png`;

const others = LEARN_PAGES.filter((p) => p.slug !== page.slug);
---
<BaseLayout
  title={`${page.title} — CladFacts`}
  description={page.description}
  ogTitle={page.title}
  ogDescription={page.description}
  ogImage={ogImage}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: page.title,
    description: page.description,
    url: pageUrl,
    author: { "@type": "Organization", name: "CladFacts" },
  }}
>
  <article class="static-page learn-page">
    <p class="small-caps upgrade__eyebrow">Learn · {page.kicker}</p>
    <h1 class="static-page__title">{page.title}</h1>
    <p class="upgrade__lede">{page.description}</p>

    <div class="learn-share" aria-label="Share this explainer">
      <span class="small-caps learn-share__label">Share</span>
      <button type="button" class="learn-share__btn" id="learn-copy" data-caption={page.shareCaption + " " + pageUrl}>
        Copy for Discord / chat
      </button>
      <a
        class="learn-share__btn"
        href={`https://bsky.app/intent/compose?text=${encodeURIComponent(page.shareCaption + "\n" + pageUrl)}`}
        target="_blank"
        rel="noopener"
      >Bluesky</a>
      <a
        class="learn-share__btn"
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(page.shareCaption)}&url=${encodeURIComponent(pageUrl)}`}
        target="_blank"
        rel="noopener"
      >X</a>
      <a class="learn-share__btn learn-share__btn--ghost" href={ogImage} target="_blank" rel="noopener">Card image</a>
    </div>
    <p class="learn-share__status" id="learn-copy-status" role="status" hidden></p>

    {page.body.map((para) => <p>{para}</p>)}

    {page.showGradeBands && (
      <div class="grade-key" role="list">
        {GRADE_BANDS.map((g) => (
          <div class="grade-key__row" role="listitem">
            <span class="grade-key__grade">{g.grade}</span>
            <span class="grade-key__title">{g.title}</span>
            <span class="grade-key__plain">{g.plain}</span>
          </div>
        ))}
      </div>
    )}

    {page.showClaimTags && (
      <div class="grade-key" role="list">
        {CLAIM_TAGS.map((t) => (
          <div class="grade-key__row" role="listitem">
            <span class="grade-key__grade grade-key__grade--tag">{t.tag}</span>
            <span class="grade-key__plain" style="grid-column: 2 / -1">{t.plain}</span>
          </div>
        ))}
      </div>
    )}

    <p class="static-page__note">
      Practice on the <a href="/quiz/">morning quiz</a>.
      Free account unlocks grades on every report —
      <a href="/register/">create one</a>.
      Campus hub: <a href="/students/">Clad for students</a>.
    </p>

    <h2 class="static-page__sub">More explainers</h2>
    <ul class="learn-more">
      {others.map((o) => (
        <li><a href={`/learn/${o.slug}/`}>{o.title}</a> — {o.kicker}</li>
      ))}
    </ul>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.getElementById("learn-copy");
    const status = document.getElementById("learn-copy-status");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-caption") || location.href;
      try {
        await navigator.clipboard.writeText(text);
        if (status) {
          status.hidden = false;
          status.textContent = "Copied — paste into Discord, iMessage, or Instagram.";
        }
      } catch {
        if (status) {
          status.hidden = false;
          status.textContent = text;
        }
      }
    });
  })();
</script>

<style>
  .learn-share {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.55rem;
    align-items: center;
    margin: 1rem 0 1.25rem;
  }
  .learn-share__label { opacity: 0.7; margin-right: 0.25rem; }
  .learn-share__btn {
    appearance: none;
    font: inherit;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    text-decoration: none;
    cursor: pointer;
  }
  .learn-share__btn--ghost {
    background: transparent;
    color: inherit;
  }
  .learn-share__status {
    font-size: 0.9rem;
    opacity: 0.85;
    margin: -0.35rem 0 1rem;
  }
  .grade-key {
    margin: 1.25rem 0 1.75rem;
    border-top: 2px solid var(--ink, #1a140d);
  }
  .grade-key__row {
    display: grid;
    grid-template-columns: 5.5rem 6.5rem 1fr;
    gap: 0.5rem 0.75rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule, #cfc3ad);
    align-items: baseline;
  }
  .grade-key__grade {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .grade-key__grade--tag {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .grade-key__title {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .grade-key__plain { font-size: 0.95rem; line-height: 1.4; }
  .learn-more { padding-left: 1.2rem; }
  .learn-more li { margin: 0.4rem 0; }
  @media (max-width: 640px) {
    .grade-key__row {
      grid-template-columns: 4.5rem 1fr;
    }
    .grade-key__title { grid-column: 2; }
    .grade-key__plain { grid-column: 1 / -1; }
  }
</style>
