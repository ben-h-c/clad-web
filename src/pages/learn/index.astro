---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { LEARN_PAGES } from "~/lib/campus";

export const prerender = false;

// Hub for explainers. Dedicated pages at /learn/[slug]/ are the shareable
// units (OG cards + Discord copy). This index stays the "start here" map.
const all = (await getCollection("posts", (p) => !p.data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const broadcasts = all.filter((p) => p.data.type === "broadcast");
const recent = broadcasts.slice(0, 3);
---
<BaseLayout
  title="New to the news? — CladFacts"
  description="Short explainers on letter grades, lean scores, claim tags, and spotting spin — for first-time news readers. Free account unlocks every grade."
>
  <section class="static-page">
    <p class="small-caps upgrade__eyebrow">Learn</p>
    <h1 class="static-page__title">New to the news?</h1>
    <p class="upgrade__lede">
      Clad grades news coverage for accuracy and political lean, with sources you can open.
      Start with the cards below — each has a share link for Discord, group chats, and stories.
      Practice on the <a href="/quiz/">morning quiz</a>. Campus hub:
      <a href="/students/">Clad for students</a>.
    </p>

    <div class="learn-grid">
      {LEARN_PAGES.map((p) => (
        <a class="learn-card" href={`/learn/${p.slug}/`}>
          <span class="learn-card__kicker small-caps">{p.kicker}</span>
          <span class="learn-card__title">{p.title}</span>
          <span class="learn-card__desc">{p.description}</span>
        </a>
      ))}
    </div>

    {recent.length > 0 && (
      <>
        <h2 class="static-page__sub">Recent graded coverage</h2>
        <ul>
          {recent.map((p) => (
            <li><a href={`/posts/${p.id}/`}>{p.data.headline}</a></li>
          ))}
        </ul>
      </>
    )}

    <p class="static-page__note">
      Full method: <a href="/how-it-works/">How it works</a>.
      Free account unlocks grades —
      <a href="/register/">create one</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 0.85rem;
    margin: 1.5rem 0 2rem;
  }
  .learn-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border: 1px solid var(--ink, #1a140d);
    color: inherit;
    text-decoration: none;
    min-height: 9rem;
  }
  .learn-card:hover {
    background: color-mix(in srgb, var(--ink, #1a140d) 6%, transparent);
  }
  .learn-card__kicker {
    opacity: 0.7;
    font-size: 0.75rem;
  }
  .learn-card__title {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1.2;
  }
  .learn-card__desc {
    font-size: 0.9rem;
    line-height: 1.4;
    opacity: 0.88;
  }
</style>
