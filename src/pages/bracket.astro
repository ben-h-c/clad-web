---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAccess } from "~/lib/access";
import { getSessionUser } from "~/lib/user-data";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import CollapsibleSection from "~/components/CollapsibleSection.astro";
import ShareBar from "~/components/ShareBar.astro";
import {
  buildRaceBoard,
  maskRaceLeaders,
  raceWhenLabel,
  statusLabel,
  type RaceCardLive,
  type RaceSideLive,
} from "~/lib/bracket";
import { RACE_BOARD_VERIFIED_ASOF } from "~/lib/races";
import {
  DEFAULT_ELECTION_ID,
  getElectionWithPublishedDates,
  picksAreOpen,
} from "~/lib/elections";
import { getBallotForUser, hasAnyLockedPick, isRacePickLocked, listResults } from "~/lib/picks";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const user = await getSessionUser(Astro.request.headers);
const reveal = access.fullAccess;
const signedIn = access.signedIn;

const election = (await getElectionWithPublishedDates(DEFAULT_ELECTION_ID, env.AGENTS))!;

const all = await getCollection("posts", (p) => !p.data.draft);
const board = maskRaceLeaders(
  buildRaceBoard(all, {
    revealScores: reveal,
    // Fixed board order — no sort UI (hot coverage + soonest vote).
    sortMode: "hot-soon",
    races: election.races,
    title: election.title,
    subtitle: election.subtitle,
  }),
  reveal
);

// Always render the full board; filter chips show/hide cards client-side so the
// pick counter (X/Y) matches the visible filter.
const cards = board.cards;

const results = await listResults(election.id);
const resultByRace = new Map(results.map((r) => [r.raceId, r]));

const ballot = user ? await getBallotForUser(user.id, election.id) : null;
const pickByRace = new Map((ballot?.picks ?? []).map((p) => [p.raceId, p.side]));
const lockedRaceIds = (ballot?.picks ?? [])
  .filter((p) => ballot && isRacePickLocked(ballot, p.raceId))
  .map((p) => p.raceId);
const lockedIdSet = new Set(lockedRaceIds);
const hasShareable = !!ballot && hasAnyLockedPick(ballot);
/** Election calendar still open — scope locks do not freeze other groups. */
const calendarOpen = picksAreOpen(election);
const draftPicks = (ballot?.picks ?? []).filter((p) => !lockedIdSet.has(p.raceId));
const score = ballot?.score ?? {
  picked: 0,
  total: election.races.length,
  called: results.filter((r) => r.winnerSide !== "other").length,
  correct: 0,
  wrong: 0,
  pending: election.races.length,
};
// Prefer counting from rendered cards so SSR matches post-pick DOM recount.
const pickedFromCards = cards.filter((c) => pickByRace.has(c.def.id)).length;
const displayPicked = Math.max(score.picked, pickedFromCards);
const displayTotal = cards.length;

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const ogImage = `${origin}/og/bracket.png`;
const pageUrl = `${origin}/bracket/`;
// Share once any group is locked — public page shows locked picks only.
const shareUrl =
  hasShareable && ballot?.shareSlug
    ? `${origin}/ballot/${ballot.shareSlug}/`
    : null;
const registerNext = encodeURIComponent("/bracket/");
const canShare = hasShareable && !!shareUrl;
const canReset = signedIn && calendarOpen && draftPicks.length > 0;
const canLock = signedIn && calendarOpen && draftPicks.length > 0;

function party(p?: string) {
  return p ? ` (${p})` : "";
}
function sideLabel(side: RaceSideLive, defSide: RaceCardLive["def"]["a"]) {
  const bits = [
    side.name + party(side.party),
    defSide.incumbent ? "Inc." : "",
    defSide.field ? "Field" : "",
  ].filter(Boolean);
  return bits.join(" · ");
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: board.title,
  description: board.subtitle,
  url: pageUrl,
};
---
<BaseLayout
  title={`${board.title} — CladFacts`}
  description={board.subtitle}
  ogTitle="Fill your 2026 midterms ballot"
  ogDescription="Pick winners for Class II Senate and midterm governors. Lock in to share and join the anonymous community tally."
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article
    class="static-page bracket-page ballot-board"
    data-election={election.id}
    data-signed-in={signedIn ? "1" : "0"}
    data-picks-open={calendarOpen ? "1" : "0"}
    data-share-url={shareUrl || ""}
    data-picked-count={String(displayPicked)}
    data-total-races={String(displayTotal)}
    data-picked-ids={JSON.stringify([...pickByRace.keys()])}
    data-locked-ids={JSON.stringify(lockedRaceIds)}
  >
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Ballot board</p>
    <h1 class="static-page__title">{board.title}</h1>
    <p class="upgrade__lede">{board.subtitle}</p>

    <nav class="bracket-modes" aria-label="Midterms modes">
      <a class="bracket-modes__on" href="/bracket/" aria-current="page">Ballot board</a>
      <a href="/bracket/votes/">Community votes</a>
      <a href="/elections/map/">Interactive map</a>
      <a href="/politicians/">Politicians</a>
      <a href="/learn/first-vote/">First-time voter</a>
    </nav>

    <div class="ballot-progress" id="ballot-progress" aria-live="polite">
      <div class="ballot-progress__main">
        <strong id="ballot-picked-label">{displayPicked}/{displayTotal} picks</strong>
        {score.called > 0 && (
          <span id="ballot-score-label">
            · Score {score.correct}–{score.wrong}
            <span class="ballot-progress__muted"> ({score.called} called)</span>
          </span>
        )}
        {lockedRaceIds.length > 0 && (
          <span class="ballot-progress__locked" id="ballot-locked-count">
            {" "}· {lockedRaceIds.length} locked
          </span>
        )}
      </div>
      <div class="ballot-progress__actions">
        {signedIn ? (
          <>
            {/* Always in the DOM while calendar open so JS can reveal after first draft pick. */}
            {calendarOpen && (
              <button
                type="button"
                class="race-share__btn"
                id="ballot-lock"
                hidden={!canLock}
              >
                Lock these picks
              </button>
            )}
            {calendarOpen && (
              <button
                type="button"
                class="race-share__btn race-share__btn--ghost"
                id="ballot-reset"
                hidden={!canReset}
              >
                Reset draft
              </button>
            )}
          </>
        ) : (
          <a class="race-share__btn" href={`/register/?next=${registerNext}`}>Sign up to pick winners</a>
        )}
      </div>
    </div>
    <p class="race-share__status" id="ballot-status" hidden></p>

    {/* Share once any group is locked (public page shows locked picks only). */}
    <ShareBar
      id="ballot-sharebar"
      class="ballot-sharebar"
      hidden={!canShare}
      url={shareUrl || `${origin}/bracket/`}
      title="My locked 2026 midterms ballot"
      hook="I picked winners for Senate + governors. Can you beat my sheet? Free on CladFacts →"
      storyImage={shareUrl ? `${origin}/og/ballot/${ballot?.shareSlug}.png` : undefined}
    />

    {signedIn && (
      <p class="ballot-note" id="ballot-lock-note">
        <strong>Lock by group.</strong> Filter to Governors or Senate, then lock — only those races freeze.
        Other groups stay open for picks. Locked picks join the
        {" "}<a href="/bracket/votes/">anonymous community tally</a> and can be shared; drafts stay private.
      </p>
    )}

    {!signedIn && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          Browse every race free. Create a free account to pick winners, lock in your sheet, share it, and track accuracy as results come in.
        </span>
        <a class="paywall-banner__cta" href={`/register/?next=${registerNext}`}>Create free account</a>
      </p>
    )}

    {board.hottest && board.hottest.heat > 0 && (
      <div class="bracket-champ" aria-label="Hottest race by coverage">
        <span class="small-caps">Hottest coverage right now</span>
        <strong>{board.hottest.def.office}</strong>
        <span class="bracket-champ__meta">
          {board.hottest.a.name} vs {board.hottest.b.name} · {board.hottest.heat} reports · heat seed #{board.hottest.heatSeed}
        </span>
      </div>
    )}

    <div class="ballot-toolbar" id="ballot-filters">
      <div class="ballot-toolbar__group" role="group" aria-label="Filter races">
        <span class="small-caps ballot-toolbar__label">Filter</span>
        <button type="button" class="ballot-chip ballot-chip--on" data-filter="all" aria-pressed="true">All</button>
        <button type="button" class="ballot-chip" data-filter="chamber" data-value="senate" aria-pressed="false">Senate</button>
        <button type="button" class="ballot-chip" data-filter="chamber" data-value="governor" aria-pressed="false">Governors</button>
        <button type="button" class="ballot-chip" data-filter="marquee" data-value="1" aria-pressed="false">Marquee only</button>
      </div>
      <p class="ballot-filter-meta small-caps" id="ballot-filter-meta" hidden></p>
    </div>

    <ul class="race-list ballot-list" id="ballot-race-list">
      {cards.map((card) => {
        const pick = pickByRace.get(card.def.id) ?? null;
        const raceLocked = lockedIdSet.has(card.def.id);
        const result = resultByRace.get(card.def.id);
        const called = result && (result.winnerSide === "a" || result.winnerSide === "b");
        const outcome =
          called && pick
            ? pick === result!.winnerSide
              ? "correct"
              : "wrong"
            : called
              ? "open"
              : "pending";
        const canPick = signedIn && calendarOpen && !called && !raceLocked;
        return (
          <li
            class="race-card"
            data-tier={card.def.tier}
            data-chamber={card.def.chamber}
            data-state={card.def.state}
            data-id={card.def.id}
            data-pick={pick || ""}
            data-race-locked={raceLocked ? "1" : "0"}
            data-outcome={outcome}
          >
            <header class="race-card__head">
              <span class="race-card__seed" title="Coverage heat seed (1 = most graded reports)">#{card.heatSeed}</span>
              <h3 class="race-card__office">{card.def.office}</h3>
              <span class="race-card__when small-caps" title={card.def.nextVoteDate === "TBD" || card.def.nextVoteTbd ? "Election date not yet decided" : card.def.nextVoteDate}>{raceWhenLabel(card)}</span>
              <span class="race-card__tier small-caps">{card.def.tier}</span>
              <span class="race-card__status small-caps">{statusLabel(card.def.status)}</span>
              <span class="race-card__heat">{card.heat} reports</span>
              {raceLocked && <span class="race-card__locked small-caps">Locked</span>}
              {called && (
                <span class="race-card__called small-caps">
                  Called · {result!.winnerName}
                </span>
              )}
              {pick && outcome === "correct" && <span class="race-card__result race-card__result--ok">Correct</span>}
              {pick && outcome === "wrong" && <span class="race-card__result race-card__result--bad">Wrong</span>}
            </header>
            <div class="race-card__sides">
              {(["a", "b"] as const).map((sideKey) => {
                const side = card[sideKey];
                const defSide = card.def[sideKey];
                const isPick = pick === sideKey;
                const isWinner = called && result!.winnerSide === sideKey;
                const classes = [
                  "race-side",
                  canPick ? "race-side--pickable" : "",
                  isPick ? "race-side--picked" : "",
                  isWinner ? "race-side--winner" : "",
                  reveal && card.leaderSlug === side.slug ? "race-side--lead" : "",
                ]
                  .filter(Boolean)
                  .join(" ");
                return (
                  <button
                    type="button"
                    class={classes}
                    data-race={card.def.id}
                    data-side={sideKey}
                    disabled={!canPick}
                    aria-pressed={isPick ? "true" : "false"}
                    aria-label={`Pick ${side.name} for ${card.def.office}`}
                  >
                    <div class="race-side__top">
                      <PoliticianAvatar slug={side.slug} name={side.name} size="md" />
                      <div class="race-side__who">
                        <span class="race-side__name">{sideLabel(side, defSide)}</span>
                        <span class="race-side__meta">
                          {side.reports} report{side.reports === 1 ? "" : "s"}
                          {reveal && side.avgFactuality != null ? ` · ${side.avgFactuality}/100` : ""}
                          {isPick ? " · Your pick" : ""}
                        </span>
                        {side.href && (
                          <a class="race-side__profile" href={side.href} onclick="event.stopPropagation()">Profile →</a>
                        )}
                      </div>
                    </div>
                    {reveal && (side.avgGrade || side.avgLean != null) && (
                      <div class="scoreband race-side__scores">
                        {side.avgGrade && (
                          <div class="scoreband__grade">
                            <LetterGrade grade={side.avgGrade} size="card" />
                            <span class="scoreband__cap small-caps">Coverage avg</span>
                          </div>
                        )}
                        {side.avgLean != null && (
                          <div class="scoreband__bias">
                            <PoliticalLean score={side.avgLean} />
                          </div>
                        )}
                      </div>
                    )}
                  </button>
                );
              })}
              <div class="race-card__vs" aria-hidden="true">vs</div>
            </div>
            {reveal && card.leaderReason && (
              <p class="race-card__why">
                Coverage context: {card.leaderSlug
                  ? `${card.leaderSlug === card.a.slug ? card.a.name : card.b.name} — ${card.leaderReason}`
                  : card.leaderReason}
                {" "}(not your election pick)
              </p>
            )}
            {card.def.note && <p class="race-card__note">{card.def.note}</p>}
          </li>
        );
      })}
    </ul>

    <p class="dateline ballot-filter-empty" id="ballot-filter-empty" hidden>
      No races match this filter.
    </p>

    <nav class="explore-next explore-next--compact" aria-label="Related midterms tools" style="border-top:none;margin-top:1rem">
      <div class="explore-next__head">
        <p class="explore-next__eyebrow small-caps">Also useful</p>
        <h2 class="explore-next__title" style="font-size:1.1rem">Around the midterms desk</h2>
      </div>
      <ul class="explore-next__grid">
        <li><a class="explore-next__card" href="/bracket/votes/"><span class="explore-next__kicker small-caps">Community</span><span class="explore-next__name">Community votes</span><span class="explore-next__blurb">Anonymous locked tallies.</span></a></li>
        <li><a class="explore-next__card" href="/elections/map/"><span class="explore-next__kicker small-caps">Map</span><span class="explore-next__name">Election map</span><span class="explore-next__blurb">Coverage heat by state.</span></a></li>
        <li><a class="explore-next__card" href="/politicians/"><span class="explore-next__kicker small-caps">People</span><span class="explore-next__name">Politicians</span><span class="explore-next__blurb">Person-level grades.</span></a></li>
        <li><a class="explore-next__card" href="/quiz/"><span class="explore-next__kicker small-caps">Play</span><span class="explore-next__name">Morning quiz</span><span class="explore-next__blurb">Spot the spin daily.</span></a></li>
      </ul>
    </nav>

    <CollapsibleSection title="How this works" eyebrow="Guide">
      <ul class="upgrade__perks">
        <li><strong>Independent races</strong> — unlike March Madness, winners don’t advance into each other. You pick each race’s winner.</li>
        <li><strong>Heat seed (#)</strong> ranks how much graded coverage Clad has on that race — popularity of the story, not a poll. Board order is fixed (hottest + soonest first).</li>
        <li><strong>Filter</strong> (Senate / Governors / Marquee) narrows the list; the pick counter shows picks for races currently on screen.</li>
        <li><strong>Your pick</strong> requires a free account. <strong>Lock</strong> freezes only the races in your current filter (e.g. Governors) — other groups stay open.</li>
        <li><strong>Locked picks</strong> join the <a href="/bracket/votes/">anonymous community tally</a> and appear on your share link. <strong>Reset draft</strong> clears unlocked picks in the current filter only.</li>
        <li><strong>Coverage lead</strong> (signed-in) is editorial context about airtime quality — separate from your ballot.</li>
        <li>Candidate map verified as of {RACE_BOARD_VERIFIED_ASOF}.</li>
      </ul>
    </CollapsibleSection>

    <p class="static-page__note">
      Community tallies: <a href="/bracket/votes/">community votes</a>.
      Map: <a href="/elections/map/">election map</a>.
      Civics: <a href="/learn/first-vote/">first-time voter guide</a>.
    </p>

    {/* Themed confirm dialog (replaces browser confirm) — follows light/dark. */}
    <div class="clad-confirm" id="clad-confirm" hidden>
      <div class="clad-confirm__backdrop" data-confirm-cancel tabindex="-1"></div>
      <div
        class="clad-confirm__dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="clad-confirm-title"
        aria-describedby="clad-confirm-body"
      >
        <p class="clad-confirm__eyebrow small-caps" id="clad-confirm-eyebrow">Confirm</p>
        <h2 class="clad-confirm__title" id="clad-confirm-title">Are you sure?</h2>
        <p class="clad-confirm__body" id="clad-confirm-body"></p>
        <div class="clad-confirm__actions">
          <button type="button" class="auth-submit secondary" data-confirm-cancel>Cancel</button>
          <button type="button" class="auth-submit" id="clad-confirm-ok">Confirm</button>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector(".ballot-board");
    if (!root) return;
    const signedIn = root.getAttribute("data-signed-in") === "1";
    /** Election calendar still open — not full-ballot freeze. */
    const calendarOpen = root.getAttribute("data-picks-open") === "1";
    const electionId = root.getAttribute("data-election") || "midterms-2026";
    const status = document.getElementById("ballot-status");
    const pickedLabel = document.getElementById("ballot-picked-label");
    const scoreLabel = document.getElementById("ballot-score-label");
    const lockedCountEl = document.getElementById("ballot-locked-count");
    const shareBar = document.getElementById("ballot-sharebar");
    const lockBtn = document.getElementById("ballot-lock");
    const resetBtn = document.getElementById("ballot-reset");
    const filterEmpty = document.getElementById("ballot-filter-empty");
    const filterMeta = document.getElementById("ballot-filter-meta");
    let shareUrl = root.getAttribute("data-share-url") || "";
    /** Full ballot size (for lock/API); visible count comes from filtered cards. */
    const allRaceCount = Number(root.getAttribute("data-total-races") || "21") || 21;

    /** Active filter: chamber null | senate | governor; marquee boolean. */
    let chamberFilter = null;
    let marqueeOnly = false;

    let lockedIds = new Set();
    try {
      const initialLocked = JSON.parse(root.getAttribute("data-locked-ids") || "[]");
      if (Array.isArray(initialLocked)) initialLocked.forEach((id) => { if (id) lockedIds.add(String(id)); });
    } catch {}

    function showShareBar(url) {
      if (!shareBar || !url) return;
      shareBar.hidden = false;
      shareBar.setAttribute("data-url", url);
      shareBar.setAttribute("data-title", "My locked 2026 midterms ballot");
      shareBar.setAttribute(
        "data-hook",
        "I picked winners for Senate + governors. Can you beat my sheet? Free on CladFacts →"
      );
      const slugMatch = /\/ballot\/([^/]+)\//.exec(url);
      if (slugMatch) {
        shareBar.setAttribute(
          "data-story-image",
          location.origin + "/og/ballot/" + slugMatch[1] + ".png"
        );
      }
      if (typeof window.cladRefreshShareBars === "function") {
        window.cladRefreshShareBars(shareBar);
      }
    }
    let pickedIds = new Set();
    try {
      const initial = JSON.parse(root.getAttribute("data-picked-ids") || "[]");
      if (Array.isArray(initial)) initial.forEach((id) => { if (id) pickedIds.add(String(id)); });
    } catch {}

    function setStatus(msg) {
      if (!status) return;
      status.hidden = !msg;
      status.textContent = msg || "";
    }

    function raceCards() {
      return [...root.querySelectorAll(".race-card")];
    }

    function visibleCards() {
      return raceCards().filter((c) => !c.hidden);
    }

    function currentScope() {
      if (marqueeOnly) return "marquee";
      if (chamberFilter === "senate") return "senate";
      if (chamberFilter === "governor") return "governor";
      return "all";
    }

    function scopeLabel(scope) {
      if (scope === "senate") return "Senate";
      if (scope === "governor") return "Governors";
      if (scope === "marquee") return "marquee races";
      return "all draft picks";
    }

    function updateLockButtonLabel() {
      if (!lockBtn) return;
      const scope = currentScope();
      if (scope === "senate") lockBtn.textContent = "Lock Senate";
      else if (scope === "governor") lockBtn.textContent = "Lock Governors";
      else if (scope === "marquee") lockBtn.textContent = "Lock marquee";
      else lockBtn.textContent = "Lock these picks";
    }

    function markRaceLocked(card) {
      if (!card) return;
      card.setAttribute("data-race-locked", "1");
      card.querySelectorAll(".race-side").forEach((el) => {
        el.disabled = true;
        el.classList.remove("race-side--pickable");
      });
      if (!card.querySelector(".race-card__locked")) {
        const badge = document.createElement("span");
        badge.className = "race-card__locked small-caps";
        badge.textContent = "Locked";
        const head = card.querySelector(".race-card__head");
        if (head) head.appendChild(badge);
      }
    }

    /**
     * Recount picks for the currently visible filter.
     * Prefer data-pick on cards so SSR + optimistic updates stay in sync.
     */
    function recountPicks() {
      const visible = visibleCards();
      const total = visible.length;
      let picked = 0;
      let draftVisible = 0;
      for (const c of visible) {
        const id = c.getAttribute("data-id") || "";
        const hasPick = !!(c.getAttribute("data-pick") || "").trim();
        const raceLocked = c.getAttribute("data-race-locked") === "1" || (id && lockedIds.has(id));
        if (hasPick) {
          picked += 1;
          if (id) pickedIds.add(id);
          if (!raceLocked) draftVisible += 1;
        }
      }
      // Full-ballot pick set still tracks off-screen races.
      for (const c of raceCards()) {
        const id = c.getAttribute("data-id") || "";
        const hasPick = !!(c.getAttribute("data-pick") || "").trim();
        if (id && hasPick) pickedIds.add(id);
        else if (id && !hasPick) pickedIds.delete(id);
        if (c.getAttribute("data-race-locked") === "1" && id) lockedIds.add(id);
      }
      let draftTotal = 0;
      for (const id of pickedIds) {
        if (!lockedIds.has(id)) draftTotal += 1;
      }
      if (pickedLabel) {
        pickedLabel.textContent = picked + "/" + total + " picks";
      }
      if (lockedCountEl) {
        if (lockedIds.size > 0) {
          lockedCountEl.hidden = false;
          lockedCountEl.textContent = " · " + lockedIds.size + " locked";
        } else {
          lockedCountEl.hidden = true;
        }
      }
      root.setAttribute("data-picked-count", String(pickedIds.size));
      if (filterEmpty) filterEmpty.hidden = total > 0;
      if (filterMeta) {
        const filtered = chamberFilter || marqueeOnly;
        if (filtered) {
          filterMeta.hidden = false;
          const bits = [];
          if (chamberFilter === "senate") bits.push("Senate");
          if (chamberFilter === "governor") bits.push("Governors");
          if (marqueeOnly) bits.push("Marquee");
          filterMeta.textContent =
            "Showing " + total + " race" + (total === 1 ? "" : "s") +
            (bits.length ? " · " + bits.join(" · ") : "") +
            " · " + draftVisible + " draft here · " +
            pickedIds.size + "/" + allRaceCount + " on full ballot";
        } else {
          filterMeta.hidden = true;
          filterMeta.textContent = "";
        }
      }
      updateLockButtonLabel();
      // Lock/reset only need draft (unlocked) picks in the current filter.
      if (resetBtn) resetBtn.hidden = !calendarOpen || draftVisible === 0;
      if (lockBtn) lockBtn.hidden = !calendarOpen || draftVisible === 0;
    }

    function applyFilter() {
      for (const c of raceCards()) {
        const chamber = c.getAttribute("data-chamber") || "";
        const tier = c.getAttribute("data-tier") || "";
        let show = true;
        if (chamberFilter === "senate" || chamberFilter === "governor") {
          show = chamber === chamberFilter;
        }
        if (show && marqueeOnly) show = tier === "marquee";
        c.hidden = !show;
      }
      // Chip pressed state
      root.querySelectorAll("[data-filter]").forEach((btn) => {
        const kind = btn.getAttribute("data-filter");
        let on = false;
        if (kind === "all") on = !chamberFilter && !marqueeOnly;
        else if (kind === "chamber") on = chamberFilter === btn.getAttribute("data-value");
        else if (kind === "marquee") on = marqueeOnly;
        btn.classList.toggle("ballot-chip--on", on);
        btn.setAttribute("aria-pressed", on ? "true" : "false");
      });
      recountPicks();
    }

    root.querySelectorAll("[data-filter]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const kind = btn.getAttribute("data-filter");
        if (kind === "all") {
          chamberFilter = null;
          marqueeOnly = false;
        } else if (kind === "chamber") {
          const v = btn.getAttribute("data-value");
          // Toggle: re-clicking same chamber returns to All (keeps marquee if on)
          chamberFilter = chamberFilter === v ? null : v;
        } else if (kind === "marquee") {
          marqueeOnly = !marqueeOnly;
        }
        applyFilter();
        updateLockButtonLabel();
      });
    });

    /** Clad-styled confirm — matches paper UI + light/dark theme tokens. */
    function cladConfirm(opts) {
      const title = opts.title || "Are you sure?";
      const body = opts.body || "";
      const okLabel = opts.okLabel || "Confirm";
      const eyebrow = opts.eyebrow || "Confirm";
      const danger = !!opts.danger;
      const el = document.getElementById("clad-confirm");
      const titleEl = document.getElementById("clad-confirm-title");
      const bodyEl = document.getElementById("clad-confirm-body");
      const okBtn = document.getElementById("clad-confirm-ok");
      const eyeEl = document.getElementById("clad-confirm-eyebrow");
      if (!el || !titleEl || !bodyEl || !okBtn) return Promise.resolve(false);

      return new Promise((resolve) => {
        let done = false;
        const finish = (val) => {
          if (done) return;
          done = true;
          el.hidden = true;
          el.classList.remove("is-open");
          document.body.style.overflow = prevOverflow;
          okBtn.classList.remove("clad-confirm__ok--danger");
          document.removeEventListener("keydown", onKey);
          resolve(val);
        };
        const onKey = (e) => {
          if (e.key === "Escape") finish(false);
        };
        titleEl.textContent = title;
        bodyEl.textContent = body;
        okBtn.textContent = okLabel;
        if (eyeEl) eyeEl.textContent = eyebrow;
        okBtn.classList.toggle("clad-confirm__ok--danger", danger);
        const prevOverflow = document.body.style.overflow;
        el.hidden = false;
        // reflow for enter animation
        void el.offsetWidth;
        el.classList.add("is-open");
        document.body.style.overflow = "hidden";
        document.addEventListener("keydown", onKey);
        okBtn.focus();

        el.querySelectorAll("[data-confirm-cancel]").forEach((btn) => {
          btn.onclick = () => finish(false);
        });
        okBtn.onclick = () => finish(true);
      });
    }

    function updateProgress(ballot, justPickedRaceId) {
      if (!ballot) return;
      if (Array.isArray(ballot.picks)) {
        const byRace = new Map(ballot.picks.map((p) => [String(p.raceId), p]));
        pickedIds = new Set(byRace.keys());
        lockedIds = new Set();
        for (const c of raceCards()) {
          const id = c.getAttribute("data-id") || "";
          const p = byRace.get(id);
          if (p) {
            c.setAttribute("data-pick", p.side);
            if (p.lockedAt) {
              lockedIds.add(id);
              markRaceLocked(c);
            }
          }
        }
      }
      if (justPickedRaceId) {
        pickedIds.add(String(justPickedRaceId));
        const card = root.querySelector('.race-card[data-id="' + CSS.escape(String(justPickedRaceId)) + '"]');
        if (card && !card.getAttribute("data-pick") && Array.isArray(ballot.picks)) {
          const p = ballot.picks.find((x) => String(x.raceId) === String(justPickedRaceId));
          if (p) card.setAttribute("data-pick", p.side);
        }
      }

      const s = ballot.score || {};
      recountPicks();

      if (scoreLabel && typeof s.called === "number" && s.called > 0) {
        scoreLabel.innerHTML =
          " · Score " + (s.correct || 0) + "–" + (s.wrong || 0) +
          ' <span class="ballot-progress__muted">(' + s.called + " called)</span>";
      }
      const anyLocked =
        lockedIds.size > 0 ||
        (Array.isArray(ballot.picks) && ballot.picks.some((p) => p.lockedAt)) ||
        !!ballot.lockedAt;
      if (anyLocked && ballot.shareSlug) {
        shareUrl = location.origin + "/ballot/" + ballot.shareSlug + "/";
        root.setAttribute("data-share-url", shareUrl);
        showShareBar(shareUrl);
      }
    }

    async function savePick(raceId, side, btn) {
      if (!signedIn) {
        location.href = "/register/?next=" + encodeURIComponent("/bracket/");
        return;
      }
      if (!calendarOpen) {
        setStatus("Picks are closed for this election.");
        return;
      }
      const card0 = btn.closest(".race-card");
      if (card0 && card0.getAttribute("data-race-locked") === "1") {
        setStatus("That race is locked — pick in another group.");
        return;
      }
      if (lockedIds.has(String(raceId))) {
        setStatus("That race is locked — pick in another group.");
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch("/api/me/ballot", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ electionId, raceId, side }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(data.error || "Could not save pick.");
          return;
        }
        const card = btn.closest(".race-card");
        if (card) {
          card.setAttribute("data-pick", side);
          card.querySelectorAll(".race-side").forEach((el) => {
            const s = el.getAttribute("data-side");
            const on = s === side;
            el.classList.toggle("race-side--picked", on);
            el.setAttribute("aria-pressed", on ? "true" : "false");
            const meta = el.querySelector(".race-side__meta");
            if (meta) {
              meta.textContent = meta.textContent.replace(/ · Your pick$/, "");
              if (on) meta.textContent += " · Your pick";
            }
          });
        }
        pickedIds.add(String(raceId));
        recountPicks();
        updateProgress(data.ballot || { picks: [], score: {} }, raceId);
        setStatus("Saved.");
        setTimeout(() => setStatus(""), 1200);
      } catch {
        setStatus("Network error — try again.");
      } finally {
        btn.disabled = false;
      }
    }

    root.querySelectorAll(".race-side--pickable").forEach((btn) => {
      btn.addEventListener("click", () => {
        const raceId = btn.getAttribute("data-race");
        const side = btn.getAttribute("data-side");
        if (raceId && side) savePick(raceId, side, btn);
      });
    });

    // Guests: clicking disabled sides still nudges to register
    if (!signedIn) {
      root.querySelectorAll(".race-side[disabled]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          location.href = "/register/?next=" + encodeURIComponent("/bracket/");
        });
        btn.removeAttribute("disabled");
        btn.classList.add("race-side--pickable");
      });
    }

    if (shareUrl) showShareBar(shareUrl);
    // Mark already-locked races from SSR.
    for (const c of raceCards()) {
      if (c.getAttribute("data-race-locked") === "1") markRaceLocked(c);
    }
    recountPicks();
    updateLockButtonLabel();

    if (lockBtn) {
      lockBtn.addEventListener("click", async () => {
        const scope = currentScope();
        const label = scopeLabel(scope);
        const ok = await cladConfirm({
          eyebrow: "Lock group",
          title: "Lock " + label + "?",
          body:
            "Only draft picks in " +
            label +
            " will freeze and join the community tally. Other groups stay open so you can keep picking.",
          okLabel: lockBtn.textContent || "Lock",
        });
        if (!ok) return;
        try {
          const res = await fetch("/api/me/ballot", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ electionId, lock: true, scope }),
          });
          const data = await res.json();
          if (!res.ok) {
            setStatus(data.error || "Could not lock.");
            return;
          }
          updateProgress(data.ballot || {});
          setStatus("Locked " + label + ". Other groups still open.");
          setTimeout(() => setStatus(""), 2200);
        } catch {
          setStatus("Network error.");
        }
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener("click", async () => {
        const scope = currentScope();
        const label = scopeLabel(scope);
        const ok = await cladConfirm({
          eyebrow: "Reset draft",
          title: "Clear draft picks in " + label + "?",
          body: "Removes unlocked picks in this filter only. Already-locked races are kept.",
          okLabel: "Clear draft",
          danger: true,
        });
        if (!ok) return;
        try {
          const res = await fetch("/api/me/ballot", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ electionId, reset: true, scope }),
          });
          const data = await res.json();
          if (!res.ok) {
            setStatus(data.error || "Could not reset.");
            return;
          }
          // Clear data-pick on unlocked cards in scope from server response
          if (data.ballot && Array.isArray(data.ballot.picks)) {
            const keep = new Set(data.ballot.picks.map((p) => String(p.raceId)));
            for (const c of raceCards()) {
              const id = c.getAttribute("data-id") || "";
              if (!keep.has(id) && c.getAttribute("data-race-locked") !== "1") {
                c.setAttribute("data-pick", "");
                c.querySelectorAll(".race-side").forEach((el) => {
                  el.classList.remove("race-side--picked");
                  el.setAttribute("aria-pressed", "false");
                  const meta = el.querySelector(".race-side__meta");
                  if (meta) meta.textContent = meta.textContent.replace(/ · Your pick$/, "");
                });
              }
            }
          }
          updateProgress(data.ballot || {});
          setStatus("Draft cleared for " + label + ".");
          setTimeout(() => setStatus(""), 1800);
        } catch {
          setStatus("Network error.");
        }
      });
    }
  })();
</script>

