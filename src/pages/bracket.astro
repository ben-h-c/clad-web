---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAccess } from "~/lib/access";
import { getSessionUser } from "~/lib/user-data";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import CollapsibleSection from "~/components/CollapsibleSection.astro";
import {
  buildRaceBoard,
  maskRaceLeaders,
  statusLabel,
  voteCountdownLabel,
  type RaceCardLive,
  type RaceSideLive,
} from "~/lib/bracket";
import { RACE_BOARD_VERIFIED_ASOF } from "~/lib/races";
import {
  DEFAULT_ELECTION_ID,
  getElection,
  parseSortMode,
  picksAreOpen,
  type RaceSortMode,
} from "~/lib/elections";
import { getBallotForUser, listResults } from "~/lib/picks";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const user = await getSessionUser(Astro.request.headers);
const reveal = access.fullAccess;
const signedIn = access.signedIn;

const election = getElection(DEFAULT_ELECTION_ID)!;
const sortMode: RaceSortMode = parseSortMode(Astro.url.searchParams.get("sort"));
const chamberFilter = Astro.url.searchParams.get("chamber"); // senate | governor | null
const stateFilter = (Astro.url.searchParams.get("state") || "").toUpperCase() || null;
const marqueeOnly = Astro.url.searchParams.get("marquee") === "1";

const all = await getCollection("posts", (p) => !p.data.draft);
const board = maskRaceLeaders(
  buildRaceBoard(all, {
    revealScores: reveal,
    sortMode,
    races: election.races,
    title: election.title,
    subtitle: election.subtitle,
  }),
  reveal
);

let cards = board.cards;
if (chamberFilter === "senate" || chamberFilter === "governor") {
  cards = cards.filter((c) => c.def.chamber === chamberFilter);
}
if (stateFilter) cards = cards.filter((c) => c.def.state === stateFilter);
if (marqueeOnly) cards = cards.filter((c) => c.def.tier === "marquee");

const results = await listResults(election.id);
const resultByRace = new Map(results.map((r) => [r.raceId, r]));

const ballot = user ? await getBallotForUser(user.id, election.id) : null;
const pickByRace = new Map((ballot?.picks ?? []).map((p) => [p.raceId, p.side]));
const isLocked = !!ballot?.lockedAt;
const picksOpen = picksAreOpen(election) && !isLocked;
const score = ballot?.score ?? {
  picked: 0,
  total: election.races.length,
  called: results.filter((r) => r.winnerSide !== "other").length,
  correct: 0,
  wrong: 0,
  pending: election.races.length,
};

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const ogImage = `${origin}/og/bracket.png`;
const pageUrl = `${origin}/bracket/`;
// Share only after lock — public pages refuse unlocked ballots.
const shareUrl =
  ballot?.lockedAt && ballot.shareSlug
    ? `${origin}/ballot/${ballot.shareSlug}/`
    : null;
const registerNext = encodeURIComponent("/bracket/");
const canShare = isLocked && !!shareUrl;
const canReset = signedIn && !isLocked && (score.picked > 0 || !!ballot);
const canLock = signedIn && picksOpen && score.picked > 0 && !isLocked;

function party(p?: string) {
  return p ? ` (${p})` : "";
}
function sideLabel(side: RaceSideLive, defSide: RaceCardLive["def"]["a"]) {
  const bits = [
    side.name + party(side.party),
    defSide.incumbent ? "Inc." : "",
    defSide.field ? "Field" : "",
  ].filter(Boolean);
  return bits.join(" · ");
}
function sortHref(mode: RaceSortMode) {
  const u = new URL(Astro.url);
  u.searchParams.set("sort", mode);
  return u.pathname + u.search;
}
function filterHref(key: string, value: string | null) {
  const u = new URL(Astro.url);
  if (value == null || value === "") u.searchParams.delete(key);
  else u.searchParams.set(key, value);
  return u.pathname + u.search;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: board.title,
  description: board.subtitle,
  url: pageUrl,
};
---
<BaseLayout
  title={`${board.title} — CladFacts`}
  description={board.subtitle}
  ogTitle="Fill your 2026 midterms ballot"
  ogDescription="Pick winners for Class II Senate and midterm governors. Lock in to share and join the anonymous community tally."
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article
    class="static-page bracket-page ballot-board"
    data-election={election.id}
    data-signed-in={signedIn ? "1" : "0"}
    data-picks-open={picksOpen ? "1" : "0"}
    data-locked={isLocked ? "1" : "0"}
    data-share-url={shareUrl || ""}
    data-picked-count={String(score.picked)}
    data-total-races={String(score.total)}
    data-picked-ids={JSON.stringify([...pickByRace.keys()])}
  >
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Ballot board</p>
    <h1 class="static-page__title">{board.title}</h1>
    <p class="upgrade__lede">{board.subtitle}</p>

    <nav class="bracket-modes" aria-label="Midterms modes">
      <a class="bracket-modes__on" href="/bracket/" aria-current="page">Ballot board</a>
      <a href="/bracket/votes/">Community votes</a>
      <a href="/elections/map/">Interactive map</a>
      <a href="/politicians/">Politicians</a>
      <a href="/learn/first-vote/">First-time voter</a>
    </nav>

    <div class="ballot-progress" id="ballot-progress" aria-live="polite">
      <div class="ballot-progress__main">
        <strong id="ballot-picked-label">{score.picked}/{score.total} picks</strong>
        {score.called > 0 && (
          <span id="ballot-score-label">
            · Score {score.correct}–{score.wrong}
            <span class="ballot-progress__muted"> ({score.called} called)</span>
          </span>
        )}
        {isLocked && <span class="ballot-progress__locked"> · Locked in</span>}
      </div>
      <div class="ballot-progress__actions">
        {signedIn ? (
          <>
            <button
              type="button"
              class="race-share__btn"
              id="ballot-share"
              hidden={!canShare}
              title={canShare ? "Copy or share your locked ballot" : "Lock your ballot to share"}
            >
              Share my ballot
            </button>
            {canLock && (
              <button type="button" class="race-share__btn" id="ballot-lock">
                Lock ballot
              </button>
            )}
            {canReset && (
              <button type="button" class="race-share__btn race-share__btn--ghost" id="ballot-reset">
                Reset picks
              </button>
            )}
          </>
        ) : (
          <a class="race-share__btn" href={`/register/?next=${registerNext}`}>Sign up to pick winners</a>
        )}
      </div>
    </div>
    <p class="race-share__status" id="ballot-status" hidden></p>

    {signedIn && !isLocked && (
      <p class="ballot-note" id="ballot-lock-note">
        <strong>Lock to share.</strong> You can change picks until you lock in.
        Sharing and the <a href="/bracket/votes/">anonymous community tally</a> only
        include locked ballots — so draft picks stay private and can be reset anytime before lock.
      </p>
    )}
    {signedIn && isLocked && (
      <p class="ballot-note ballot-note--locked">
        Your ballot is locked. You can <button type="button" class="auth-linklike" id="ballot-share-inline">share it</button>
        {" "}and it counts in the <a href="/bracket/votes/">community votes</a> board. Picks can no longer be edited or reset.
      </p>
    )}

    {!signedIn && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          Browse every race free. Create a free account to pick winners, lock in your sheet, share it, and track accuracy as results come in.
        </span>
        <a class="paywall-banner__cta" href={`/register/?next=${registerNext}`}>Create free account</a>
      </p>
    )}

    {board.hottest && board.hottest.heat > 0 && (
      <div class="bracket-champ" aria-label="Hottest race by coverage">
        <span class="small-caps">Hottest coverage right now</span>
        <strong>{board.hottest.def.office}</strong>
        <span class="bracket-champ__meta">
          {board.hottest.a.name} vs {board.hottest.b.name} · {board.hottest.heat} reports · heat seed #{board.hottest.heatSeed}
        </span>
      </div>
    )}

    <div class="ballot-toolbar">
      <div class="ballot-toolbar__group" role="group" aria-label="Sort races">
        <span class="small-caps ballot-toolbar__label">Sort</span>
        {(
          [
            ["hot-soon", "Hot + soon"],
            ["soonest", "Soonest vote"],
            ["heat", "Most coverage"],
            ["marquee", "Marquee first"],
          ] as const
        ).map(([mode, label]) => (
          <a
            class:list={["ballot-chip", sortMode === mode && "ballot-chip--on"]}
            href={sortHref(mode)}
          >{label}</a>
        ))}
      </div>
      <div class="ballot-toolbar__group" role="group" aria-label="Filter">
        <span class="small-caps ballot-toolbar__label">Filter</span>
        <a class:list={["ballot-chip", !chamberFilter && "ballot-chip--on"]} href={filterHref("chamber", null)}>All</a>
        <a class:list={["ballot-chip", chamberFilter === "senate" && "ballot-chip--on"]} href={filterHref("chamber", "senate")}>Senate</a>
        <a class:list={["ballot-chip", chamberFilter === "governor" && "ballot-chip--on"]} href={filterHref("chamber", "governor")}>Governors</a>
        <a class:list={["ballot-chip", marqueeOnly && "ballot-chip--on"]} href={filterHref("marquee", marqueeOnly ? null : "1")}>Marquee only</a>
      </div>
    </div>

    <ul class="race-list ballot-list">
      {cards.map((card) => {
        const pick = pickByRace.get(card.def.id) ?? null;
        const result = resultByRace.get(card.def.id);
        const called = result && (result.winnerSide === "a" || result.winnerSide === "b");
        const outcome =
          called && pick
            ? pick === result!.winnerSide
              ? "correct"
              : "wrong"
            : called
              ? "open"
              : "pending";
        const canPick = signedIn && picksOpen && !called;
        return (
          <li
            class="race-card"
            data-tier={card.def.tier}
            data-chamber={card.def.chamber}
            data-id={card.def.id}
            data-pick={pick || ""}
            data-outcome={outcome}
          >
            <header class="race-card__head">
              <span class="race-card__seed" title="Coverage heat seed (1 = most graded reports)">#{card.heatSeed}</span>
              <h3 class="race-card__office">{card.def.office}</h3>
              <span class="race-card__when small-caps">{voteCountdownLabel(card.daysToVote)}</span>
              <span class="race-card__tier small-caps">{card.def.tier}</span>
              <span class="race-card__status small-caps">{statusLabel(card.def.status)}</span>
              <span class="race-card__heat">{card.heat} reports</span>
              {called && (
                <span class="race-card__called small-caps">
                  Called · {result!.winnerName}
                </span>
              )}
              {pick && outcome === "correct" && <span class="race-card__result race-card__result--ok">Correct</span>}
              {pick && outcome === "wrong" && <span class="race-card__result race-card__result--bad">Wrong</span>}
            </header>
            <div class="race-card__sides">
              {(["a", "b"] as const).map((sideKey) => {
                const side = card[sideKey];
                const defSide = card.def[sideKey];
                const isPick = pick === sideKey;
                const isWinner = called && result!.winnerSide === sideKey;
                const classes = [
                  "race-side",
                  canPick ? "race-side--pickable" : "",
                  isPick ? "race-side--picked" : "",
                  isWinner ? "race-side--winner" : "",
                  reveal && card.leaderSlug === side.slug ? "race-side--lead" : "",
                ]
                  .filter(Boolean)
                  .join(" ");
                return (
                  <button
                    type="button"
                    class={classes}
                    data-race={card.def.id}
                    data-side={sideKey}
                    disabled={!canPick}
                    aria-pressed={isPick ? "true" : "false"}
                    aria-label={`Pick ${side.name} for ${card.def.office}`}
                  >
                    <div class="race-side__top">
                      <PoliticianAvatar slug={side.slug} name={side.name} size="md" />
                      <div class="race-side__who">
                        <span class="race-side__name">{sideLabel(side, defSide)}</span>
                        <span class="race-side__meta">
                          {side.reports} report{side.reports === 1 ? "" : "s"}
                          {reveal && side.avgFactuality != null ? ` · ${side.avgFactuality}/100` : ""}
                          {isPick ? " · Your pick" : ""}
                        </span>
                        {side.href && (
                          <a class="race-side__profile" href={side.href} onclick="event.stopPropagation()">Profile →</a>
                        )}
                      </div>
                    </div>
                    {reveal && (side.avgGrade || side.avgLean != null) && (
                      <div class="scoreband race-side__scores">
                        {side.avgGrade && (
                          <div class="scoreband__grade">
                            <LetterGrade grade={side.avgGrade} size="card" />
                            <span class="scoreband__cap small-caps">Coverage avg</span>
                          </div>
                        )}
                        {side.avgLean != null && (
                          <div class="scoreband__bias">
                            <PoliticalLean score={side.avgLean} />
                          </div>
                        )}
                      </div>
                    )}
                  </button>
                );
              })}
              <div class="race-card__vs" aria-hidden="true">vs</div>
            </div>
            {reveal && card.leaderReason && (
              <p class="race-card__why">
                Coverage context: {card.leaderSlug
                  ? `${card.leaderSlug === card.a.slug ? card.a.name : card.b.name} — ${card.leaderReason}`
                  : card.leaderReason}
                {" "}(not your election pick)
              </p>
            )}
            {card.def.note && <p class="race-card__note">{card.def.note}</p>}
          </li>
        );
      })}
    </ul>

    {cards.length === 0 && (
      <p class="dateline">No races match this filter.</p>
    )}

    <nav class="explore-next explore-next--compact" aria-label="Related midterms tools" style="border-top:none;margin-top:1rem">
      <div class="explore-next__head">
        <p class="explore-next__eyebrow small-caps">Also useful</p>
        <h2 class="explore-next__title" style="font-size:1.1rem">Around the midterms desk</h2>
      </div>
      <ul class="explore-next__grid">
        <li><a class="explore-next__card" href="/bracket/votes/"><span class="explore-next__kicker small-caps">Community</span><span class="explore-next__name">Community votes</span><span class="explore-next__blurb">Anonymous locked tallies.</span></a></li>
        <li><a class="explore-next__card" href="/elections/map/"><span class="explore-next__kicker small-caps">Map</span><span class="explore-next__name">Election map</span><span class="explore-next__blurb">Coverage heat by state.</span></a></li>
        <li><a class="explore-next__card" href="/politicians/"><span class="explore-next__kicker small-caps">People</span><span class="explore-next__name">Politicians</span><span class="explore-next__blurb">Person-level grades.</span></a></li>
        <li><a class="explore-next__card" href="/quiz/"><span class="explore-next__kicker small-caps">Play</span><span class="explore-next__name">Morning quiz</span><span class="explore-next__blurb">Spot the spin daily.</span></a></li>
      </ul>
    </nav>

    <CollapsibleSection title="How this works" eyebrow="Guide">
      <ul class="upgrade__perks">
        <li><strong>Independent races</strong> — unlike March Madness, winners don’t advance into each other. You pick each race’s winner.</li>
        <li><strong>Heat seed (#)</strong> ranks how much graded coverage Clad has on that race — popularity of the story, not a poll.</li>
        <li><strong>Soonest vote</strong> uses the next primary, special, or general date for that race.</li>
        <li><strong>Your pick</strong> requires a free account. <strong>Lock</strong> when you&rsquo;re ready — only then can you share, and only locked ballots join the <a href="/bracket/votes/">anonymous community tally</a>.</li>
        <li><strong>Reset picks</strong> clears your draft before lock. After lock, picks are final for scoring and sharing.</li>
        <li><strong>Coverage lead</strong> (signed-in) is editorial context about airtime quality — separate from your ballot.</li>
        <li>Candidate map verified as of {RACE_BOARD_VERIFIED_ASOF}.</li>
      </ul>
    </CollapsibleSection>

    <p class="static-page__note">
      Community tallies: <a href="/bracket/votes/">community votes</a>.
      Map: <a href="/elections/map/">election map</a>.
      Civics: <a href="/learn/first-vote/">first-time voter guide</a>.
    </p>

    {/* Themed confirm dialog (replaces browser confirm) — follows light/dark. */}
    <div class="clad-confirm" id="clad-confirm" hidden>
      <div class="clad-confirm__backdrop" data-confirm-cancel tabindex="-1"></div>
      <div
        class="clad-confirm__dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="clad-confirm-title"
        aria-describedby="clad-confirm-body"
      >
        <p class="clad-confirm__eyebrow small-caps" id="clad-confirm-eyebrow">Confirm</p>
        <h2 class="clad-confirm__title" id="clad-confirm-title">Are you sure?</h2>
        <p class="clad-confirm__body" id="clad-confirm-body"></p>
        <div class="clad-confirm__actions">
          <button type="button" class="auth-submit secondary" data-confirm-cancel>Cancel</button>
          <button type="button" class="auth-submit" id="clad-confirm-ok">Confirm</button>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector(".ballot-board");
    if (!root) return;
    const signedIn = root.getAttribute("data-signed-in") === "1";
    let picksOpen = root.getAttribute("data-picks-open") === "1";
    let locked = root.getAttribute("data-locked") === "1";
    const electionId = root.getAttribute("data-election") || "midterms-2026";
    const status = document.getElementById("ballot-status");
    const pickedLabel = document.getElementById("ballot-picked-label");
    const scoreLabel = document.getElementById("ballot-score-label");
    const shareBtn = document.getElementById("ballot-share");
    const shareInline = document.getElementById("ballot-share-inline");
    const lockBtn = document.getElementById("ballot-lock");
    const resetBtn = document.getElementById("ballot-reset");
    let shareUrl = root.getAttribute("data-share-url") || "";
    const totalRaces = Number(root.getAttribute("data-total-races") || "21") || 21;
    let pickedIds = new Set();
    try {
      const initial = JSON.parse(root.getAttribute("data-picked-ids") || "[]");
      if (Array.isArray(initial)) initial.forEach((id) => { if (id) pickedIds.add(String(id)); });
    } catch {}

    function setStatus(msg) {
      if (!status) return;
      status.hidden = !msg;
      status.textContent = msg || "";
    }

    function setPickedLabel(n) {
      if (!pickedLabel) return;
      const count = typeof n === "number" ? n : pickedIds.size;
      pickedLabel.textContent = count + "/" + totalRaces + " picks";
      root.setAttribute("data-picked-count", String(count));
    }

    /** Clad-styled confirm — matches paper UI + light/dark theme tokens. */
    function cladConfirm(opts) {
      const title = opts.title || "Are you sure?";
      const body = opts.body || "";
      const okLabel = opts.okLabel || "Confirm";
      const eyebrow = opts.eyebrow || "Confirm";
      const danger = !!opts.danger;
      const el = document.getElementById("clad-confirm");
      const titleEl = document.getElementById("clad-confirm-title");
      const bodyEl = document.getElementById("clad-confirm-body");
      const okBtn = document.getElementById("clad-confirm-ok");
      const eyeEl = document.getElementById("clad-confirm-eyebrow");
      if (!el || !titleEl || !bodyEl || !okBtn) return Promise.resolve(false);

      return new Promise((resolve) => {
        let done = false;
        const finish = (val) => {
          if (done) return;
          done = true;
          el.hidden = true;
          el.classList.remove("is-open");
          document.body.style.overflow = prevOverflow;
          okBtn.classList.remove("clad-confirm__ok--danger");
          document.removeEventListener("keydown", onKey);
          resolve(val);
        };
        const onKey = (e) => {
          if (e.key === "Escape") finish(false);
        };
        titleEl.textContent = title;
        bodyEl.textContent = body;
        okBtn.textContent = okLabel;
        if (eyeEl) eyeEl.textContent = eyebrow;
        okBtn.classList.toggle("clad-confirm__ok--danger", danger);
        const prevOverflow = document.body.style.overflow;
        el.hidden = false;
        // reflow for enter animation
        void el.offsetWidth;
        el.classList.add("is-open");
        document.body.style.overflow = "hidden";
        document.addEventListener("keydown", onKey);
        okBtn.focus();

        el.querySelectorAll("[data-confirm-cancel]").forEach((btn) => {
          btn.onclick = () => finish(false);
        });
        okBtn.onclick = () => finish(true);
      });
    }

    function updateProgress(ballot, justPickedRaceId) {
      if (!ballot) return;
      // Rebuild pick set from server when present; always fold in the race just saved
      // so the header never lags behind a successful click.
      if (Array.isArray(ballot.picks)) {
        pickedIds = new Set(ballot.picks.map((p) => String(p.raceId)));
      }
      if (justPickedRaceId) pickedIds.add(String(justPickedRaceId));

      const s = ballot.score || {};
      const picked =
        typeof s.picked === "number" && s.picked >= pickedIds.size
          ? s.picked
          : pickedIds.size;
      setPickedLabel(picked);

      if (scoreLabel && typeof s.called === "number" && s.called > 0) {
        scoreLabel.innerHTML =
          " · Score " + (s.correct || 0) + "–" + (s.wrong || 0) +
          ' <span class="ballot-progress__muted">(' + s.called + " called)</span>";
      }
      locked = !!ballot.lockedAt;
      picksOpen = !locked;
      root.setAttribute("data-locked", locked ? "1" : "0");
      root.setAttribute("data-picks-open", picksOpen ? "1" : "0");
      if (ballot.lockedAt && ballot.shareSlug) {
        shareUrl = location.origin + "/ballot/" + ballot.shareSlug + "/";
        root.setAttribute("data-share-url", shareUrl);
      } else {
        shareUrl = "";
        root.setAttribute("data-share-url", "");
      }
      if (shareBtn) shareBtn.hidden = !locked || !shareUrl;
      if (resetBtn) resetBtn.hidden = locked || picked === 0;
      if (lockBtn) lockBtn.hidden = locked || picked === 0;
    }

    async function savePick(raceId, side, btn) {
      if (!signedIn) {
        location.href = "/register/?next=" + encodeURIComponent("/bracket/");
        return;
      }
      if (!picksOpen || locked) {
        setStatus("Picks are locked.");
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch("/api/me/ballot", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ electionId, raceId, side }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(data.error || "Could not save pick.");
          return;
        }
        const card = btn.closest(".race-card");
        if (card) {
          card.setAttribute("data-pick", side);
          card.querySelectorAll(".race-side").forEach((el) => {
            const s = el.getAttribute("data-side");
            const on = s === side;
            el.classList.toggle("race-side--picked", on);
            el.setAttribute("aria-pressed", on ? "true" : "false");
            const meta = el.querySelector(".race-side__meta");
            if (meta) {
              meta.textContent = meta.textContent.replace(/ · Your pick$/, "");
              if (on) meta.textContent += " · Your pick";
            }
          });
        }
        // Optimistic: count this race immediately, then reconcile with server ballot.
        pickedIds.add(String(raceId));
        setPickedLabel(pickedIds.size);
        if (resetBtn) resetBtn.hidden = false;
        if (lockBtn) lockBtn.hidden = locked;
        updateProgress(data.ballot || { picks: [], score: { picked: pickedIds.size, total: totalRaces } }, raceId);
        setStatus("Saved.");
        setTimeout(() => setStatus(""), 1200);
      } catch {
        setStatus("Network error — try again.");
      } finally {
        btn.disabled = false;
      }
    }

    root.querySelectorAll(".race-side--pickable").forEach((btn) => {
      btn.addEventListener("click", () => {
        const raceId = btn.getAttribute("data-race");
        const side = btn.getAttribute("data-side");
        if (raceId && side) savePick(raceId, side, btn);
      });
    });

    // Guests: clicking disabled sides still nudges to register
    if (!signedIn) {
      root.querySelectorAll(".race-side[disabled]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          location.href = "/register/?next=" + encodeURIComponent("/bracket/");
        });
        btn.removeAttribute("disabled");
        btn.classList.add("race-side--pickable");
      });
    }

    async function doShare() {
      if (!locked || !shareUrl) {
        setStatus("Lock your ballot first — then you can share.");
        return;
      }
      const text = "My locked 2026 midterms ballot on CladFacts — fill yours: " + shareUrl;
      try {
        if (navigator.share) {
          await navigator.share({ title: "My Clad midterms ballot", text, url: shareUrl });
        } else {
          await navigator.clipboard.writeText(text);
          setStatus("Share link copied.");
        }
      } catch {
        try {
          await navigator.clipboard.writeText(shareUrl);
          setStatus("Link copied.");
        } catch {
          setStatus(shareUrl);
        }
      }
    }

    if (shareBtn) shareBtn.addEventListener("click", doShare);
    if (shareInline) shareInline.addEventListener("click", doShare);

    if (lockBtn) {
      lockBtn.addEventListener("click", async () => {
        const ok = await cladConfirm({
          eyebrow: "Lock ballot",
          title: "Lock this ballot in?",
          body: "You won’t be able to change or reset picks after this — but you can share your sheet, and your anonymous picks join the community tally.",
          okLabel: "Lock ballot",
        });
        if (!ok) return;
        try {
          const res = await fetch("/api/me/ballot", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ electionId, lock: true }),
          });
          const data = await res.json();
          if (!res.ok) {
            setStatus(data.error || "Could not lock.");
            return;
          }
          location.reload();
        } catch {
          setStatus("Network error.");
        }
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener("click", async () => {
        const ok = await cladConfirm({
          eyebrow: "Reset picks",
          title: "Clear all picks?",
          body: "This removes every pick on your draft ballot. You can only do this before locking. This cannot be undone.",
          okLabel: "Clear picks",
          danger: true,
        });
        if (!ok) return;
        try {
          const res = await fetch("/api/me/ballot", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ electionId, reset: true }),
          });
          const data = await res.json();
          if (!res.ok) {
            setStatus(data.error || "Could not reset.");
            return;
          }
          location.reload();
        } catch {
          setStatus("Network error.");
        }
      });
    }
  })();
</script>

