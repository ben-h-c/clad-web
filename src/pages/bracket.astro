---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAccess } from "~/lib/access";
import { buildCoverageBracket, roundLabel, type BracketMatchup } from "~/lib/bracket";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const reveal = access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const board = buildCoverageBracket(all, reveal);

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const ogImage = `${origin}/og/bracket.png`;

const byRound = {
  r16: board.matchups.filter((m) => m.round === "r16"),
  qf: board.matchups.filter((m) => m.round === "qf"),
  sf: board.matchups.filter((m) => m.round === "sf"),
  final: board.matchups.filter((m) => m.round === "final"),
};

function slotLine(m: BracketMatchup, side: "a" | "b") {
  const s = m[side];
  const p = s.politician;
  if (!p) return { seed: "—", name: "TBD", href: null as string | null, meta: "", lead: false };
  const lead = m.leaderSlug === p.slug;
  const meta = reveal
    ? `${p.appearances.length} reports` + (p.avgFactuality != null ? ` · ${p.avgFactuality}/100` : "")
    : `${p.appearances.length} reports`;
  return {
    seed: s.seed ? String(s.seed) : "—",
    name: p.name,
    href: `/politicians/${p.slug}/`,
    meta,
    lead,
  };
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: board.title,
  description: board.subtitle,
  url: `${origin}/bracket/`,
};
---
<BaseLayout
  title={`${board.title} — CladFacts`}
  description={board.subtitle}
  ogTitle={board.title}
  ogDescription="March Madness for the midterms: who gets the most graded coverage on CladFacts — and whose coverage holds up."
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="static-page bracket-page">
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Coverage tournament</p>
    <h1 class="static-page__title">{board.title}</h1>
    <p class="upgrade__lede">{board.subtitle}</p>

    {!reveal && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          Guests see the field and report counts. Sign in free to reveal who leads each
          matchup by coverage grade (volume + average factuality) — not polls.
        </span>
        <a class="paywall-banner__cta" href="/register/">Create free account</a>
      </p>
    )}

    {reveal && board.champion && (
      <div class="bracket-champ" aria-label="Current coverage champion">
        <span class="small-caps">Coverage champion (live)</span>
        <a href={`/politicians/${board.champion.slug}/`}>{board.champion.name}</a>
        <span class="bracket-champ__meta">
          {board.champion.appearances.length} reports
          {board.champion.avgGrade ? ` · avg ${board.champion.avgGrade}` : ""}
          {board.champion.avgFactuality != null ? ` · ${board.champion.avgFactuality}/100` : ""}
        </span>
      </div>
    )}

    {board.field.length < 4 ? (
      <p class="dateline">Not enough graded coverage yet to fill a bracket — check back after more midterm reports publish.</p>
    ) : (
      <div class="bracket-board">
        {(["r16", "qf", "sf", "final"] as const).map((round) => (
          <section class={`bracket-col bracket-col--${round}`}>
            <h2 class="bracket-col__title">{roundLabel(round)}</h2>
            <ul class="bracket-list">
              {byRound[round].map((m) => {
                const a = slotLine(m, "a");
                const b = slotLine(m, "b");
                return (
                  <li class="bracket-match" data-region={m.region}>
                    <p class="bracket-match__region small-caps">{m.region}</p>
                    <div class:list={["bracket-slot", { "bracket-slot--lead": a.lead }]}>
                      <span class="bracket-slot__seed">{a.seed}</span>
                      {a.href ? (
                        <a class="bracket-slot__name" href={a.href}>{a.name}</a>
                      ) : (
                        <span class="bracket-slot__name">{a.name}</span>
                      )}
                      <span class="bracket-slot__meta">{a.meta}</span>
                    </div>
                    <div class="bracket-slot__vs" aria-hidden="true">vs</div>
                    <div class:list={["bracket-slot", { "bracket-slot--lead": b.lead }]}>
                      <span class="bracket-slot__seed">{b.seed}</span>
                      {b.href ? (
                        <a class="bracket-slot__name" href={b.href}>{b.name}</a>
                      ) : (
                        <span class="bracket-slot__name">{b.name}</span>
                      )}
                      <span class="bracket-slot__meta">{b.meta}</span>
                    </div>
                    {reveal && m.leaderReason && (
                      <p class="bracket-match__why">{m.leaderReason}</p>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>
        ))}
      </div>
    )}

    <h2 class="static-page__sub">How the bracket works</h2>
    <ul class="upgrade__perks">
      <li><strong>Field:</strong> the 16 people with the most graded CladFacts reports right now.</li>
      <li><strong>Seeding:</strong> #1 = most coverage volume; classic 1-vs-16 pairings.</li>
      <li><strong>Advancement:</strong> higher coverage score wins — report count first, then average factuality of the coverage about them.</li>
      <li><strong>Not polls:</strong> this ranks how the media covering them grades, not vote intention.</li>
    </ul>

    <p class="static-page__note">
      Updates as new reports publish.
      <a href="/politicians/">All politician cards</a>
      ·
      <a href="/how-it-works/">Methodology</a>
      ·
      <a href="/week/">Week in grades</a>
    </p>
  </article>
</BaseLayout>

<style>
  .bracket-champ {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    margin: 1.25rem 0;
    padding: 1rem 1.25rem;
    border: 3px double var(--ink, #1a140d);
  }
  .bracket-champ a {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: inherit;
  }
  .bracket-champ__meta { opacity: 0.8; font-size: 0.95rem; }

  .bracket-board {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.75rem 0 2rem;
    overflow-x: auto;
  }
  @media (max-width: 960px) {
    .bracket-board {
      grid-template-columns: 1fr;
    }
  }
  .bracket-col__title {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .bracket-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bracket-match {
    border: 1px solid var(--ink, #1a140d);
    padding: 0.65rem 0.75rem;
    background: var(--paper, #f5edd9);
  }
  .bracket-match__region {
    margin: 0 0 0.4rem;
    opacity: 0.65;
    font-size: 0.72rem;
  }
  .bracket-slot {
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.4rem;
    padding: 0.25rem 0.2rem;
  }
  .bracket-slot--lead {
    background: color-mix(in srgb, var(--ink, #1a140d) 8%, transparent);
    outline: 1px solid var(--ink, #1a140d);
  }
  .bracket-slot__seed {
    grid-row: 1 / span 2;
    font-weight: 700;
    opacity: 0.55;
    font-size: 0.85rem;
    padding-top: 0.15rem;
  }
  .bracket-slot__name {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    font-size: 0.98rem;
  }
  .bracket-slot__name:hover { text-decoration: underline; }
  .bracket-slot__meta {
    font-size: 0.78rem;
    opacity: 0.75;
  }
  .bracket-slot__vs {
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.45;
    margin: 0.15rem 0;
  }
  .bracket-match__why {
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    opacity: 0.75;
  }
</style>
