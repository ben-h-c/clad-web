---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAccess } from "~/lib/access";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import {
  buildRaceBoard,
  maskRaceLeaders,
  statusLabel,
  type RaceCardLive,
  type RaceSideLive,
} from "~/lib/bracket";
import { RACE_BOARD_VERIFIED_ASOF } from "~/lib/races";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const reveal = access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const board = maskRaceLeaders(buildRaceBoard(all, reveal), reveal);

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const ogImage = `${origin}/og/bracket.png`;
const pageUrl = `${origin}/bracket/`;

const view = Astro.url.searchParams.get("view") === "region" ? "region" : "chamber";

function party(p?: string) {
  return p ? ` (${p})` : "";
}

function sideClass(card: RaceCardLive, slug: string) {
  return card.leaderSlug === slug ? "race-side race-side--lead" : "race-side";
}

function sideLabel(side: RaceSideLive, defSide: RaceCardLive["def"]["a"]) {
  const bits = [
    side.name + party(side.party),
    defSide.incumbent ? "Inc." : "",
    defSide.field ? "Field" : "",
  ].filter(Boolean);
  return bits.join(" · ");
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: board.title,
  description: board.subtitle,
  url: pageUrl,
};
---
<BaseLayout
  title={`${board.title} — CladFacts`}
  description={board.subtitle}
  ogTitle={board.title}
  ogDescription="2026 midterm races that are actually on the calendar — Class II Senate and midterm governors — with live coverage grades, not polls."
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="static-page bracket-page">
    <p class="small-caps upgrade__eyebrow">Midterms 2026 · Race board</p>
    <h1 class="static-page__title">{board.title}</h1>
    <p class="upgrade__lede">{board.subtitle}</p>

    <nav class="bracket-modes" aria-label="Bracket modes">
      <a class="bracket-modes__on" href="/bracket/" aria-current="page">Race board</a>
      <a href="/elections/map/">Interactive map</a>
      <a href="/bracket/coverage/">Coverage tournament</a>
      <a href="/politicians/">All politicians</a>
      <a href="/learn/first-vote/">First-time voter guide</a>
    </nav>

    <section class="civics" aria-label="How midterms work">
      <h2 class="static-page__sub">How midterms work (short)</h2>
      <ul class="civics__list">
        <li>{board.civics.midterm}</li>
        <li>{board.civics.senateClass}</li>
        <li>{board.civics.vacancy}</li>
        <li>{board.civics.house}</li>
        <li>{board.civics.notPolls}</li>
      </ul>
    </section>

    {!reveal && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>
          Guests see report counts (heat). Sign in free to see which side
          <em>leads</em> each race by coverage volume + average factuality of that
          coverage — not by polls.
        </span>
        <a class="paywall-banner__cta" href="/register/">Create free account</a>
      </p>
    )}

    {board.hottest && board.hottest.heat > 0 && (
      <div class="bracket-champ" aria-label="Hottest race by coverage">
        <span class="small-caps">Hottest on-cycle race (by graded reports)</span>
        <strong>{board.hottest.def.office}</strong>
        <span class="bracket-champ__meta">
          {board.hottest.a.name} vs {board.hottest.b.name} · {board.hottest.heat} combined reports
          {board.hottest.def.senateClass ? ` · Senate Class ${board.hottest.def.senateClass}` : ""}
        </span>
      </div>
    )}

    <div class="race-share">
      <button type="button" class="race-share__btn" id="race-copy" data-url={pageUrl}>
        Copy link
      </button>
      <a
        class="race-share__btn"
        href={`https://bsky.app/intent/compose?text=${encodeURIComponent("2026 midterm race board on CladFacts — Class II Senate + governors, coverage grades not polls.\n" + pageUrl)}`}
        target="_blank"
        rel="noopener"
      >Share on Bluesky</a>
      <a class="race-share__btn race-share__btn--ghost" href="/bracket/card/">Share card</a>
      <a class="race-share__btn race-share__btn--ghost" href={view === "region" ? "/bracket/" : "/bracket/?view=region"}>
        {view === "region" ? "Group by chamber" : "Group by region"}
      </a>
    </div>
    <p class="race-share__status" id="race-copy-status" hidden></p>

    {(view === "chamber" ? board.byChamber : board.byRegion.map((g) => ({
      chamber: "senate" as const,
      label: g.region,
      cards: g.cards,
    }))).map((g) => (
      <section class="race-region">
        <h2 class="race-region__title">{g.label}</h2>
        <ul class="race-list">
          {g.cards.map((card) => (
            <li class="race-card" data-tier={card.def.tier} data-chamber={card.def.chamber} data-id={card.def.id}>
              <header class="race-card__head">
                <h3 class="race-card__office">{card.def.office}</h3>
                <span class="race-card__tier small-caps">{card.def.tier}</span>
                <span class="race-card__status small-caps">{statusLabel(card.def.status)}</span>
                {card.def.senateClass && (
                  <span class="race-card__class small-caps">Class {card.def.senateClass}</span>
                )}
                <span class="race-card__heat">{card.heat} reports</span>
              </header>
              <div class="race-card__sides">
                <div class={sideClass(card, card.a.slug)}>
                  <div class="race-side__top">
                    <PoliticianAvatar slug={card.a.slug} name={card.a.name} size="md" />
                    <div class="race-side__who">
                      {card.a.href ? (
                        <a href={card.a.href}>{sideLabel(card.a, card.def.a)}</a>
                      ) : (
                        <span class="race-side__name">{sideLabel(card.a, card.def.a)}</span>
                      )}
                      <span class="race-side__meta">
                        {card.a.reports} report{card.a.reports === 1 ? "" : "s"}
                        {reveal && card.a.avgFactuality != null ? ` · ${card.a.avgFactuality}/100` : ""}
                      </span>
                    </div>
                  </div>
                  {reveal && (card.a.avgGrade || card.a.avgLean != null) && (
                    <div class="scoreband race-side__scores">
                      {card.a.avgGrade && (
                        <div class="scoreband__grade">
                          <LetterGrade grade={card.a.avgGrade} size="card" />
                          <span class="scoreband__cap small-caps">Avg</span>
                        </div>
                      )}
                      {card.a.avgLean != null && (
                        <div class="scoreband__bias">
                          <PoliticalLean score={card.a.avgLean} />
                        </div>
                      )}
                    </div>
                  )}
                </div>
                <div class="race-card__vs" aria-hidden="true">vs</div>
                <div class={sideClass(card, card.b.slug)}>
                  <div class="race-side__top">
                    <PoliticianAvatar slug={card.b.slug} name={card.b.name} size="md" />
                    <div class="race-side__who">
                      {card.b.href ? (
                        <a href={card.b.href}>{sideLabel(card.b, card.def.b)}</a>
                      ) : (
                        <span class="race-side__name">{sideLabel(card.b, card.def.b)}</span>
                      )}
                      <span class="race-side__meta">
                        {card.b.reports} report{card.b.reports === 1 ? "" : "s"}
                        {reveal && card.b.avgFactuality != null ? ` · ${card.b.avgFactuality}/100` : ""}
                      </span>
                    </div>
                  </div>
                  {reveal && (card.b.avgGrade || card.b.avgLean != null) && (
                    <div class="scoreband race-side__scores">
                      {card.b.avgGrade && (
                        <div class="scoreband__grade">
                          <LetterGrade grade={card.b.avgGrade} size="card" />
                          <span class="scoreband__cap small-caps">Avg</span>
                        </div>
                      )}
                      {card.b.avgLean != null && (
                        <div class="scoreband__bias">
                          <PoliticalLean score={card.b.avgLean} />
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
              {reveal && card.leaderReason && (
                <p class="race-card__why">
                  {card.leaderSlug
                    ? `Coverage lead: ${card.leaderSlug === card.a.slug ? card.a.name : card.b.name} — ${card.leaderReason}`
                    : card.leaderReason}
                </p>
              )}
              {card.def.note && <p class="race-card__note">{card.def.note}</p>}
            </li>
          ))}
        </ul>
      </section>
    ))}

    <h2 class="static-page__sub">How to read this board</h2>
    <ul class="upgrade__perks">
      <li><strong>Candidate map verified</strong> as of {RACE_BOARD_VERIFIED_ASOF}. A background agent re-checks dropouts and nominees with web search every other day; stale pairings get fixed in code.</li>
      <li><strong>On-cycle only.</strong> Senate cards are Class II (2026). Class I (next 2030) and Class III (next 2028) are not marquee Senate cards here.</li>
      <li><strong>Open seats</strong> mark retirements (Tillis, Peters, Smith, Shaheen, Durbin) or term-limited governors — not “incumbent vs field.”</li>
      <li><strong>Special</strong> marks a mid-term vacancy under the 17th Amendment + state law (South Carolina after Graham’s death).</li>
      <li><strong>Heat</strong> = combined graded reports mentioning either side (public).</li>
      <li><strong>Coverage lead</strong> (signed-in) = more reports, then higher average factuality of that coverage — not a vote forecast.</li>
      <li><strong>Field</strong> means the nominee is not locked in our data; we show a coverage stand-in and note it. Withdrawn candidates (e.g. Platner in Maine) are not listed as active sides.</li>
      <li><strong>House:</strong> all 435 seats every midterm — national control still shows up in the <a href="/bracket/coverage/">coverage tournament</a>.</li>
    </ul>

    <p class="static-page__note">
      People-level tournament (volume seeding): <a href="/bracket/coverage/">coverage tournament</a>.
      Civics explainers: <a href="/learn/first-vote/">first-time voter guide</a>.
    </p>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.getElementById("race-copy");
    const status = document.getElementById("race-copy-status");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-url") || location.href;
      try {
        await navigator.clipboard.writeText(url);
        if (status) { status.hidden = false; status.textContent = "Link copied."; }
      } catch {
        if (status) { status.hidden = false; status.textContent = url; }
      }
    });
  })();
</script>

<style>
  .bracket-modes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0.75rem 0 1.25rem;
    font-size: 0.95rem;
  }
  .bracket-modes a { color: inherit; }
  .bracket-modes__on {
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .civics {
    margin: 0 0 1.5rem;
    padding: 1rem 1.15rem;
    border: 1px solid var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
  }
  .civics__list {
    margin: 0.5rem 0 0;
    padding-left: 1.2rem;
  }
  .civics__list li {
    margin: 0.45rem 0;
    line-height: 1.45;
    font-size: 0.95rem;
  }
  .bracket-champ {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    margin: 1rem 0;
    padding: 0.9rem 1.1rem;
    border: 3px double var(--ink, #1a140d);
  }
  .bracket-champ__meta { opacity: 0.8; font-size: 0.92rem; }
  .race-share {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 1.5rem;
  }
  .race-share__btn {
    appearance: none;
    font: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    text-decoration: none;
    cursor: pointer;
  }
  .race-share__btn--ghost {
    background: transparent;
    color: inherit;
  }
  .race-share__status { font-size: 0.9rem; opacity: 0.85; margin: -0.75rem 0 1rem; }
  .race-region { margin: 1.75rem 0; }
  .race-region__title {
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .race-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }
  .race-card {
    border: 1px solid var(--ink, #1a140d);
    padding: 0.85rem 1rem;
  }
  .race-card[data-tier="marquee"] {
    border-width: 2px;
  }
  .race-card__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.65rem;
    margin-bottom: 0.65rem;
  }
  .race-card__office {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.12rem;
    font-weight: 700;
    margin: 0;
  }
  .race-card__tier,
  .race-card__status,
  .race-card__class {
    opacity: 0.65;
    font-size: 0.72rem;
  }
  .race-card__heat { margin-left: auto; font-size: 0.85rem; opacity: 0.8; }
  .race-card__sides {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    align-items: start;
  }
  @media (max-width: 640px) {
    .race-card__sides { grid-template-columns: 1fr; }
    .race-card__vs { text-align: center; }
  }
  .race-side {
    padding: 0.55rem 0.55rem;
  }
  .race-side--lead {
    outline: 2px solid var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 7%, transparent);
  }
  .race-side__top {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
  }
  .race-side__who { min-width: 0; flex: 1; }
  .race-side a,
  .race-side__name {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    display: block;
    line-height: 1.2;
  }
  .race-side a:hover { text-decoration: underline; }
  .race-side__meta {
    display: block;
    font-size: 0.82rem;
    opacity: 0.78;
    margin-top: 0.25rem;
  }
  .race-side__scores {
    margin: 0.55rem 0 0;
    padding-top: 0.45rem;
    border-top: 1px solid var(--rule, #cfc3ad);
  }
  .race-side__scores.scoreband {
    margin-bottom: 0;
    gap: 0.5rem 0.75rem;
  }
  .race-card__vs {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.45;
    padding-top: 0.5rem;
  }
  .race-card__why {
    margin: 0.55rem 0 0;
    font-size: 0.85rem;
    opacity: 0.85;
  }
  .race-card__note {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    opacity: 0.7;
    font-style: italic;
  }
</style>
