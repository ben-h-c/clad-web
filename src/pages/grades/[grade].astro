---
import { publishedPostsSorted } from "~/lib/publishedPosts";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { metaDescription } from "~/lib/seo";

/**
 * Per-grade archive — every report that earned one letter grade, an evergreen
 * companion to the rubric on /how-it-works/ (PolitiFact/Snopes-style rating
 * archives). Indexable and sitemapped.
 *
 * Gating carve-out (owner decision 2026-07-07): the LISTING is public — which
 * stories earned this grade is deliberately disclosed to anonymous readers as
 * an SEO asset, like PolitiFact's rating archives. The cards themselves still
 * render the locked variant for guests (no grade/lean/sentiment markup), so
 * scoreboard VALUES stay account-gated and checkAnonLeak still holds; the
 * page heading is the one sanctioned grade signal.
 */
export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

// URL slug ↔ letter grade. Order here drives prev/next links.
const GRADES: { slug: string; grade: string }[] = [
  { slug: "a-plus", grade: "A+" },
  { slug: "a", grade: "A" },
  { slug: "a-minus", grade: "A-" },
  { slug: "b-plus", grade: "B+" },
  { slug: "b", grade: "B" },
  { slug: "b-minus", grade: "B-" },
  { slug: "c-plus", grade: "C+" },
  { slug: "c", grade: "C" },
  { slug: "c-minus", grade: "C-" },
  { slug: "d-plus", grade: "D+" },
  { slug: "d", grade: "D" },
  { slug: "d-minus", grade: "D-" },
  { slug: "f", grade: "F" },
];

// What each band means — mirrors the grading rubric in src/lib/broadcast.ts
// and the methodology page; the plus/minus shading is described per page.
const BAND_MEANING: Record<string, string> = {
  A: "high accuracy: claims were well-sourced, coverage was balanced, and any issues were minimal",
  B: "mostly accurate coverage with a few minor concerns an attentive viewer should know about",
  C: "a mix of accurate and problematic claims — noticeable patterns like one-sided sourcing or missing context",
  D: "significant factual issues, heavy partisan framing, or major claims presented without sources",
  F: "pervasive misinformation or propaganda-level distortion of the story being covered",
};

const entry = GRADES.find((g) => g.slug === Astro.params.grade);
if (!entry) return new Response(null, { status: 404 });
const { slug, grade } = entry;
const band = grade[0]!;
const shade = grade.includes("+")
  ? "the strongest reports in the band"
  : grade.includes("-")
    ? "the weakest reports in the band"
    : "squarely in the middle of the band";

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

// sampleUnlockedId re-sorts its input internally, so `all` needn't be sorted;
// sort only the matched band instead of the whole ~2530-post collection.
const all = await publishedPostsSorted();
const matching = all
  .filter((p) => p.data.letterGrade === grade)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// The daily sample renders fully unlocked (marked subtree) when it carries
// this grade; every other card stays in its locked variant for guests.
const sampleId = locked ? sampleUnlockedId(all) : null;

const idx = GRADES.findIndex((g) => g.slug === slug);
const prev = idx > 0 ? GRADES[idx - 1] : null;
const next = idx < GRADES.length - 1 ? GRADES[idx + 1] : null;

const desc = metaDescription(
  `Every news broadcast Clad graded ${grade}: ${grade}-rated reports mean ${BAND_MEANING[band]}. Browse the full ${grade} archive of fact-checked, bias-rated coverage.`
);
---
<BaseLayout title={`Reports graded ${grade} — CladFacts`} description={desc}>
  <section class="topic-page grade-page">
    <p class="small-caps" style="color:var(--muted-ink)">Grade archive</p>
    <h2 class="topic-page__title">Graded {grade}</h2>
    <p class="dateline">
      A <strong>{grade}</strong> on Clad means {BAND_MEANING[band]}{band === "F" ? "" : ` — ${shade}`}.
      The full rubric lives on the <a href="/how-it-works/#rubric">methodology page</a>.
    </p>

    <p class="dateline" style="margin-top:0.5rem">
      Browse other grades:
      {GRADES.map((g, i) => (
        <>
          {i > 0 ? " · " : " "}
          {g.slug === slug ? <strong>{g.grade}</strong> : <a href={`/grades/${g.slug}/`}>{g.grade}</a>}
        </>
      ))}
    </p>

    <div class="rule rule--double" aria-hidden="true" style="margin:1.25rem 0"></div>

    {matching.length === 0 ? (
      <p class="dateline">No reports have earned a {grade} yet{prev || next ? " — try a neighboring grade" : ""}.</p>
    ) : (
      <>
        <p class="dateline" style="margin-bottom:0.75rem">
          {matching.length} {matching.length === 1 ? "report" : "reports"}, newest first.
          {locked && (
            <> Full scorecards unlock with a <a href="/register/">free CladFacts account</a>.</>
          )}
        </p>
        <div class="feed-list">
          {matching.map((p) => (
            <ReportCard post={p} variant="bar" locked={locked && p.id !== sampleId} sample={locked && p.id === sampleId} />
          ))}
        </div>
      </>
    )}

    <p class="dateline" style="margin-top:1.5rem">
      {prev && <a href={`/grades/${prev.slug}/`}>← Graded {prev.grade}</a>}
      {prev && next && " · "}
      {next && <a href={`/grades/${next.slug}/`}>Graded {next.grade} →</a>}
    </p>
  </section>
</BaseLayout>
