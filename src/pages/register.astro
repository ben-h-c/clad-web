---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAuth, enabledSocialProviders } from "~/lib/auth-server";
import { safeNextPath } from "~/lib/safeNext";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const dest = safeNextPath(Astro.url.searchParams.get("next"), "/account/");
const session = await getAuth().api.getSession({ headers: Astro.request.headers });
if (session?.user) return Astro.redirect(dest);

const PROVIDER_LABELS: Record<string, string> = { google: "Google", apple: "Apple", twitter: "X" };
const providers = enabledSocialProviders();
const loginHref = dest !== "/account/" ? `/login/?next=${encodeURIComponent(dest)}` : "/login/";
---
<BaseLayout title="Create account — Clad" description="Create a free CladFacts account — every grade, political-lean rating, and sentiment score, no card required." noindex={true}>
  <article class="static-page auth-page" id="register-article" data-next={dest}>
    <h2 class="static-page__title">Create your account</h2>
    <p class="dateline">A free account is full access — every letter grade, factuality score, political-lean rating, and social-sentiment score. No card, no trial clock. Plus saved reports and custom topic alerts.</p>
    {dest !== "/account/" && (
      <p class="auth-return small-caps">After you verify, we&rsquo;ll send you back to finish what you started.</p>
    )}

    {providers.length > 0 && (
      <div class="auth-social">
        {providers.map((p) => (
          <button type="button" class:list={["auth-social__btn", p === "apple" && "auth-social__btn--app-only"]} data-provider={p}>Continue with {PROVIDER_LABELS[p] ?? p}</button>
        ))}
        <div class="auth-or"><span>or</span></div>
      </div>
    )}

    <form id="register-form" class="auth-form">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="password">Password (8+ characters)</label>
        <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" required />
      </div>
      <button type="submit" class="auth-submit">Create account</button>
      <div id="register-status" class="auth-status" role="status"></div>
    </form>

    <p class="auth-alt">Already have an account? <a href={loginHref}>Sign in</a></p>
  </article>

  <script is:inline>
    const status = document.getElementById("register-status");
    const articleEl = document.getElementById("register-article");
    const nextDest = (articleEl && articleEl.getAttribute("data-next")) || "/account/";
    const verifiedCallback =
      nextDest && nextDest !== "/account/"
        ? "/verified/?next=" + encodeURIComponent(nextDest)
        : "/verified/";
    const loginWithNext =
      nextDest && nextDest !== "/account/"
        ? "/login/?next=" + encodeURIComponent(nextDest)
        : "/login/";
    try { sessionStorage.setItem("clad_auth_next", nextDest); } catch {}
    const setErr = (m) => { status.className = "auth-status auth-status--error"; status.textContent = m; };
    document.getElementById("register-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector(".auth-submit");
      btn.disabled = true;
      status.textContent = "Creating your account…";
      try {
        const nameEl = document.getElementById("name");
        const emailEl = document.getElementById("email");
        const pwEl = document.getElementById("password");
        const res = await fetch("/api/auth/sign-up/email", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name: nameEl.value.trim(), email: emailEl.value.trim(), password: pwEl.value }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.message || "Could not create account.");
        // Email verification is required, so a new account never gets a session
        // here — always show the "check your email" confirmation.
        const addr = emailEl.value.trim();
        const article = document.getElementById("register-article");
        const h = document.createElement("h2");
        h.className = "static-page__title";
        h.textContent = "Check your email";
        const p1 = document.createElement("p");
        p1.append("We sent a verification link to ");
        const strong = document.createElement("strong");
        strong.textContent = addr;
        p1.append(strong, ". Click it to confirm your account and finish signing up.");
        const p2 = document.createElement("p");
        p2.className = "dateline";
        p2.append("Didn't get it? Check your spam folder, or ");
        const resend = document.createElement("button");
        resend.type = "button";
        resend.className = "auth-linklike";
        resend.textContent = "resend the email";
        p2.append(resend, ".");
        const rstatus = document.createElement("div");
        rstatus.className = "auth-status";
        rstatus.setAttribute("role", "status");
        const p3 = document.createElement("p");
        p3.className = "auth-alt";
        const signin = document.createElement("a");
        signin.href = loginWithNext;
        signin.textContent = "Sign in";
        p3.append("Already verified? ", signin);
        resend.addEventListener("click", async () => {
          resend.disabled = true;
          rstatus.className = "auth-status";
          rstatus.textContent = "Sending…";
          try {
            const r = await fetch("/api/auth/send-verification-email", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email: addr, callbackURL: verifiedCallback }),
            });
            if (!r.ok) throw new Error("Could not resend. Try again in a moment.");
            rstatus.textContent = "Sent — check your inbox (and spam).";
          } catch (err) {
            rstatus.className = "auth-status auth-status--error";
            rstatus.textContent = String(err.message || err);
            resend.disabled = false;
          }
        });
        article.replaceChildren(h, p1, p2, rstatus, p3);
      } catch (err) { setErr(String(err.message || err)); btn.disabled = false; }
    });
    document.querySelectorAll(".auth-social__btn").forEach((b) => {
      b.addEventListener("click", async () => {
        const provider = b.getAttribute("data-provider");
        // In the iOS app, Google/Apple OAuth can't complete inside the webview
        // (passkeys / disallowed_useragent). Hand off to native sign-in, which
        // posts an id token to the server and injects the session cookie back.
        if (window.__cladNative && (provider === "google" || provider === "apple")
            && window.webkit?.messageHandlers?.cladAuth) {
          window.webkit.messageHandlers.cladAuth.postMessage({ provider });
          return;
        }
        b.disabled = true;
        try {
          const res = await fetch("/api/auth/sign-in/social", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ provider, callbackURL: nextDest }),
          });
          const data = await res.json().catch(() => ({}));
          if (data.url) window.location.href = data.url;
          else throw new Error(data.message || "Could not start sign-in.");
        } catch (err) { setErr(String(err.message || err)); b.disabled = false; }
      });
    });
  </script>
</BaseLayout>
