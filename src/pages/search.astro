---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getAccess } from "~/lib/access";
import { searchPosts } from "~/lib/search";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const fullAccess = (await getAccess(Astro.request.headers)).fullAccess;

// Facets only — outlet list + top topics for the filter UI. The full post
// records are NOT shipped to the browser; results come from the server
// (rendered below, refreshed via /api/search as you type).
const posts = await getCollection("posts", (p) => !p.data.draft);
const outlets = [...new Set(posts.map((p) => p.data.sourceTitle).filter((s): s is string => !!s))].sort(
  (a, b) => a.localeCompare(b)
);
const topicFreq = new Map<string, number>();
for (const p of posts) for (const t of p.data.topics ?? []) topicFreq.set(t, (topicFreq.get(t) ?? 0) + 1);
const topTopics = [...topicFreq.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12).map(([t]) => t);

// Server-rendered results for the URL's query params — the page works with no
// JS (real GET form); the inline script upgrades it to live search.
const sp = Astro.url.searchParams;
const qParam = sp.get("q") || "";
const outletParam = sp.get("outlet") || "";
const gradeParam = sp.get("grade") || "";
const biasParam = sp.get("bias") || "";
const fromParam = sp.get("from") || "";
const toParam = sp.get("to") || "";

const { total, results } = searchPosts(
  posts,
  { q: qParam, outlet: outletParam, grade: gradeParam, bias: biasParam, from: fromParam, to: toParam },
  !fullAccess
);

const leanText = (s: number | null) =>
  s === null ? "" : Math.abs(s) < 5 ? "Centered" : `${Math.abs(s)}% ${s > 0 ? "Right" : "Left"}`;
const shortDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
const countText = results.length
  ? `${total} result${total === 1 ? "" : "s"}${total > results.length ? ` (showing ${results.length})` : ""}`
  : "No matches.";
---
<BaseLayout
  title="Search — Clad"
  description="Search Clad's fact-checked political reports by topic, headline, network, grade, bias, or date."
  noindex={true}
>
  <section class="search-page" data-full-access={fullAccess ? "1" : "0"}>
    <h2 class="search-page__title">Search</h2>
    <p class="dateline">Search reports by topic, headline, or network — then filter by outlet, date{fullAccess ? ", grade, and political bias" : ""}.</p>

    <form id="search-form" role="search" method="get" action="/search/">
      <input
        id="search-input"
        name="q"
        type="search"
        value={qParam}
        placeholder="e.g. Iran, Trump, inflation, CBS…"
        autocomplete="off"
        autofocus
      />

      <div class="search-filters">
        <label class="search-filter">
          <span>Outlet</span>
          <select id="f-outlet" name="outlet">
            <option value="">All outlets</option>
            {outlets.map((o) => <option value={o} selected={o === outletParam}>{o}</option>)}
          </select>
        </label>
        {fullAccess && (
          <label class="search-filter">
            <span>Grade</span>
            <select id="f-grade" name="grade">
              <option value="">Any grade</option>
              {["A", "B", "C", "D", "F"].map((g) => (
                <option value={g} selected={g === gradeParam.toUpperCase()}>{g}</option>
              ))}
            </select>
          </label>
        )}
        {fullAccess && (
          <label class="search-filter">
            <span>Political bias</span>
            <select id="f-bias" name="bias">
              <option value="">Any lean</option>
              <option value="left" selected={biasParam === "left"}>Leans left</option>
              <option value="center" selected={biasParam === "center"}>Centered</option>
              <option value="right" selected={biasParam === "right"}>Leans right</option>
            </select>
          </label>
        )}
        <label class="search-filter">
          <span>From</span>
          <input type="date" id="f-from" name="from" value={fromParam} />
        </label>
        <label class="search-filter">
          <span>To</span>
          <input type="date" id="f-to" name="to" value={toParam} />
        </label>
        <button type="submit" class="auth-submit">Search</button>
        <button type="button" id="f-clear" class="search-filter__clear">Clear</button>
      </div>
    </form>

    <div id="topic-chips" class="topic-chips">
      {topTopics.map((t) => (
        <button type="button" class="topic-chip" data-topic={t}>{t}</button>
      ))}
    </div>
    <p id="search-count" class="dateline">{countText}</p>
    <div id="search-results" class="feed-list" data-ssr="1">
      {results.map((r) => (
        <a class="search-result" href={`/posts/${r.id}/`}>
          {r.thumbnail && (
            <div class="search-result__thumb">
              <img src={r.thumbnail} alt="" loading="lazy" width="160" height="90" />
            </div>
          )}
          <div class="search-result__body">
            <div class="search-result__head">
              {r.grade && <span class="search-result__grade">{r.grade}</span>}
              <span class="search-result__hl">{r.headline}</span>
            </div>
            <p class="search-result__meta">{shortDate(r.date)}{r.channel ? ` · ${r.channel}` : ""}{leanText(r.leanScore) ? ` · ${leanText(r.leanScore)}` : ""}</p>
            <p class="search-result__blurb">{r.blurb || ""}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    const form = $("search-form");
    const input = $("search-input");
    const resultsEl = $("search-results");
    const countEl = $("search-count");
    const fOutlet = $("f-outlet");
    const fGrade = $("f-grade");
    const fBias = $("f-bias");
    const fFrom = $("f-from");
    const fTo = $("f-to");

    const LEAN = (s) =>
      s === null || s === undefined ? "" : Math.abs(s) < 5 ? "Centered" : `${Math.abs(s)}% ${s > 0 ? "Right" : "Left"}`;
    const shortDate = (iso) =>
      new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    const esc = (s) =>
      String(s).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

    function render(list, total) {
      countEl.textContent = list.length
        ? `${total} result${total === 1 ? "" : "s"}${total > list.length ? ` (showing ${list.length})` : ""}`
        : "No matches.";
      resultsEl.innerHTML = list
        .map((r) => {
          const lean = LEAN(r.leanScore);
          const gradeBadge = r.grade ? `<span class="search-result__grade">${esc(r.grade)}</span>` : "";
          const thumb = r.thumbnail
            ? `<div class="search-result__thumb"><img src="${esc(r.thumbnail)}" alt="" loading="lazy" width="160" height="90"></div>` : "";
          return `<a class="search-result" href="/posts/${esc(r.id)}/">
            ${thumb}
            <div class="search-result__body">
              <div class="search-result__head">${gradeBadge}<span class="search-result__hl">${esc(r.headline)}</span></div>
              <p class="search-result__meta">${shortDate(r.date)}${r.channel ? " · " + esc(r.channel) : ""}${lean ? " · " + lean : ""}</p>
              <p class="search-result__blurb">${esc(r.blurb || "")}</p>
            </div>
          </a>`;
        })
        .join("");
    }

    let seq = 0;
    async function run() {
      const params = new URLSearchParams();
      if (input.value.trim()) params.set("q", input.value.trim());
      if (fOutlet && fOutlet.value) params.set("outlet", fOutlet.value);
      if (fGrade && fGrade.value) params.set("grade", fGrade.value);
      if (fBias && fBias.value) params.set("bias", fBias.value);
      if (fFrom && fFrom.value) params.set("from", fFrom.value);
      if (fTo && fTo.value) params.set("to", fTo.value);
      const mine = ++seq;
      countEl.textContent = "Searching…";
      try {
        const res = await fetch("/api/search?" + params.toString());
        const data = await res.json();
        if (mine !== seq) return; // a newer query superseded this one
        render(data.results || [], data.total || 0);
      } catch {
        if (mine === seq) countEl.textContent = "Search failed. Try again.";
      }
    }

    let t;
    const debouncedRun = () => { clearTimeout(t); t = setTimeout(run, 220); };

    function syncUrl(q) {
      const u = new URL(location.href);
      if (q) u.searchParams.set("q", q); else u.searchParams.delete("q");
      history.replaceState(null, "", u);
    }

    // With JS, the GET form becomes a live search — no full-page reload.
    form.addEventListener("submit", (e) => { e.preventDefault(); syncUrl(input.value.trim()); run(); });
    input.addEventListener("input", () => { debouncedRun(); syncUrl(input.value); });
    [fOutlet, fGrade, fBias, fFrom, fTo].forEach((el) => el && el.addEventListener("change", run));
    document.querySelectorAll(".topic-chip").forEach((b) => {
      b.addEventListener("click", () => {
        input.value = b.getAttribute("data-topic");
        syncUrl(input.value);
        run();
      });
    });
    const clearBtn = $("f-clear");
    if (clearBtn) clearBtn.addEventListener("click", () => {
      [fOutlet, fGrade, fBias, fFrom, fTo].forEach((el) => { if (el) el.value = ""; });
      run();
    });

    // Results for the current URL were server-rendered — skip the initial fetch.
    if (!resultsEl.hasAttribute("data-ssr")) run();
  </script>
</BaseLayout>
