---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import SocialSentiment from "~/components/SocialSentiment.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getSentiments } from "~/lib/agents";
import { aggregateTopics } from "~/lib/topics";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { metaDescription } from "~/lib/seo";
import { shortDate } from "~/lib/dateline";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
// Social-media sentiment (KV, scanner-scored) — Premium like grade/lean; the
// read is skipped for restricted readers so the value never reaches their HTML.
const sentiments = locked ? {} : await getSentiments(env.AGENTS);
const topic = aggregateTopics(all, sentiments).find((t) => t.slug === Astro.params.topic);
if (!topic) return new Response(null, { status: 404 });

const sorted = topic.posts.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// Big topics stream hundreds of full cards in one document — paginate so the
// heaviest pages stay light (INP/LCP). Canonical stays on the bare path
// (BaseLayout ignores the query string), so pages never compete in search.
const PER_PAGE = 50;
const pageCount = Math.max(1, Math.ceil(sorted.length / PER_PAGE));
const page = Number(Astro.url.searchParams.get("page") ?? "1");
if (!Number.isInteger(page) || page < 1 || page > pageCount) {
  return new Response(null, { status: 404 });
}
const posts = sorted.slice((page - 1) * PER_PAGE, page * PER_PAGE);
const pageUrl = (n: number) => `/topics/${topic.slug}/${n === 1 ? "" : `?page=${n}`}`;

// Report of the Day — today's sample card renders unlocked for restricted readers.
const sampleId = locked ? sampleUnlockedId(all) : null;

const shareUrl = new URL(`/topics/${topic.slug}/`, Astro.site ?? "https://cladfacts.com").href;
const leanLbl =
  topic.avgLean === null
    ? null
    : Math.abs(topic.avgLean) < 5
      ? "Centered"
      : `${Math.abs(topic.avgLean)}% ${topic.avgLean > 0 ? "Right" : "Left"}-leaning`;
const countLabel = `${topic.count} fact-checked ${topic.count === 1 ? "report" : "reports"} on ${topic.display}`;
// Restricted readers (incl. crawlers) get a grade-free description so the
// topic's avg grade/lean values stay account-gated even in <head> — keyed to
// fullAccess, same pattern as posts/[slug].astro.
const ogDescription = !access.fullAccess
  ? `${countLabel} — every report graded for accuracy and political lean`
  : [countLabel, topic.avgGrade ? `avg grade ${topic.avgGrade}` : null, leanLbl]
      .filter(Boolean)
      .join(" · ");
// SERP description: differentiated per topic (count, freshness, the newest
// headlines) instead of the old one-size template — grade-free, so identical
// for anonymous crawlers and signed-out readers.
const newestHeads = sorted.slice(0, 2).map((p) => p.data.headline).join("; ");
const serpDescription = metaDescription(
  `${countLabel}, updated ${shortDate(sorted[0]!.data.publishedAt)}. Latest: ${newestHeads}.`
);
---
<BaseLayout
  title={`${topic.display} fact-checks — ${topic.count} graded ${topic.count === 1 ? "report" : "reports"} — CladFacts`}
  description={serpDescription}
  ogTitle={`${topic.display} — ${topic.count} ${topic.count === 1 ? "report" : "reports"}`}
  ogDescription={ogDescription}
  ogImage={`/og/topic-${topic.slug}.png`}
  ogType="website"
>
  <Fragment slot="head">
    {page > 1 && <link rel="prev" href={pageUrl(page - 1)} />}
    {page < pageCount && <link rel="next" href={pageUrl(page + 1)} />}
  </Fragment>
  <section class="topic-page">
    <p class="small-caps" style="color:var(--muted-ink)">Topic · {topic.count} {topic.count === 1 ? "report" : "reports"}</p>
    <h1 class="topic-page__title">{topic.display}</h1>

    {locked ? (
      <p class="grade-lock-panel" style="margin:0.75rem 0">
        <span aria-hidden="true">🔒</span> Average grade, political-lean &amp; social sentiment for this topic unlock with a
        <a href="/register/"> free CladFacts account</a>.
      </p>
    ) : (
      <div class="topic-page__agg">
        {topic.avgGrade && (
          <div class="scoreband__grade">
            <LetterGrade grade={topic.avgGrade} size="card" />
            <span class="scoreband__cap small-caps">Avg grade</span>
          </div>
        )}
        {topic.avgLean !== null && (
          <div class="scoreband__bias"><PoliticalLean score={topic.avgLean} /></div>
        )}
        {topic.avgSentiment !== null && (
          <div class="scoreband__bias"><SocialSentiment score={topic.avgSentiment} /></div>
        )}
      </div>
    )}

    <ShareBar url={shareUrl} title={`${topic.display} — CladFacts`} />

    <div class="rule rule--double" aria-hidden="true" style="margin:1.25rem 0"></div>

    <div class="feed-list">
      {posts.map((p) => (
        <ReportCard post={p} variant="bar" locked={locked && p.id !== sampleId} sample={locked && p.id === sampleId} />
      ))}
    </div>
    {pageCount > 1 && (
      <nav class="archive-nav" aria-label="Topic pages">
        {page > 1 && <a href={pageUrl(page - 1)}>← Newer</a>}
        <span class="small-caps" style="color:var(--muted-ink)">Page {page} of {pageCount}</span>
        {page < pageCount && <a href={pageUrl(page + 1)} style="margin-left:auto">Older →</a>}
      </nav>
    )}
  </section>
</BaseLayout>
