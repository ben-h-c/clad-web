---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import SocialSentiment from "~/components/SocialSentiment.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getSentiments } from "~/lib/agents";
import { aggregateTopics } from "~/lib/topics";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
// Social-media sentiment (KV, scanner-scored) — Premium like grade/lean; the
// read is skipped for restricted readers so the value never reaches their HTML.
const sentiments = locked ? {} : await getSentiments(env.AGENTS);
const topic = aggregateTopics(all, sentiments).find((t) => t.slug === Astro.params.topic);
if (!topic) return new Response(null, { status: 404 });

const posts = topic.posts.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// Report of the Day — today's sample card renders unlocked for restricted readers.
const sampleId = locked ? sampleUnlockedId(all) : null;

const shareUrl = new URL(`/topics/${topic.slug}/`, Astro.site ?? "https://cladfacts.com").href;
const leanLbl =
  topic.avgLean === null
    ? null
    : Math.abs(topic.avgLean) < 5
      ? "Centered"
      : `${Math.abs(topic.avgLean)}% ${topic.avgLean > 0 ? "Right" : "Left"}-leaning`;
const ogDescription = [
  `${topic.count} fact-checked ${topic.count === 1 ? "report" : "reports"} on ${topic.display}`,
  topic.avgGrade ? `avg grade ${topic.avgGrade}` : null,
  leanLbl,
].filter(Boolean).join(" · ");
---
<BaseLayout
  title={`${topic.display} — Clad`}
  description={`All Clad reports tagged ${topic.display}.`}
  ogTitle={`${topic.display} — ${topic.count} ${topic.count === 1 ? "report" : "reports"}`}
  ogDescription={ogDescription}
  ogImage={`/og/topic-${topic.slug}.png`}
  ogType="website"
>
  <section class="topic-page">
    <p class="small-caps" style="color:var(--muted-ink)">Topic · {topic.count} {topic.count === 1 ? "report" : "reports"}</p>
    <h2 class="topic-page__title">{topic.display}</h2>

    {locked ? (
      <p class="grade-lock-panel" style="margin:0.75rem 0">
        <span aria-hidden="true">🔒</span> Average grade, political-lean &amp; social sentiment for this topic unlock with a
        <a href="/register/"> free CladFacts account</a>.
      </p>
    ) : (
      <div class="topic-page__agg">
        {topic.avgGrade && (
          <div class="scoreband__grade">
            <LetterGrade grade={topic.avgGrade} size="card" />
            <span class="scoreband__cap small-caps">Avg grade</span>
          </div>
        )}
        {topic.avgLean !== null && (
          <div class="scoreband__bias"><PoliticalLean score={topic.avgLean} /></div>
        )}
        {topic.avgSentiment !== null && (
          <div class="scoreband__bias"><SocialSentiment score={topic.avgSentiment} /></div>
        )}
      </div>
    )}

    <ShareBar url={shareUrl} title={`${topic.display} — Clad`} />

    <div class="rule rule--double" aria-hidden="true" style="margin:1.25rem 0"></div>

    <div class="feed-list">
      {posts.map((p) => (
        <ReportCard post={p} variant="bar" locked={locked && p.id !== sampleId} sample={locked && p.id === sampleId} />
      ))}
    </div>
  </section>
</BaseLayout>
