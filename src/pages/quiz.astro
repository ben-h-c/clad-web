---
import { publishedPostsSorted } from "~/lib/publishedPosts";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ExploreNext from "~/components/ExploreNext.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getShareTags } from "~/lib/agents";
import { nyDateParts } from "~/lib/dateline";
import { OG_VERSIONS } from "~/lib/ogCard";
import { pickQuizQuestions } from "~/lib/quiz";

export const prerender = false;

// The Morning Quiz: five claims from recent reports; the reader calls the
// verdict, then sees Clad's ruling with the editor's note and a link to the
// receipts. Claim verdicts + notes are FREE report-body content — nothing
// gated renders here. Questions are deterministic per Eastern day so every
// reader (and every cache) gets the same daily quiz — selection lives in
// ~/lib/quiz, shared with the OG card route so the card's teased claim is
// always on this page.
const pad = (n: number) => String(n).padStart(2, "0");
const { y, m, d } = nyDateParts(new Date());
const today = `${y}-${pad(m)}-${pad(d)}`;
const yesterdayParts = nyDateParts(new Date(Date.now() - 24 * 60 * 60 * 1000));
const yesterday = `${yesterdayParts.y}-${pad(yesterdayParts.m)}-${pad(yesterdayParts.d)}`;

const posts = await publishedPostsSorted();
const questions = pickQuizQuestions(posts, today);

const shareTags = (await getShareTags(env.AGENTS))?.tags ?? {};

const VERDICTS = ["verified", "disputed", "missing context", "unsupported"] as const;
const label = (v: string) => v.charAt(0).toUpperCase() + v.slice(1);
---
<BaseLayout
  title="The Morning Quiz — CladFacts"
  description="Five claims from this week's news broadcasts — can you spot the spin? A new quiz every day, with Clad's verdict and sources for every claim."
  ogTitle="The Morning Quiz — can you spot the spin?"
  ogImage={`/og/quiz/${today}.png?v=${OG_VERSIONS.quiz}`}
>
  <section class="topic-page quiz" data-today={today} data-yesterday={yesterday}>
    <p class="small-caps" style="color:var(--muted-ink)">Daily · five claims · new at midnight Eastern</p>
    <h1 class="topic-page__title">The Morning Quiz</h1>
    <p class="dateline">
      Five claims Clad checked recently. Call each one — <em>verified</em>, <em>disputed</em>,
      <em>missing context</em>, or <em>unsupported</em> — then compare your read with the report's.
    </p>
    <p class="quiz__streak-hint small-caps" id="quiz-streak-hint" hidden style="color:var(--muted-ink)"></p>
    <div class="rule rule--double" aria-hidden="true"></div>

    {questions.length < 5 ? (
      <p class="dateline">Not enough fresh reports for a quiz today — come back tomorrow.</p>
    ) : (
      <>
        <ol class="quiz__list">
          {questions.map((q) => (
            <li class="quiz-q" data-answer={q.verdict}>
              <p class="quiz-q__kicker small-caps">Claim {q.n} of 5 · aired on {q.source}</p>
              <blockquote class="quiz-q__claim">{q.claim}</blockquote>
              <div class="quiz-q__opts" role="group" aria-label={`Your verdict on claim ${q.n}`}>
                {VERDICTS.map((v) => (
                  <button type="button" class="quiz-q__opt" data-verdict={v} hidden>{label(v)}</button>
                ))}
              </div>
              <details class="quiz-q__reveal">
                <summary class="small-caps">Reveal Clad's verdict</summary>
                <div class={`km ${q.verdict === "verified" ? "km--verified" : q.verdict === "disputed" ? "km--disputed" : q.verdict.includes("context") ? "km--context" : "km--unsupported"}`} style="margin-top:0.6rem">
                  <span class="km__verdict small-caps">{q.verdict}</span>
                  <p class="km__note">{q.note}</p>
                  <p class="km__note"><a href={`/posts/${q.slug}/`}>Read the full report →</a></p>
                </div>
              </details>
            </li>
          ))}
        </ol>

        <div class="quiz__result" id="quiz-result" hidden>
          <div class="rule rule--double" aria-hidden="true"></div>
          <p class="quiz__score">You called <strong id="quiz-score">0</strong> of 5 the way the report did.</p>
          <p class="quiz__streak small-caps" id="quiz-streak"></p>
          <p class="quiz__streak small-caps" id="quiz-return-hook"></p>
          <ShareBar
            id="quiz-sharebar"
            class="quiz-sharebar"
            url="https://cladfacts.com/quiz/"
            title="I just took today's CladFacts Morning Quiz"
            hook={shareTags.quiz ?? "5 claims from this week's news. Most people get 2 wrong — can you spot the spin?"}
          />
          <div class="quiz__cta">
            <a href="/register/?next=%2Fquiz%2F">Free account unlocks every grade →</a>
          </div>
        </div>
        <noscript>
          <p class="dateline">Reveal each verdict above — every claim links to the full, sourced report.</p>
        </noscript>
      </>
    )}
    <ExploreNext context="quiz" title="After the quiz" eyebrow="Next" />
  </section>

  <style>
    .quiz__list { list-style: none; padding: 0; margin: 1.4rem 0; }
    .quiz-q { border-bottom: 1px solid var(--rule); padding: 1.1rem 0 1.3rem; }
    .quiz-q__kicker { color: var(--muted-ink); }
    .quiz-q__claim { margin: 0.5rem 0 0.8rem; padding-left: 0.9rem; border-left: 3px solid var(--ink); font-size: 1.12rem; line-height: 1.45; font-style: italic; }
    .quiz-q__opts { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.7rem; }
    .quiz-q__opt { font: inherit; font-size: 0.88rem; padding: 0.35rem 0.8rem; background: transparent; border: 1px solid var(--ink); color: var(--ink); cursor: pointer; }
    .quiz-q__opt:hover { background: var(--ink); color: var(--paper, #f5edd9); }
    .quiz-q__opt[data-picked] { outline: 2px solid var(--ink); }
    .quiz-q__opt[disabled] { opacity: 0.55; cursor: default; }
    .quiz-q__opt.is-right { background: var(--ink); color: var(--paper, #f5edd9); opacity: 1; }
    .quiz-q__reveal summary { cursor: pointer; color: var(--muted-ink); }
    .quiz-q__ruling { margin: 0.6rem 0 0.3rem; line-height: 1.5; }
    .quiz__score { font-size: 1.25rem; margin: 0.9rem 0 0.3rem; }
    .quiz__streak { color: var(--muted-ink); }
    .quiz__cta { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-top: 0.8rem; }
    .quiz-sharebar { margin: 0.75rem 0 0.25rem; }
  </style>

  <script is:inline>
    (() => {
      const quiz = document.querySelector(".quiz");
      const qs = [...document.querySelectorAll(".quiz-q")];
      if (!quiz) return;
      const today = quiz.getAttribute("data-today");
      // Pre-play streak reminder (local only; never blocks play).
      try {
        const hint = document.getElementById("quiz-streak-hint");
        if (hint && today) {
          const last = localStorage.getItem("clad_quiz_last_date");
          const streak = Number(localStorage.getItem("clad_quiz_streak") || "0");
          if (last === today) {
            hint.textContent =
              "You've played today — come back tomorrow to reach day " + (streak + 1) + ".";
            hint.hidden = false;
          } else if (streak > 1 && last) {
            hint.textContent =
              "Your streak — day " + streak + ". Keep it alive: today's five are ready.";
            hint.hidden = false;
          }
        }
      } catch {}
      if (qs.length === 0) return;
      const result = document.getElementById("quiz-result");
      let answered = 0;
      let score = 0;

      const finish = () => {
        document.getElementById("quiz-score").textContent = String(score);
        // Streak lives only in this browser: consecutive Eastern-date plays.
        const yesterday = quiz.getAttribute("data-yesterday");
        let streak = 1, best = score;
        try {
          const last = localStorage.getItem("clad_quiz_last_date");
          streak = Number(localStorage.getItem("clad_quiz_streak") || "0");
          best = Number(localStorage.getItem("clad_quiz_best") || "0");
          if (last !== today) streak = last === yesterday ? streak + 1 : 1;
          best = Math.max(best, score);
          localStorage.setItem("clad_quiz_last_date", today);
          localStorage.setItem("clad_quiz_streak", String(streak));
          localStorage.setItem("clad_quiz_best", String(best));
        } catch {}
        const parts = [];
        if (streak > 1) parts.push(`${streak}-day streak`);
        if (best > 0) parts.push(`best score ${best}/5`);
        document.getElementById("quiz-streak").textContent = parts.join(" · ");
        const hook = document.getElementById("quiz-return-hook");
        if (hook) {
          hook.textContent =
            streak > 0
              ? "A fresh five drops at midnight Eastern — come back to reach day " + (streak + 1) + "."
              : "A fresh five drops at midnight Eastern — come back tomorrow.";
        }
        result.hidden = false;
        const streakBit = streak > 1 ? ` · ${streak}-day streak` : "";
        const shareBar = document.getElementById("quiz-sharebar");
        if (shareBar) {
          // Single line — this doubles as the mailto subject / Reddit title.
          shareBar.setAttribute("data-title", `CladFacts Morning Quiz ${today} — I called ${score}/5${streakBit}`);
          // Wordle-style spoiler-free grid, read in DOM/question order from
          // the data-hit stamps (readers answer in any sequence). 🟩⬛ is
          // luminance-distinct and colorblind-safe; 🟩🟥 is not.
          const grid = qs.map((q) => (q.getAttribute("data-hit") === "1" ? "🟩" : "⬛")).join("");
          const priorHook = shareBar.getAttribute("data-hook") || "";
          shareBar.setAttribute("data-hook", grid + "\n" + priorHook);
          shareBar.setAttribute("data-url", "https://cladfacts.com/quiz/");
          if (typeof window.cladRefreshShareBars === "function") {
            window.cladRefreshShareBars(shareBar);
          }
        }
      };

      for (const q of qs) {
        const answer = q.getAttribute("data-answer");
        const opts = [...q.querySelectorAll(".quiz-q__opt")];
        const reveal = q.querySelector(".quiz-q__reveal");
        for (const b of opts) {
          b.hidden = false;
          b.addEventListener("click", () => {
            if (q.hasAttribute("data-done")) return;
            q.setAttribute("data-done", "1");
            b.setAttribute("data-picked", "1");
            const hit = b.getAttribute("data-verdict") === answer;
            if (hit) score++;
            // Stamped on the question element so the share grid reads in
            // DOM order, not click order.
            q.setAttribute("data-hit", hit ? "1" : "0");
            for (const o of opts) {
              o.disabled = true;
              if (o.getAttribute("data-verdict") === answer) o.classList.add("is-right");
            }
            reveal.open = true;
            if (++answered === qs.length) finish();
          });
        }
      }
    })();
  </script>
</BaseLayout>
