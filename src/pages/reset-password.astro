---
import BaseLayout from "~/layouts/BaseLayout.astro";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

// Two modes on one page:
//  - no ?token=  → request form (emails a reset link via Better Auth)
//  - ?token=...  → set-new-password form (completes the reset)
// Better Auth appends ?error=INVALID_TOKEN when a link is expired/reused.
const token = Astro.url.searchParams.get("token") ?? "";
const invalid = Astro.url.searchParams.get("error") === "INVALID_TOKEN";
---
<BaseLayout title="Reset password — CladFacts" description="Reset your CladFacts account password." noindex={true}>
  <article class="static-page auth-page">
    <h2 class="static-page__title">Reset your password</h2>

    {invalid && (
      <p class="auth-status auth-status--error">
        That reset link is no longer valid — request a fresh one below.
      </p>
    )}

    {token && !invalid ? (
      <form id="reset-form" class="auth-form" data-token={token}>
        <div class="field">
          <label for="password">New password (8+ characters)</label>
          <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" required />
        </div>
        <button type="submit" class="auth-submit">Set new password</button>
        <div id="reset-status" class="auth-status" role="status"></div>
      </form>
    ) : (
      <form id="request-form" class="auth-form">
        <p class="dateline">Enter your account email and we'll send you a reset link.</p>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <button type="submit" class="auth-submit">Email me a reset link</button>
        <div id="request-status" class="auth-status" role="status"></div>
      </form>
    )}

    <p class="auth-alt">Remembered it? <a href="/login/">Sign in</a></p>
  </article>

  <script is:inline>
    (() => {
      const req = document.getElementById("request-form");
      if (req) {
        const status = document.getElementById("request-status");
        req.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = req.querySelector(".auth-submit");
          btn.disabled = true;
          status.textContent = "Sending…";
          try {
            await fetch("/api/auth/request-password-reset", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                email: document.getElementById("email").value.trim(),
                redirectTo: "/reset-password/",
              }),
            });
          } catch {
            /* same message either way — no account enumeration */
          }
          req.hidden = true;
          status.textContent = "If that address has an account, a reset link is on its way.";
        });
      }

      const form = document.getElementById("reset-form");
      if (form) {
        const status = document.getElementById("reset-status");
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = form.querySelector(".auth-submit");
          btn.disabled = true;
          status.textContent = "Saving…";
          try {
            const res = await fetch("/api/auth/reset-password", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                newPassword: document.getElementById("password").value,
                token: form.getAttribute("data-token"),
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(data.message || "Could not reset the password.");
            form.hidden = true;
            status.innerHTML = 'Password updated — <a href="/login/">sign in</a>.';
          } catch (err) {
            status.className = "auth-status auth-status--error";
            status.textContent = String(err.message || err);
            btn.disabled = false;
          }
        });
      }
    })();
  </script>
</BaseLayout>
