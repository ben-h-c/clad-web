---
/**
 * Standard password-reset workflow (Better Auth + Resend):
 *  1) No token → request form posts to /api/auth/request-password-reset
 *     (emails a one-hour link; no account enumeration).
 *  2) User clicks the email link → Better Auth validates and redirects here
 *     with ?token=…
 *  3) Token form posts to /api/auth/reset-password with the new password.
 */
import BaseLayout from "~/layouts/BaseLayout.astro";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

// Better Auth appends ?error=INVALID_TOKEN when a link is expired/reused.
const token = Astro.url.searchParams.get("token") ?? "";
const invalid = Astro.url.searchParams.get("error") === "INVALID_TOKEN";
---
<BaseLayout title="Reset password — CladFacts" description="Reset your CladFacts account password." noindex={true}>
  <article class="static-page auth-page">
    <h2 class="static-page__title">Reset your password</h2>

    {invalid && (
      <p class="auth-status auth-status--error">
        That reset link is no longer valid — request a fresh one below.
      </p>
    )}

    {token && !invalid ? (
      <form id="reset-form" class="auth-form" data-token={token}>
        <p class="dateline">Choose a new password for your account (at least 8 characters).</p>
        <div class="field">
          <label for="password">New password</label>
          <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" required />
        </div>
        <div class="field">
          <label for="password2">Confirm new password</label>
          <input id="password2" name="password2" type="password" autocomplete="new-password" minlength="8" required />
        </div>
        <button type="submit" class="auth-submit">Set new password</button>
        <div id="reset-status" class="auth-status" role="status"></div>
      </form>
    ) : (
      <form id="request-form" class="auth-form">
        <p class="dateline">
          Enter the email on your account. If it matches, we’ll send a reset link that expires in one hour.
        </p>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <button type="submit" class="auth-submit">Email me a reset link</button>
        <div id="request-status" class="auth-status" role="status"></div>
      </form>
    )}

    <p class="auth-alt">Remembered it? <a href="/login/">Sign in</a></p>
  </article>

  <script is:inline>
    (() => {
      const req = document.getElementById("request-form");
      if (req) {
        const status = document.getElementById("request-status");
        req.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = req.querySelector(".auth-submit");
          btn.disabled = true;
          status.className = "auth-status";
          status.textContent = "Sending…";
          try {
            // Better Auth: creates a verification token and emails the link.
            // Always show the same success copy (no account enumeration).
            await fetch("/api/auth/request-password-reset", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({
                email: document.getElementById("email").value.trim(),
                redirectTo: "/reset-password/",
              }),
            });
          } catch {
            /* same message either way */
          }
          req.hidden = true;
          status.textContent =
            "If that address has an account, a reset link is on its way. Check your inbox (and spam) — the link expires in one hour.";
        });
      }

      const form = document.getElementById("reset-form");
      if (form) {
        const status = document.getElementById("reset-status");
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = form.querySelector(".auth-submit");
          const p1 = document.getElementById("password").value;
          const p2 = document.getElementById("password2").value;
          status.className = "auth-status";
          if (p1 !== p2) {
            status.className = "auth-status auth-status--error";
            status.textContent = "Passwords don’t match.";
            return;
          }
          if (p1.length < 8) {
            status.className = "auth-status auth-status--error";
            status.textContent = "Use at least 8 characters.";
            return;
          }
          btn.disabled = true;
          status.textContent = "Saving…";
          try {
            const res = await fetch("/api/auth/reset-password", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({
                newPassword: p1,
                token: form.getAttribute("data-token"),
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              const msg =
                data.message ||
                data.error ||
                (res.status === 400 ? "That link is invalid or expired. Request a new one." : "Could not reset the password.");
              throw new Error(msg);
            }
            form.hidden = true;
            status.className = "auth-status";
            status.innerHTML = 'Password updated — <a href="/login/">sign in with your new password</a>.';
          } catch (err) {
            status.className = "auth-status auth-status--error";
            status.textContent = String(err.message || err);
            btn.disabled = false;
          }
        });
      }
    })();
  </script>
</BaseLayout>
