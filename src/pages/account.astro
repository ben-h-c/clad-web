---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getAuth } from "~/lib/auth-server";
import { getPrefs, listFavorites, listAlerts, userHasPassword } from "~/lib/user-data";
import { TOPIC_LABELS } from "~/lib/topics";
import { getAccess, PRICE } from "~/lib/access";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const session = await getAuth().api.getSession({ headers: Astro.request.headers });
if (!session?.user) return Astro.redirect("/login/");
const user = session.user;

const access = await getAccess(Astro.request.headers);
const trialDaysLeft =
  access.tier === "trial" && access.trialEndsAt
    ? Math.max(1, Math.ceil((access.trialEndsAt - Date.now()) / 86_400_000))
    : null;

const [prefs, favorites, alerts, hasPassword] = await Promise.all([
  getPrefs(user.id),
  listFavorites(user.id),
  listAlerts(user.id),
  userHasPassword(user.id),
]);
const alertTopics = new Set(alerts.map((a) => a.topic.toLowerCase()));
const suggestions = TOPIC_LABELS.filter((t) => !alertTopics.has(t.toLowerCase()));
const firstName = (user.name || "").trim().split(/\s+/)[0] || "there";
const planLabel = access.tier === "paid" ? "Premium" : access.tier === "trial" ? "Free trial" : "Free";
---
<BaseLayout title="Your account — Clad" description="Manage your CladFacts membership, email preferences, topic alerts, and saved articles." noindex={true}>
  <article class="static-page account">
    <header class="account-hero">
      <p class="account-hero__eyebrow small-caps">Your account</p>
      <h2 class="account-hero__title">Welcome back, {firstName}.</h2>
      <p class="account-hero__meta">
        <span>{user.email}</span>
        {user.emailVerified
          ? <span class="account-pill account-pill--ok">Verified</span>
          : <span class="account-pill account-pill--warn">Email unverified</span>}
        <span class="account-pill">{planLabel}</span>
      </p>
    </header>

    {access.tier !== "paid" && (
      <section class="account-card clad-app-only">
        <div class="account-card__head">
          <h3 class="account-card__title">Go Premium</h3>
        </div>
        <p class="account-card__desc">
          Unlock every letter grade and political-lean rating, the News Trends
          dashboard, topics, and search — across the app, web, and your widget.
        </p>
        <div class="account-actions">
          <button type="button" class="auth-submit js-app-purchase">Go Premium</button>
        </div>
      </section>
    )}

    <section class="account-card account-card--plan" id="plan-section">
      <div class="account-card__head">
        <h3 class="account-card__title">Membership</h3>
        {access.tier === "paid" ? (
          <span class="plan-badge plan-badge--paid">Premium</span>
        ) : access.tier === "trial" ? (
          <span class="plan-badge plan-badge--trial">Trial · {trialDaysLeft} {trialDaysLeft === 1 ? "day" : "days"} left</span>
        ) : (
          <span class="plan-badge plan-badge--free">Free</span>
        )}
      </div>
      {access.tier === "paid" ? (
        <>
          <p class="account-card__desc">
            You have <strong>full access</strong> — every letter grade, political-lean rating,
            the News Trends dashboard, search, and the ability to flag coverage. Thanks for
            supporting independent fact-checking.
          </p>
          <div class="account-actions">
            <button type="button" id="portal-btn" class="auth-submit secondary">Manage billing</button>
            <span id="portal-status" class="auth-status"></span>
          </div>
        </>
      ) : access.tier === "trial" ? (
        <>
          <p class="account-card__desc">
            Your free week unlocks <strong>everything</strong> — grades, political-lean ratings,
            Trends, and search. It ends in <strong>{trialDaysLeft} {trialDaysLeft === 1 ? "day" : "days"}</strong>;
            subscribe now so nothing locks.
          </p>
          <div class="account-actions">
            <a class="auth-submit" href="/upgrade/">Go Premium — {PRICE.monthly}/mo</a>
          </div>
        </>
      ) : (
        <>
          <p class="account-card__desc">
            On the free plan, <strong>grades and political-lean ratings are hidden</strong> and the
            Trends dashboard, search, and flagging are locked. Upgrade to unlock the full picture.
          </p>
          <div class="account-actions">
            <a class="auth-submit" href="/upgrade/">See plans — from {PRICE.monthly}/mo</a>
          </div>
        </>
      )}
    </section>

    <section class="account-card" id="prefs-section">
      <div class="account-card__head">
        <h3 class="account-card__title">Email preferences</h3>
      </div>
      <p class="account-card__desc">We only email what you turn on here — and never sell your address.</p>
      <form id="prefs-form" class="prefs">
        <label class="pref-row">
          <input type="checkbox" id="pref-newsletter" checked={prefs.newsletter} />
          <span>
            <strong>Weekly newsletter</strong>
            <small>A short rundown of the week's most-checked stories and biggest grade swings, sent every Monday.</small>
          </span>
        </label>
        <label class="pref-row">
          <input type="checkbox" id="pref-breaking" checked={prefs.breakingAlerts} />
          <span>
            <strong>Breaking-news alerts</strong>
            <small>A one-off email the moment a major story hits Breaking News — high-impact events only, not every post.</small>
          </span>
        </label>
        <div class="pref-row pref-row--select">
          <span>
            <strong>News digest</strong>
            <small>A recurring roundup of new fact-checks on a set schedule.</small>
          </span>
          <select id="pref-digest" aria-label="Digest frequency">
            <option value="off" selected={prefs.digest === "off"}>Don't send</option>
            <option value="weekly" selected={prefs.digest === "weekly"}>Weekly</option>
            <option value="daily" selected={prefs.digest === "daily"}>Daily</option>
          </select>
        </div>
        <div class="account-actions">
          <button type="submit" class="auth-submit">Save preferences</button>
          <span id="prefs-status" class="auth-status" role="status"></span>
        </div>
      </form>
    </section>

    <section class="account-card" id="alerts-section">
      <div class="account-card__head">
        <h3 class="account-card__title">Followed topics</h3>
        <span class="account-count" id="alert-count">{alerts.length}</span>
      </div>
      <p class="account-card__desc">
        Topics you follow power your alerts and digest — we'll prioritize new coverage on these.
      </p>
      <ul class="chip-list" id="alert-list">
        {alerts.length === 0 && <li class="chip-empty" data-empty>You're not following any topics yet — add one below.</li>}
        {alerts.map((a) => (
          <li class="chip" data-id={a.id}>
            <span class="chip__label">{a.topic}</span>
            <button type="button" class="chip__remove" aria-label={`Unfollow ${a.topic}`}>×</button>
          </li>
        ))}
      </ul>
      <form id="alert-form" class="alert-add">
        <input
          type="text"
          id="alert-input"
          list="topic-suggestions"
          maxlength="80"
          placeholder="Follow a topic — e.g. Elections, AI &amp; Tech, Iran…"
          autocomplete="off"
        />
        <datalist id="topic-suggestions">
          {suggestions.map((t) => <option value={t}></option>)}
        </datalist>
        <button type="submit" class="auth-submit secondary">Follow</button>
        <span id="alert-status" class="auth-status" role="status"></span>
      </form>
    </section>

    <section class="account-card" id="favorites-section">
      <div class="account-card__head">
        <h3 class="account-card__title">Saved articles</h3>
        <span class="account-count" id="fav-count">{favorites.length}</span>
      </div>
      <p class="account-card__desc">Reports you've bookmarked to read later.</p>
      <ul class="fav-list" id="fav-list">
        {favorites.length === 0 && (
          <li class="fav-empty" data-empty>
            Nothing saved yet — tap <strong>♥ Save</strong> on any report to keep it here.
          </li>
        )}
        {favorites.map((f) => (
          <li class="fav" data-slug={f.slug}>
            <a class="fav__link" href={`/posts/${f.slug}/`}>{f.headline || f.slug}</a>
            <button type="button" class="fav__remove" aria-label="Remove from saved">Remove</button>
          </li>
        ))}
      </ul>
    </section>

    <div class="account-actions account-signout">
      <button type="button" id="logout-btn" class="auth-submit secondary">Sign out</button>
      <span id="logout-status" class="auth-status"></span>
    </div>

    <section class="account-card account-danger" id="delete-section">
      <div class="account-card__head">
        <h3 class="account-card__title">Delete account</h3>
      </div>
      <p class="account-card__desc">
        Permanently delete your CladFacts account and everything tied to it —
        your profile, saved articles, followed topics, email preferences,
        comments, and subscription records. <strong>This can't be undone.</strong>
      </p>
      <p class="account-card__desc account-danger__note">
        Subscribed through the <strong>iOS app</strong>? Apple-billed
        subscriptions can't be cancelled here — also cancel in
        <strong>iOS Settings → your Apple Account → Subscriptions</strong> to
        stop future charges.
      </p>
      <details class="del-acct">
        <summary class="del-acct__summary">Delete my account…</summary>
        <div class="del-acct__body">
          {hasPassword ? (
            <label class="del-acct__label">
              Confirm your password to continue
              <input type="password" id="del-password" autocomplete="current-password" />
            </label>
          ) : (
            <label class="del-acct__label">
              Type your email (<strong>{user.email}</strong>) to confirm
              <input type="email" id="del-confirm-email" autocomplete="off" inputmode="email" />
            </label>
          )}
          <div class="account-actions">
            <button type="button" id="del-acct-btn" class="auth-submit del-acct__btn">
              Permanently delete account
            </button>
            <span id="del-acct-status" class="auth-status" role="status"></span>
          </div>
        </div>
      </details>
    </section>
  </article>

  <script is:inline>
    (() => {
      const setStatus = (el, kind, msg) => {
        el.className = "auth-status" + (kind === "error" ? " auth-status--error" : "");
        el.textContent = msg;
      };
      const setCount = (id, n) => { const el = document.getElementById(id); if (el) el.textContent = String(n); };

      // --- Preferences ---
      const prefsForm = document.getElementById("prefs-form");
      const prefsStatus = document.getElementById("prefs-status");
      prefsForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        setStatus(prefsStatus, "info", "Saving…");
        try {
          const res = await fetch("/api/me/preferences", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              newsletter: document.getElementById("pref-newsletter").checked,
              breakingAlerts: document.getElementById("pref-breaking").checked,
              digest: document.getElementById("pref-digest").value,
            }),
          });
          if (!res.ok) throw new Error("Could not save.");
          setStatus(prefsStatus, "info", "Saved.");
        } catch (err) {
          setStatus(prefsStatus, "error", String(err.message || err));
        }
      });

      // --- Topic alerts ---
      const alertForm = document.getElementById("alert-form");
      const alertInput = document.getElementById("alert-input");
      const alertList = document.getElementById("alert-list");
      const alertStatus = document.getElementById("alert-status");
      const clearEmpty = (ul) => { const e = ul.querySelector("[data-empty]"); if (e) e.remove(); };

      const addChip = (alert) => {
        clearEmpty(alertList);
        const li = document.createElement("li");
        li.className = "chip";
        li.setAttribute("data-id", alert.id);
        const label = document.createElement("span");
        label.className = "chip__label";
        label.textContent = alert.topic;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "chip__remove";
        btn.setAttribute("aria-label", "Remove " + alert.topic);
        btn.textContent = "×";
        li.append(label, btn);
        alertList.append(li);
        setCount("alert-count", alertList.querySelectorAll(".chip").length);
      };

      alertForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const topic = alertInput.value.trim();
        if (!topic) return;
        setStatus(alertStatus, "info", "Adding…");
        try {
          const res = await fetch("/api/me/alerts", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "add", topic }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Could not add topic.");
          addChip(data.alert);
          alertInput.value = "";
          setStatus(alertStatus, "info", "");
        } catch (err) {
          setStatus(alertStatus, "error", String(err.message || err));
        }
      });

      alertList.addEventListener("click", async (e) => {
        const btn = e.target.closest(".chip__remove");
        if (!btn) return;
        const li = btn.closest(".chip");
        const id = li.getAttribute("data-id");
        btn.disabled = true;
        try {
          const res = await fetch("/api/me/alerts", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "remove", id }),
          });
          if (!res.ok) throw new Error();
          li.remove();
          setCount("alert-count", alertList.querySelectorAll(".chip").length);
          if (!alertList.querySelector(".chip")) {
            const empty = document.createElement("li");
            empty.className = "chip-empty";
            empty.setAttribute("data-empty", "");
            empty.textContent = "You're not following any topics yet — add one below.";
            alertList.append(empty);
          }
        } catch {
          btn.disabled = false;
          setStatus(alertStatus, "error", "Could not remove. Try again.");
        }
      });

      // --- Saved articles ---
      const favList = document.getElementById("fav-list");
      favList.addEventListener("click", async (e) => {
        const btn = e.target.closest(".fav__remove");
        if (!btn) return;
        const li = btn.closest(".fav");
        const slug = li.getAttribute("data-slug");
        btn.disabled = true;
        try {
          const res = await fetch("/api/me/favorites", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug, favorite: false }),
          });
          if (!res.ok) throw new Error();
          li.remove();
          setCount("fav-count", favList.querySelectorAll(".fav").length);
          if (!favList.querySelector(".fav")) {
            const empty = document.createElement("li");
            empty.className = "fav-empty";
            empty.setAttribute("data-empty", "");
            empty.textContent = "Nothing saved yet.";
            favList.append(empty);
          }
        } catch {
          btn.disabled = false;
        }
      });

      // --- Manage subscription (Stripe billing portal) ---
      const portal = document.getElementById("portal-btn");
      if (portal) portal.addEventListener("click", async () => {
        portal.disabled = true;
        const s = document.getElementById("portal-status");
        try {
          const res = await fetch("/api/stripe/portal", { method: "POST" });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.url) throw new Error(data.error || "Could not open billing.");
          location.href = data.url;
        } catch (err) {
          if (s) { s.className = "auth-status auth-status--error"; s.textContent = String(err.message || err); }
          portal.disabled = false;
        }
      });

      // --- Sign out ---
      document.getElementById("logout-btn").addEventListener("click", async (e) => {
        e.target.disabled = true;
        try {
          await fetch("/api/auth/sign-out", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: "{}",
          });
        } catch {}
        window.location.href = "/";
      });

      // --- Delete account ---
      const delBtn = document.getElementById("del-acct-btn");
      if (delBtn) delBtn.addEventListener("click", async () => {
        const status = document.getElementById("del-acct-status");
        const pwEl = document.getElementById("del-password");
        const emEl = document.getElementById("del-confirm-email");
        const payload = pwEl
          ? { password: pwEl.value }
          : { confirmEmail: emEl ? emEl.value : "" };
        if (!window.confirm("Permanently delete your account? This cannot be undone.")) return;
        delBtn.disabled = true;
        setStatus(status, "info", "Deleting…");
        try {
          const res = await fetch("/api/me/delete-account", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Could not delete account.");
          window.location.href = data.redirect || "/";
        } catch (err) {
          setStatus(status, "error", String(err.message || err));
          delBtn.disabled = false;
        }
      });
    })();
  </script>

  <style>
    .account-danger { border: 1px solid rgba(150, 30, 20, 0.45); }
    .account-danger .account-card__title { color: rgb(150, 30, 20); }
    .account-danger__note { font-size: 0.9rem; }
    .del-acct { margin-top: 0.4rem; }
    .del-acct__summary { cursor: pointer; color: rgb(150, 30, 20); font-weight: 600; }
    .del-acct__body { margin-top: 1rem; }
    .del-acct__label { display: block; font-size: 0.9rem; line-height: 1.5; margin-bottom: 0.9rem; }
    .del-acct__label input {
      display: block; width: 100%; max-width: 22rem; margin-top: 0.35rem;
      font: inherit; padding: 0.5rem 0.6rem; border: 1px solid var(--rule);
      background: var(--paper); box-sizing: border-box;
    }
    .del-acct__btn { background: rgb(150, 30, 20); border-color: rgb(150, 30, 20); }
    .del-acct__btn:hover { background: rgb(120, 24, 16); }
  </style>
</BaseLayout>
