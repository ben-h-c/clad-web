---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Verdict from "~/components/Verdict.astro";
import { shortDate } from "~/lib/dateline";

export const prerender = true;

const MONTH_NAMES = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

export async function getStaticPaths() {
  const all = await getCollection("posts", (p) => !p.data.draft);
  const years = new Set<number>();
  for (const p of all) years.add(p.data.publishedAt.getUTCFullYear());
  return [...years].map((year) => {
    const posts = all
      .filter((p) => p.data.publishedAt.getUTCFullYear() === year)
      .sort(
        (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
      );
    const months = new Set<number>(
      posts.map((p) => p.data.publishedAt.getUTCMonth())
    );
    return {
      params: { year: String(year) },
      props: { year, posts, months: [...months].sort((a, b) => b - a) },
    };
  });
}

const { year, posts, months } = Astro.props;
---
<BaseLayout title={`${year} — Clad Archive`}>
  <section class="archive-page">
    <p class="small-caps archive-page__eyebrow">
      <a href="/archive/" style="color:inherit">Archive</a>
    </p>
    <h2 class="archive-page__title">{year}</h2>
    <div class="rule rule--double" aria-hidden="true"></div>

    {months.length > 1 && (
      <ul class="archive-index" style="margin-top:1rem">
        {months.map((m) => (
          <li>
            <a href={`/archive/${year}/${String(m + 1).padStart(2, "0")}/`}>
              {MONTH_NAMES[m]}
            </a>
          </li>
        ))}
      </ul>
    )}

    <ul class="archive-list">
      {posts.map((p) => (
        <li>
          <span class="archive-date">{shortDate(p.data.publishedAt)}</span>
          <span style="flex:1;min-width:0">
            <Verdict verdict={p.data.verdict} />{" "}
            <a href={`/posts/${p.id}/`}>{p.data.headline}</a>
          </span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
