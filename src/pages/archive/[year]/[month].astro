---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { nyDateParts, shortDate } from "~/lib/dateline";

export const prerender = false;

// One month of reports (Eastern calendar), newest first, as a light link
// list — a month can hold >1,000 reports, so no card rendering here.
const year = Number(Astro.params.year);
const month = Number(Astro.params.month);
if (!Number.isInteger(year) || !Number.isInteger(month) || month < 1 || month > 12) {
  return new Response(null, { status: 404 });
}

const all = await getCollection("posts", (p) => !p.data.draft);
const monthPosts = all
  .filter((p) => {
    const { y, m } = nyDateParts(p.data.publishedAt);
    return y === year && m === month;
  })
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
if (monthPosts.length === 0) return new Response(null, { status: 404 });

// A month can hold >1,000 reports; even as a light link list that outgrows a
// sane document. Paginate; canonical stays on the bare path (query ignored).
const PER_PAGE = 250;
const pageCount = Math.max(1, Math.ceil(monthPosts.length / PER_PAGE));
const page = Number(Astro.url.searchParams.get("page") ?? "1");
if (!Number.isInteger(page) || page < 1 || page > pageCount) {
  return new Response(null, { status: 404 });
}
const posts = monthPosts.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const MONTHS = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];
const label = `${MONTHS[month - 1]} ${year}`;

// Prev/next month links (only where posts exist).
const monthKeys = new Set(
  all.map((p) => {
    const { y, m } = nyDateParts(p.data.publishedAt);
    return `${y}-${m}`;
  })
);
const prev = month === 1 ? { y: year - 1, m: 12 } : { y: year, m: month - 1 };
const next = month === 12 ? { y: year + 1, m: 1 } : { y: year, m: month + 1 };
const hasPrev = monthKeys.has(`${prev.y}-${prev.m}`);
const hasNext = monthKeys.has(`${next.y}-${next.m}`);
const monthUrl = (d: { y: number; m: number }) => `/archive/${d.y}/${String(d.m).padStart(2, "0")}/`;
const pageUrl = (n: number) => `${monthUrl({ y: year, m: month })}${n === 1 ? "" : `?page=${n}`}`;
---
<BaseLayout
  title={`${label} archive — CladFacts`}
  description={`All ${posts.length} fact-checked CladFacts reports from ${label}.`}
>
  <Fragment slot="head">
    {page > 1 && <link rel="prev" href={pageUrl(page - 1)} />}
    {page < pageCount && <link rel="next" href={pageUrl(page + 1)} />}
  </Fragment>
  <section class="topic-page">
    <p class="small-caps" style="color:var(--muted-ink)"><a href="/archive/">Archive</a></p>
    <h1 class="topic-page__title">{label}</h1>
    <p class="dateline">
      {monthPosts.length.toLocaleString("en-US")} reports.{pageCount > 1 ? ` Page ${page} of ${pageCount}.` : ""}
    </p>
    <div class="rule rule--double" aria-hidden="true"></div>
    <ol class="archive-list">
      {posts.map((p) => (
        <li class="archive-list__item">
          <a href={`/posts/${p.id}/`}>{p.data.headline}</a>
          <span class="archive-list__meta">
            {p.data.sourceTitle ? `${p.data.sourceTitle} · ` : ""}{shortDate(p.data.publishedAt)}
          </span>
        </li>
      ))}
    </ol>
    {pageCount > 1 && (
      <nav class="archive-nav" aria-label="Month pages">
        {page > 1 && <a href={pageUrl(page - 1)}>← Newer</a>}
        <span class="small-caps" style="color:var(--muted-ink)">Page {page} of {pageCount}</span>
        {page < pageCount && <a href={pageUrl(page + 1)} style="margin-left:auto">Older →</a>}
      </nav>
    )}
    <nav class="archive-nav" aria-label="Archive months">
      {hasPrev && <a href={monthUrl(prev)}>← {MONTHS[prev.m - 1]} {prev.y}</a>}
      {hasNext && <a href={monthUrl(next)} style="margin-left:auto">{MONTHS[next.m - 1]} {next.y} →</a>}
    </nav>
  </section>
</BaseLayout>
