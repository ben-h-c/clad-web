---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CollapsibleSection from "~/components/CollapsibleSection.astro";
import ExploreNext from "~/components/ExploreNext.astro";
import { getAccess } from "~/lib/access";
import { buildRaceBoard, maskRaceLeaders, statusLabel } from "~/lib/bracket";
import { buildElectionMap, type StateMapCell } from "~/lib/electionMap";
import { buildStateForecasts, FORECAST_ASOF, LAYER_LABELS } from "~/lib/electionForecast";
import { DEFAULT_ELECTION_ID, getElectionWithPublishedDates } from "~/lib/elections";
import { RACE_BOARD_VERIFIED_ASOF } from "~/lib/races";
import { US_MAP_VIEWBOX, US_STATE_PATHS } from "~/lib/usMapPaths";
import { registerHref } from "~/lib/safeNext";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const reveal = access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const election = await getElectionWithPublishedDates(DEFAULT_ELECTION_ID, env.AGENTS);
const board = maskRaceLeaders(
  buildRaceBoard(all, {
    revealScores: reveal,
    races: election?.races,
    title: election?.title,
    subtitle: election?.subtitle,
  }),
  reveal
);
const map = buildElectionMap(board.cards);
const forecast = buildStateForecasts();

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/elections/map/`;

// Serialize for client interactivity (no gated grades if locked — grades already masked)
const clientPayload = {
  reveal,
  maxHeat: map.maxHeat,
  forecastAsOf: forecast.asOf,
  layerLabels: LAYER_LABELS,
  states: Object.fromEntries(
    map.states.map((s) => [
      s.code,
      {
        code: s.code,
        name: s.name,
        classII: s.classII,
        governor2026: s.governor2026,
        heat: s.heat,
        fill: s.fill,
        chips: s.chips,
        glance: s.glance,
        hasBoardCard: s.hasBoardCard,
        forecast: forecast.byCode[s.code] ?? null,
        races: s.races.map((r) => ({
          id: r.id,
          office: r.office,
          chamber: r.chamber,
          status: r.status,
          statusLabel: statusLabel(r.status),
          tier: r.tier,
          heat: r.heat,
          voteDateLabel: r.voteDateLabel ?? null,
          nextVoteDate: r.nextVoteDate ?? null,
          aName: r.aName,
          bName: r.bName,
          aParty: r.aParty ?? null,
          bParty: r.bParty ?? null,
          aSlug: r.aSlug,
          bSlug: r.bSlug,
          aHref: r.aHref,
          bHref: r.bHref,
          aGrade: reveal ? r.aGrade : null,
          bGrade: reveal ? r.bGrade : null,
          aLean: reveal ? r.aLean : null,
          bLean: reveal ? r.bLean : null,
          leaderSlug: reveal ? r.leaderSlug : null,
          note: r.note ?? null,
        })),
      },
    ])
  ),
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Midterms 2026 interactive map — CladFacts",
  description:
    "Party & outlook map of the 2026 midterms — state control, flip risk, Senate, governors, and CladFacts coverage. Tap any state.",
  url: pageUrl,
};

// Default view: Party & outlook → State control. Featured = flip risk first, then heat.
const flipRiskCodes = new Set(
  Object.entries(forecast.byCode)
    .filter(([, f]) => f.control?.flipRisk)
    .map(([code]) => code)
);
const featured = [...map.states]
  .filter((s) => flipRiskCodes.has(s.code) || s.hasBoardCard)
  .sort((a, b) => {
    const af = flipRiskCodes.has(a.code) ? 0 : 1;
    const bf = flipRiskCodes.has(b.code) ? 0 : 1;
    return af - bf || b.heat - a.heat || a.name.localeCompare(b.name);
  })
  .slice(0, 8);

const flipCount = flipRiskCodes.size;
const registerMap = registerHref("/elections/map/");

---
<BaseLayout
  title="Midterms 2026 map — CladFacts"
  description="Interactive U.S. map of the 2026 midterms: party control, 2026 outlook, flip risk, Senate, governors, and CladFacts coverage heat. Tap a state to dig in."
  ogTitle="Midterms 2026 interactive map"
  ogDescription="Party & outlook · state control · flip risk — tap any state. Not a poll."
  ogImage={`${origin}/og/bracket.png`}
  jsonLd={jsonLd}
>
  <article class="emap-page">
    <header class="emap-hero">
      <p class="small-caps upgrade__eyebrow">Midterms 2026 · Interactive map</p>
      <h1 class="static-page__title">Election map</h1>
      <p class="upgrade__lede">
        Defaults to <strong>Party &amp; outlook</strong> on <strong>state control</strong> —
        who holds power now, who is favored in 2026, and where flip risk is highest.
        Switch to Senate, governor, or House layers, or flip to <strong>Coverage</strong> for
        CladFacts graded-report heat. Tap a state to dig in
        {reveal ? "." : " (sign in free for coverage grades & lean)."}
      </p>

      <nav class="emap-modes" aria-label="Election tools">
        <a class="emap-modes__on" href="/elections/map/" aria-current="page">Map</a>
        <a href="/bracket/">Ballot board</a>
        <a href="/bracket/votes/">Community votes</a>
        <a href="/politicians/">Politicians</a>
        <a href="/learn/first-vote/">First-time voter</a>
      </nav>

      <ul class="emap-stats" aria-label="Map summary">
        <li><strong>{map.stats.classII}</strong><span>Class II Senate states</span></li>
        <li><strong>{map.stats.governors}</strong><span>Governor races 2026</span></li>
        <li><strong>{flipCount}</strong><span>Flip-risk (state control)</span></li>
        <li><strong>{map.stats.hotStates}</strong><span>States with graded reports</span></li>
      </ul>
    </header>

    <p class="emap-how-to" id="emap-how-to">
      <span class="small-caps emap-how-to__k">How to use</span>
      <span>
        Colors show the <strong>2026 outlook</strong> for the selected layer.
        Striped states = <strong>flip risk</strong>. Tap a state for who holds power now,
        the outlook band, and CladFacts race cards — then lock picks on the
        <a href="/bracket/">ballot board</a>.
      </span>
    </p>

    {!reveal && (
      <p class="paywall-banner" style="margin: 0 0 1rem">
        <span>Map is public. Coverage grades &amp; lean on race cards unlock free with any account.</span>
        <a class="paywall-banner__cta" href={registerMap}>Create free account</a>
      </p>
    )}

    <div class="emap-toolbar" role="toolbar" aria-label="Map view controls">
      <div class="emap-toolbar__group">
        <span class="small-caps emap-toolbar__label">Map</span>
        <div class="emap-seg" role="group" aria-label="Map type">
          <button type="button" class="emap-seg__btn emap-seg__btn--on" data-mode="party" id="mode-party">Party &amp; outlook</button>
          <button type="button" class="emap-seg__btn" data-mode="coverage" id="mode-coverage">Coverage</button>
        </div>
      </div>
      <div class="emap-toolbar__group" id="layer-group">
        <span class="small-caps emap-toolbar__label">Election</span>
        <div class="emap-seg emap-seg--wrap" role="group" aria-label="Election layer">
          <button type="button" class="emap-seg__btn emap-seg__btn--on" data-layer="control">State control</button>
          <button type="button" class="emap-seg__btn" data-layer="senate">Senate</button>
          <button type="button" class="emap-seg__btn" data-layer="governor">Governor</button>
          <button type="button" class="emap-seg__btn" data-layer="house">House</button>
        </div>
      </div>
    </div>
    <div class="emap-shell">
      <div class="emap-map-col">
        <div class="emap-map-wrap">
          {/* Legend only when Coverage map is selected */}
          <div class="emap-legend" id="legend-coverage" hidden aria-label="Coverage map legend">
            <span class="emap-leg emap-leg--hot">Hot</span>
            <span class="emap-leg emap-leg--marquee">Marquee</span>
            <span class="emap-leg emap-leg--watch">Watch</span>
            <span class="emap-leg emap-leg--lean">Board</span>
            <span class="emap-leg emap-leg--senate">Senate</span>
            <span class="emap-leg emap-leg--governor">Gov</span>
            <span class="emap-leg emap-leg--quiet">House</span>
          </div>

          <p class="emap-hint small-caps" id="emap-hint">Tap a state for control, outlook &amp; races · Tab + Enter</p>

          <svg
            class="emap-svg"
            viewBox={US_MAP_VIEWBOX}
            role="img"
            aria-labelledby="emap-title emap-desc"
            id="emap-svg"
          >
            <title id="emap-title">United States midterms 2026 map</title>
            <desc id="emap-desc">
              Interactive map of U.S. states colored by party control and 2026 outlook, with flip-risk states highlighted.
            </desc>
            <g class="emap-states">
              {map.states.map((s) => (
                <path
                  id={`st-${s.code}`}
                  class={`emap-state emap-fill--${s.fill}`}
                  d={US_STATE_PATHS[s.code]}
                  data-code={s.code}
                  data-fill={s.fill}
                  data-heat={s.heat}
                  tabindex="0"
                  role="button"
                  aria-label={`${s.name}: ${s.glance}`}
                />
              ))}
            </g>
          </svg>

          <!-- Live hover / focus chip (desktop + tablet) -->
          <div class="emap-float" id="emap-float" hidden>
            <p class="emap-float__code small-caps" id="emap-float-code"></p>
            <p class="emap-float__name" id="emap-float-name"></p>
            <p class="emap-float__glance" id="emap-float-glance"></p>
            <div class="emap-float__chips" id="emap-float-chips"></div>
          </div>
        </div>

        <p class="emap-disclaimer" id="emap-disclaimer-party">
          Party map is an editorial snapshot (as of {FORECAST_ASOF}) — solid/likely/lean/toss-up bands for glanceability.
          It is <strong>not</strong> a CladFacts grade, poll average, or prediction market.
        </p>
        <p class="emap-disclaimer" id="emap-disclaimer-coverage" hidden>
          Coverage map shows ballot structure and graded-report heat on CladFacts — not who is winning the election.
        </p>
      </div>

      <aside class="emap-panel" id="emap-panel" aria-live="polite">
        <div class="emap-panel__empty" id="emap-panel-empty">
          <h2 class="emap-panel__title">Start with a state</h2>
          <p>
            You’re viewing <strong>state control</strong> outlook. Stripes mark flip risk.
            Pick a state below, or tap the map — then cast picks on the ballot board.
          </p>
          <p class="emap-panel__cta-row">
            <a class="emap-panel__cta" href="/bracket/">Fill your ballot →</a>
            <a class="emap-panel__cta emap-panel__cta--ghost" href="/bracket/votes/">Community votes</a>
          </p>
          <p class="small-caps emap-featured-label">Watch these first</p>
          <ul class="emap-featured">
            {featured.map((s) => (
              <li>
                <button type="button" class="emap-featured__btn" data-pick={s.code}>
                  <span class="emap-featured__code">{s.code}</span>
                  <span class="emap-featured__body">
                    <strong>{s.name}</strong>
                    <span>
                      {flipRiskCodes.has(s.code) ? "Flip risk · " : ""}
                      {s.glance}
                    </span>
                  </span>
                  {s.heat > 0 && <span class="emap-featured__heat">{s.heat}</span>}
                </button>
              </li>
            ))}
          </ul>
        </div>

        <div class="emap-panel__detail" id="emap-panel-detail" hidden>
          <button type="button" class="emap-panel__close" id="emap-close" aria-label="Close state detail">×</button>
          <p class="small-caps emap-panel__eyebrow" id="emap-detail-code"></p>
          <h2 class="emap-panel__title" id="emap-detail-name"></h2>
          <p class="emap-panel__glance" id="emap-detail-glance"></p>
          <div class="emap-panel__badges" id="emap-detail-badges"></div>
          <div class="emap-panel__races" id="emap-detail-races"></div>
          <div class="emap-panel__links" id="emap-detail-links"></div>
        </div>
      </aside>
    </div>

    <!-- Mobile bottom sheet (mirrors panel content when open). Swipe down to dismiss. -->
    <div class="emap-sheet" id="emap-sheet" hidden>
      <div class="emap-sheet__grab" id="emap-sheet-grab" aria-hidden="true">
        <div class="emap-sheet__handle"></div>
        <p class="emap-sheet__hint small-caps">Swipe down to close</p>
      </div>
      <div class="emap-sheet__body" id="emap-sheet-body"></div>
      <button type="button" class="emap-sheet__close" id="emap-sheet-close">Close</button>
    </div>
    <div class="emap-sheet-backdrop" id="emap-backdrop" hidden></div>

    <section class="emap-list-section" aria-label="Jump to a state">
      <h2 class="static-page__sub">Jump to a state</h2>
      <p class="emap-list-lede">Can’t tap the map? Pick a state here — same detail panel opens.</p>
      <label class="emap-select-wrap">
        <span class="visually-hidden">Select a state</span>
        <select id="emap-state-select" class="emap-select">
          <option value="">Select a state…</option>
          {map.states
            .slice()
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((s: StateMapCell) => (
              <option value={s.code}>
                {s.code} — {s.name}
                {s.hasBoardCard ? " · on board" : ""}
                {s.heat > 0 ? ` · ${s.heat} reports` : ""}
              </option>
            ))}
        </select>
      </label>
    </section>

    <CollapsibleSection title="How to read these maps" eyebrow="Guide">
      <ul class="upgrade__perks">
        <li><strong>Party &amp; outlook (default)</strong> — who holds the seat/control now, Cook-style solid/likely/lean/toss-up bands for 2026, and flip-risk striping when the favored party differs from the holder. Editorial snapshot as of {FORECAST_ASOF}.</li>
        <li><strong>State control (default layer)</strong> — simplified lean of governor + legislature for the whole state. Switch to Senate, governor, or House for office-specific outlooks.</li>
        <li><strong>Coverage map</strong> — ballot structure + CladFacts graded-report heat. Not a forecast of who wins.</li>
        <li><strong>Class II Senate</strong> = one-third of the chamber up in 2026 (Art. I §3). Candidate map verified {RACE_BOARD_VERIFIED_ASOF}.</li>
        <li><strong>House</strong> = all 435 seats every midterm; colors are statewide lean only, not districts.</li>
        <li><strong>Your picks</strong> — after exploring, lock winners on the <a href="/bracket/">ballot board</a> (account required). Community tallies stay anonymous.</li>
      </ul>
    </CollapsibleSection>

    <ExploreNext
      context="midterms"
      title="After the map"
      eyebrow="Next"
      locked={!reveal}
      returnTo="/elections/map/"
    />

    <p class="static-page__note">
      Dig deeper: <a href="/bracket/">ballot board</a> · <a href="/bracket/votes/">community votes</a> ·
      <a href="/politicians/">politician cards</a> ·
      <a href="/learn/first-vote/">first-time voter guide</a>.
      Map paths: Wikimedia Commons blank US map (public domain).
    </p>
  </article>
</BaseLayout>

<script type="application/json" id="emap-data" set:html={JSON.stringify(clientPayload)} />

<script is:inline>
  (() => {
    const raw = document.getElementById("emap-data");
    if (!raw) return;
    let DATA;
    try { DATA = JSON.parse(raw.textContent || "{}"); } catch { return; }
    const states = DATA.states;
    const svg = document.getElementById("emap-svg");
    const floatEl = document.getElementById("emap-float");
    const floatCode = document.getElementById("emap-float-code");
    const floatName = document.getElementById("emap-float-name");
    const floatGlance = document.getElementById("emap-float-glance");
    const floatChips = document.getElementById("emap-float-chips");
    const panelEmpty = document.getElementById("emap-panel-empty");
    const panelDetail = document.getElementById("emap-panel-detail");
    const sheet = document.getElementById("emap-sheet");
    const sheetBody = document.getElementById("emap-sheet-body");
    const sheetGrab = document.getElementById("emap-sheet-grab");
    const backdrop = document.getElementById("emap-backdrop");
    const layerGroup = document.getElementById("layer-group");
    const legendCov = document.getElementById("legend-coverage");
    const discParty = document.getElementById("emap-disclaimer-party");
    const discCov = document.getElementById("emap-disclaimer-coverage");
    const hintEl = document.getElementById("emap-hint");
    let selected = null;
    let hover = null;
    // Default: party & outlook on state control (user preference / product default).
    let mode = "party"; // party | coverage
    let layer = "control"; // control | senate | governor | house
    let sheetScrollY = 0;

    /** Freeze the page under the sheet so swipes don’t scroll the document (esp. iOS WKWebView). */
    function lockPageScroll(on) {
      const html = document.documentElement;
      if (on) {
        if (html.classList.contains("emap-sheet-open")) return;
        sheetScrollY = window.scrollY || window.pageYOffset || 0;
        html.classList.add("emap-sheet-open");
        document.body.classList.add("emap-sheet-open");
        document.body.style.top = `-${sheetScrollY}px`;
      } else {
        html.classList.remove("emap-sheet-open");
        document.body.classList.remove("emap-sheet-open");
        document.body.style.top = "";
        window.scrollTo(0, sheetScrollY);
      }
    }

    function resetSheetTransform() {
      if (!sheet) return;
      sheet.style.transition = "";
      sheet.style.transform = "";
      sheet.classList.remove("is-dragging");
    }

    const isMobile = () => window.matchMedia("(max-width: 860px)").matches;

    function esc(s) {
      return String(s ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function party(p) {
      return p ? ` (${esc(p)})` : "";
    }

    function partyWord(p) {
      return p === "D" ? "Democratic" : p === "R" ? "Republican" : p === "S" ? "Split" : "—";
    }

    function ratingWord(r) {
      const map = {
        "solid-d": "Solid Dem", "likely-d": "Likely Dem", "lean-d": "Lean Dem",
        tossup: "Toss-up", "lean-r": "Lean GOP", "likely-r": "Likely GOP",
        "solid-r": "Solid GOP", "no-race": "No race",
      };
      return map[r] || r;
    }

    function layerForecast(st) {
      if (!st.forecast) return null;
      return st.forecast[layer] || null;
    }

    function partyGlance(st) {
      const f = layerForecast(st);
      if (!f) return st.glance;
      const layerName = (DATA.layerLabels && DATA.layerLabels[layer]) || layer;
      let g = layerName + ": " + f.label;
      if (f.favored) g += " · Favored: " + f.favored;
      if (f.flipRisk) g += " · Flip risk";
      return g;
    }

    function partyChips(st) {
      const f = layerForecast(st);
      if (!f) return st.chips;
      const chips = [ratingWord(f.rating), "Holds " + partyWord(f.current)];
      if (f.flipRisk) chips.push("Flip risk");
      if (f.favored) chips.push(f.favored.split(" ").slice(0, 4).join(" "));
      return chips.slice(0, 5);
    }

    function applyColors() {
      document.querySelectorAll(".emap-state").forEach((path) => {
        const code = path.getAttribute("data-code");
        const st = states[code];
        if (!st) return;
        [...path.classList].forEach((c) => {
          if (c.startsWith("emap-fill--") || c.startsWith("emap-party--") || c === "emap-state--flip") {
            path.classList.remove(c);
          }
        });
        if (mode === "coverage") {
          path.classList.add("emap-fill--" + st.fill);
        } else {
          const f = layerForecast(st);
          const rating = f ? f.rating : "no-race";
          path.classList.add("emap-party--" + rating);
          if (f && f.flipRisk) path.classList.add("emap-state--flip");
        }
        path.setAttribute("aria-label", st.name + ": " + (mode === "coverage" ? st.glance : partyGlance(st)));
      });
      // Hot / Watch / Marquee legend ONLY when Map selection is Coverage.
      // Party & outlook (any election layer) must not show coverage chips.
      if (legendCov) {
        const showCovLegend = mode === "coverage";
        legendCov.hidden = !showCovLegend;
        legendCov.setAttribute("aria-hidden", showCovLegend ? "false" : "true");
      }
      if (layerGroup) layerGroup.hidden = mode !== "party";
      if (discParty) discParty.hidden = mode !== "party";
      if (discCov) discCov.hidden = mode !== "coverage";
      if (hintEl) {
        hintEl.textContent =
          mode === "party"
            ? "Tap a state for control, outlook & races · Tab + Enter"
            : "Tap a state for coverage heat & race cards · Tab + Enter";
      }
      if (selected && states[selected]) paintDetail(states[selected]);
    }

    function setMode(next) {
      mode = next;
      document.querySelectorAll("[data-mode]").forEach((b) => {
        b.classList.toggle("emap-seg__btn--on", b.getAttribute("data-mode") === mode);
      });
      applyColors();
    }

    function setLayer(next) {
      layer = next;
      document.querySelectorAll("[data-layer]").forEach((b) => {
        b.classList.toggle("emap-seg__btn--on", b.getAttribute("data-layer") === layer);
      });
      applyColors();
    }

    function coverageRacesHtml(st) {
      if (!st.races.length) {
        return `<p class="emap-muted">No featured race card yet — still a full House slate${st.classII ? " plus Class II Senate" : ""}${st.governor2026 ? " and a governor race" : ""}.</p>`;
      }
      return st.races
        .map((r) => {
          const aLead = r.leaderSlug && r.leaderSlug === r.aSlug;
          const bLead = r.leaderSlug && r.leaderSlug === r.bSlug;
          const aName = r.aHref
            ? `<a href="${esc(r.aHref)}">${esc(r.aName)}${party(r.aParty)}</a>`
            : `${esc(r.aName)}${party(r.aParty)}`;
          const bName = r.bHref
            ? `<a href="${esc(r.bHref)}">${esc(r.bName)}${party(r.bParty)}</a>`
            : `${esc(r.bName)}${party(r.bParty)}`;
          const aGrade = r.aGrade
            ? `<span class="emap-grade-pill emap-grade-pill--${String(r.aGrade).charAt(0).toUpperCase()}">${esc(r.aGrade)}</span>`
            : "";
          const bGrade = r.bGrade
            ? `<span class="emap-grade-pill emap-grade-pill--${String(r.bGrade).charAt(0).toUpperCase()}">${esc(r.bGrade)}</span>`
            : "";
          const when = r.voteDateLabel
            ? `<span class="small-caps emap-race__when" title="${esc(r.nextVoteDate || "TBD")}">${esc(r.voteDateLabel)}</span>`
            : "";
          return `<article class="emap-race" data-tier="${esc(r.tier)}">
            <header class="emap-race__head">
              <h3>${esc(r.office)}</h3>
              <span class="small-caps">${esc(r.tier)}</span>
              <span class="small-caps">${esc(r.statusLabel)}</span>
              ${when}
              <span class="emap-race__heat">${r.heat} reports</span>
            </header>
            <div class="emap-race__sides">
              <div class="emap-race__side${aLead ? " emap-race__side--lead" : ""}">
                <div class="emap-race__who">${aName} ${aGrade}</div>
              </div>
              <div class="emap-race__vs">vs</div>
              <div class="emap-race__side${bLead ? " emap-race__side--lead" : ""}">
                <div class="emap-race__who">${bName} ${bGrade}</div>
              </div>
            </div>
            ${r.note ? `<p class="emap-race__note">${esc(r.note)}</p>` : ""}
          </article>`;
        })
        .join("");
    }

    function partyBlockHtml(st) {
      const f = layerForecast(st);
      if (!f) return "";
      const layerName = (DATA.layerLabels && DATA.layerLabels[layer]) || layer;
      return `<div class="emap-forecast">
        <h3 class="emap-forecast__title">${esc(layerName)}</h3>
        <dl class="emap-forecast__dl">
          <div><dt>Currently holds</dt><dd class="emap-party-tag emap-party-tag--${esc(f.current)}">${esc(partyWord(f.current))}</dd></div>
          <div><dt>2026 outlook</dt><dd><span class="emap-rating-pill emap-party--${esc(f.rating)}">${esc(ratingWord(f.rating))}</span></dd></div>
          ${f.favored ? `<div><dt>Favored / matchup</dt><dd>${esc(f.favored)}</dd></div>` : ""}
          <div><dt>Flip risk</dt><dd>${f.flipRisk ? "<strong>Yes</strong> — favored party differs from holder, or race is a toss-up" : "Low on this snapshot"}</dd></div>
        </dl>
        ${f.note ? `<p class="emap-race__note">${esc(f.note)}</p>` : ""}
        <p class="emap-muted">Snapshot as of ${esc(DATA.forecastAsOf || "")}. Editorial bands for glanceability — not CladFacts grades or a poll.</p>
      </div>`;
    }

    function detailHtml(st) {
      const glance = mode === "party" ? partyGlance(st) : st.glance;
      const chips = mode === "party" ? partyChips(st) : st.chips;
      const badges = chips.map((c) => `<span class="emap-chip">${esc(c)}</span>`).join("");
      let body = "";
      if (mode === "party") {
        body = partyBlockHtml(st) + '<h3 class="emap-forecast__sub">On our coverage board</h3>' + coverageRacesHtml(st);
      } else {
        body = coverageRacesHtml(st);
      }
      const links = `<p class="emap-panel__more">
        <a href="/bracket/">Ballot board</a> ·
        <a href="/bracket/votes/">Community votes</a> ·
        <a href="/politicians/">Politicians</a> ·
        <a href="/quiz/">Morning quiz</a>
      </p>`;
      return { code: st.code, name: st.name, glance, badges, body, links };
    }

    function paintDetail(st) {
      const d = detailHtml(st);
      document.getElementById("emap-detail-code").textContent = st.code + " · Midterms 2026";
      document.getElementById("emap-detail-name").textContent = d.name;
      document.getElementById("emap-detail-glance").textContent = d.glance;
      document.getElementById("emap-detail-badges").innerHTML = d.badges;
      document.getElementById("emap-detail-races").innerHTML = d.body;
      document.getElementById("emap-detail-links").innerHTML = d.links;
      panelEmpty.hidden = true;
      panelDetail.hidden = false;

      if (isMobile()) {
        sheetBody.innerHTML = `
          <p class="small-caps">${esc(d.code)} · Midterms 2026</p>
          <h2 class="emap-panel__title">${esc(d.name)}</h2>
          <p class="emap-panel__glance">${esc(d.glance)}</p>
          <div class="emap-panel__badges">${d.badges}</div>
          <div class="emap-panel__races">${d.body}</div>
          ${d.links}`;
        resetSheetTransform();
        sheet.hidden = false;
        backdrop.hidden = false;
        sheet.scrollTop = 0;
        lockPageScroll(true);
      }
    }

    function clearDetail() {
      selected = null;
      document.querySelectorAll(".emap-state--selected").forEach((el) => el.classList.remove("emap-state--selected"));
      panelEmpty.hidden = false;
      panelDetail.hidden = true;
      sheet.hidden = true;
      backdrop.hidden = true;
      resetSheetTransform();
      lockPageScroll(false);
      if (location.hash) history.replaceState(null, "", location.pathname + location.search);
    }

    // Swipe-down to dismiss the mobile bottom sheet (handle or content at top).
    if (sheet) {
      let drag = null; // { startY, lastY, active, fromGrab }
      const DISMISS_PX = 88;
      const DISMISS_V = 0.55; // px/ms

      const yOf = (e) => (e.touches && e.touches[0] ? e.touches[0].clientY : e.clientY);

      const beginDrag = (e, fromGrab) => {
        if (sheet.hidden) return;
        // Content area: only start a dismiss drag when already scrolled to the top.
        if (!fromGrab && sheet.scrollTop > 2) return;
        const y = yOf(e);
        drag = { startY: y, lastY: y, t0: performance.now(), active: false, fromGrab: !!fromGrab };
      };

      const moveDrag = (e) => {
        if (!drag) return;
        const y = yOf(e);
        const dy = y - drag.startY;
        drag.lastY = y;
        // Upward or tiny moves: don’t steal scroll inside the sheet.
        if (dy < 6 && !drag.active) return;
        if (dy < 0 && !drag.active) {
          drag = null;
          return;
        }
        // Require a mostly-vertical gesture so horizontal wiggles don’t hijack.
        if (!drag.active && dy >= 6) {
          drag.active = true;
          sheet.classList.add("is-dragging");
          sheet.style.transition = "none";
        }
        if (!drag.active) return;
        e.preventDefault();
        const offset = Math.max(0, dy);
        sheet.style.transform = `translate3d(0, ${offset}px, 0)`;
        if (backdrop) {
          const fade = Math.max(0.12, 1 - offset / 420);
          backdrop.style.opacity = String(fade);
        }
      };

      const endDrag = () => {
        if (!drag) return;
        const dy = Math.max(0, drag.lastY - drag.startY);
        const dt = Math.max(16, performance.now() - drag.t0);
        const v = dy / dt;
        const shouldClose = drag.active && (dy >= DISMISS_PX || (dy > 40 && v > DISMISS_V));
        const wasActive = drag.active;
        drag = null;
        if (!wasActive) return;

        sheet.classList.remove("is-dragging");
        if (backdrop) backdrop.style.opacity = "";

        if (shouldClose) {
          sheet.style.transition = "transform 0.28s cubic-bezier(0.4, 0, 0.2, 1)";
          sheet.style.transform = "translate3d(0, 110%, 0)";
          window.setTimeout(() => clearDetail(), 280);
        } else {
          sheet.style.transition = "transform 0.32s cubic-bezier(0.16, 1, 0.3, 1)";
          sheet.style.transform = "translate3d(0, 0, 0)";
          window.setTimeout(() => {
            if (!sheet.classList.contains("is-dragging")) resetSheetTransform();
          }, 340);
        }
      };

      // Prefer pointer events. Capture on the grab zone so moves stay with us on iOS.
      const grabEl = sheetGrab || sheet;
      grabEl.addEventListener("pointerdown", (e) => {
        if (e.pointerType === "mouse" && e.button !== 0) return;
        beginDrag(e, true);
        try { grabEl.setPointerCapture(e.pointerId); } catch (_) {}
      });
      sheet.addEventListener("pointerdown", (e) => {
        if (e.pointerType === "mouse" && e.button !== 0) return;
        if (e.target.closest && e.target.closest(".emap-sheet__grab, .emap-sheet__close, a, button")) return;
        beginDrag(e, false);
        try { sheet.setPointerCapture(e.pointerId); } catch (_) {}
      });
      // Document-level so capture on grab/sheet still routes moves/ends correctly.
      document.addEventListener("pointermove", (e) => {
        if (!drag) return;
        moveDrag(e);
      });
      document.addEventListener("pointerup", endDrag);
      document.addEventListener("pointercancel", endDrag);

      // Non-passive touchmove so we can preventDefault while dragging on iOS.
      document.addEventListener(
        "touchmove",
        (e) => {
          if (drag && drag.active) e.preventDefault();
        },
        { passive: false }
      );
    }

    function selectState(code, { fromHash } = {}) {
      const st = states[code];
      if (!st) return;
      selected = code;
      document.querySelectorAll(".emap-state--selected").forEach((el) => el.classList.remove("emap-state--selected"));
      const path = document.getElementById("st-" + code);
      if (path) path.classList.add("emap-state--selected");
      paintDetail(st);
      const sel = document.getElementById("emap-state-select");
      if (sel && sel.value !== code) sel.value = code;
      if (!fromHash) history.replaceState(null, "", "#" + code);
    }

    function showFloat(code, clientX, clientY) {
      const st = states[code];
      if (!st || !floatEl || isMobile()) return;
      hover = code;
      floatCode.textContent = st.code;
      floatName.textContent = st.name;
      floatGlance.textContent = mode === "party" ? partyGlance(st) : st.glance;
      const chips = mode === "party" ? partyChips(st) : st.chips;
      floatChips.innerHTML = chips.map((c) => `<span class="emap-chip">${esc(c)}</span>`).join("");
      floatEl.hidden = false;
      const wrap = floatEl.parentElement.getBoundingClientRect();
      const x = Math.min(wrap.width - 220, Math.max(8, clientX - wrap.left + 12));
      const y = Math.min(wrap.height - 120, Math.max(8, clientY - wrap.top + 12));
      floatEl.style.transform = `translate(${x}px, ${y}px)`;
    }

    function hideFloat() {
      hover = null;
      if (floatEl) floatEl.hidden = true;
    }

    if (svg) {
      svg.addEventListener("pointerover", (e) => {
        const t = e.target.closest(".emap-state");
        if (!t) return;
        t.classList.add("emap-state--hover");
        showFloat(t.getAttribute("data-code"), e.clientX, e.clientY);
      });
      svg.addEventListener("pointermove", (e) => {
        const t = e.target.closest(".emap-state");
        if (!t || !hover) return;
        showFloat(t.getAttribute("data-code"), e.clientX, e.clientY);
      });
      svg.addEventListener("pointerout", (e) => {
        const t = e.target.closest(".emap-state");
        if (t) t.classList.remove("emap-state--hover");
        if (!e.relatedTarget || !svg.contains(e.relatedTarget)) hideFloat();
      });
      svg.addEventListener("click", (e) => {
        const t = e.target.closest(".emap-state");
        if (!t) return;
        selectState(t.getAttribute("data-code"));
      });
      svg.addEventListener("keydown", (e) => {
        if (e.key !== "Enter" && e.key !== " ") return;
        const t = e.target.closest(".emap-state");
        if (!t) return;
        e.preventDefault();
        selectState(t.getAttribute("data-code"));
      });
    }

    document.querySelectorAll("[data-pick]").forEach((btn) => {
      btn.addEventListener("click", () => selectState(btn.getAttribute("data-pick")));
    });
    document.querySelectorAll("[data-mode]").forEach((btn) => {
      btn.addEventListener("click", () => setMode(btn.getAttribute("data-mode")));
    });
    document.querySelectorAll("[data-layer]").forEach((btn) => {
      btn.addEventListener("click", () => setLayer(btn.getAttribute("data-layer")));
    });

    document.getElementById("emap-close")?.addEventListener("click", clearDetail);
    document.getElementById("emap-sheet-close")?.addEventListener("click", clearDetail);
    backdrop?.addEventListener("click", clearDetail);

    const stateSelect = document.getElementById("emap-state-select");
    if (stateSelect) {
      stateSelect.addEventListener("change", () => {
        const code = stateSelect.value;
        if (code) selectState(code);
      });
    }

    // URL: #party-control-GA | #party-senate-GA | #coverage-GA | #GA
    const hash = (location.hash || "").replace(/^#/, "");
    const parts = hash.split("-");
    if (parts[0] === "party" && parts[1]) {
      setMode("party");
      if (["senate", "governor", "house", "control"].includes(parts[1])) setLayer(parts[1]);
      const code = (parts[2] || "").toUpperCase();
      if (code && states[code]) selectState(code, { fromHash: true });
    } else if (parts[0] === "coverage") {
      setMode("coverage");
      const code = (parts[1] || "").toUpperCase();
      if (code && states[code]) selectState(code, { fromHash: true });
    } else {
      // Default party + state control
      applyColors();
      const code = hash.toUpperCase();
      if (code && states[code]) selectState(code, { fromHash: true });
    }
  })();
</script>

