---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import { getAccess } from "~/lib/access";
import { findPolitician } from "~/lib/politicians";
import { shortDate } from "~/lib/dateline";
import { metaDescription } from "~/lib/seo";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const slug = Astro.params.slug ?? "";
const all = await getCollection("posts", (p) => !p.data.draft);
const pol = findPolitician(all, slug);
if (!pol) return new Response("Not found", { status: 404 });

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/politicians/${pol.slug}/`;
const ogImage = `${origin}/og/politician/${pol.slug}.png`;
const publicDesc = metaDescription(
  `Every ${pol.name} appearance CladFacts has graded: ${pol.appearances.length} report${pol.appearances.length === 1 ? "" : "s"}. Claim-by-claim verdicts with sources. Free account unlocks average grades.`
);
const title = `${pol.name} — Fact-check report card | CladFacts`;
const shareText = `${pol.name} on CladFacts: ${pol.appearances.length} graded report${pol.appearances.length === 1 ? "" : "s"}. How the coverage held up.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: title,
  url: pageUrl,
  dateModified: new Date().toISOString(),
  mainEntity: {
    "@type": "Person",
    name: pol.name,
    description: publicDesc,
  },
  publisher: {
    "@type": "NewsMediaOrganization",
    name: "CladFacts",
    url: origin,
  },
};
---
<BaseLayout
  title={title}
  description={publicDesc}
  ogTitle={`${pol.name} — CladFacts report card`}
  ogDescription={publicDesc}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="static-page politician">
    <header class="pol-hero">
      <PoliticianAvatar slug={pol.slug} name={pol.name} size="xl" decorative={false} />
      <div class="pol-hero__text">
        <p class="small-caps upgrade__eyebrow">
          Politician report card{pol.race ? ` · ${pol.race}` : ""}
          {pol.bucket ? ` · ${pol.bucket}` : ""}
        </p>
        <h1 class="static-page__title pol-hero__name">{pol.name}</h1>
        <p class="upgrade__lede pol-hero__lede">
          {pol.appearances.length} graded report{pol.appearances.length === 1 ? "" : "s"}
          on CladFacts.
          {locked ? (
            <>
              {" "}Sign in free to see average grade, factuality, and lean —
              <a href="/register/">create an account</a>.
            </>
          ) : (
            <> Averages below are computed from every report listed.</>
          )}
        </p>
      </div>
    </header>

    <div class="pol-share" aria-label="Share this report card">
      <span class="pol-share__label small-caps">Share</span>
      <a
        class="pol-share__btn"
        href={`https://bsky.app/intent/compose?text=${encodeURIComponent(shareText + "\n" + pageUrl)}`}
        target="_blank"
        rel="noopener noreferrer"
      >Bluesky</a>
      <a
        class="pol-share__btn"
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`}
        target="_blank"
        rel="noopener noreferrer"
      >X</a>
      <button type="button" class="pol-share__btn" id="pol-copy" data-url={pageUrl}>Copy link</button>
    </div>
    <p class="pol-share__status" id="pol-copy-status" role="status" hidden></p>

    {locked ? (
      <div class="scoreband scoreband--locked pol-scoreband" aria-hidden="true">
        <span class="grade-lock">🔒 Average grade &amp; political lean — free with any account</span>
      </div>
    ) : (pol.avgGrade || pol.avgFactuality != null || pol.avgLean != null) ? (
      <div class="scoreband pol-scoreband" aria-label="Aggregate grades">
        {pol.avgGrade && (
          <div class="scoreband__grade">
            <LetterGrade grade={pol.avgGrade} size="hero" />
            <span class="scoreband__cap small-caps">Avg grade</span>
          </div>
        )}
        {pol.avgLean != null && (
          <div class="scoreband__bias">
            <PoliticalLean score={pol.avgLean} size="header" />
          </div>
        )}
        {pol.avgFactuality != null && (
          <div class="pol-fact-pill">
            <span class="pol-fact-pill__num">{pol.avgFactuality}</span>
            <span class="small-caps">Avg factuality / 100</span>
          </div>
        )}
      </div>
    ) : null}

    {locked && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>Averages locked for guests — free with any account.</span>
        <a class="paywall-banner__cta" href="/register/">Create free account</a>
      </p>
    )}

    <h2 class="static-page__sub">Graded appearances</h2>
    <ol class="politician-list" reversed>
      {pol.appearances.map((a) => (
        <li class="politician-list__item">
          <div class="politician-list__main">
            <a href={`/posts/${a.id}/`}>{a.headline}</a>
            <span class="politician-list__meta">
              {shortDate(a.publishedAt)}
              {a.sourceTitle ? ` · ${a.sourceTitle}` : ""}
              {!locked && a.factualityScore != null && (
                <> · {a.factualityScore}/100</>
              )}
            </span>
          </div>
          {!locked && a.letterGrade && (
            <div class="politician-list__grade">
              <LetterGrade grade={a.letterGrade} size="badge" />
            </div>
          )}
          {!locked && a.leanScore != null && (
            <div class="politician-list__lean" title="Political lean of this report">
              <PoliticalLean score={a.leanScore} />
            </div>
          )}
        </li>
      ))}
    </ol>

    <p class="static-page__note">
      Portrait via Wikimedia Commons when available. Verdicts are researched with AI assistance and reviewed by an editor.
      <a href="/how-it-works/">How grading works</a>
      ·
      <a href="/corrections/">Corrections</a>
      ·
      <a href="/politicians/">All politician cards</a>
      ·
      <a href="/bracket/">Race board</a>
    </p>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const btn = document.getElementById("pol-copy");
    const status = document.getElementById("pol-copy-status");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-url") || location.href;
      try {
        await navigator.clipboard.writeText(url);
        if (status) {
          status.hidden = false;
          status.textContent = "Link copied.";
        }
      } catch {
        if (status) {
          status.hidden = false;
          status.textContent = url;
        }
      }
    });
  })();
</script>

<style>
  .pol-hero {
    display: flex;
    gap: 1.25rem 1.5rem;
    align-items: flex-start;
    margin-bottom: 0.5rem;
  }
  .pol-hero__text { min-width: 0; flex: 1; }
  .pol-hero__name { margin-top: 0.15rem; }
  .pol-hero__lede { margin-bottom: 0; }
  @media (max-width: 520px) {
    .pol-hero { flex-direction: column; align-items: center; text-align: center; }
    .pol-hero__text { width: 100%; }
  }

  .pol-share {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.65rem;
    margin: 1rem 0 1.25rem;
  }
  .pol-share__label {
    margin-right: 0.25rem;
    opacity: 0.7;
  }
  .pol-share__btn {
    appearance: none;
    font: inherit;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    text-decoration: none;
    cursor: pointer;
  }
  .pol-share__status {
    font-size: 0.9rem;
    opacity: 0.85;
    margin: -0.5rem 0 1rem;
  }

  .pol-scoreband {
    margin: 0.5rem 0 1.5rem;
    padding: 1rem 1.15rem;
    border: 3px double var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
  }
  .pol-fact-pill {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-left: auto;
  }
  .pol-fact-pill__num {
    font-family: var(--serif, Georgia, serif);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
  }

  .politician-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }
  .politician-list__item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(7rem, 11rem);
    gap: 0.65rem 1rem;
    align-items: center;
    margin: 0;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--rule, #cfc3ad);
  }
  .politician-list__main { min-width: 0; }
  .politician-list__item a {
    font-family: var(--serif, Georgia, serif);
    font-weight: 600;
    color: inherit;
  }
  .politician-list__meta {
    display: block;
    font-size: 0.9rem;
    opacity: 0.8;
    margin-top: 0.15rem;
  }
  .politician-list__grade {
    justify-self: end;
  }
  .politician-list__lean {
    min-width: 0;
  }
  .politician-list__lean :global(.lean__label) {
    font-size: 0.62rem;
  }
  .politician-list__lean :global(.lean__value) {
    font-size: 0.88rem;
  }
  @media (max-width: 720px) {
    .politician-list__item {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "main grade"
        "lean lean";
    }
    .politician-list__main { grid-area: main; }
    .politician-list__grade { grid-area: grade; }
    .politician-list__lean { grid-area: lean; }
  }
</style>
