---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import ShareBar from "~/components/ShareBar.astro";
import { env } from "cloudflare:workers";
import { getAccess } from "~/lib/access";
import { bucketLabel, bucketSlug, findPolitician } from "~/lib/politicians";
import { shortDate } from "~/lib/dateline";
import { metaDescription } from "~/lib/seo";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const slug = Astro.params.slug ?? "";
const all = await getCollection("posts", (p) => !p.data.draft);
const pol = await findPolitician(all, slug, env.AGENTS);
if (!pol) return new Response("Not found", { status: 404 });

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/politicians/${pol.slug}/`;
const ogImage = `${origin}/og/politician/${pol.slug}.png`;
const publicDesc = metaDescription(
  `Every ${pol.name} appearance CladFacts has graded: ${pol.appearances.length} report${pol.appearances.length === 1 ? "" : "s"}. Claim-by-claim verdicts with sources. Free account unlocks average grades.`
);
const title = `${pol.name} — Fact-check report card | CladFacts`;
const shareText = `${pol.name} on CladFacts: ${pol.appearances.length} graded report${pol.appearances.length === 1 ? "" : "s"}. How the coverage held up.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: title,
  url: pageUrl,
  dateModified: new Date().toISOString(),
  mainEntity: {
    "@type": "Person",
    name: pol.name,
    description: publicDesc,
  },
  publisher: {
    "@type": "NewsMediaOrganization",
    name: "CladFacts",
    url: origin,
  },
};
---
<BaseLayout
  title={title}
  description={publicDesc}
  ogTitle={`${pol.name} — CladFacts report card`}
  ogDescription={publicDesc}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="static-page politician">
    <header class="pol-hero">
      <PoliticianAvatar slug={pol.slug} name={pol.name} size="xl" decorative={false} />
      <div class="pol-hero__text">
        <p class="small-caps upgrade__eyebrow">
          Politician report card{pol.race ? ` · ${pol.race}` : ""}
          {pol.bucket ? ` · ${pol.bucket}` : ""}
        </p>
        <h1 class="static-page__title pol-hero__name">{pol.name}</h1>
        <p class="upgrade__lede pol-hero__lede">
          {pol.appearances.length === 0 ? (
            <>
              On the CladFacts roster — no graded broadcast coverage yet.
              When {pol.name.split(" ").slice(-1)[0]} appears in a report we grade, it lands here.
            </>
          ) : (
            <>
              {pol.appearances.length} graded report{pol.appearances.length === 1 ? "" : "s"}
              mentioning them on CladFacts.
              {locked ? (
                <>
                  {" "}Sign in free to see <em>their</em> ideology and claim record —
                  <a href="/register/">create an account</a>.
                </>
              ) : (
                <> Scores below are about {pol.name.split(" ").slice(-1)[0]} personally — not an average of the media that covers them.</>
              )}
            </>
          )}
        </p>
      </div>
    </header>

    <ShareBar
      url={pageUrl}
      title={`${pol.name} — CladFacts report card`}
      hook={
        pol.appearances.length > 0
          ? `${pol.appearances.length} graded reports. How did the coverage hold up? Free with any account →`
          : "On the CladFacts roster — see how coverage holds up when they show up."
      }
    />

    {locked ? (
      <div class="scoreband scoreband--locked pol-scoreband" aria-hidden="true">
        <span class="grade-lock">🔒 Their ideology &amp; claim record — free with any account</span>
      </div>
    ) : (pol.personGrade || pol.personFactuality != null || pol.personLean != null) ? (
      <div class="scoreband pol-scoreband" aria-label="Person scores">
        {pol.personGrade && (
          <div class="scoreband__grade">
            <LetterGrade grade={pol.personGrade} size="hero" />
            <span class="scoreband__cap small-caps">Claim record</span>
          </div>
        )}
        {pol.personLean != null && (
          <div class="scoreband__bias">
            <PoliticalLean score={pol.personLean} size="header" />
          </div>
        )}
        {pol.personFactuality != null && (
          <div class="pol-fact-pill">
            <span class="pol-fact-pill__num">{pol.personFactuality}</span>
            <span class="small-caps">Claim factuality / 100</span>
          </div>
        )}
      </div>
    ) : (
      <p class="dateline" style="margin: 0.75rem 0">
        Person scores not yet graded — a daily agent scores ideology and claim reliability.
      </p>
    )}

    {!locked && (pol.personLeanRationale || pol.personGradeRationale) && (
      <div class="pol-person-notes">
        {pol.personLeanRationale && (
          <p class="pol-person-notes__line">
            <span class="small-caps">Why this lean:</span> {pol.personLeanRationale}
          </p>
        )}
        {pol.personGradeRationale && (
          <p class="pol-person-notes__line">
            <span class="small-caps">Why this record grade:</span> {pol.personGradeRationale}
          </p>
        )}
      </div>
    )}

    {locked && (
      <p class="paywall-banner" style="margin: 1rem 0">
        <span>Person scores locked for guests — free with any account.</span>
        <a class="paywall-banner__cta" href="/register/">Create free account</a>
      </p>
    )}

    {!locked && (pol.coverageGrade || pol.coverageLean != null) && (
      <p class="dateline pol-coverage-meta">
        Coverage of them
        {pol.coverageGrade ? ` · media avg grade ${pol.coverageGrade}` : ""}
        {pol.coverageLean != null
          ? ` · media avg lean ${Math.abs(pol.coverageLean)}% ${pol.coverageLean > 0 ? "right" : "left"}`
          : ""}
        {" "}(how outlets covering them scored — not {pol.name.split(" ").slice(-1)[0]}’s own ideology)
      </p>
    )}

    <h2 class="static-page__sub">Graded appearances</h2>
    {pol.appearances.length === 0 ? (
      <p class="dateline">
        No graded reports yet. Browse{" "}
        <a href={`/politicians/?branch=${bucketSlug(pol.bucket)}`}>{bucketLabel(pol.bucket)}</a>
        {" "}or the{" "}
        <a href="/">front page</a>
        {" "}for the latest coverage.
      </p>
    ) : (
      <ol class="politician-list" reversed>
        {pol.appearances.map((a) => (
          <li class="politician-list__item">
            <div class="politician-list__main">
              <a href={`/posts/${a.id}/`}>{a.headline}</a>
              <span class="politician-list__meta">
                {shortDate(a.publishedAt)}
                {a.sourceTitle ? ` · ${a.sourceTitle}` : ""}
                {!locked && a.factualityScore != null && (
                  <> · {a.factualityScore}/100</>
                )}
              </span>
            </div>
            {!locked && a.letterGrade && (
              <div class="politician-list__grade">
                <LetterGrade grade={a.letterGrade} size="badge" />
              </div>
            )}
            {!locked && a.leanScore != null && (
              <div class="politician-list__lean" title="Political lean of this report">
                <PoliticalLean score={a.leanScore} />
              </div>
            )}
          </li>
        ))}
      </ol>
    )}

    <p class="static-page__note">
      Portrait via Wikimedia Commons when available
      (<a href="/politicians/photo-credits/">photo credits</a>). Person lean is ideology; claim record grades the reliability of their public statements — not how TV covered them.
      <a href="/how-it-works/">How grading works</a>
      ·
      <a href="/corrections/">Corrections</a>
      ·
      <a href={`/politicians/?branch=${bucketSlug(pol.bucket)}`}>{bucketLabel(pol.bucket)}</a>
      ·
      <a href="/politicians/">All branches</a>
      ·
      <a href="/bracket/">Race board</a>
    </p>
  </article>
</BaseLayout>

<style>
  .pol-hero {
    display: flex;
    gap: 1.25rem 1.5rem;
    align-items: flex-start;
    margin-bottom: 0.5rem;
  }
  .pol-hero__text { min-width: 0; flex: 1; }
  .pol-hero__name { margin-top: 0.15rem; }
  .pol-hero__lede { margin-bottom: 0; }
  @media (max-width: 520px) {
    .pol-hero { flex-direction: column; align-items: center; text-align: center; }
    .pol-hero__text { width: 100%; }
  }

  .pol-scoreband {
    margin: 0.5rem 0 1.5rem;
    padding: 1rem 1.15rem;
    border: 3px double var(--ink, #1a140d);
    background: color-mix(in srgb, var(--ink, #1a140d) 4%, transparent);
  }
  .pol-person-notes {
    margin: -0.75rem 0 1.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid color-mix(in srgb, var(--rule, #16110c) 55%, transparent);
    background: color-mix(in srgb, var(--ink, #1a140d) 3%, transparent);
    font-size: 0.95rem;
    line-height: 1.45;
  }
  .pol-person-notes__line { margin: 0.35rem 0; }
  .pol-person-notes__line .small-caps {
    color: var(--muted-ink, #6e5e4d);
    margin-right: 0.35rem;
  }
  .pol-coverage-meta {
    margin: 0 0 1.25rem;
    opacity: 0.85;
  }
  .pol-fact-pill {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-left: auto;
  }
  .pol-fact-pill__num {
    font-family: var(--serif, Georgia, serif);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
  }

  .politician-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }
  .politician-list__item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(7rem, 11rem);
    gap: 0.65rem 1rem;
    align-items: center;
    margin: 0;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--rule, #cfc3ad);
  }
  .politician-list__main { min-width: 0; }
  .politician-list__item a {
    font-family: var(--serif, Georgia, serif);
    font-weight: 600;
    color: inherit;
  }
  .politician-list__meta {
    display: block;
    font-size: 0.9rem;
    opacity: 0.8;
    margin-top: 0.15rem;
  }
  .politician-list__grade {
    justify-self: end;
  }
  .politician-list__lean {
    min-width: 0;
  }
  .politician-list__lean :global(.lean__label) {
    font-size: 0.62rem;
  }
  .politician-list__lean :global(.lean__value) {
    font-size: 0.88rem;
  }
  @media (max-width: 720px) {
    .politician-list__item {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "main grade"
        "lean lean";
    }
    .politician-list__main { grid-area: main; }
    .politician-list__grade { grid-area: grade; }
    .politician-list__lean { grid-area: lean; }
  }
</style>
