---
/**
 * Politician directory — hub of government areas, then drill into one branch.
 * Never dumps the full roster on a single screen.
 */
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import { env } from "cloudflare:workers";
import { getAccess } from "~/lib/access";
import {
  buildPoliticianIndexLive,
  bucketBlurb,
  bucketFromSlug,
  bucketLabel,
  bucketSlug,
  groupPoliticiansByBucket,
  resolvePoliticianSeeds,
  type RaceBucket,
} from "~/lib/politicians";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const { updatedAt, source } = await resolvePoliticianSeeds(env.AGENTS);
const politicians = await buildPoliticianIndexLive(all, env.AGENTS);
const groups = groupPoliticiansByBucket(politicians);
const totalReports = politicians.reduce((n, p) => n + p.appearances.length, 0);
const officeCount = politicians.filter((p) => p.bucket !== "Coverage").length;

const branchParam = Astro.url.searchParams.get("branch");
const activeBucket: RaceBucket | null = bucketFromSlug(branchParam);
const activeGroup = activeBucket
  ? groups.find((g) => g.bucket === activeBucket) ?? null
  : null;
/** Drill-in only when the branch exists and has people (or we still show empty). */
const isDrillIn = activeBucket != null;

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = isDrillIn
  ? `${origin}/politicians/?branch=${bucketSlug(activeBucket!)}`
  : `${origin}/politicians/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: isDrillIn
    ? `${bucketLabel(activeBucket!)} report cards — CladFacts`
    : "Politician fact-check report cards — CladFacts",
  url: pageUrl,
  description: isDrillIn
    ? `CladFacts report cards in ${bucketLabel(activeBucket!)}.`
    : "How candidates and officeholders grade on CladFacts: pick a branch of government, then open a person.",
  isPartOf: { "@type": "WebSite", name: "CladFacts", url: origin },
  numberOfItems: isDrillIn ? (activeGroup?.items.length ?? 0) : politicians.length,
};

const pageTitle = isDrillIn
  ? `${bucketLabel(activeBucket!)} — Politician report cards | CladFacts`
  : "Politician report cards — CladFacts";
const pageDesc = isDrillIn
  ? `Fact-check grade history for ${activeGroup?.items.length ?? 0} people in ${bucketLabel(activeBucket!)}. Free account unlocks average grades and lean.`
  : `Fact-check grade history for ${politicians.length} candidates and officeholders — pick a branch, then a person. Free account unlocks grades and lean.`;
---
<BaseLayout
  title={pageTitle}
  description={pageDesc}
  ogImage={`${origin}/og/brand.png`}
  jsonLd={jsonLd}
>
  <article class="static-page politicians-dir">
    <p class="small-caps upgrade__eyebrow">
      Report cards · {isDrillIn ? bucketLabel(activeBucket!) : "by branch"}
    </p>
    <h1 class="static-page__title">
      {isDrillIn ? bucketLabel(activeBucket!) : "Politician report cards"}
    </h1>
    <p class="upgrade__lede">
      {isDrillIn ? (
        <>
          {bucketBlurb(activeBucket!)}
          {" "}
          {activeGroup?.items.length ?? 0} people
          · grades describe the <em>person</em> (ideology and claim record), not an average of news about them.
          {locked ? (
            <>
              {" "}Scores unlock with a
              <a href="/register/">free account</a>.
            </>
          ) : (
            <> Person scores below are live for your account.</>
          )}
        </>
      ) : (
        <>
          Choose a branch of government — executive, Senate, House, governors, or the
          Supreme Court — then open a person. {officeCount} officeholders
          {politicians.length > officeCount ? ` · ${politicians.length - officeCount} also in coverage` : ""}
          · {totalReports} report links.
          Grades and lean describe the <em>person</em>, not an average of coverage about them.
          {locked ? (
            <>
              {" "}Scores unlock with a
              <a href="/register/">free account</a>.
            </>
          ) : null}
        </>
      )}
    </p>

    {politicians.length === 0 ? (
      <p class="dateline">No politician pages yet — check back after the next graded debate.</p>
    ) : isDrillIn ? (
      <>
        <nav class="pol-crumb" aria-label="Directory breadcrumb">
          <a href="/politicians/">All branches</a>
          <span aria-hidden="true"> / </span>
          <span>{bucketLabel(activeBucket!)}</span>
        </nav>

        <div class="pol-branch-nav" role="navigation" aria-label="Switch branch">
          {groups.map((g) => (
            <a
              class:list={["pol-branch-chip", g.bucket === activeBucket && "pol-branch-chip--on"]}
              href={`/politicians/?branch=${bucketSlug(g.bucket)}`}
              aria-current={g.bucket === activeBucket ? "page" : undefined}
            >
              {bucketLabel(g.bucket)}
              <span class="pol-branch-chip__n">{g.items.length}</span>
            </a>
          ))}
        </div>

        {(activeGroup?.items.length ?? 0) === 0 ? (
          <p class="dateline">No one in this branch yet.</p>
        ) : (
          <>
            <div class="pol-toolbar">
              <label class="pol-search">
                <span class="visually-hidden">Search in {bucketLabel(activeBucket!)}</span>
                <input
                  id="pol-q"
                  type="search"
                  placeholder={`Search ${bucketLabel(activeBucket!)}…`}
                  autocomplete="off"
                  enterkeyhint="search"
                />
              </label>
              <p class="pol-count" id="pol-count" aria-live="polite">
                Showing {activeGroup!.items.length}
              </p>
            </div>

            <ul class="politician-grid" id="pol-list">
              {activeGroup!.items.map((p) => (
                <li
                  class="pol-card"
                  data-name={p.name.toLowerCase()}
                  data-race={(p.race ?? "").toLowerCase()}
                >
                  <a class="pol-card__link" href={`/politicians/${p.slug}/`}>
                    <PoliticianAvatar slug={p.slug} name={p.name} size="lg" />
                    <div class="pol-card__body">
                      <h2 class="pol-card__name">{p.name}</h2>
                      {p.race && <p class="pol-card__race small-caps">{p.race}</p>}
                      <p class="pol-card__count">
                        {p.appearances.length} report{p.appearances.length === 1 ? "" : "s"}
                      </p>
                      {locked ? (
                        <div class="scoreband scoreband--locked pol-card__scores" aria-hidden="true">
                          <span class="grade-lock">Lean &amp; record — Unlock free</span>
                        </div>
                      ) : (
                        <div class="scoreband pol-card__scores">
                          {p.personGrade ? (
                            <div class="scoreband__grade">
                              <LetterGrade grade={p.personGrade} size="card" />
                              <span class="scoreband__cap small-caps">Record</span>
                            </div>
                          ) : (
                            <div class="scoreband__grade scoreband__grade--empty">
                              <span class="pol-card__na">—</span>
                              <span class="scoreband__cap small-caps">Record</span>
                            </div>
                          )}
                          {p.personLean != null ? (
                            <div class="scoreband__bias">
                              <PoliticalLean score={p.personLean} />
                            </div>
                          ) : null}
                        </div>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <p class="pol-empty" id="pol-empty" hidden>No matches — try another name or race.</p>
          </>
        )}
      </>
    ) : (
      <>
        <p class="pol-hub-kicker small-caps">Select an area of government</p>
        <ul class="pol-hub" role="list">
          {groups.map((g) => (
            <li class="pol-hub__item" role="listitem">
              <a class="pol-hub__card" href={`/politicians/?branch=${bucketSlug(g.bucket)}`}>
                <span class="pol-hub__label">{bucketLabel(g.bucket)}</span>
                <span class="pol-hub__count">{g.items.length}</span>
                <span class="pol-hub__blurb">{bucketBlurb(g.bucket)}</span>
                <span class="pol-hub__go">Open →</span>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    <p class="static-page__note">
      Roster source: {source}
      {updatedAt ? ` · updated ${updatedAt.slice(0, 10)}` : ""}.
      Portraits from Wikimedia Commons where available
      (<a href="/politicians/photo-credits/">photo credits</a>).
      Pages update when new reports publish.
      <a href="/how-it-works/">Methodology</a>
      ·
      <a href="/corrections/">Corrections</a>
      ·
      <a href="/elections/map/">Election map</a>
      ·
      <a href="/bracket/">Race board</a>
      ·
      <a href="/week/">Week in grades</a>.
    </p>
  </article>
</BaseLayout>

{isDrillIn && (
  <script is:inline>
    (() => {
      const input = document.getElementById("pol-q");
      const countEl = document.getElementById("pol-count");
      const empty = document.getElementById("pol-empty");
      if (!input) return;
      const rows = Array.from(document.querySelectorAll(".pol-card"));
      const total = rows.length;

      const apply = () => {
        const q = (input.value || "").trim().toLowerCase();
        let shown = 0;
        for (const row of rows) {
          const hay = [
            row.getAttribute("data-name") || "",
            row.getAttribute("data-race") || "",
          ].join(" ");
          const ok = !q || hay.includes(q);
          row.hidden = !ok;
          if (ok) shown++;
        }
        if (countEl) countEl.textContent = q ? `Showing ${shown} of ${total}` : `Showing ${total}`;
        if (empty) empty.hidden = shown > 0;
      };
      input.addEventListener("input", apply);
    })();
  </script>
)}

<style>
  .pol-hub-kicker {
    margin: 1.25rem 0 0.75rem;
    opacity: 0.75;
  }
  .pol-hub {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr));
    gap: 0.85rem;
  }
  .pol-hub__item { margin: 0; }
  .pol-hub__card {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    gap: 0.35rem 0.75rem;
    padding: 1rem 1.05rem;
    min-height: 8.5rem;
    border: 2px solid var(--ink, #1a140d);
    background-color: var(--card, var(--paper, #f5edd9));
    background-image: none;
    color: inherit;
    text-decoration: none;
    height: 100%;
    box-sizing: border-box;
    transition: background 0.15s ease, transform 0.15s ease;
    isolation: isolate;
  }
  .pol-hub__card:hover {
    background-color: var(--card-deep, var(--paper, #f5edd9));
    transform: translateY(-2px);
  }
  .pol-hub__label {
    grid-column: 1;
    font-family: var(--serif, Georgia, serif);
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .pol-hub__count {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--serif, Georgia, serif);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    opacity: 0.85;
  }
  .pol-hub__blurb {
    grid-column: 1 / -1;
    font-size: 0.88rem;
    line-height: 1.4;
    opacity: 0.8;
  }
  .pol-hub__go {
    grid-column: 1 / -1;
    align-self: end;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    margin-top: 0.35rem;
  }

  .pol-crumb {
    margin: 0.75rem 0 1rem;
    font-size: 0.92rem;
  }
  .pol-crumb a { color: inherit; }

  .pol-branch-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 1.15rem;
  }
  .pol-branch-chip {
    appearance: none;
    font: inherit;
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.32rem 0.55rem;
    border: 1px solid var(--rule, #cfc3ad);
    background: var(--paper, #f5edd9);
    color: inherit;
    text-decoration: none;
    line-height: 1.2;
  }
  .pol-branch-chip:hover {
    border-color: var(--ink, #1a140d);
  }
  .pol-branch-chip--on {
    border-color: var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    font-weight: 700;
  }
  .pol-branch-chip__n {
    opacity: 0.7;
    margin-left: 0.25rem;
    font-weight: 600;
  }

  .pol-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    margin: 0.25rem 0 0.85rem;
  }
  .pol-search {
    flex: 1 1 16rem;
  }
  .pol-search input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--paper, #f5edd9);
    font: inherit;
    color: inherit;
  }
  .pol-count {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.75;
  }
  .politician-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17.5rem, 1fr));
    gap: 0.85rem;
  }
  .pol-card {
    margin: 0;
    border: 1px solid var(--ink, #1a140d);
    background-color: var(--card, var(--paper, #f5edd9));
    background-image: none;
    border-radius: 4px;
    box-shadow:
      0 1px 0 color-mix(in srgb, #fff 45%, transparent),
      0 10px 22px color-mix(in srgb, var(--shadow, rgba(26, 20, 13, 0.28)) 40%, transparent);
    transition: box-shadow 0.2s ease, transform 0.2s cubic-bezier(0.2, 0.9, 0.25, 1);
    isolation: isolate;
  }
  .pol-card[hidden] { display: none !important; }
  .pol-card:hover {
    box-shadow:
      0 18px 36px color-mix(in srgb, var(--shadow, rgba(26, 20, 13, 0.28)) 55%, transparent),
      0 0 28px color-mix(in srgb, var(--accent, #96201e) 16%, transparent);
    transform: translateY(-8px) scale(1.02);
  }
  .pol-card__link {
    display: flex;
    gap: 0.85rem;
    padding: 0.85rem;
    color: inherit;
    text-decoration: none;
    height: 100%;
    box-sizing: border-box;
  }
  .pol-card__body {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .pol-card__name {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }
  .pol-card__race {
    margin: 0;
    font-size: 0.72rem;
    opacity: 0.72;
    line-height: 1.3;
  }
  .pol-card__count {
    margin: 0.15rem 0 0.35rem;
    font-size: 0.88rem;
    opacity: 0.85;
  }
  .pol-card__scores {
    margin-top: auto;
    margin-bottom: 0;
    padding: 0.45rem 0 0;
    border-top: 1px solid var(--rule, #cfc3ad);
  }
  .pol-card__scores.scoreband {
    gap: 0.65rem 0.9rem;
    margin-bottom: 0;
  }
  .pol-card__na {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.6rem;
    font-weight: 700;
    opacity: 0.35;
  }
  .pol-empty {
    margin: 1rem 0;
    opacity: 0.8;
  }
</style>
