---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import PoliticianAvatar from "~/components/PoliticianAvatar.astro";
import { env } from "cloudflare:workers";
import { getAccess } from "~/lib/access";
import {
  buildPoliticianIndex,
  bucketLabel,
  groupPoliticiansByBucket,
  resolvePoliticianSeeds,
} from "~/lib/politicians";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const all = await getCollection("posts", (p) => !p.data.draft);
const { seeds, updatedAt, source } = await resolvePoliticianSeeds(env.AGENTS);
const politicians = buildPoliticianIndex(all, seeds);
const groups = groupPoliticiansByBucket(politicians);
const totalReports = politicians.reduce((n, p) => n + p.appearances.length, 0);
const officeCount = politicians.filter((p) => p.bucket !== "Coverage").length;

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Politician fact-check report cards — CladFacts",
  url: `${origin}/politicians/`,
  description:
    "How candidates and officeholders grade on CladFacts: every report that covers them, claim by claim.",
  isPartOf: { "@type": "WebSite", name: "CladFacts", url: origin },
  numberOfItems: politicians.length,
};
---
<BaseLayout
  title="Politician report cards — CladFacts"
  description={`Fact-check grade history for ${politicians.length} candidates and officeholders — ${totalReports} graded reports. Free account unlocks average grades and lean.`}
  ogImage={`${origin}/og/brand.png`}
  jsonLd={jsonLd}
>
  <article class="static-page politicians-dir">
    <p class="small-caps upgrade__eyebrow">Report cards · by branch</p>
    <h1 class="static-page__title">Politician report cards</h1>
    <p class="upgrade__lede">
      Who holds office now — executive, Senate, House, governors, and the
      Supreme Court — grouped by branch. {officeCount} officeholders
      {politicians.length > officeCount ? ` · ${politicians.length - officeCount} also in coverage` : ""}
      · {totalReports} report links.
      A daily agent refreshes the roster
      {updatedAt ? ` (last sync ${new Date(updatedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })})` : " (using snapshot until first sync)"}.
      {locked ? (
        <>
          {" "}Average grades unlock with a
          <a href="/register/">free account</a>.
        </>
      ) : (
        <> Average grades and lean ratings below are live for your account.</>
      )}
    </p>

    {politicians.length === 0 ? (
      <p class="dateline">No politician pages yet — check back after the next graded debate.</p>
    ) : (
      <>
        <div class="pol-toolbar">
          <label class="pol-search">
            <span class="visually-hidden">Search politicians</span>
            <input
              id="pol-q"
              type="search"
              placeholder="Search name or race…"
              autocomplete="off"
              enterkeyhint="search"
            />
          </label>
          <p class="pol-count" id="pol-count" aria-live="polite">
            Showing {politicians.length}
          </p>
        </div>

        <div id="pol-groups">
          {groups.map((g) => (
            <section class="pol-group" data-bucket={g.bucket}>
              <h2 class="pol-group__title">{bucketLabel(g.bucket)} <span class="pol-group__n">({g.items.length})</span></h2>
              <ul class="politician-grid">
                {g.items.map((p) => (
                  <li
                    class="pol-card"
                    data-name={p.name.toLowerCase()}
                    data-race={(p.race ?? "").toLowerCase()}
                    data-bucket={p.bucket.toLowerCase()}
                  >
                    <a class="pol-card__link" href={`/politicians/${p.slug}/`}>
                      <PoliticianAvatar slug={p.slug} name={p.name} size="lg" />
                      <div class="pol-card__body">
                        <h3 class="pol-card__name">{p.name}</h3>
                        {p.race && <p class="pol-card__race small-caps">{p.race}</p>}
                        <p class="pol-card__count">
                          {p.appearances.length} report{p.appearances.length === 1 ? "" : "s"}
                        </p>
                        {locked ? (
                          <div class="scoreband scoreband--locked pol-card__scores" aria-hidden="true">
                            <span class="grade-lock">🔒 Grade &amp; lean</span>
                          </div>
                        ) : (
                          <div class="scoreband pol-card__scores">
                            {p.avgGrade ? (
                              <div class="scoreband__grade">
                                <LetterGrade grade={p.avgGrade} size="card" />
                                <span class="scoreband__cap small-caps">Avg grade</span>
                              </div>
                            ) : (
                              <div class="scoreband__grade scoreband__grade--empty">
                                <span class="pol-card__na">—</span>
                                <span class="scoreband__cap small-caps">Avg grade</span>
                              </div>
                            )}
                            {p.avgLean != null ? (
                              <div class="scoreband__bias">
                                <PoliticalLean score={p.avgLean} />
                              </div>
                            ) : p.avgFactuality != null ? (
                              <div class="pol-card__fact">
                                <span class="pol-card__fact-num">{p.avgFactuality}</span>
                                <span class="small-caps">Avg factuality</span>
                              </div>
                            ) : null}
                          </div>
                        )}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
        <p class="pol-empty" id="pol-empty" hidden>No matches — try another name or race.</p>
      </>
    )}

    <p class="static-page__note">
      Roster source: {source}. Portraits from Wikimedia Commons where available.
      Pages update when new reports publish.
      <a href="/how-it-works/">Methodology</a>
      ·
      <a href="/corrections/">Corrections</a>
      ·
      <a href="/elections/map/">Election map</a>
      ·
      <a href="/bracket/">Race board</a>
      ·
      <a href="/week/">Week in grades</a>.
    </p>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const input = document.getElementById("pol-q");
    const countEl = document.getElementById("pol-count");
    const empty = document.getElementById("pol-empty");
    if (!input) return;
    const rows = Array.from(document.querySelectorAll(".pol-card"));
    const groups = Array.from(document.querySelectorAll(".pol-group"));
    const total = rows.length;

    const apply = () => {
      const q = (input.value || "").trim().toLowerCase();
      let shown = 0;
      for (const row of rows) {
        const hay = [
          row.getAttribute("data-name") || "",
          row.getAttribute("data-race") || "",
          row.getAttribute("data-bucket") || "",
        ].join(" ");
        const ok = !q || hay.includes(q);
        row.hidden = !ok;
        if (ok) shown++;
      }
      for (const g of groups) {
        const any = Array.from(g.querySelectorAll(".pol-card")).some((r) => !r.hidden);
        g.hidden = !any;
      }
      if (countEl) countEl.textContent = q ? `Showing ${shown} of ${total}` : `Showing ${total}`;
      if (empty) empty.hidden = shown > 0;
    };
    input.addEventListener("input", apply);
  })();
</script>

<style>
  .pol-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    margin: 1.25rem 0 0.5rem;
  }
  .pol-search {
    flex: 1 1 16rem;
  }
  .pol-search input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--paper, #f5edd9);
    font: inherit;
    color: inherit;
  }
  .pol-count {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.75;
  }
  .pol-group {
    margin-top: 1.75rem;
  }
  .pol-group__title {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--ink, #1a140d);
  }
  .pol-group__n {
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    opacity: 0.55;
    font-size: 0.9em;
  }
  .politician-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17.5rem, 1fr));
    gap: 0.85rem;
  }
  .pol-card {
    margin: 0;
    border: 1px solid var(--ink, #1a140d);
    background:
      linear-gradient(160deg, color-mix(in srgb, var(--paper, #f5edd9) 88%, #fff), var(--paper, #f5edd9));
    border-radius: 4px;
    box-shadow:
      0 1px 0 color-mix(in srgb, #fff 45%, transparent),
      0 10px 22px color-mix(in srgb, var(--shadow, rgba(26, 20, 13, 0.28)) 40%, transparent);
    transition: box-shadow 0.2s ease, transform 0.2s cubic-bezier(0.2, 0.9, 0.25, 1);
  }
  .pol-card:hover {
    box-shadow:
      0 18px 36px color-mix(in srgb, var(--shadow, rgba(26, 20, 13, 0.28)) 55%, transparent),
      0 0 28px color-mix(in srgb, var(--accent, #96201e) 16%, transparent);
    transform: translateY(-8px) scale(1.02);
  }
  .pol-card__link {
    display: flex;
    gap: 0.85rem;
    padding: 0.85rem;
    color: inherit;
    text-decoration: none;
    height: 100%;
    box-sizing: border-box;
  }
  .pol-card__body {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .pol-card__name {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
  }
  .pol-card__race {
    margin: 0;
    font-size: 0.72rem;
    opacity: 0.72;
    line-height: 1.3;
  }
  .pol-card__count {
    margin: 0.15rem 0 0.35rem;
    font-size: 0.88rem;
    opacity: 0.85;
  }
  .pol-card__scores {
    margin-top: auto;
    margin-bottom: 0;
    padding: 0.45rem 0 0;
    border-top: 1px solid var(--rule, #cfc3ad);
  }
  .pol-card__scores.scoreband {
    gap: 0.65rem 0.9rem;
    margin-bottom: 0;
  }
  .pol-card__na {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.6rem;
    font-weight: 700;
    opacity: 0.35;
    line-height: 1;
  }
  .pol-card__fact {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .pol-card__fact-num {
    font-family: var(--serif, Georgia, serif);
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1;
  }
  .pol-empty {
    margin-top: 1.5rem;
    opacity: 0.8;
  }
  @media (max-width: 480px) {
    .politician-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
