---
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import AdminNav from "~/components/AdminNav.astro";
import ShareBar from "~/components/ShareBar.astro";
import { CAMPAIGN_FEATURES, getCampaigns } from "~/lib/campaign";
import { shortDate } from "~/lib/dateline";

export const prerender = false;

const campaigns = await getCampaigns(env.AGENTS);
const featuresJson = JSON.stringify(CAMPAIGN_FEATURES);
const siteOrigin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
---
<BaseLayout title="Clad — Campaign Studio" noindex={true}>
  <section class="admin admin--wide camp">
    <AdminNav current="marketing" />
    <h2 class="admin__title">Campaign Studio</h2>
    <p class="dateline">
      Turn a plain-language brief into ready-to-post social copy and a share card.
      Grok writes in the CladFacts voice; you edit, save, and paste. Nothing posts without an explicit owner action.
    </p>

    <form class="camp-form" id="camp-form" onsubmit="return false;">
      <div class="field">
        <label for="camp-brief">Brief</label>
        <textarea
          id="camp-brief"
          rows="4"
          placeholder="e.g. Promote the 2026 midterms plus our ballot board and election map"
          maxlength="4000"
        ></textarea>
      </div>

      <div class="camp-grid-2">
        <div class="field">
          <label for="camp-type">Campaign type</label>
          <select id="camp-type">
            <option>Feature launch</option>
            <option>Seasonal/news moment</option>
            <option>Evergreen awareness</option>
            <option>App install</option>
            <option>Re-engagement</option>
          </select>
        </div>
        <div class="field">
          <label for="camp-tone">Tone</label>
          <select id="camp-tone">
            <option selected>Restrained</option>
            <option>Plainspoken</option>
            <option>Civic-urgent (still no hype)</option>
            <option>Wry-dry</option>
          </select>
        </div>
        <div class="field">
          <label for="camp-audience">Audience</label>
          <select id="camp-audience">
            <option selected>General readers</option>
            <option>News junkies</option>
            <option>Students/educators</option>
            <option>Journalists</option>
            <option>Politically engaged</option>
          </select>
        </div>
        <div class="field">
          <label for="camp-cta">Primary CTA path</label>
          <input
            id="camp-cta"
            type="text"
            value="/bracket/"
            readonly
            aria-readonly="true"
            title="Derived from the features you promote (first concrete feature in catalog order)"
          />
          <p class="dateline camp-cta-hint" id="camp-cta-hint">
            Set automatically from Features to promote below.
          </p>
        </div>
      </div>

      <fieldset class="camp-fieldset">
        <legend class="small-caps">Platforms</legend>
        <div class="camp-checks">
          {["x", "threads", "bluesky", "linkedin", "instagram"].map((p) => (
            <label class="camp-check">
              <input type="checkbox" class="camp-platform" value={p} checked={p === "x" || p === "bluesky" || p === "threads"} />
              <span>{p === "x" ? "X" : p.charAt(0).toUpperCase() + p.slice(1)}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="camp-fieldset">
        <legend class="small-caps">Features to promote</legend>
        <p class="dateline camp-feat-lede">
          Primary CTA uses the first selected feature (catalog order), preferring a concrete
          feature over “Graded TV-news report cards” (/).
        </p>
        <div class="camp-checks camp-checks--wrap">
          {CAMPAIGN_FEATURES.map((f) => (
            <label class="camp-check">
              <input
                type="checkbox"
                class="camp-highlight"
                value={f.key}
                data-url={f.url}
                data-name={f.name}
                checked={f.key === "ballot" || f.key === "map" || f.key === "core"}
              />
              <span>{f.name}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <label class="camp-check camp-check--solo">
        <input type="checkbox" id="camp-peg" />
        <span>Peg to current news (web search — slower, costs more)</span>
      </label>

      <div class="camp-toolbar">
        <button type="button" id="camp-generate">Generate</button>
        <button type="button" id="camp-save" class="secondary" disabled>Save campaign</button>
        <span id="camp-status" class="dateline"></span>
      </div>
    </form>

    <div id="camp-results" class="camp-results" hidden>
      <div class="camp-results__grid">
        <div>
          <h3 class="camp-section-title small-caps">Platform copy</h3>
          <p class="dateline">Edit freely, then save. Copy paste-ready text without another network call.</p>
          <div id="camp-posts"></div>
        </div>
        <div>
          <h3 class="camp-section-title small-caps">Share card</h3>
          <div class="camp-card-fields">
            <div class="field">
              <label for="card-kicker">Kicker</label>
              <input id="card-kicker" type="text" maxlength="40" />
            </div>
            <div class="field">
              <label for="card-headline">Headline</label>
              <input id="card-headline" type="text" maxlength="120" />
            </div>
            <div class="field">
              <label for="card-subhead">Subhead</label>
              <input id="card-subhead" type="text" maxlength="140" />
            </div>
            <div class="field">
              <label for="card-stat">Stat line</label>
              <input id="card-stat" type="text" maxlength="90" />
            </div>
            <div class="field">
              <label for="card-cta-label">CTA label</label>
              <input id="card-cta-label" type="text" maxlength="30" />
            </div>
            <div class="field">
              <label for="card-cta-url">CTA path</label>
              <input id="card-cta-url" type="text" maxlength="500" />
            </div>
          </div>
          <div class="camp-preview-wrap">
            <p class="dateline" id="camp-preview-hint">Save to render the share card preview.</p>
            <img id="camp-card" class="camp-card-img" alt="Campaign share card preview" hidden />
          </div>

          {/* Same share targets as posts / ballot / app — shown once campaign is saved */}
          <div id="camp-share-wrap" class="camp-share-wrap" hidden>
            <h3 class="camp-section-title small-caps">Share this campaign</h3>
            <p class="dateline camp-share-lede">
              Same options as on CladFacts: system Share (with the card image when the device allows it),
              Text, X, Bluesky, Threads, Reddit, Email, Copy link.
              X / Bluesky / Threads use your edited platform copy when available.
            </p>
            <ShareBar
              id="camp-sharebar"
              class="camp-sharebar"
              url={`${siteOrigin}/`}
              title="CladFacts"
              hook="Graded TV-news report cards."
            />
          </div>

          <div id="camp-citations" class="camp-citations" hidden></div>
        </div>
      </div>
    </div>

    <section class="camp-history">
      <h3 class="camp-section-title small-caps">Saved campaigns</h3>
      {campaigns.length === 0 ? (
        <p class="dateline">No campaigns saved yet.</p>
      ) : (
        <ul class="camp-history__list" id="camp-history-list">
          {campaigns.map((c) => (
            <li data-id={c.id}>
              <button type="button" class="camp-history__load" data-load={c.id}>
                <strong>{c.title}</strong>
                <span class="dateline">
                  {shortDate(new Date(c.updatedAt))} · {c.posts.map((p) => p.platform).join(", ")}
                </span>
              </button>
              <button type="button" class="camp-history__del secondary" data-del={c.id} aria-label="Delete campaign">
                Delete
              </button>
            </li>
          ))}
        </ul>
      )}
    </section>
  </section>

  <script is:inline define:vars={{ featuresJson, savedCampaigns: campaigns, siteOrigin }}>
    (() => {
      const FEATURES = typeof featuresJson === "string" ? JSON.parse(featuresJson) : featuresJson;
      const ORIGIN = siteOrigin || "https://cladfacts.com";
      const PLATFORM_LIMITS = { x: 280, bluesky: 300, threads: 500, linkedin: 1300, instagram: 2200 };
      const PLATFORM_LABEL = {
        x: "X",
        threads: "Threads",
        bluesky: "Bluesky",
        linkedin: "LinkedIn",
        instagram: "Instagram",
      };

      let currentId = null;
      let currentUpdatedAt = null;
      let draftIllustrationPrompt = "";
      let draftCitations = [];
      let lastInput = null;

      const statusEl = document.getElementById("camp-status");
      const setStatus = (msg, err) => {
        if (!statusEl) return;
        statusEl.textContent = msg || "";
        statusEl.style.color = err ? "var(--red-ink, #941a1a)" : "";
      };

      /** Catalog-order CTA from checked features; prefer non-core over home. */
      function ctaFromHighlights(keys) {
        const selected = FEATURES.filter((f) => keys.indexOf(f.key) >= 0);
        if (!selected.length) return { url: "/", name: null };
        const nonCore = selected.filter((f) => f.key !== "core");
        const pick = nonCore[0] || selected[0];
        return { url: pick.url || "/", name: pick.name || null };
      }

      function syncCtaFromFeatures() {
        const highlights = [...document.querySelectorAll(".camp-highlight:checked")].map((el) => el.value);
        const { url, name } = ctaFromHighlights(highlights);
        const ctaInput = document.getElementById("camp-cta");
        const hint = document.getElementById("camp-cta-hint");
        if (ctaInput) ctaInput.value = url;
        if (hint) {
          hint.textContent = name
            ? "From feature: " + name + " → " + url
            : "Select a feature below to set the primary CTA.";
        }
        // Keep card CTA in sync when owner hasn't customized a different path
        const cardCta = document.getElementById("card-cta-url");
        if (cardCta && (!cardCta.value || cardCta.dataset.auto !== "0")) {
          cardCta.value = url;
          cardCta.dataset.auto = "1";
        }
      }

      function collect() {
        const platforms = [...document.querySelectorAll(".camp-platform:checked")].map((el) => el.value);
        const highlights = [...document.querySelectorAll(".camp-highlight:checked")].map((el) => el.value);
        const { url: ctaUrl } = ctaFromHighlights(highlights);
        return {
          brief: document.getElementById("camp-brief").value.trim(),
          campaignType: document.getElementById("camp-type").value,
          tone: document.getElementById("camp-tone").value,
          audience: document.getElementById("camp-audience").value,
          ctaUrl,
          platforms,
          highlights,
          pegToNews: document.getElementById("camp-peg").checked,
        };
      }

      function collectDraft() {
        const posts = [...document.querySelectorAll(".camp-post")].map((el) => ({
          platform: el.getAttribute("data-platform"),
          text: el.querySelector("textarea.camp-post-text").value,
          altText: el.querySelector("textarea.camp-post-alt").value,
        }));
        return {
          id: currentId || undefined,
          input: lastInput || collect(),
          posts,
          card: {
            kicker: document.getElementById("card-kicker").value,
            headline: document.getElementById("card-headline").value,
            subhead: document.getElementById("card-subhead").value,
            statLine: document.getElementById("card-stat").value,
            ctaLabel: document.getElementById("card-cta-label").value,
            ctaUrl: document.getElementById("card-cta-url").value,
          },
          citations: draftCitations,
          illustrationPrompt: draftIllustrationPrompt,
        };
      }

      function showResults(show) {
        document.getElementById("camp-results").hidden = !show;
        document.getElementById("camp-save").disabled = !show;
      }

      function renderPosts(posts) {
        const root = document.getElementById("camp-posts");
        root.innerHTML = "";
        (posts || []).forEach((m) => {
          const limit = PLATFORM_LIMITS[m.platform] || 500;
          const wrap = document.createElement("div");
          wrap.className = "camp-post";
          wrap.setAttribute("data-platform", m.platform);
          const label = PLATFORM_LABEL[m.platform] || m.platform;
          wrap.innerHTML =
            '<div class="camp-post__head">' +
            "<strong>" +
            label +
            '</strong> <span class="camp-post__count dateline"></span>' +
            '<button type="button" class="secondary camp-copy-btn">Copy paste-ready text</button>' +
            "</div>" +
            '<textarea class="camp-post-text" rows="4"></textarea>' +
            '<label class="dateline">Alt text (share card)</label>' +
            '<textarea class="camp-post-alt" rows="2"></textarea>';
          wrap.querySelector(".camp-post-text").value = m.text || "";
          wrap.querySelector(".camp-post-alt").value = m.altText || m.alt_text || "";
          const countEl = wrap.querySelector(".camp-post__count");
          const ta = wrap.querySelector(".camp-post-text");
          const updateCount = () => {
            const n = ta.value.length;
            countEl.textContent = n + " / " + limit;
            countEl.style.color = n > limit ? "var(--red-ink, #941a1a)" : "";
          };
          ta.addEventListener("input", updateCount);
          updateCount();
          wrap.querySelector(".camp-copy-btn").addEventListener("click", async () => {
            try {
              await navigator.clipboard.writeText(ta.value);
              setStatus("Copied " + label + " text.");
            } catch {
              ta.select();
              setStatus("Select and copy manually (clipboard blocked).", true);
            }
          });
          root.appendChild(wrap);
        });
      }

      function fillCard(card) {
        document.getElementById("card-kicker").value = card?.kicker || "";
        document.getElementById("card-headline").value = card?.headline || "";
        document.getElementById("card-subhead").value = card?.subhead || "";
        document.getElementById("card-stat").value = card?.statLine || card?.stat_line || "";
        document.getElementById("card-cta-label").value = card?.ctaLabel || card?.cta_label || "";
        const cardCta = document.getElementById("card-cta-url");
        const path = card?.ctaUrl || card?.cta_url || document.getElementById("camp-cta").value || "/";
        cardCta.value = path;
        // Treat loaded/generated card CTA as auto unless user later edits it
        cardCta.dataset.auto = "1";
      }

      function setCardPreview(id, updatedAt) {
        const img = document.getElementById("camp-card");
        const hint = document.getElementById("camp-preview-hint");
        if (!id || !updatedAt) {
          img.hidden = true;
          hint.hidden = false;
          hideShareBar();
          return;
        }
        img.src = "/og/campaign/" + encodeURIComponent(id) + ".png?v=" + encodeURIComponent(updatedAt);
        img.hidden = false;
        hint.hidden = true;
        refreshShareBar();
      }

      function absoluteCtaUrl(path) {
        let p = String(path || "/").trim() || "/";
        if (!p.startsWith("/")) p = "/" + p;
        if (p.startsWith("//") || p.includes("://")) p = "/";
        if (p.startsWith("/api/") || p.startsWith("/admin")) p = "/";
        return ORIGIN.replace(/\/$/, "") + p;
      }

      function postTextFor(platform) {
        const el = document.querySelector('.camp-post[data-platform="' + platform + '"] textarea.camp-post-text');
        return el ? el.value.trim() : "";
      }

      function hideShareBar() {
        const wrap = document.getElementById("camp-share-wrap");
        if (wrap) wrap.hidden = true;
      }

      /** Wire the same ShareBar as the app/site once the campaign is saved. */
      function refreshShareBar() {
        const wrap = document.getElementById("camp-share-wrap");
        const bar = document.getElementById("camp-sharebar");
        if (!wrap || !bar || !currentId || !currentUpdatedAt) {
          hideShareBar();
          return;
        }

        const headline =
          (document.getElementById("card-headline") && document.getElementById("card-headline").value.trim()) ||
          "CladFacts";
        const subhead =
          (document.getElementById("card-subhead") && document.getElementById("card-subhead").value.trim()) || "";
        const stat =
          (document.getElementById("card-stat") && document.getElementById("card-stat").value.trim()) || "";
        const ctaPath =
          (document.getElementById("card-cta-url") && document.getElementById("card-cta-url").value.trim()) ||
          (document.getElementById("camp-cta") && document.getElementById("camp-cta").value.trim()) ||
          "/";
        const url = absoluteCtaUrl(ctaPath);
        const hook = [subhead, stat].filter(Boolean).join("\n") || "Graded TV-news report cards.";
        const cardImg =
          ORIGIN.replace(/\/$/, "") +
          "/og/campaign/" +
          encodeURIComponent(currentId) +
          ".png?v=" +
          encodeURIComponent(currentUpdatedAt);

        // Card fields drive the universal bar (Text / Email / Reddit / Copy / native).
        // Platform posts override X / Bluesky / Threads intents below.
        const xText = postTextFor("x");
        const bskyText = postTextFor("bluesky");
        const threadsText = postTextFor("threads");
        const nativeHook =
          xText || bskyText || threadsText || hook;

        bar.setAttribute("data-url", url);
        bar.setAttribute("data-title", headline);
        bar.setAttribute("data-hook", nativeHook);
        bar.setAttribute("data-story-image", cardImg);
        wrap.hidden = false;

        if (typeof window.cladRefreshShareBars === "function") {
          window.cladRefreshShareBars(bar);
        }

        // Prefer owner-edited platform copy for compose intents (when present).
        const enc = encodeURIComponent;
        const ensureUrl = (text) =>
          text.includes("cladfacts.com") || text.includes(url) ? text : text + "\n\n" + url;
        const xEl = bar.querySelector('[data-share="x"]');
        const bskyEl = bar.querySelector('[data-share="bluesky"]');
        const threadsEl = bar.querySelector('[data-share="threads"]');
        if (xEl && xText) {
          xEl.setAttribute("href", "https://twitter.com/intent/tweet?text=" + enc(ensureUrl(xText)));
        }
        if (bskyEl && bskyText) {
          bskyEl.setAttribute(
            "href",
            "https://bsky.app/intent/compose?text=" + enc(ensureUrl(bskyText))
          );
        }
        if (threadsEl && threadsText) {
          threadsEl.setAttribute(
            "href",
            "https://www.threads.net/intent/post?text=" + enc(ensureUrl(threadsText))
          );
        }
      }

      function renderCitations(list) {
        const el = document.getElementById("camp-citations");
        if (!list || !list.length) {
          el.hidden = true;
          el.innerHTML = "";
          return;
        }
        el.hidden = false;
        el.innerHTML =
          '<p class="small-caps camp-section-title">Citations</p><ul>' +
          list
            .map(
              (c) =>
                "<li><a href=\"" +
                String(c.url).replace(/"/g, "") +
                "\" target=\"_blank\" rel=\"noopener\">" +
                String(c.title || c.url).replace(/</g, "") +
                "</a></li>"
            )
            .join("") +
          "</ul>";
      }

      function applyDraft(draft, input) {
        lastInput = input || lastInput || collect();
        draftIllustrationPrompt = draft.illustrationPrompt || draft.illustration_prompt || "";
        draftCitations = draft.citations || [];
        renderPosts(draft.posts || []);
        fillCard(draft.card || {});
        renderCitations(draftCitations);
        showResults(true);
      }

      function applyCampaign(c) {
        currentId = c.id;
        currentUpdatedAt = c.updatedAt;
        lastInput = c.input || collect();
        if (c.input) {
          document.getElementById("camp-brief").value = c.input.brief || "";
          document.getElementById("camp-type").value = c.input.campaignType || "Feature launch";
          document.getElementById("camp-tone").value = c.input.tone || "Restrained";
          document.getElementById("camp-audience").value = c.input.audience || "General readers";
          document.getElementById("camp-peg").checked = !!c.input.pegToNews;
          const plat = new Set(c.input.platforms || []);
          document.querySelectorAll(".camp-platform").forEach((el) => {
            el.checked = plat.has(el.value);
          });
          const hl = new Set(c.input.highlights || []);
          document.querySelectorAll(".camp-highlight").forEach((el) => {
            el.checked = hl.has(el.value);
          });
          // CTA path always follows selected features (re-derive after restoring checks)
          syncCtaFromFeatures();
        }
        applyDraft(c, c.input);
        setCardPreview(c.id, c.updatedAt);
      }

      document.querySelectorAll(".camp-highlight").forEach((el) => {
        el.addEventListener("change", () => {
          syncCtaFromFeatures();
          if (currentId) refreshShareBar();
        });
      });
      // Mark card CTA as user-owned if they type a different path after generate
      const cardCtaEl = document.getElementById("card-cta-url");
      if (cardCtaEl) {
        cardCtaEl.addEventListener("input", () => {
          cardCtaEl.dataset.auto = "0";
        });
      }
      syncCtaFromFeatures();

      document.getElementById("camp-generate").addEventListener("click", async (e) => {
        const btn = e.currentTarget;
        const body = collect();
        if (!body.brief) {
          setStatus("Write a brief first.", true);
          return;
        }
        if (!body.platforms.length) {
          setStatus("Pick at least one platform.", true);
          return;
        }
        btn.disabled = true;
        setStatus(body.pegToNews ? "Generating with web search (up to ~2 min)…" : "Generating…");
        try {
          const res = await fetch("/api/admin/campaign", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "generate", ...body }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "Generate failed");
          // New generate is a draft until save — keep id if editing same campaign
          applyDraft(data.draft, data.input || body);
          if (!currentId) setCardPreview(null, null);
          setStatus(
            "Draft ready — edit posts/card, then Save to render the share card." +
              (data.draft.posts?.length ? " " + data.draft.posts.length + " platform(s)." : "")
          );
        } catch (err) {
          setStatus(String(err.message || err), true);
        } finally {
          btn.disabled = false;
        }
      });

      document.getElementById("camp-save").addEventListener("click", async (e) => {
        const btn = e.currentTarget;
        btn.disabled = true;
        setStatus("Saving…");
        try {
          const payload = collectDraft();
          const res = await fetch("/api/admin/campaign", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "save", ...payload }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "Save failed");
          currentId = data.id;
          currentUpdatedAt = data.updatedAt;
          setCardPreview(data.id, data.updatedAt);
          setStatus("Saved. Share card and share bar ready.");
        } catch (err) {
          setStatus(String(err.message || err), true);
        } finally {
          btn.disabled = false;
        }
      });

      // Re-wire share targets when owner edits card fields or platform posts
      document.getElementById("camp-results").addEventListener("input", (e) => {
        if (!currentId) return;
        const t = e.target;
        if (
          t &&
          (t.id === "card-headline" ||
            t.id === "card-subhead" ||
            t.id === "card-stat" ||
            t.id === "card-cta-url" ||
            t.classList.contains("camp-post-text"))
        ) {
          refreshShareBar();
        }
      });

      document.querySelectorAll("[data-load]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-load");
          const list = Array.isArray(savedCampaigns) ? savedCampaigns : [];
          const c = list.find((x) => x.id === id);
          if (!c) {
            setStatus("Campaign not in page snapshot — refresh.", true);
            return;
          }
          applyCampaign(c);
          setStatus("Loaded “" + (c.title || id) + "”.");
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      });

      document.querySelectorAll("[data-del]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = btn.getAttribute("data-del");
          if (!confirm("Delete this campaign?")) return;
          try {
            const res = await fetch("/api/admin/campaign", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ action: "delete", id }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || "Delete failed");
            const li = btn.closest("li");
            if (li) li.remove();
            if (currentId === id) {
              currentId = null;
              setCardPreview(null, null);
            }
            setStatus("Deleted.");
          } catch (err) {
            setStatus(String(err.message || err), true);
          }
        });
      });

      // silence unused FEATURES lint if tree-shaken in some builds
      void FEATURES;
    })();
  </script>

  <style>
    .camp { max-width: 56rem; }
    .camp-form { margin-top: 1.25rem; }
    .camp-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 1rem;
    }
    @media (max-width: 640px) {
