---
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import AdminNav from "~/components/AdminNav.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import { findNearDuplicates, leanSpread, listDrafts, publishedPostsMeta, type NearDuplicate } from "~/lib/agents";
import { isTertiarySource } from "~/lib/citations";
import { eventTypeLabel, type EventType } from "~/lib/draftQuality";
import { lintHeadline } from "~/lib/headlineLint";
import { embedUrl } from "~/lib/youtube";

export const prerender = false;

const allDrafts = await listDrafts(env.AGENTS);

// Track C: priority / quality score first, then newest — debate nights and
// clean drafts surface above thin or style-flagged ones.
const sortedDrafts = [...allDrafts].sort((a, b) => {
  const pa = a.quality?.priority ? 1 : 0;
  const pb = b.quality?.priority ? 1 : 0;
  if (pb !== pa) return pb - pa;
  const sa = a.quality?.score ?? 50;
  const sb = b.quality?.score ?? 50;
  if (sb !== sa) return sb - sa;
  return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();
});

// Render a bounded page of the queue. Rendering every pending draft stops
// scaling once approvals lag: each fresh near-dup computation scans the posts
// collection, and an unbounded page of embedded videos + full report bodies is
// unusable anyway. The 2026-07-06 backlog (160 drafts) 503'd this page outright.
const QUEUE_PAGE_SIZE = 40;
const drafts = sortedDrafts.slice(0, QUEUE_PAGE_SIZE);

// Per-draft editorial QA: cross-network near-duplicate cluster (stored on the
// draft at submit time, else computed fresh) and headline verdict-phrase lint.
const nearDupsById = new Map<string, NearDuplicate[]>();
const spreadById = new Map<string, number>();
const lintById = new Map<string, string[]>();
// Preload the posts collection once for the whole loop — otherwise each fresh
// near-dup computation re-materializes all ~2530 posts (the 160-draft backlog
// that 503'd this page). Only needed if some draft lacks a stored result.
const allPosts = drafts.some((d) => !d.nearDuplicates) ? await publishedPostsMeta() : [];
for (const d of drafts) {
  const dups =
    d.nearDuplicates ??
    (await findNearDuplicates(env.AGENTS, {
      texts: [d.source.videoTitle ?? "", d.report.headline],
      publishedAt: d.source.publishedAt,
      excludeDraftId: d.draftId,
      preloadedDrafts: allDrafts,
      preloadedPosts: allPosts,
    }));
  nearDupsById.set(d.draftId, dups);
  spreadById.set(d.draftId, leanSpread([...dups, { leanScore: d.report.leanScore }]));
  lintById.set(d.draftId, lintHeadline(d.report.headline));
}
---
<BaseLayout title="Clad — Pending Queue">
  <section class="admin">
    <AdminNav current="queue" />
    <h2 class="admin__title">Pending Approval</h2>
    <p class="dateline">
      Reports drafted by agents. Review each, then approve (publishes live) or
      reject (discards). Nothing here is public until you approve it.
    </p>

    {allDrafts.length > drafts.length && (
      <p class="dateline" style="margin-top:0.5rem">
        <strong>{allDrafts.length.toLocaleString("en-US")} drafts pending</strong> — showing the
        newest {drafts.length}. Approve or reject these and reload for the next batch.
      </p>
    )}

    {drafts.length === 0 ? (
      <p class="dateline" style="margin-top:2rem">The queue is empty.</p>
    ) : (
      <>
        <div class="queue-bulk" style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin:1rem 0">
          <button type="button" id="q-submit-all">Submit all ({drafts.length})</button>
          <span id="q-bulk-status" class="dateline"></span>
          <span class="dateline" style="opacity:.8">
            Publishes clean drafts; auto-rejects duplicates and style-flagged headlines so the queue clears.
          </span>
        </div>
      <div class="queue">
        {drafts.map((d) => (
          <article class="queue-item" data-draft-id={d.draftId}>
            <div class="queue-item__head">
              <span class="grade-tag">
                <span class="grade-tag__label small-caps">Grade</span>
                <LetterGrade grade={d.report.letterGrade} />
              </span>
              <h3 class="queue-item__headline">{d.report.headline}</h3>
            </div>
            <p class="queue-qa dateline">
              {d.quality?.priority && <span class="qa-pill qa-pill--priority">Priority</span>}
              {d.quality?.eventType && d.quality.eventType !== "other" && (
                <span class="qa-pill">{eventTypeLabel(d.quality.eventType as EventType)}</span>
              )}
              {d.quality != null && (
                <span class="qa-pill qa-pill--score" title="Draft quality score">
                  QA {d.quality.score}
                </span>
              )}
              {(d.quality?.politicians?.length ?? 0) > 0 && (
                <span class="qa-pill">
                  {d.quality!.politicians.map((p) => p.name).join(" · ")}
                </span>
              )}
            </p>
            {(lintById.get(d.draftId) ?? []).length > 0 && (
              <div class="notice notice--error" data-headline-lint>
                <span class="small-caps">Style:</span> headline states the verdict
                ({(lintById.get(d.draftId) ?? []).map((w) => `“${w}”`).join(", ")}) —
                headlines should be descriptive; the grade carries the verdict.
              </div>
            )}
            {(d.quality?.warnings?.length ?? 0) > 0 && (
              <div class="notice notice--warn">
                <span class="small-caps">QA:</span>
                <ul style="margin:.35rem 0 0;padding-left:1.25rem">
                  {d.quality!.warnings.map((w) => (
                    <li>{w}</li>
                  ))}
                </ul>
              </div>
            )}
            <p class="dateline">
              {d.source.channel ?? "Unknown channel"} ·{" "}
              Factuality {d.report.factualityScore}/100 ·{" "}
              {d.source.transcriptUsed ? "transcript" : "web research only"} ·{" "}
              <a href={d.sourceUrl} target="_blank" rel="noopener noreferrer">source video</a>
            </p>
            {(nearDupsById.get(d.draftId) ?? []).length > 0 && (
              <div class="notice notice--error">
                <span class="small-caps">Near-duplicate coverage in the last 48h:</span>
                <ul style="margin:.4rem 0 0;padding-left:1.25rem">
                  {(nearDupsById.get(d.draftId) ?? []).map((m) => (
                    <li>
                      {m.pending ? (
                        <span>{m.headline} (pending draft)</span>
                      ) : (
                        <a href={`/posts/${m.id}/`} target="_blank" rel="noopener noreferrer">{m.headline}</a>
                      )}
                      {" "}— {m.channel ?? "unknown channel"}{m.leanScore != null ? `, lean ${m.leanScore}%` : ""}
                    </li>
                  ))}
                </ul>
                {(spreadById.get(d.draftId) ?? 0) >= 20 && (
                  <p style="margin:.4rem 0 0">Lean spread across cluster: {spreadById.get(d.draftId)} pts</p>
                )}
              </div>
            )}

            {d.report.gradeRationale && (
              <p class="grade-rationale"><span class="small-caps">Why this grade:</span> {d.report.gradeRationale}</p>
            )}
            <PoliticalLean score={d.report.leanScore} lean={d.report.politicalLean} />
            {d.report.leanRationale && (
              <p class="lean-rationale"><span class="small-caps">Why this lean:</span> {d.report.leanRationale}</p>
            )}

            <div class="video-embed" style="max-width:480px;margin:1rem 0">
              <iframe
                src={embedUrl(d.videoId)}
                title={d.report.headline}
                loading="lazy"
                allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                referrerpolicy="strict-origin-when-cross-origin"
              ></iframe>
            </div>

            <details>
              <summary class="small-caps">Summary &amp; assessment</summary>
              <p>{d.report.summary}</p>
              <p><em>{d.report.assessment}</em></p>
            </details>

            {d.report.keyMoments.length > 0 && (
              <details>
                <summary class="small-caps">{d.report.keyMoments.length} key moments</summary>
                <ul>
                  {d.report.keyMoments.map((m) => (
                    <li><strong>[{m.verdict}]</strong> {m.claim} — <em>{m.note}</em></li>
                  ))}
                </ul>
              </details>
            )}

            {d.report.citations.length > 0 && (
              <details>
                <summary class="small-caps">{d.report.citations.length} citations</summary>
                <ol>
                  {d.report.citations.map((c) => (
                    <li>
                      <a href={c.url} target="_blank" rel="noopener noreferrer">{c.title}</a>
                      {isTertiarySource(c.url) && <span class="small-caps"> · background</span>}
                    </li>
                  ))}
                </ol>
              </details>
            )}

            <div class="q-revise">
              <label class="small-caps" for={`rev-${d.draftId}`}>Flag for revision — tell Grok what's wrong</label>
              <textarea
                id={`rev-${d.draftId}`}
                class="q-comment"
                rows="2"
                placeholder="e.g. Anthropic's Claude models DO exist — correct the claim that they don't and re-grade accordingly."
              ></textarea>
              <button type="button" class="secondary q-revise-btn">Send to Grok to fix</button>
            </div>

            <div class="queue-item__actions">
              <label><input type="checkbox" class="q-featured" /> Feature on front page</label>
              <button type="button" class="q-approve">Approve &amp; Publish</button>
              <button type="button" class="secondary q-reject">Reject</button>
            </div>
            <div class="q-status"></div>
          </article>
        ))}
      </div>
      </>
    )}
  </section>

  <style is:global>
    .queue-qa { display: flex; flex-wrap: wrap; gap: 0.35rem 0.5rem; margin: 0.35rem 0 0.5rem; }
    .qa-pill {
      display: inline-block;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 0.2rem 0.45rem;
      border: 1px solid var(--ink, #1a140d);
      background: transparent;
    }
    .qa-pill--priority {
      background: var(--ink, #1a140d);
      color: var(--paper, #f5edd9);
    }
    .qa-pill--score { opacity: 0.85; }
    .notice--warn {
      border-color: #8a6a1f;
      background: color-mix(in srgb, #8a6a1f 12%, transparent);
    }
  </style>

  <script is:inline>
    // Controllers for each rendered draft, so the "Submit all" button can drive
    // them without duplicating the per-item publish / reject logic.
    const bulkItems = [];
    document.querySelectorAll(".queue-item").forEach((item) => {
      const id = item.getAttribute("data-draft-id");
      const status = item.querySelector(".q-status");
      const hasLint = !!item.querySelector("[data-headline-lint]");
      const isPending = () => !!item.querySelector(".q-approve") && document.body.contains(item);
      const setStatus = (kind, msg) => {
        status.innerHTML = msg
          ? `<div class="notice ${kind === "error" ? "notice--error" : ""}">${msg}</div>`
          : "";
      };
      // Non-interactive reject for the bulk flow: discards the draft and removes
      // the card. Returns true on success.
      const rejectNoConfirm = async (reason) => {
        item.querySelectorAll("button").forEach((b) => (b.disabled = true));
        setStatus("info", reason ? `Rejecting — ${reason}` : "Discarding…");
        try {
          const res = await fetch("/api/admin/queue", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "reject", draftId: id }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Reject failed");
          item.remove();
          return true;
        } catch (err) {
          setStatus("error", String(err.message || err));
          item.querySelectorAll("button").forEach((b) => (b.disabled = false));
          return false;
        }
      };
      // Non-interactive approve for the bulk flow: publishes without prompting,
      // and never forces past a duplicate (409) — bulk then auto-rejects those.
      // Returns "published" | "duplicate" | "error".
      const approveNoConfirm = async () => {
        item.querySelectorAll("button").forEach((b) => (b.disabled = true));
        setStatus("info", "Publishing…");
        try {
          const res = await fetch("/api/admin/queue", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              action: "approve",
              draftId: id,
              force: false,
              featured: item.querySelector(".q-featured")?.checked,
            }),
          });
          const data = await res.json();
          if (res.status === 409 && data.duplicate) {
            setStatus("error", "Duplicate — rejecting…");
            return "duplicate";
          }
          if (!res.ok) throw new Error(data.error || "Failed");
          setStatus("info", `Published. <a href="${data.postUrl}">${data.postUrl}</a> — live in ~30s.`);
          item.querySelectorAll("button").forEach((b) => b.remove());
          return "published";
        } catch (err) {
          setStatus("error", String(err.message || err));
          item.querySelectorAll("button").forEach((b) => (b.disabled = false));
          return "error";
        }
      };
      bulkItems.push({ hasLint, isPending, approveNoConfirm, rejectNoConfirm });
      const send = async (action, force = false) => {
        item.querySelectorAll("button").forEach((b) => (b.disabled = true));
        setStatus("info", action === "approve" ? "Publishing…" : "Discarding…");
        try {
          const res = await fetch("/api/admin/queue", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              action,
              draftId: id,
              force,
              featured: item.querySelector(".q-featured")?.checked,
            }),
          });
          const data = await res.json();
          if (res.status === 409 && data.duplicate) {
            item.querySelectorAll("button").forEach((b) => (b.disabled = false));
            if (confirm(data.error + "\n\nPublish anyway?")) return send("approve", true);
            setStatus("error", "Skipped (possible duplicate).");
            return;
          }
          if (!res.ok) throw new Error(data.error || "Failed");
          if (action === "reject") {
            item.remove();
          } else {
            setStatus("info", `Published. <a href="${data.postUrl}">${data.postUrl}</a> — live in ~30s.`);
            item.querySelectorAll("button").forEach((b) => b.remove());
          }
        } catch (err) {
          setStatus("error", String(err.message || err));
          item.querySelectorAll("button").forEach((b) => (b.disabled = false));
        }
      };
      item.querySelector(".q-approve").addEventListener("click", () => {
        if (
          item.querySelector("[data-headline-lint]") &&
          !confirm("The headline appears to state the verdict — headlines should be descriptive. Approve anyway?")
        ) {
          return;
        }
        send("approve");
      });
      item.querySelector(".q-reject").addEventListener("click", () => send("reject"));

      item.querySelector(".q-revise-btn").addEventListener("click", async () => {
        const comment = item.querySelector(".q-comment").value.trim();
        if (comment.length < 3) {
          setStatus("error", "Add a comment describing what to fix.");
          return;
        }
        item.querySelectorAll("button").forEach((b) => (b.disabled = true));
        setStatus("info", "Sending to Grok to fix — this can take ~20–40s…");
        try {
          const res = await fetch("/api/admin/queue", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: "revise", draftId: id, comment }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || "Revision failed");
          setStatus("info", "Revised. Reloading to show the corrected draft…");
          setTimeout(() => location.reload(), 900);
        } catch (err) {
          setStatus("error", String(err.message || err));
          item.querySelectorAll("button").forEach((b) => (b.disabled = false));
        }
      });
    });

    // "Submit all": publish clean drafts; auto-reject anything the bulk flow
    // would not publish (headline style flags + API-flagged duplicates) so the
    // queue does not leave leftovers to clear by hand. Transient API errors
    // stay in the queue for retry.
    const bulkBtn = document.getElementById("q-submit-all");
    const bulkStatus = document.getElementById("q-bulk-status");
    if (bulkBtn) {
      bulkBtn.addEventListener("click", async () => {
        const pending = bulkItems.filter((i) => i.isPending());
        const total = pending.length;
        if (total === 0) {
          bulkStatus.textContent = "Nothing left to process.";
          return;
        }
        if (
          !confirm(
            `Process ${total} draft(s)?\n\n` +
              `• Clean drafts → publish\n` +
              `• Duplicates & style-flagged headlines → reject & remove\n` +
              `• Transient failures stay for you to retry\n\n` +
              `This cannot be undone for rejected drafts.`,
          )
        ) {
          return;
        }
        bulkBtn.disabled = true;
        let published = 0;
        let rejected = 0;
        let failed = 0;
        let done = 0;
        const render = (prefix) => {
          bulkStatus.textContent =
            `${prefix} ${done}/${total} — ${published} published, ` +
            `${rejected} rejected, ${failed} failed.`;
        };
        render("Processing…");
        for (const it of pending) {
          if (!it.isPending()) {
            done += 1;
            render("Processing…");
            continue;
          }
          // Style-flagged headlines: bulk never publishes these — reject.
          if (it.hasLint) {
            const ok = await it.rejectNoConfirm("headline states the verdict");
            if (ok) rejected += 1;
            else failed += 1;
            done += 1;
            render("Processing…");
            continue;
          }
          const outcome = await it.approveNoConfirm();
          if (outcome === "published") {
            published += 1;
          } else if (outcome === "duplicate") {
            const ok = await it.rejectNoConfirm("possible duplicate");
            if (ok) rejected += 1;
            else failed += 1;
          } else {
            failed += 1;
          }
          done += 1;
          render("Processing…");
        }
        render("Done —");
        bulkBtn.disabled = false;
      });
    }
  </script>
</BaseLayout>
