---
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import AdminNav from "~/components/AdminNav.astro";
import { shortDate } from "~/lib/dateline";

export const prerender = false;

interface UserRow {
  id: string;
  name: string | null;
  email: string;
  emailVerified: number;
  createdAt: string;
}

let users: UserRow[] = [];
let providersByUser = new Map<string, string[]>();
let subByUser = new Map<string, string>();
let dbError = "";
try {
  const u = await env.DB.prepare(
    "SELECT id, name, email, emailVerified, createdAt FROM user ORDER BY createdAt DESC LIMIT 1000"
  ).all<UserRow>();
  users = u.results ?? [];
  const a = await env.DB.prepare("SELECT userId, providerId FROM account").all<{ userId: string; providerId: string }>();
  for (const row of a.results ?? []) {
    if (!providersByUser.has(row.userId)) providersByUser.set(row.userId, []);
    providersByUser.get(row.userId)!.push(row.providerId);
  }
  const s = await env.DB.prepare("SELECT userId, status FROM subscription").all<{ userId: string; status: string }>();
  for (const row of s.results ?? []) subByUser.set(row.userId, row.status);
} catch (e: any) {
  dbError = e?.message ?? "Could not read users";
}

const PROVIDER_LABEL: Record<string, string> = {
  credential: "Email",
  google: "Google",
  apple: "Apple",
  twitter: "X",
};
function methods(id: string): string {
  const ps = providersByUser.get(id) ?? [];
  if (ps.length === 0) return "—";
  return [...new Set(ps.map((p) => PROVIDER_LABEL[p] ?? p))].join(", ");
}
function stamp(iso: string): string {
  try {
    return shortDate(new Date(iso));
  } catch {
    return iso;
  }
}
function planLabel(id: string): { text: string; paid: boolean } {
  const status = subByUser.get(id);
  if (status === "active" || status === "trialing") return { text: "Premium", paid: true };
  // Hybrid access model: no trial tier — every account is full-access Free.
  return { text: "Free", paid: false };
}
---
<BaseLayout title="Clad — Users">
  <section class="admin">
    <AdminNav current="users" />
    <h2 class="admin__title">Users</h2>
    <p class="dateline">
      Registered accounts ({users.length}). Created via email/password or social
      sign-in. <strong>Delete</strong> permanently removes an account and its
      sessions, preferences, and alerts.
    </p>

    {dbError ? (
      <p class="comp-empty">Couldn't load users: {dbError}</p>
    ) : users.length === 0 ? (
      <p class="dateline" style="margin-top:2rem">No accounts yet.</p>
    ) : (
      <>
      <div class="user-search">
        <input id="user-search-input" type="search" placeholder="Search by name, email, or plan…" autocomplete="off" />
        <span id="user-search-count" class="dateline"></span>
      </div>
      <ul class="user-rows">
        {users.map((u) => {
          const plan = planLabel(u.id);
          const search = `${u.name ?? ""} ${u.email} ${methods(u.id)} ${plan.text}`.toLowerCase();
          return (
          <li class="user-row" data-id={u.id} data-search={search}>
            <div class="user-row__main">
              <span class="user-row__name">{u.name || "(no name)"}</span>
              <span class="user-row__email">{u.email}</span>
            </div>
            <p class="dateline">
              {methods(u.id)} · {u.emailVerified ? "verified" : "unverified"} · joined {stamp(u.createdAt)} · <strong>{plan.text}</strong>
            </p>
            <div class="user-row__actions" data-paid={plan.paid ? "1" : "0"}>
              <button type="button" class="small u-grant">Grant Premium</button>
              <button type="button" class="secondary small u-revoke">Revoke</button>
              <button type="button" class="secondary small u-delete">Delete</button>
              <span class="u-status"></span>
            </div>
          </li>
          );
        })}
      </ul>
      </>
    )}
  </section>

  <script is:inline>
    (() => {
      const input = document.getElementById("user-search-input");
      const countEl = document.getElementById("user-search-count");
      const rows = Array.from(document.querySelectorAll(".user-row"));
      if (!input) return;
      const apply = () => {
        const q = input.value.trim().toLowerCase();
        let shown = 0;
        rows.forEach((r) => {
          const hit = !q || (r.getAttribute("data-search") || "").includes(q);
          r.style.display = hit ? "" : "none";
          if (hit) shown++;
        });
        if (countEl) countEl.textContent = q ? `${shown} of ${rows.length}` : `${rows.length} accounts`;
      };
      input.addEventListener("input", apply);
      apply();
    })();

    document.querySelectorAll(".user-row").forEach((row) => {
      const id = row.getAttribute("data-id");
      const status = row.querySelector(".u-status");
      const post = async (body) => {
        const res = await fetch("/api/admin/users", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ ...body, id }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "Failed");
        return data;
      };

      row.querySelector(".u-grant").addEventListener("click", async () => {
        status.textContent = "Granting…";
        try { await post({ action: "grant" }); status.textContent = "Premium granted."; }
        catch (err) { status.textContent = String(err.message || err); }
      });
      row.querySelector(".u-revoke").addEventListener("click", async () => {
        status.textContent = "Revoking…";
        try { await post({ action: "revoke" }); status.textContent = "Reverted to free."; }
        catch (err) { status.textContent = String(err.message || err); }
      });

      const del = row.querySelector(".u-delete");
      del.addEventListener("click", async () => {
        if (!confirm("Permanently delete this account and all its data?")) return;
        del.disabled = true;
        status.textContent = "Deleting…";
        try {
          await post({ action: "delete" });
          row.style.opacity = "0.5";
          status.textContent = "Deleted.";
          del.remove();
        } catch (err) {
          status.textContent = String(err.message || err);
          del.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>
