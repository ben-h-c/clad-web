---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import { SECTIONS, sectionSlug } from "~/lib/sections";

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection("posts", (p) => !p.data.draft);
  return SECTIONS.map((section) => {
    const posts = all
      .filter((p) => p.data.section === section)
      .sort(
        (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
      );
    return {
      params: { section: sectionSlug(section) },
      props: { section, posts },
    };
  });
}

const { section, posts } = Astro.props;
---
<BaseLayout
  title={`${section} — Clad`}
  description={`Fact-checked news reports in ${section}, edited like a 1920s broadsheet.`}
>
  <section class="section-page">
    <p class="small-caps section-page__eyebrow">Section</p>
    <h2 class="section-page__title">{section}</h2>
    <div class="rule rule--double" aria-hidden="true"></div>

    {posts.length === 0 ? (
      <p class="dateline" style="margin-top:2rem">
        No reports in this section yet.
      </p>
    ) : (
      <div class="card-grid" style="margin-top:1.5rem">
        {posts.map((p) => <ReportCard post={p} />)}
      </div>
    )}
  </section>
</BaseLayout>
