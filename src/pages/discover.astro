---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import PaywallPanel from "~/components/PaywallPanel.astro";
import { getDiscover } from "~/lib/agents";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

// Discover is free with an account (hybrid model) — anonymous readers get a
// teaser (first sections, grades/lean hidden) with a register panel instead
// of a bodyless redirect.
const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const sections = await getDiscover(env.AGENTS);
const all = await getCollection("posts", (p) => !p.data.draft);
const byId = new Map(all.map((p) => [p.id, p]));
const resolved = sections
  .map((s) => ({ ...s, posts: s.ids.map((id) => byId.get(id)).filter((p) => p !== undefined) }))
  .filter((s) => s.posts.length >= 2);
const visible = locked
  ? resolved.slice(0, 2).map((s) => ({ ...s, posts: s.posts.slice(0, 4) }))
  : resolved;

// Report of the Day — today's sample card renders unlocked for restricted readers.
const sampleId = locked ? sampleUnlockedId(all) : null;
---
<BaseLayout
  title="Discover — Clad"
  description="Serendipitous collections of fact-checked coverage — offbeat angles you wouldn't ordinarily see grouped."
>
  <section class="discover">
    <header class="discover__head">
      <p class="small-caps discover__eyebrow">From the desk</p>
      <h1 class="discover__title">Discover</h1>
      <p class="discover__lede">
        Fresh, unexpected collections from the CladFacts desk — offbeat angles
        and hidden throughlines you wouldn't ordinarily see grouped together.
        Refreshed regularly.
      </p>
    </header>

    {visible.length === 0 ? (
      <p class="dateline" style="margin-top:2rem">
        New collections are being curated — check back shortly.
      </p>
    ) : (
      visible.map((s) => (
        <section class="discover-sec">
          <h2 class="discover-sec__title">{s.title}</h2>
          {s.blurb && <p class="discover-sec__blurb">{s.blurb}</p>}
          <div class="rule rule--double" aria-hidden="true"></div>
          <div class="feed-list">
            {s.posts.map((p) => (
              <ReportCard post={p!} variant="bar" locked={locked && p!.id !== sampleId} sample={locked && p!.id === sampleId} />
            ))}
          </div>
        </section>
      ))
    )}

    {locked && <PaywallPanel signedIn={access.signedIn} returnTo="/discover/") />}
  </section>
</BaseLayout>
