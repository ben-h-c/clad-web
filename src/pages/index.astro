---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import BreakingStrip from "~/components/BreakingStrip.astro";
import TopicRow from "~/components/TopicRow.astro";
import GradeBoard from "~/components/GradeBoard.astro";
import HomeCharts from "~/components/HomeCharts.astro";
import Ticker from "~/components/Ticker.astro";
import QuipTicker from "~/components/QuipTicker.astro";
import PaywallPanel from "~/components/PaywallPanel.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import NewsletterSignup from "~/components/NewsletterSignup.astro";
import ReportCard from "~/components/ReportCard.astro";
import { getFrontpage, getBreaking, getTicker, getQuips, getSentiments } from "~/lib/agents";
import { aggregateTopics, gradeToGpa, leanScoreOf } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { APP_STORE_URL, APP_STORE_LIVE } from "~/lib/app-store";

// SSR so the hero reflects the curator's live KV-stored selection without a
// rebuild. Per-user (grades hidden for restricted readers), so never shared-cache.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const byId = new Map(all.map((p) => [p.id, p]));

// Hero = the Front Page Curator's selection (ordered) — news-media talk-show /
// panel / commentary segments across any network. Fall back to manually
// featured, then most-recent, if the curator hasn't run yet.
let curated = await getFrontpage(env.AGENTS);
let heroPosts = curated.map((id) => byId.get(id)).filter((p) => p !== undefined);
if (heroPosts.length === 0) {
  const flagged = all.filter((p) => p.data.featured);
  heroPosts = flagged.length > 0 ? flagged : all.slice(0, 8);
}
heroPosts = heroPosts.slice(0, 24);

// Breaking News = the curator's impact-ordered selection: single outlet posts,
// or temporary same-story groups (shown as a topic shell with aggregated grade
// + lean). Resolve each item; a group needs ≥2 resolvable members, else it
// degrades to a single post.
const breakingItems = await getBreaking(env.AGENTS);
let breaking = breakingItems
  .map((it) => {
    if (it.type === "post") {
      const p = byId.get(it.id);
      return p && isNewsOutlet(p.data.sourceTitle) ? { kind: "post" as const, post: p } : null;
    }
    const members = it.ids
      .map((id) => byId.get(id))
      .filter((p): p is NonNullable<typeof p> => p !== undefined && isNewsOutlet(p.data.sourceTitle));
    if (members.length >= 2) return { kind: "group" as const, slug: it.slug, title: it.title, topic: it.topic, members };
    if (members.length === 1) return { kind: "post" as const, post: members[0] };
    return null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .slice(0, 24);

// Recent = the newest reports overall (any type/outlet), newest first —
// excluding anything already shown in the hero or breaking strips.
const shown = new Set([
  ...heroPosts.map((p) => p.id),
  ...breaking.flatMap((b) => (b.kind === "post" ? [b.post.id] : b.members.map((m) => m.id))),
]);
let recent = all.filter((p) => !shown.has(p.id)).slice(0, 30);

const ticker = await getTicker(env.AGENTS);
const quips = await getQuips(env.AGENTS);

// Anonymous readers see all the pages and article text (great for SEO), but
// the scoreboard unlocks with an account — hidden everywhere via `locked`,
// and the graded analytics sections are replaced with a register panel.
const locked = !access.fullAccess;
// Report of the Day — one card renders fully unlocked (with a sample badge)
// for restricted readers; same pick site-wide per NY day.
const sampleId = locked ? sampleUnlockedId(all) : null;
// The free-card section is the sole unlocked scoreband for guests. Keep that
// post out of every strip (hero / recent / breaking) so anonymous HTML has
// exactly one real LetterGrade — smoke-anon allows only one on /.
// (2026-07: prod smoke failed 2× when the sample also appeared in Breaking
// with unlockedId, re-rendering the sample badge.)
if (sampleId) {
  heroPosts = heroPosts.filter((p) => p.id !== sampleId);
  recent = recent.filter((p) => p.id !== sampleId);
  breaking = breaking
    .map((it) => {
      if (it.kind === "post") return it.post.id === sampleId ? null : it;
      // Drop the sample member from a group; degrade to a single post or drop.
      const members = it.members.filter((p) => p.id !== sampleId);
      if (members.length >= 2) return { ...it, members };
      if (members.length === 1) return { kind: "post" as const, post: members[0] };
      return null;
    })
    .filter((x): x is NonNullable<typeof x> => x !== null);
}

// Social-media sentiment (KV, scanner-scored) — Premium; the read is skipped
// for restricted readers so the reception analytics never reach their HTML.
const sentiments = locked ? {} : await getSentiments(env.AGENTS);

const topics = aggregateTopics(all, sentiments);
const TOPICS_PER_PAGE = 20;

// Best & worst graded. Rank only graded (broadcast) posts; recency breaks ties.
const graded = all.filter((p) => gradeToGpa(p.data.letterGrade) != null);
const byGradeDesc = [...graded].sort(
  (a, b) =>
    gradeToGpa(b.data.letterGrade)! - gradeToGpa(a.data.letterGrade)! ||
    b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const topGraded = byGradeDesc.slice(0, 5);
const topIds = new Set(topGraded.map((p) => p.id));
// Lowest = worst-first, excluding any already shown in the top column.
const bottomGraded = [...graded]
  .filter((p) => !topIds.has(p.id))
  .sort(
    (a, b) =>
      gradeToGpa(a.data.letterGrade)! - gradeToGpa(b.data.letterGrade)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  )
  .slice(0, 5);

// Most politically biased: the most left-leaning and most right-leaning posts.
const leaned = all.filter((p) => leanScoreOf(p.data) != null);
const mostLeft = [...leaned]
  .sort(
    (a, b) =>
      leanScoreOf(a.data)! - leanScoreOf(b.data)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  )
  .slice(0, 5);
const leftIds = new Set(mostLeft.map((p) => p.id));
const mostRight = [...leaned]
  .filter((p) => !leftIds.has(p.id))
  .sort(
    (a, b) =>
      leanScoreOf(b.data)! - leanScoreOf(a.data)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  )
  .slice(0, 5);
---
<BaseLayout
  title="Clad — Grading Content & Exposing Bias"
  description="Fact-checked political broadcasts, graded for accuracy and called out for bias, edited like a 1920s broadsheet."
  tour
>
  <h1 class="visually-hidden">Clad — fact-checked news, graded for accuracy and bias</h1>
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      {APP_STORE_LIVE && (
        <>
          <aside class="app-promo" id="app-promo" data-app-hide hidden>
            <p class="app-promo__msg">
              <span class="app-promo__kicker">Now on iOS</span>
              Read the front page on your phone — every grade, political-lean rating, and
              breaking-news alert in the CladFacts app.
            </p>
            <a class="app-promo__cta" href={APP_STORE_URL} target="_blank" rel="noopener">Get the app →</a>
            <button type="button" class="app-promo__close" id="app-promo-close" aria-label="Dismiss app promotion">×</button>
          </aside>
          <script is:inline>
            (() => {
              const el = document.getElementById("app-promo");
              if (!el) return;
              const KEY = "clad_app_promo_dismissed";
              let dismissed = false;
              try { dismissed = !!localStorage.getItem(KEY); } catch {}
              // Reveal only for visitors who haven't dismissed it (avoids a flash for
              // those who have). Inside the iOS app it stays hidden via data-app-hide.
              if (!dismissed) el.hidden = false;
              const close = document.getElementById("app-promo-close");
              if (close) close.addEventListener("click", () => {
                el.hidden = true;
                try { localStorage.setItem(KEY, "1"); } catch {}
              });
            })();
          </script>
        </>
      )}
      {locked && (
        <aside class="paywall-banner">
          <span>
            Reading as a guest — every grade, political-lean rating &amp; sentiment
            score unlocks with a free account. No card, no clock.
            Prefer email first? <a href="/newsletter/">Get the free weekly</a>.
          </span>
          <a class="paywall-banner__cta" href="/register/">Create free account</a>
        </aside>
      )}
      {locked && sampleId && byId.has(sampleId) && (
        <section class="free-card" aria-labelledby="free-card-title">
          <div class="feed__head">
            <h2 class="feed__title" id="free-card-title">Today's Free Report Card</h2>
            <span class="free-card__note">One full grade, free every day — a free account unlocks this on every report.</span>
          </div>
          <div class="rule rule--double" aria-hidden="true"></div>
          <ReportCard post={byId.get(sampleId)!} sample />
        </section>
      )}
      {/* Decorative fun strip above the main rows; aria-hidden inside the
          component, so screen readers skip straight to the day's content. */}
      <QuipTicker data={quips} />
      {/* unlockedId omitted: free-card above is the only sanctioned sample. */}
      <BreakingStrip items={breaking} locked={locked} />
      <Ticker data={ticker} />
      <HeroStrip posts={heroPosts} title="Front Page" locked={locked} />
      <HeroStrip posts={recent} title="Recent" locked={locked} />
      <section class="feed">
        <div class="feed__head">
          <h2 class="feed__title">Topics</h2>
          <a class="category__more" href="/search/">Search all →</a>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="topic-rows">
          {topics.map((t, i) => (
            <li class="topic-row-item" hidden={i >= TOPICS_PER_PAGE}>
              <TopicRow topic={t} locked={locked} />
            </li>
          ))}
        </ul>
        {topics.length > TOPICS_PER_PAGE && (
          <button type="button" id="topics-more" class="show-more" data-step={TOPICS_PER_PAGE}>
            Show more <span aria-hidden="true">↓</span>
          </button>
        )}
      </section>
      <script is:inline>
        (() => {
          const btn = document.getElementById("topics-more");
          if (!btn) return;
          const items = Array.from(document.querySelectorAll(".topic-row-item"));
          const step = Number(btn.getAttribute("data-step")) || 20;
          let shown = step;
          btn.addEventListener("click", () => {
            shown += step;
            items.forEach((el, i) => { if (i < shown) el.hidden = false; });
            if (shown >= items.length) btn.hidden = true;
          });
        })();
      </script>
      {locked ? (
        <PaywallPanel signedIn={access.signedIn} />
      ) : (
        <>
          <HomeCharts posts={all} topics={topics} sentiments={sentiments} />
          {topGraded.length > 0 && <GradeBoard top={topGraded} bottom={bottomGraded} />}
          {mostLeft.length > 0 && (
            <GradeBoard
              title="Most Politically Biased"
              topLabel="Most Left-Leaning"
              bottomLabel="Most Right-Leaning"
              top={mostLeft}
              bottom={mostRight}
            />
          )}
        </>
      )}
    </>
  )}
  <section class="feed">
    <div class="feed__head">
      <h2 class="feed__title">The Record</h2>
      <a class="category__more" href="/week/">The Week in Grades →</a>
    </div>
    <div class="rule rule--double" aria-hidden="true"></div>
    <p class="dateline">
      The week's best &amp; worst graded coverage, its most disputed claims, and
      where coverage skewed to one side — wrapped up weekly, alongside the
      long-run <a href="/trends/">News Trends</a>. Midterms:
      <a href="/politicians/">politician report cards</a>
      ·
      <a href="/bracket/">coverage bracket</a>.
      New to this? <a href="/students/">Clad for students</a>
      ·
      <a href="/learn/grades/">What does a C− mean?</a>
    </p>
  </section>
  <NewsletterSignup />
  <Disclaimer />
</BaseLayout>
