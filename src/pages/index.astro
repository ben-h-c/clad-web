---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import BreakingStrip from "~/components/BreakingStrip.astro";
import TopicRow from "~/components/TopicRow.astro";
import GradeBoard from "~/components/GradeBoard.astro";
import Ticker from "~/components/Ticker.astro";
import QuipTicker from "~/components/QuipTicker.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import { getFrontpage, getBreaking, getTicker, getQuips } from "~/lib/agents";
import { aggregateTopics, gradeToGpa } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";

// SSR so the hero reflects the curator's live KV-stored selection without a
// rebuild. Edge/browser-cached briefly to keep load down.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "public, max-age=120");

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const byId = new Map(all.map((p) => [p.id, p]));

// Hero = the Front Page Curator's selection (ordered) — news-media talk-show /
// panel / commentary segments across any network. Fall back to manually
// featured, then most-recent, if the curator hasn't run yet.
let curated = await getFrontpage(env.AGENTS);
let heroPosts = curated.map((id) => byId.get(id)).filter((p) => p !== undefined);
if (heroPosts.length === 0) {
  const flagged = all.filter((p) => p.data.featured);
  heroPosts = flagged.length > 0 ? flagged : all.slice(0, 8);
}
heroPosts = heroPosts.slice(0, 50);

// Breaking News = the curator's impact-ordered selection: single outlet posts,
// or temporary same-story groups (shown as a topic shell with aggregated grade
// + lean). Resolve each item; a group needs ≥2 resolvable members, else it
// degrades to a single post.
const breakingItems = await getBreaking(env.AGENTS);
const breaking = breakingItems
  .map((it) => {
    if (it.type === "post") {
      const p = byId.get(it.id);
      return p && isNewsOutlet(p.data.sourceTitle) ? { kind: "post" as const, post: p } : null;
    }
    const members = it.ids
      .map((id) => byId.get(id))
      .filter((p): p is NonNullable<typeof p> => p !== undefined && isNewsOutlet(p.data.sourceTitle));
    if (members.length >= 2) return { kind: "group" as const, slug: it.slug, title: it.title, topic: it.topic, members };
    if (members.length === 1) return { kind: "post" as const, post: members[0] };
    return null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .slice(0, 50);

const ticker = await getTicker(env.AGENTS);
const quips = await getQuips(env.AGENTS);

const topics = aggregateTopics(all);
const TOPICS_PER_PAGE = 20;

// Best & worst graded. Rank only graded (broadcast) posts; recency breaks ties.
const graded = all.filter((p) => gradeToGpa(p.data.letterGrade) != null);
const byGradeDesc = [...graded].sort(
  (a, b) =>
    gradeToGpa(b.data.letterGrade)! - gradeToGpa(a.data.letterGrade)! ||
    b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const topGraded = byGradeDesc.slice(0, 10);
const topIds = new Set(topGraded.map((p) => p.id));
// Lowest = worst-first, excluding any already shown in the top column.
const bottomGraded = [...graded]
  .filter((p) => !topIds.has(p.id))
  .sort(
    (a, b) =>
      gradeToGpa(a.data.letterGrade)! - gradeToGpa(b.data.letterGrade)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  )
  .slice(0, 10);
---
<BaseLayout
  title="Clad — Grading Content & Exposing Bias"
  description="Fact-checked political broadcasts, graded for accuracy and called out for bias, edited like a 1920s broadsheet."
>
  <QuipTicker data={quips} />
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      <BreakingStrip items={breaking} />
      <Ticker data={ticker} />
      <HeroStrip posts={heroPosts} title="Front Page" />
      <section class="feed">
        <div class="feed__head">
          <h2 class="feed__title">Topics</h2>
          <a class="category__more" href="/search/">Search all →</a>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="topic-rows">
          {topics.map((t, i) => (
            <li class="topic-row-item" hidden={i >= TOPICS_PER_PAGE}>
              <TopicRow topic={t} />
            </li>
          ))}
        </ul>
        {topics.length > TOPICS_PER_PAGE && (
          <button type="button" id="topics-more" class="show-more" data-step={TOPICS_PER_PAGE}>
            Show more <span aria-hidden="true">↓</span>
          </button>
        )}
      </section>
      <script is:inline>
        (() => {
          const btn = document.getElementById("topics-more");
          if (!btn) return;
          const items = Array.from(document.querySelectorAll(".topic-row-item"));
          const step = Number(btn.getAttribute("data-step")) || 20;
          let shown = step;
          btn.addEventListener("click", () => {
            shown += step;
            items.forEach((el, i) => { if (i < shown) el.hidden = false; });
            if (shown >= items.length) btn.hidden = true;
          });
        })();
      </script>
      {topGraded.length > 0 && <GradeBoard top={topGraded} bottom={bottomGraded} />}
    </>
  )}
  <Disclaimer />
</BaseLayout>
