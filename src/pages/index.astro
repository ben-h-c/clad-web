---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import CategorySection from "~/components/CategorySection.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import { SECTIONS } from "~/lib/sections";

export const prerender = true;

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const featured = all.filter((p) => p.data.featured).slice(0, 12);
// If nothing is flagged featured, fall back to the most recent so the strip
// is never empty.
const heroPosts = featured.length > 0 ? featured : all.slice(0, 8);

const bySection = SECTIONS.map((section) => ({
  section,
  posts: all.filter((p) => p.data.section === section),
})).filter((g) => g.posts.length > 0);
---
<BaseLayout title="Clad — Fact-Checked News Reports">
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      <HeroStrip posts={heroPosts} />
      {bySection.map((g) => (
        <CategorySection section={g.section} posts={g.posts} />
      ))}
    </>
  )}
  <Disclaimer />
</BaseLayout>
