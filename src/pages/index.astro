---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import ReportCard from "~/components/ReportCard.astro";
import Disclaimer from "~/components/Disclaimer.astro";

export const prerender = true;

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const featured = all.filter((p) => p.data.featured).slice(0, 12);
// If nothing is flagged featured, fall back to the most recent so the strip
// is never empty.
const heroPosts = featured.length > 0 ? featured : all.slice(0, 8);
---
<BaseLayout
  title="Clad — Political Fact-Checks & Media Bias"
  description="Fact-checked political broadcasts, graded for accuracy and called out for bias, edited like a 1920s broadsheet."
>
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      <HeroStrip posts={heroPosts} />
      <section class="feed">
        <div class="feed__head">
          <h2 class="feed__title">All Reports</h2>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <div class="feed-list">
          {all.map((p) => <ReportCard post={p} variant="bar" />)}
        </div>
      </section>
    </>
  )}
  <Disclaimer />
</BaseLayout>
