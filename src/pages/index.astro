---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import BreakingStrip from "~/components/BreakingStrip.astro";
import TopicRow from "~/components/TopicRow.astro";
import GradeBoard from "~/components/GradeBoard.astro";
import HomeCharts from "~/components/HomeCharts.astro";
import PaywallPanel from "~/components/PaywallPanel.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import NewsletterSignup from "~/components/NewsletterSignup.astro";
import ReportCard from "~/components/ReportCard.astro";
import { getFrontpage, getBreaking, getSentiments } from "~/lib/agents";
import { aggregateTopics, gradeToGpa, gpaToGrade } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { APP_STORE_URL, APP_STORE_LIVE } from "~/lib/app-store";

// SSR so the hero reflects the curator's live KV-stored selection without a
// rebuild. Per-user (grades hidden for restricted readers), so never shared-cache.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const byId = new Map(all.map((p) => [p.id, p]));

// Hero = Front Page Curator selection. Fall back to featured, then most-recent.
let curated = await getFrontpage(env.AGENTS);
let heroPosts = curated.map((id) => byId.get(id)).filter((p) => p !== undefined);
if (heroPosts.length === 0) {
  const flagged = all.filter((p) => p.data.featured);
  heroPosts = flagged.length > 0 ? flagged : all.slice(0, 8);
}
// Home is a newspaper front page — not an infinite archive. Cap hard.
heroPosts = heroPosts.slice(0, 12);

// Breaking = impact-ordered; cap for mobile length.
const breakingItems = await getBreaking(env.AGENTS);
let breaking = breakingItems
  .map((it) => {
    if (it.type === "post") {
      const p = byId.get(it.id);
      return p && isNewsOutlet(p.data.sourceTitle) ? { kind: "post" as const, post: p } : null;
    }
    const members = it.ids
      .map((id) => byId.get(id))
      .filter((p): p is NonNullable<typeof p> => p !== undefined && isNewsOutlet(p.data.sourceTitle));
    if (members.length >= 2) return { kind: "group" as const, slug: it.slug, title: it.title, topic: it.topic, members };
    if (members.length === 1) return { kind: "post" as const, post: members[0] };
    return null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .slice(0, 10);

const locked = !access.fullAccess;
const sampleId = locked ? sampleUnlockedId(all) : null;
// Free-card is the sole unlocked scoreband for guests — keep it out of strips.
if (sampleId) {
  heroPosts = heroPosts.filter((p) => p.id !== sampleId);
  breaking = breaking
    .map((it) => {
      if (it.kind === "post") return it.post.id === sampleId ? null : it;
      const members = it.members.filter((p) => p.id !== sampleId);
      if (members.length >= 2) return { ...it, members };
      if (members.length === 1) return { kind: "post" as const, post: members[0] };
      return null;
    })
    .filter((x): x is NonNullable<typeof x> => x !== null);
}

const sentiments = locked ? {} : await getSentiments(env.AGENTS);
const topics = aggregateTopics(all, sentiments);
const TOPICS_ON_HOME = 8;

// Best & worst — compact (3 each) for signed-in desk board.
const graded = all.filter((p) => gradeToGpa(p.data.letterGrade) != null);
const byGradeDesc = [...graded].sort(
  (a, b) =>
    gradeToGpa(b.data.letterGrade)! - gradeToGpa(a.data.letterGrade)! ||
    b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const topGraded = byGradeDesc.slice(0, 3);
const topIds = new Set(topGraded.map((p) => p.id));
const bottomGraded = [...graded]
  .filter((p) => !topIds.has(p.id))
  .sort(
    (a, b) =>
      gradeToGpa(a.data.letterGrade)! - gradeToGpa(b.data.letterGrade)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  )
  .slice(0, 3);

// Public pulse stats (no gated grades in labels for guests).
const broadcastCount = all.filter((p) => p.data.type === "broadcast").length;
const outletSet = new Set(
  all.map((p) => p.data.sourceTitle).filter((n): n is string => Boolean(n) && isNewsOutlet(n))
);
const weekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
const weekCount = all.filter((p) => p.data.publishedAt.valueOf() >= weekAgo).length;

// Signed-in: one-line desk average (safe — only rendered when unlocked).
const weekGpas = all
  .filter((p) => p.data.publishedAt.valueOf() >= weekAgo)
  .map((p) => gradeToGpa(p.data.letterGrade))
  .filter((n): n is number => n != null);
const weekAvgGpa =
  weekGpas.length > 0 ? weekGpas.reduce((a, b) => a + b, 0) / weekGpas.length : null;
const weekAvgLetter = !locked && weekAvgGpa != null ? gpaToGrade(weekAvgGpa) : null;
---
<BaseLayout
  title="Clad — Grading Content & Exposing Bias"
  description="Fact-checked political broadcasts, graded for accuracy and called out for bias, edited like a 1920s broadsheet."
  tour
>
  <h1 class="visually-hidden">Clad — fact-checked news, graded for accuracy and bias</h1>
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      {APP_STORE_LIVE && (
        <>
          <aside class="app-promo" id="app-promo" data-app-hide hidden>
            <p class="app-promo__msg">
              <span class="app-promo__kicker">Now on iOS</span>
              Every grade and alert in your pocket.
            </p>
            <a class="app-promo__cta" href={APP_STORE_URL} target="_blank" rel="noopener">Get the app →</a>
            <button type="button" class="app-promo__close" id="app-promo-close" aria-label="Dismiss app promotion">×</button>
          </aside>
          <script is:inline>
            (() => {
              const el = document.getElementById("app-promo");
              if (!el) return;
              const KEY = "clad_app_promo_dismissed";
              let dismissed = false;
              try { dismissed = !!localStorage.getItem(KEY); } catch {}
              if (!dismissed) el.hidden = false;
              const close = document.getElementById("app-promo-close");
              if (close) close.addEventListener("click", () => {
                el.hidden = true;
                try { localStorage.setItem(KEY, "1"); } catch {}
              });
            })();
          </script>
        </>
      )}

      {/* Value prop first — not a wall of carousels. */}
      <section class="home-lede" aria-label="What Clad is">
        <p class="home-lede__kicker small-caps">Independent fact-check desk</p>
        <p class="home-lede__line">
          We grade TV news for <strong>accuracy</strong> and <strong>bias</strong> —
          letter grade, lean score, claim tags, sources you can open.
        </p>
        <ul class="home-pulse" aria-label="Desk at a glance">
          <li><strong>{broadcastCount.toLocaleString()}</strong><span>graded reports</span></li>
          <li><strong>{weekCount}</strong><span>this week</span></li>
          <li><strong>{outletSet.size}</strong><span>outlets watched</span></li>
          {weekAvgLetter && (
            <li><strong>{weekAvgLetter}</strong><span>avg this week</span></li>
          )}
        </ul>
        {locked ? (
          <p class="home-lede__cta-row">
            <a class="home-lede__cta" href="/register/">Unlock every grade — free</a>
            <a class="home-lede__ghost" href="/learn/grades/">What do grades mean?</a>
          </p>
        ) : (
          <p class="home-lede__cta-row">
            <a class="home-lede__ghost" href="/quiz/">Morning quiz</a>
            <a class="home-lede__ghost" href="/elections/map/">Midterms map</a>
            <a class="home-lede__ghost" href="/trends/">News trends</a>
          </p>
        )}
      </section>

      {/* Guest aha: one real grade before the feed noise. */}
      {locked && sampleId && byId.has(sampleId) && (
        <section class="free-card" aria-labelledby="free-card-title">
          <div class="feed__head">
            <h2 class="feed__title" id="free-card-title">Start here — today&rsquo;s free grade</h2>
            <span class="free-card__note">One full report card, free every day. An account unlocks the rest.</span>
          </div>
          <div class="rule rule--double" aria-hidden="true"></div>
          <ReportCard post={byId.get(sampleId)!} sample />
        </section>
      )}

      <BreakingStrip items={breaking} locked={locked} />

      <HeroStrip
        posts={heroPosts}
        title="Front Page"
        locked={locked}
        moreHref="/recent/"
        moreLabel="Latest →"
      />

      {/* Product discovery without another carousel of cards. */}
      <nav class="desk-rails" aria-label="Explore Clad">
        <a class="desk-rails__card" href="/elections/map/">
          <span class="desk-rails__kicker small-caps">Midterms 2026</span>
          <span class="desk-rails__title">Election map</span>
          <span class="desk-rails__blurb">Class II Senate, governors, coverage heat — not polls.</span>
        </a>
        <a class="desk-rails__card" href="/bracket/">
          <span class="desk-rails__kicker small-caps">Midterms 2026</span>
          <span class="desk-rails__title">Race board</span>
          <span class="desk-rails__blurb">Who&rsquo;s on the ballot, with coverage grades.</span>
        </a>
        <a class="desk-rails__card" href="/quiz/">
          <span class="desk-rails__kicker small-caps">Daily</span>
          <span class="desk-rails__title">Morning quiz</span>
          <span class="desk-rails__blurb">Five real claims. Spot the spin in two minutes.</span>
        </a>
        <a class="desk-rails__card" href="/students/">
          <span class="desk-rails__kicker small-caps">Campus</span>
          <span class="desk-rails__title">For students</span>
          <span class="desk-rails__blurb">Grades, explainers, share kit — free account.</span>
        </a>
      </nav>

      <section class="feed">
        <div class="feed__head">
          <h2 class="feed__title">Topics</h2>
          <a class="category__more" href="/search/">Search all →</a>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="topic-rows">
          {topics.slice(0, TOPICS_ON_HOME).map((t) => (
            <li class="topic-row-item">
              <TopicRow topic={t} locked={locked} />
            </li>
          ))}
        </ul>
        {topics.length > TOPICS_ON_HOME && (
          <p class="feed__foot">
            <a href="/search/">Browse {topics.length} topics in search →</a>
          </p>
        )}
      </section>

      {locked ? (
        <PaywallPanel signedIn={access.signedIn} />
      ) : (
        <>
          <HomeCharts posts={all} topics={topics} sentiments={sentiments} />
          {topGraded.length > 0 && <GradeBoard top={topGraded} bottom={bottomGraded} />}
          <p class="home-more-analytics">
            Lean extremes and week-over-week quality live on{" "}
            <a href="/trends/">News Trends</a>
            {" · "}
            <a href="/bias/">Check your bias</a>.
          </p>
        </>
      )}

      <section class="more-clad" aria-labelledby="more-clad-title">
        <div class="feed__head">
          <h2 class="feed__title" id="more-clad-title">More from Clad</h2>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="more-clad__list">
          <li><a href="/week/"><strong>Week in Grades</strong></a> — best, worst, and blind spots</li>
          <li><a href="/trends/"><strong>News Trends</strong></a> — quality and lean over time</li>
          <li><a href="/politicians/"><strong>Politician cards</strong></a> — coverage report cards for the trail</li>
          <li><a href="/learn/"><strong>New to the news?</strong></a> — six short explainers</li>
          <li><a href="/how-it-works/"><strong>How Clad works</strong></a> — full methodology</li>
        </ul>
      </section>
    </>
  )}
  <NewsletterSignup />
  <Disclaimer />
</BaseLayout>
