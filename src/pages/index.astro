---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import BreakingStrip from "~/components/BreakingStrip.astro";
import TopicRow from "~/components/TopicRow.astro";
import GradeBoard from "~/components/GradeBoard.astro";
import HomeCharts from "~/components/HomeCharts.astro";
import PaywallPanel from "~/components/PaywallPanel.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import NewsletterSignup from "~/components/NewsletterSignup.astro";
import HomePromoBanner from "~/components/HomePromoBanner.astro";
import { getFrontpage, getBreaking, getSentiments } from "~/lib/agents";
import { aggregateTopics, gradeToGpa } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";
import { getAccess } from "~/lib/access";
import { APP_STORE_URL, APP_STORE_LIVE } from "~/lib/app-store";

// SSR so the hero reflects the curator's live KV-stored selection without a
// rebuild. Per-user (grades hidden for restricted readers), so never shared-cache.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);

const all = (await getCollection("posts", (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const byId = new Map(all.map((p) => [p.id, p]));

// Hero = Front Page Curator selection. Fall back to featured, then most-recent.
let curated = await getFrontpage(env.AGENTS);
let heroPosts = curated.map((id) => byId.get(id)).filter((p) => p !== undefined);
if (heroPosts.length === 0) {
  const flagged = all.filter((p) => p.data.featured);
  heroPosts = flagged.length > 0 ? flagged : all.slice(0, 8);
}
// Home is a newspaper front page — not an infinite archive. Cap hard.
heroPosts = heroPosts.slice(0, 12);

// Breaking = impact-ordered; cap for mobile length.
const breakingItems = await getBreaking(env.AGENTS);
let breaking = breakingItems
  .map((it) => {
    if (it.type === "post") {
      const p = byId.get(it.id);
      return p && isNewsOutlet(p.data.sourceTitle) ? { kind: "post" as const, post: p } : null;
    }
    const members = it.ids
      .map((id) => byId.get(id))
      .filter((p): p is NonNullable<typeof p> => p !== undefined && isNewsOutlet(p.data.sourceTitle));
    if (members.length >= 2) return { kind: "group" as const, slug: it.slug, title: it.title, topic: it.topic, members };
    if (members.length === 1) return { kind: "post" as const, post: members[0] };
    return null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .slice(0, 10);

const locked = !access.fullAccess;

const sentiments = locked ? {} : await getSentiments(env.AGENTS);
const topics = aggregateTopics(all, sentiments);
const TOPICS_ON_HOME = 8;

// Best & worst — compact (3 each) for the signed-in desk board (GradeBoard).
// Only full-access readers see it, so skip the two full sorts over the graded
// corpus for locked readers — the highest-traffic case that fills the edge cache.
let topGraded: typeof all = [];
let bottomGraded: typeof all = [];
if (!locked) {
  const graded = all.filter((p) => gradeToGpa(p.data.letterGrade) != null);
  const byGradeDesc = [...graded].sort(
    (a, b) =>
      gradeToGpa(b.data.letterGrade)! - gradeToGpa(a.data.letterGrade)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );
  topGraded = byGradeDesc.slice(0, 3);
  const topIds = new Set(topGraded.map((p) => p.id));
  bottomGraded = [...graded]
    .filter((p) => !topIds.has(p.id))
    .sort(
      (a, b) =>
        gradeToGpa(a.data.letterGrade)! - gradeToGpa(b.data.letterGrade)! ||
        b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
    )
    .slice(0, 3);
}
---
<BaseLayout
  title="Clad — Grading Content & Exposing Bias"
  description="Fact-checked political broadcasts, graded for accuracy and called out for bias, edited like a 1920s broadsheet."
  tour
>
  <h1 class="visually-hidden">Clad — fact-checked news, graded for accuracy and bias</h1>
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      {/* Configurable spotlight(s) — midterms, campus, hot nights, etc. */}
      <HomePromoBanner />

      {APP_STORE_LIVE && (
        <>
          <aside class="app-promo" id="app-promo" data-app-hide hidden>
            <p class="app-promo__msg">
              <span class="app-promo__kicker">Now on iOS</span>
              Every grade and alert in your pocket.
            </p>
            <a class="app-promo__cta" href={APP_STORE_URL} target="_blank" rel="noopener">Get the app →</a>
            <button type="button" class="app-promo__close" id="app-promo-close" aria-label="Dismiss app promotion">×</button>
          </aside>
          <script is:inline>
            (() => {
              const el = document.getElementById("app-promo");
              if (!el) return;
              const KEY = "clad_app_promo_dismissed";
              let dismissed = false;
              try { dismissed = !!localStorage.getItem(KEY); } catch {}
              if (!dismissed) el.hidden = false;
              const close = document.getElementById("app-promo-close");
              if (close) close.addEventListener("click", () => {
                el.hidden = true;
                try { localStorage.setItem(KEY, "1"); } catch {}
              });
            })();
          </script>
        </>
      )}

      <BreakingStrip items={breaking} locked={locked} />

      <HeroStrip
        posts={heroPosts}
        title="Front Page"
        locked={locked}
        moreHref="/recent/"
        moreLabel="Latest →"
      />

      <nav class="home-rails" aria-label="Explore Clad">
        <a class="home-rails__card" href="/bracket/">
          <span class="home-rails__kicker small-caps">Midterms</span>
          <span class="home-rails__title">Ballot board</span>
          <span class="home-rails__blurb">Pick winners, share your sheet, track accuracy all season.</span>
        </a>
        <a class="home-rails__card" href="/elections/map/">
          <span class="home-rails__kicker small-caps">Midterms</span>
          <span class="home-rails__title">Election map</span>
          <span class="home-rails__blurb">Who&rsquo;s up in 2026 — and where coverage is loudest.</span>
        </a>
        <a class="home-rails__card" href="/quiz/">
          <span class="home-rails__kicker small-caps">Play</span>
          <span class="home-rails__title">Morning quiz</span>
          <span class="home-rails__blurb">Five real claims. Can you spot the spin?</span>
        </a>
        <a class="home-rails__card" href="/discover/">
          <span class="home-rails__kicker small-caps">Read</span>
          <span class="home-rails__title">Discover</span>
          <span class="home-rails__blurb">Curated stories worth your time.</span>
        </a>
        <a class="home-rails__card" href="/bias/">
          <span class="home-rails__kicker small-caps">You</span>
          <span class="home-rails__title">Check your bias</span>
          <span class="home-rails__blurb">See how the coverage you open leans.</span>
        </a>
        <a class="home-rails__card" href="/politicians/">
          <span class="home-rails__kicker small-caps">People</span>
          <span class="home-rails__title">Politicians</span>
          <span class="home-rails__blurb">Report cards for the trail — grades, not polls.</span>
        </a>
      </nav>

      <section class="feed">
        <div class="feed__head">
          <h2 class="feed__title">Topics</h2>
          <a class="category__more" href="/search/">Hot today · search all →</a>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="topic-rows">
          {topics.slice(0, TOPICS_ON_HOME).map((t) => (
            <li class="topic-row-item">
              <TopicRow topic={t} locked={locked} />
            </li>
          ))}
        </ul>
        {topics.length > TOPICS_ON_HOME && (
          <p class="feed__foot">
            <a href="/search/">Browse {topics.length} topics in search →</a>
          </p>
        )}
      </section>

      {locked ? (
        <PaywallPanel signedIn={access.signedIn} returnTo="/" />
      ) : (
        <>
          <HomeCharts posts={all} topics={topics} sentiments={sentiments} />
          {topGraded.length > 0 && <GradeBoard top={topGraded} bottom={bottomGraded} />}
          <p class="home-more-analytics">
            Want the long view?{" "}
            <a href="/trends/">News Trends</a>
            {" · "}
            <a href="/bias/">Check your bias</a>
            {" · "}
            <a href="/week/">Week in Grades</a>
            {" · "}
            <a href="/good-news/">Good News</a>.
          </p>
        </>
      )}

      <section class="more-clad" aria-labelledby="more-clad-title">
        <div class="feed__head">
          <h2 class="feed__title" id="more-clad-title">Keep reading</h2>
        </div>
        <div class="rule rule--double" aria-hidden="true"></div>
        <ul class="more-clad__list">
          <li><a href="/week/"><strong>Week in Grades</strong></a> — best, worst, and what got ignored</li>
          <li><a href="/trends/"><strong>News Trends</strong></a> — is coverage getting better or worse?</li>
          <li><a href="/good-news/"><strong>Good News</strong></a> — solid reporting, lighter load</li>
          <li><a href="/students/"><strong>For students</strong></a> — how to read grades and share them</li>
          <li><a href="/learn/"><strong>New to the news?</strong></a> — short explainers, no jargon</li>
          <li><a href="/how-it-works/"><strong>How Clad works</strong></a> — the method, start to finish</li>
          <li><a href="/newsletter/"><strong>Newsletter</strong></a> — Sunday desk in your inbox</li>
        </ul>
      </section>
    </>
  )}
  <NewsletterSignup />
  <Disclaimer />
</BaseLayout>
