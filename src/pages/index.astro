---
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import HeroStrip from "~/components/HeroStrip.astro";
import BreakingStrip from "~/components/BreakingStrip.astro";
import TopicRow from "~/components/TopicRow.astro";
import GradeBoard from "~/components/GradeBoard.astro";
import CoverageLeanBar from "~/components/CoverageLeanBar.astro";
import HomeElectionMap from "~/components/HomeElectionMap.astro";
import PaywallPanel from "~/components/PaywallPanel.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import NewsletterSignup from "~/components/NewsletterSignup.astro";
import HomeSpotlightCarousel from "~/components/HomeSpotlightCarousel.astro";
import GuestHero from "~/components/GuestHero.astro";
import HomeFeatureHighlight from "~/components/HomeFeatureHighlight.astro";
import HomeCalendar from "~/components/HomeCalendar.astro";
import TodayInHistory from "~/components/TodayInHistory.astro";
import HumanSpotlight from "~/components/HumanSpotlight.astro";
import QuipTicker from "~/components/QuipTicker.astro";
import {
  getFrontpage,
  getBreaking,
  getSentiments,
  getTodayInHistory,
  getHumanSpotlight,
  getHomeLayout,
  getDiscover,
  getGoodNews,
  getCalendarEventsStore,
  getQuips,
  getPoliticianPhotoMap,
} from "~/lib/agents";
import { buildGoodNewsSections } from "~/lib/goodnews";
import { aggregateTopics, aggregateTopicsCached, gradeToGpa } from "~/lib/topics";
import { isNewsOutlet } from "~/lib/networks";
import { getAccess } from "~/lib/access";
import { APP_STORE_URL, APP_STORE_LIVE } from "~/lib/app-store";
import { homePromosForPage } from "~/lib/homePromos";
import { resolveHomeHighlight, resolveHomeOrder } from "~/lib/homeLayout";
import { buildHomeFeatureItems } from "~/lib/homeFeatures";
import { buildPoliticianSpotlightItems } from "~/lib/homePoliticians";
import { buildPoliticianIndexLive } from "~/lib/politicians";
import { DEFAULT_ELECTION_ID, getElectionWithPublishedDates } from "~/lib/elections";
import {
  normalizeCalendarEvent,
  buildCalendarEvents,
  type CalendarEvent,
} from "~/lib/calendarEvents";
import { buildDaySummariesCached } from "~/lib/calendarDays";
import { publishedPostsSorted } from "~/lib/publishedPosts";

// SSR so the hero reflects the curator's live KV-stored selection without a
// rebuild. Per-user (grades hidden for restricted readers), so never shared-cache.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const all = [...(await publishedPostsSorted())];
const byId = new Map(all.map((p) => [p.id, p]));

// Independent KV reads in one wave (C2). Sentiments only for full-access.
const [
  curated,
  breakingItems,
  sentiments,
  election,
  calStore,
  todayInHistory,
  humanSpotlight,
  homeLayout,
  photoMapStore,
  discoverStore,
  goodNewsStore,
  quipsStore,
] = await Promise.all([
  getFrontpage(env.AGENTS),
  getBreaking(env.AGENTS),
  locked ? Promise.resolve({}) : getSentiments(env.AGENTS),
  getElectionWithPublishedDates(DEFAULT_ELECTION_ID, env.AGENTS),
  getCalendarEventsStore(env.AGENTS),
  getTodayInHistory(env.AGENTS),
  getHumanSpotlight(env.AGENTS),
  getHomeLayout(env.AGENTS),
  getPoliticianPhotoMap(env.AGENTS),
  getDiscover(env.AGENTS),
  getGoodNews(env.AGENTS),
  getQuips(env.AGENTS),
]);

// Hero = Front Page Curator selection. Fall back to featured, then most-recent.
let heroPosts = curated.map((id) => byId.get(id)).filter((p) => p !== undefined);
if (heroPosts.length === 0) {
  const flagged = all.filter((p) => p.data.featured);
  heroPosts = flagged.length > 0 ? flagged : all.slice(0, 8);
}
// Home is a curated front page — not an infinite archive. Cap hard.
heroPosts = heroPosts.slice(0, 12);

// Breaking = impact-ordered; cap for mobile length.
let breaking = breakingItems
  .map((it) => {
    if (it.type === "post") {
      const p = byId.get(it.id);
      return p && isNewsOutlet(p.data.sourceTitle) ? { kind: "post" as const, post: p } : null;
    }
    const members = it.ids
      .map((id) => byId.get(id))
      .filter((p): p is NonNullable<typeof p> => p !== undefined && isNewsOutlet(p.data.sourceTitle));
    if (members.length >= 2) return { kind: "group" as const, slug: it.slug, title: it.title, topic: it.topic, members };
    if (members.length === 1) return { kind: "post" as const, post: members[0] };
    return null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null)
  .slice(0, 10);

// Full-access: live recency + sentiment clustering. Locked: memoized (no sentiments).
const topics = locked
  ? aggregateTopicsCached(all as any)
  : aggregateTopics(all as any, sentiments);
const TOPICS_ON_HOME = 8;

// Live promo inputs: hottest topic + freshest report for top-of-home cards
const hotTopic =
  topics.find((t) => t.todayCount >= 2) ??
  topics.find((t) => t.recentCount >= 4) ??
  null;
const newest = all[0];
const hotPost = newest
  ? {
      id: newest.id,
      headline: newest.data.headline,
      ageHours: (Date.now() - newest.data.publishedAt.valueOf()) / 3_600_000,
    }
  : null;

// Fixed top spotlight carousel: midterms + hot topic/report + popular sections.
// Prefer midterms first when present, then priority order for the rest.
const rawSpotlight = homePromosForPage({
  locked,
  hotTopic: hotTopic
    ? {
        display: hotTopic.display,
        slug: hotTopic.slug,
        todayCount: hotTopic.todayCount,
        recentCount: hotTopic.recentCount,
      }
    : null,
  hotPost,
  max: 8,
});
const midtermsPromo = rawSpotlight.find((p) => p.id === "midterms-2026-ballot");
const spotlightPromos = midtermsPromo
  ? [midtermsPromo, ...rawSpotlight.filter((p) => p.id !== midtermsPromo.id)]
  : rawSpotlight;

// Best & worst — compact (3 each) for the signed-in desk board (GradeBoard).
// Only reports published in the last 7 days so the board stays current.
// Full-access only; skip the sorts for locked readers (highest-traffic case).
let topGraded: typeof all = [];
let bottomGraded: typeof all = [];
if (!locked) {
  const weekAgo = Date.now() - 7 * 86_400_000;
  const graded = all.filter(
    (p) =>
      gradeToGpa(p.data.letterGrade) != null &&
      p.data.publishedAt.valueOf() >= weekAgo
  );
  const byGradeDesc = [...graded].sort(
    (a, b) =>
      gradeToGpa(b.data.letterGrade)! - gradeToGpa(a.data.letterGrade)! ||
      b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );
  topGraded = byGradeDesc.slice(0, 3);
  const topIds = new Set(topGraded.map((p) => p.id));
  bottomGraded = [...graded]
    .filter((p) => !topIds.has(p.id))
    .sort(
      (a, b) =>
        gradeToGpa(a.data.letterGrade)! - gradeToGpa(b.data.letterGrade)! ||
        b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
    )
    .slice(0, 3);
}

// Home calendar: race dates + agent news feed + recent Clad reports on publish days.
const calendarRaces = election?.races;
const calendarLive: CalendarEvent[] = (calStore?.events ?? [])
  .map((e) => normalizeCalendarEvent(e, "agent"))
  .filter((e): e is CalendarEvent => e != null);
// Cap day payload: fewer peeks + ~3 months so the home HTML stays lean.
const calendarDays = buildDaySummariesCached(all as any, {
  locked,
  topPerDay: 2,
  maxDays: 92,
});
// Dynamic landing plan (home-layout-curator agent — Grok + web_search).
const homeOrder = resolveHomeOrder(homeLayout);
const homeHighlight = resolveHomeHighlight(homeLayout, {
  signedIn: access.signedIn,
});
// “Today” media strip: desk highlight + daybook + fresh graded reports.
const featureCalendar = buildCalendarEvents({
  races: calendarRaces ?? undefined,
  live: calendarLive,
});
const featureItems = buildHomeFeatureItems({
  highlight: homeHighlight,
  calendarEvents: featureCalendar,
  posts: all,
  max: 10,
});

// Politician media strip — people in recent coverage + midterms race sides.
const politiciansLive = await buildPoliticianIndexLive(all as any, env.AGENTS);
const photoMap = photoMapStore?.bySlug ?? {};
const politicianSpotlightItems = buildPoliticianSpotlightItems({
  politicians: politiciansLive,
  photoBySlug: photoMap,
  races: calendarRaces ?? undefined,
  postsById: byId,
  locked,
  max: 10,
});

// Discover + Good News — same horizontal strip format as Breaking / Front Page.
// Flatten curated section post ids (order preserved, de-duped). Cap for mobile.
// `exclude` skips ids already shown in another home strip (e.g. Discover vs Good News).
function postsFromSections(
  sections: { ids: string[] }[],
  map: typeof byId,
  max = 12,
  exclude?: Set<string>
): typeof all {
  const seen = new Set<string>(exclude ?? []);
  const out: typeof all = [];
  for (const s of sections) {
    for (const id of s.ids || []) {
      if (seen.has(id)) continue;
      const p = map.get(id);
      if (!p) continue;
      seen.add(id);
      out.push(p);
      if (out.length >= max) return out;
    }
  }
  return out;
}
const discoverSections = discoverStore ?? [];
const goodNewsCurated = goodNewsStore ?? [];
const goodNewsSections =
  goodNewsCurated.length > 0 ? goodNewsCurated : buildGoodNewsSections(all);
const discoverPosts = postsFromSections(discoverSections, byId, 12);
// Good News never repeats a card already in Discover (common curator overlap).
const goodNewsPosts = postsFromSections(
  goodNewsSections,
  byId,
  12,
  new Set(discoverPosts.map((p) => p.id))
);
// Decorative marquee — loads after the main story rows so crawlers hit real content first.
const quips = quipsStore ?? [];
---
<BaseLayout
  title="CladFacts — Grading Content & Exposing Bias"
  description={`${all.length.toLocaleString("en-US")} political broadcasts fact-checked claim by claim — graded for accuracy and political lean.`}
>
  <h1 class="visually-hidden">Clad — fact-checked news, graded for accuracy and bias</h1>
  {all.length === 0 ? (
    <p class="dateline" style="margin-top:2rem">No reports published yet.</p>
  ) : (
    <>
      {/*
        Section order is dynamic when home-layout-curator has a fresh plan
        (Grok + web_search). Missing/expired plan → DEFAULT_HOME_ORDER.
      */}
      {homeOrder.map((section) => (
        <>
          {section === "guest-hero" && !access.signedIn && (
            <GuestHero
              posts={
                heroPosts.some((p) => p.data.letterGrade)
                  ? heroPosts
                  : all.filter((p) => p.data.letterGrade).slice(0, 8)
              }
              reportCount={all.length}
              class="guest-hero--home"
            />
          )}

          {section === "feature-highlight" && featureItems.length > 0 && (
            <HomeFeatureHighlight items={featureItems} title="Today" />
          )}

          {section === "spotlight" && spotlightPromos.length > 0 && (
            <HomeSpotlightCarousel promos={spotlightPromos} class="home-spotlight--top" />
          )}

          {section === "app-promo" && APP_STORE_LIVE && (
            <>
              <aside class="app-promo" id="app-promo" data-app-hide hidden>
                <p class="app-promo__msg">
                  <span class="app-promo__kicker">Now on iOS</span>
                  Every grade and alert in your pocket.
                </p>
                <a class="app-promo__cta" href={APP_STORE_URL} target="_blank" rel="noopener">Get the app →</a>
                <button type="button" class="app-promo__close" id="app-promo-close" aria-label="Dismiss app promotion">×</button>
              </aside>
              <script is:inline>
                (() => {
                  const el = document.getElementById("app-promo");
                  if (!el) return;
                  const KEY = "clad_app_promo_dismissed";
                  let dismissed = false;
                  try { dismissed = !!localStorage.getItem(KEY); } catch {}
                  if (!dismissed) el.hidden = false;
                  const close = document.getElementById("app-promo-close");
                  if (close) close.addEventListener("click", () => {
                    el.hidden = true;
                    try { localStorage.setItem(KEY, "1"); } catch {}
                  });
                })();
              </script>
            </>
          )}

          {section === "breaking" && (
            <BreakingStrip items={breaking} locked={locked} />
          )}

          {section === "front-page" && (
            <HeroStrip
              posts={heroPosts}
              title="Front Page"
              locked={locked}
              moreHref="/recent/"
              moreLabel="Latest →"
            />
          )}

          {section === "lean" && !locked && (
            <CoverageLeanBar posts={all} class="home-lean" />
          )}

          {section === "calendar" && (
            <HomeCalendar
              races={calendarRaces}
              live={calendarLive}
              days={calendarDays.days}
              first={calendarDays.first}
              last={calendarDays.last}
              locked={locked}
            />
          )}

          {section === "topics" && (
            <section class="feed">
              <div class="feed__head">
                <h2 class="feed__title">Topics</h2>
                <a class="category__more" href="/search/">Hot today · search all →</a>
              </div>
              <div class="rule rule--double" aria-hidden="true"></div>
              <ul class="topic-rows">
                {topics.slice(0, TOPICS_ON_HOME).map((t) => (
                  <li class="topic-row-item">
                    <TopicRow topic={t} locked={locked} />
                  </li>
                ))}
              </ul>
              {topics.length > TOPICS_ON_HOME && (
                <p class="feed__foot">
                  <a href="/search/">Browse {topics.length} topics in search →</a>
                </p>
              )}
            </section>
          )}

          {section === "politician-spotlight" && politicianSpotlightItems.length > 0 && (
            <HomeFeatureHighlight
              items={politicianSpotlightItems}
              title="People in the news"
              moreHref="/politicians/"
              moreLabel="All politicians →"
              stripId="home-politicians"
              class="home-features--politicians"
            />
          )}

          {section === "election-map" && (
            <HomeElectionMap races={calendarRaces} posts={all} />
          )}

          {section === "grades" && (
            locked ? (
              <PaywallPanel signedIn={access.signedIn} returnTo="/" />
            ) : (
              topGraded.length > 0 && (
                <GradeBoard
                  top={topGraded}
                  bottom={bottomGraded}
                  title="Best & Worst Graded · Last 7 Days"
                />
              )
            )
          )}

          {section === "today-history" && !locked && (
            <TodayInHistory payload={todayInHistory} />
          )}

          {section === "human-spotlight" && (
            <>
              <HumanSpotlight payload={humanSpotlight} />
              {!locked && (
                <p class="home-more-analytics">
                  Want the long view?{" "}
                  <a href="/trends/">News Trends</a>
                  {" · "}
                  <a href="/bias/">Check your bias</a>
                  {" · "}
                  <a href="/week/">Week in Grades</a>
                  {" · "}
                  <a href="/good-news/">Good News</a>.
                </p>
              )}
            </>
          )}

          {section === "discover" && (
            <HeroStrip
              posts={discoverPosts}
              title="Discover"
              locked={locked}
              moreHref="/discover/"
              moreLabel="All collections →"
            />
          )}

          {section === "good-news" && (
            <HeroStrip
              posts={goodNewsPosts}
              title="Good News"
              locked={locked}
              moreHref="/good-news/"
              moreLabel="All good news →"
            />
          )}

          {section === "quips" && <QuipTicker data={quips} />}

          {section === "more" && (
            <section class="more-clad" aria-labelledby="more-clad-title">
              <div class="feed__head">
                <h2 class="feed__title" id="more-clad-title">Keep reading</h2>
              </div>
              <div class="rule rule--double" aria-hidden="true"></div>
              <ul class="more-clad__list">
                <li><a href="/week/"><strong>Week in Grades</strong></a> — best, worst, and what got ignored</li>
                <li><a href="/trends/"><strong>News Trends</strong></a> — is coverage getting better or worse?</li>
                <li><a href="/good-news/"><strong>Good News</strong></a> — solid reporting, lighter load</li>
                <li><a href="/students/"><strong>For students</strong></a> — how to read grades and share them</li>
                <li><a href="/learn/"><strong>New to the news?</strong></a> — short explainers, no jargon</li>
                <li><a href="/how-it-works/"><strong>How Clad works</strong></a> — the method, start to finish</li>
                <li><a href="/newsletter/"><strong>Newsletter</strong></a> — Sunday desk in your inbox</li>
              </ul>
            </section>
          )}
        </>
      ))}
    </>
  )}
  <NewsletterSignup />
  <Disclaimer />
</BaseLayout>
