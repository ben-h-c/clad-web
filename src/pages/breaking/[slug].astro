---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getBreaking } from "~/lib/agents";
import { gradeToGpa, gpaToGrade, leanScoreOf } from "~/lib/topics";
import { LEAN_THRESHOLD } from "~/lib/trends";
import { isNewsOutlet } from "~/lib/networks";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { displayableThumb } from "~/lib/imagePolicy";

// Ephemeral: a breaking-news group exists only while the story is active. SSR so
// it reflects the live KV selection; 404 once the group ages out of the feed.
export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

const access = await getAccess(Astro.request.headers);
const locked = !access.fullAccess;

const slug = Astro.params.slug;
const items = await getBreaking(env.AGENTS);
const group = items.find((it) => it.type === "group" && it.slug === slug);
if (!group || group.type !== "group") {
  return new Response("Not found", { status: 404 });
}

const all = await getCollection("posts", (p) => !p.data.draft);
const byId = new Map(all.map((p) => [p.id, p]));
const members = group.ids
  .map((id) => byId.get(id))
  .filter((p) => p !== undefined && isNewsOutlet(p!.data.sourceTitle))
  .sort((a, b) => b!.data.publishedAt.valueOf() - a!.data.publishedAt.valueOf());

if (members.length === 0) {
  return new Response("Not found", { status: 404 });
}

const gpas = members.map((p) => gradeToGpa(p!.data.letterGrade)).filter((n): n is number => n != null);
const leans = members.map((p) => leanScoreOf(p!.data)).filter((n): n is number => n != null);
const avgGrade = gpas.length ? gpaToGrade(gpas.reduce((a, b) => a + b, 0) / gpas.length) : null;
const avgLean = leans.length ? Math.round(leans.reduce((a, b) => a + b, 0) / leans.length) : null;

// Coverage balance: bucket member leans with the site-wide ±LEAN_THRESHOLD
// convention (account-gated, same policy as avgLean above).
const left = leans.filter((l) => l <= -LEAN_THRESHOLD).length;
const right = leans.filter((l) => l >= LEAN_THRESHOLD).length;
const center = leans.length - left - right;
const unknown = members.length - leans.length;

// Report of the Day — today's sample card renders unlocked for restricted readers.
const sampleId = locked ? sampleUnlockedId(all) : null;

const shareUrl = new URL(`/breaking/${slug}/`, Astro.site ?? "https://cladfacts.com").href;

// This is a topic hub, so it's titled by TOPIC — using the newest member's
// headline here mislabels the page and wastes its shot at "[topic] fact
// check" queries. group.title (latest headline) stays as on-page context.
const hubName = group.topic ?? group.title;
const pageTitle = `${hubName} — developing story — CladFacts`;
// Unfurl title stays short (platforms truncate ~60-70 chars); the report count
// lives in the description where it isn't competing with the topic name.
const ogTitle = `${hubName} — developing story`;

const heroThumb = displayableThumb(
  members.find((p) => p!.data.thumbnail)?.data.thumbnail
);
const heroClass = [
  "media-hero",
  "breaking-hero",
  heroThumb ? "media-hero--has-image" : "media-hero--plain",
].join(" ");
---
<BaseLayout
  title={pageTitle}
  ogTitle={ogTitle}
  description={`Developing story: ${members.length} fact-checked report${members.length === 1 ? "" : "s"} on ${hubName}, graded for accuracy and political lean.`}
  ogImage={`/og/breaking-${slug}.png`}
  ogType="website"
>
  <section class="breaking-story">
    {/* Full-bleed hero — image spans the viewport, not the reading column */}
    <header class={`${heroClass} breaking-hero--bleed`}>
      {heroThumb && (
        <div class="media-hero__bg" aria-hidden="true">
          <img
            src={heroThumb}
            alt=""
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>
      )}
      <div class="media-hero__scrim" aria-hidden="true"></div>
      <div class="media-hero__content breaking-hero__content">
        <p class="media-hero__kicker small-caps">
          {group.topic ? `${group.topic} · ` : ""}Developing story · {members.length} reports
        </p>
        <h1 class="media-hero__title breaking-hero__title">{group.title}</h1>

        {locked ? (
          <p class="breaking-hero__lock">
            Average grade &amp; lean unlock with a
            <a href="/register/">free account</a> — no card required.
          </p>
        ) : (
          <div class="breaking-hero__agg">
            {avgGrade && (
              <div class="scoreband scoreband--on-media breaking-hero__score">
                <div class="scoreband__grade">
                  <LetterGrade grade={avgGrade} size="card" />
                  <span class="scoreband__cap small-caps">Avg grade</span>
                </div>
                {avgLean !== null && (
                  <div class="scoreband__bias"><PoliticalLean score={avgLean} /></div>
                )}
              </div>
            )}
            {leans.length > 0 && (
              <div class="breaking-hero__balance">
                <div class="callout__split callout__split--on-media" aria-hidden="true">
                  <span class="split split--l" style={`flex:${left || 0.001}`}>{left || ""}</span>
                  <span class="split split--c" style={`flex:${center || 0.001}`}>{center || ""}</span>
                  <span class="split split--r" style={`flex:${right || 0.001}`}>{right || ""}</span>
                </div>
                <p class="callout__splitcap callout__splitcap--on-media">
                  Coverage: {left} left · {center} center · {right} right{unknown > 0 ? ` · ${unknown} unrated` : ""}
                </p>
              </div>
            )}
          </div>
        )}
      </div>
    </header>

    <div class="breaking-story__body topic-page">
      <p class="dateline breaking-story__lede">
        A temporary grouping of multiple outlets' coverage of the same breaking
        story. It dissolves back into the regular topics once the story settles.
      </p>

      <ShareBar
        url={shareUrl}
        title={`${group.title} — developing on CladFacts`}
        hook={`${members.length} outlets graded on the same developing story. Same facts, different tellings — see who held up.`}
      />

      <div class="rule rule--double" aria-hidden="true" style="margin:1.25rem 0"></div>

      <div class="feed-list">
        {members.map((p) => (
          <ReportCard post={p!} variant="bar" locked={locked && p!.id !== sampleId} sample={locked && p!.id === sampleId} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
