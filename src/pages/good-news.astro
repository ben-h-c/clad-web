---
import { getCollection } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ReportCard from "~/components/ReportCard.astro";
import { getGoodNews } from "~/lib/agents";
import { buildGoodNewsSections } from "~/lib/goodnews";
import { getAccess } from "~/lib/access";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "private, no-store");

// Good News is a Premium perk — restricted readers get the upgrade wall.
const access = await getAccess(Astro.request.headers);
if (!access.fullAccess) return Astro.redirect("/upgrade/");

const all = await getCollection("posts", (p) => !p.data.draft);
// Prefer the Grok-curated collections the runner writes to KV; if they're not
// there yet (curator hasn't run / runner is down), build a themed page from the
// published posts directly so /good-news is never empty.
const curated = await getGoodNews(env.AGENTS);
const sections = curated.length > 0 ? curated : buildGoodNewsSections(all);
const byId = new Map(all.map((p) => [p.id, p]));
const resolved = sections
  .map((s) => ({ ...s, posts: s.ids.map((id) => byId.get(id)).filter((p) => p !== undefined) }))
  .filter((s) => s.posts.length >= 2);
---
<BaseLayout
  title="Good News — Clad"
  description="The brighter side of the news — fact-checked positive, uplifting, and genuinely interesting coverage, grouped into fresh collections."
  noindex={true}
>
  <section class="discover">
    <header class="discover__head">
      <p class="small-caps discover__eyebrow">Premium</p>
      <h2 class="discover__title">Good News</h2>
      <p class="discover__lede">
        The brighter side of the desk — fact-checked stories that are positive,
        uplifting, or just genuinely interesting. Breakthroughs, comebacks,
        discoveries and human-interest wins, grouped into fresh collections.
        Refreshed regularly.
      </p>
    </header>

    {resolved.length === 0 ? (
      <p class="dateline" style="margin-top:2rem">
        New collections are being curated — check back shortly.
      </p>
    ) : (
      resolved.map((s) => (
        <section class="discover-sec">
          <h3 class="discover-sec__title">{s.title}</h3>
          {s.blurb && <p class="discover-sec__blurb">{s.blurb}</p>}
          <div class="rule rule--double" aria-hidden="true"></div>
          <div class="feed-list">
            {s.posts.map((p) => <ReportCard post={p!} variant="bar" />)}
          </div>
        </section>
      ))
    )}
  </section>
</BaseLayout>
