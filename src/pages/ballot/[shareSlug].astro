---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ShareBar from "~/components/ShareBar.astro";
import { getPublicSharedBallot, listResults } from "~/lib/picks";
import { getElection } from "~/lib/elections";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "public, max-age=60, s-maxage=60");

const shareSlug = String(Astro.params.shareSlug ?? "").trim();
// Only locked ballots are publicly shareable.
const ballot = shareSlug ? await getPublicSharedBallot(shareSlug) : null;
if (!ballot) {
  return Astro.redirect("/bracket/");
}
const election = getElection(ballot.electionId);
if (!election) {
  return Astro.redirect("/bracket/");
}

const results = await listResults(ballot.electionId);
const resultByRace = new Map(results.map((r) => [r.raceId, r]));
const pickByRace = new Map(ballot.picks.map((p) => [p.raceId, p]));

const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const pageUrl = `${origin}/ballot/${ballot.shareSlug}/`;
const ogImage = `${origin}/og/ballot/${ballot.shareSlug}.png`;
const displayName = ballot.displayName || "A Clad reader";
const score = ballot.score;

const rows = election.races.map((race) => {
  const pick = pickByRace.get(race.id);
  const result = resultByRace.get(race.id);
  const pickedSide = pick?.side ?? null;
  const pickName =
    pickedSide === "a" ? race.a.name : pickedSide === "b" ? race.b.name : null;
  let outcome: "correct" | "wrong" | "pending" | "open" = "pending";
  if (result?.winnerSide === "a" || result?.winnerSide === "b") {
    if (!pickedSide) outcome = "open";
    else outcome = pickedSide === result.winnerSide ? "correct" : "wrong";
  }
  return {
    race,
    pickName,
    pickedSide,
    winnerName: result?.winnerName ?? null,
    outcome,
  };
});

// Marquee picks lead the unfurl text — the names a stranger recognizes.
const marqueePicks = rows
  .filter((r) => r.pickName && r.race.tier === "marquee")
  .slice(0, 3)
  .map((r) => `${r.pickName!.split(" ").pop()} in ${r.race.state}`);
const pickTeaser = marqueePicks.length
  ? `${marqueePicks.join(", ")} — ${score.picked} races locked. Pick against them on CladFacts.`
  : `${score.picked} of ${score.total} races picked. Pick against them on CladFacts.`;
---
<BaseLayout
  title={`${displayName}'s midterms ballot — CladFacts`}
  description={`${displayName} picked ${score.picked} of ${score.total} races on the CladFacts 2026 ballot board.`}
  ogTitle={`${displayName}'s 2026 ballot — ${score.picked} races picked`}
  ogDescription={
    score.called > 0
      ? `Record ${score.correct}–${score.wrong} with ${score.called} races called. See every pick.`
      : pickTeaser
  }
  ogImage={ogImage}
>
  <article class="static-page public-ballot">
    <p class="small-caps upgrade__eyebrow">Shared ballot · Midterms 2026</p>
    <h1 class="static-page__title">{displayName}&rsquo;s ballot</h1>
    <p class="upgrade__lede">
      {score.picked} of {score.total} races picked
      {score.called > 0 && (
        <> · Score <strong>{score.correct}–{score.wrong}</strong> ({score.called} called)</>
      )}
      . Not polls — personal picks on CladFacts.
    </p>

    {/* Head-to-head vs the visitor's own ballot. The page is publicly cached
        (s-maxage=60), so ALL personalization happens client-side: the script
        below compares the signed-in visitor's locked picks (GET /api/me/ballot)
        against this shared ballot and reveals the strip. The embedded JSON is
        exactly the data already rendered on this public page — nothing new. */}
    <script
      type="application/json"
      id="shared-ballot"
      is:inline
      set:html={JSON.stringify({
        electionId: ballot.electionId,
        shareSlug: ballot.shareSlug,
        displayName,
        picks: ballot.picks.map((p) => ({ raceId: p.raceId, side: p.side })),
        score,
      }).replace(/</g, "\\u003c")}
    />
    <section class="h2h" id="h2h" hidden aria-live="polite">
      <p class="h2h__eyebrow small-caps">Head to head</p>
      <p class="h2h__line" id="h2h-agree"></p>
      <p class="h2h__line h2h__line--score" id="h2h-score" hidden>
        You called <strong id="h2h-mine"></strong> · they called <strong id="h2h-theirs"></strong>
      </p>
    </section>

    <ShareBar
      id="ballot-share"
      url={pageUrl}
      title={`${displayName}'s locked 2026 midterms ballot`}
      hook={
        score.called > 0
          ? `${score.correct} right, ${score.wrong} wrong, ${score.total - score.called} races still open. Think you'd have done better?`
          : `${score.picked} Senate and governor calls, locked before the results. Beat this sheet on CladFacts.`
      }
      storyImage={ogImage}
    />

    <p class="public-ballot__cta">
      <a class="race-share__btn" href="/bracket/">Fill your own ballot →</a>
      <a class="race-share__btn race-share__btn--ghost" href="/register/?next=/bracket/">Create free account</a>
    </p>

    <ul class="public-ballot__list">
      {rows.map((row) => (
        <li class={`public-ballot__row public-ballot__row--${row.outcome}`} data-outcome={row.outcome}>
          <div class="public-ballot__office">{row.race.office}</div>
          <div class="public-ballot__matchup">
            <span class:list={["public-ballot__side", row.pickedSide === "a" && "is-pick"]}>
              {row.race.a.name}{row.race.a.party ? ` (${row.race.a.party})` : ""}
            </span>
            <span class="public-ballot__vs">vs</span>
            <span class:list={["public-ballot__side", row.pickedSide === "b" && "is-pick"]}>
              {row.race.b.name}{row.race.b.party ? ` (${row.race.b.party})` : ""}
            </span>
          </div>
          <div class="public-ballot__meta">
            {row.pickName ? (
              <span>Pick: <strong>{row.pickName}</strong></span>
            ) : (
              <span class="public-ballot__muted">No pick</span>
            )}
            {row.winnerName && (
              <span> · Winner: <strong>{row.winnerName}</strong></span>
            )}
            {row.outcome === "correct" && <span class="public-ballot__tag public-ballot__tag--ok"> Correct</span>}
            {row.outcome === "wrong" && <span class="public-ballot__tag public-ballot__tag--bad"> Wrong</span>}
          </div>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<script is:inline>
  // Head-to-head: compare the signed-in visitor's LOCKED picks with this
  // shared ballot, then point the share bar at the visitor's own ballot so a
  // received share produces a new one. Silent no-op when signed out, no
  // locked picks, viewing your own ballot, or zero shared races.
  (async () => {
    const dataEl = document.getElementById("shared-ballot");
    if (!dataEl) return;
    let shared;
    try { shared = JSON.parse(dataEl.textContent || ""); } catch { return; }
    let res;
    try {
      res = await fetch("/api/me/ballot?election=" + encodeURIComponent(shared.electionId || ""), {
        credentials: "same-origin",
      });
    } catch { return; }
    if (!res.ok) return; // 401 = signed out
    let me;
    try { me = await res.json(); } catch { return; }
    const mine = me && me.ballot;
    if (!mine || !Array.isArray(mine.picks)) return;
    if (mine.shareSlug && mine.shareSlug === shared.shareSlug) return; // own ballot

    const myLocked = mine.picks.filter(
      (p) => p && p.lockedAt && p.raceId && (p.side === "a" || p.side === "b")
    );
    if (myLocked.length === 0) return;

    const theirPick = new Map((shared.picks || []).map((p) => [p.raceId, p.side]));
    let overlap = 0;
    let agree = 0;
    for (const p of myLocked) {
      if (!theirPick.has(p.raceId)) continue;
      overlap++;
      if (theirPick.get(p.raceId) === p.side) agree++;
    }
    if (overlap === 0) return;

    const name = String(shared.displayName || "this reader");
    const ms = mine.score || {};
    const ss = shared.score || {};
    const bothCalled = (ss.called || 0) > 0 && (ms.called || 0) > 0;

    const strip = document.getElementById("h2h");
    const agreeLine = document.getElementById("h2h-agree");
    if (strip && agreeLine) {
      agreeLine.textContent =
        "You vs " + name + ": agree on " + agree + " of " + overlap + " shared picks.";
      if (bothCalled) {
        const scoreLine = document.getElementById("h2h-score");
        const m = document.getElementById("h2h-mine");
        const t = document.getElementById("h2h-theirs");
        if (scoreLine && m && t) {
          m.textContent = String(ms.correct || 0);
          t.textContent = String(ss.correct || 0);
          if ((ms.correct || 0) > (ss.correct || 0)) m.classList.add("h2h__lead");
          else if ((ss.correct || 0) > (ms.correct || 0)) t.classList.add("h2h__lead");
          scoreLine.hidden = false;
        }
      }
      strip.hidden = false;
    }

    // Outbound share becomes the visitor's own sheet (their slug must exist —
    // it does whenever they have a locked pick).
    const bar = document.getElementById("ballot-share");
    if (bar && mine.shareSlug) {
      const win = bothCalled && (ms.correct || 0) > (ss.correct || 0);
      const disagree = overlap - agree;
      bar.setAttribute("data-url", location.origin + "/ballot/" + mine.shareSlug + "/");
      bar.setAttribute("data-story-image", location.origin + "/og/ballot/" + mine.shareSlug + ".png");
      bar.setAttribute(
        "data-title",
        win ? "I beat " + name + "'s 2026 midterms sheet" : "My midterms sheet vs " + name + "'s"
      );
      bar.setAttribute(
        "data-hook",
        win
          ? (ms.correct || 0) + " correct to " + (ss.correct || 0) + " on the CladFacts ballot board."
          : disagree === 0
            ? "We agree on all " + overlap + " shared races. Settled on election night — free on CladFacts."
            : "We split on " + disagree + " of " + overlap + " shared races. Settled on election night — free on CladFacts."
      );
      if (typeof window.cladRefreshShareBars === "function") window.cladRefreshShareBars(bar);
    }
  })();
</script>

<style>
  .h2h {
    border: 2px solid var(--ink, #1a140d);
    padding: 0.7rem 0.9rem;
    margin: 0 0 0.9rem;
  }
  .h2h__eyebrow {
    margin: 0 0 0.25rem;
    color: var(--muted-ink, #6e5e4d);
  }
  .h2h__line {
    margin: 0;
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    font-size: 1.02rem;
  }
  .h2h__line--score {
    margin-top: 0.2rem;
  }
  .h2h__lead {
    color: #941a1a;
  }

  .public-ballot__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 1.5rem;
  }
  .race-share__btn {
    appearance: none;
    font: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--ink, #1a140d);
    background: var(--ink, #1a140d);
    color: var(--paper, #f5edd9);
    text-decoration: none;
    cursor: pointer;
  }
  .race-share__btn--ghost {
    background: transparent;
    color: inherit;
  }
  .public-ballot__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }
  .public-ballot__row {
    border: 1px solid var(--ink, #1a140d);
    padding: 0.75rem 0.9rem;
  }
  .public-ballot__row--correct {
    border-color: color-mix(in srgb, #2d6a4f 50%, var(--ink, #1a140d));
  }
  .public-ballot__row--wrong {
    border-color: color-mix(in srgb, #941a1a 50%, var(--ink, #1a140d));
  }
  .public-ballot__office {
    font-family: var(--serif, Georgia, serif);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .public-ballot__matchup {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.55rem;
    margin-top: 0.35rem;
    font-size: 0.95rem;
  }
  .public-ballot__vs { opacity: 0.5; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.08em; align-self: center; }
  .public-ballot__side.is-pick { font-weight: 700; text-decoration: underline; text-underline-offset: 2px; }
  .public-ballot__meta { margin-top: 0.4rem; font-size: 0.88rem; opacity: 0.9; }
  .public-ballot__muted { opacity: 0.65; }
  .public-ballot__tag { font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.72rem; }
  .public-ballot__tag--ok { color: #1b4332; }
  .public-ballot__tag--bad { color: #941a1a; }
</style>
