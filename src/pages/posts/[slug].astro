---
import { getCollection, render } from "astro:content";
import { env } from "cloudflare:workers";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Verdict from "~/components/Verdict.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import FactualityBar from "~/components/FactualityBar.astro";
import KeyMoments from "~/components/KeyMoments.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import SocialSentiment from "~/components/SocialSentiment.astro";
import { getSentiments } from "~/lib/agents";
import Disclaimer from "~/components/Disclaimer.astro";
import NewsletterSignup from "~/components/NewsletterSignup.astro";
import ShareBar from "~/components/ShareBar.astro";
import { dateline, shortDate } from "~/lib/dateline";
import { embedUrl } from "~/lib/youtube";
import { getAccess } from "~/lib/access";
import { sampleUnlockedId } from "~/lib/sample";
import { metaDescription } from "~/lib/seo";
import { splitCitations } from "~/lib/citations";
import { slugify } from "~/lib/slug";
import { aggregateTopics, canonicalTopic, topicSlug } from "~/lib/topics";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-store");

// Article text is open (SEO); the scoreboard unlocks with any account.
const access = await getAccess(Astro.request.headers);

const all = await getCollection("posts", (p) => !p.data.draft);
const post = all.find((p) => p.id === Astro.params.slug);
if (!post) return new Response(null, { status: 404 });
// Report of the Day — today's sample renders fully unlocked for restricted
// readers (badge + data-sample-unlocked marker); everything else stays gated.
const sampleId = sampleUnlockedId(all);
const isSample = post.id === sampleId;
const locked = !access.fullAccess && !isSample;
const original = post.data.correctionOf
  ? all.find((q) => q.id === post.data.correctionOf) ?? null
  : null;
const successors = all
  .filter((q) => q.data.correctionOf === post.id)
  .sort((a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf());
const { Content } = await render(post);
const d = post.data;
const isBroadcast = d.type === "broadcast";
const sourceHost = (() => {
  try {
    return new URL(d.sourceUrl).hostname.replace(/^www\./, "");
  } catch {
    return d.sourceUrl;
  }
})();
const paragraphs = (text: string) =>
  text.split(/\n{2,}/).map((s) => s.trim()).filter(Boolean);
// Reading time from the text every reader sees (report bodies live mostly in
// frontmatter). Gated fields (grade/lean rationales, sentiment) are excluded
// so the count is identical for locked and unlocked readers.
const readableText = isBroadcast
  ? [
      d.summary,
      d.assessment ?? "",
      ...d.keyMoments.flatMap((m) => [m.claim, m.note]),
      ...d.notableConcerns,
      post.body ?? "",
    ].join(" ")
  : post.body ?? "";
const readMinutes = Math.max(1, Math.round(readableText.split(/\s+/).filter(Boolean).length / 200));
const shareUrl = new URL(`/posts/${post.id}/`, Astro.site ?? "https://cladfacts.com").href;

// Social-preview composition: surface grade + political lean alongside the
// headline so they show in the unfurl card (image + title) on every platform.
function leanLabel(score: number | null | undefined, lean: string | undefined): string | null {
  const enumScore: Record<string, number> = {
    left: -80, "center-left": -40, center: 0, "center-right": 40, right: 80, none: 0,
  };
  const s = typeof score === "number" ? score : lean ? enumScore[lean] ?? null : null;
  if (s === null) return null;
  return Math.abs(s) < 5 ? "Centered" : `${Math.abs(s)}% ${s > 0 ? "Right" : "Left"}-leaning`;
}
const VERDICT_LABELS: Record<string, string> = {
  true: "True", "mostly-true": "Mostly True", mixed: "Mixed",
  "mostly-false": "Mostly False", false: "False", unverified: "Unverified",
};
const lean = leanLabel(d.leanScore, d.politicalLean);
const ogParts = isBroadcast
  ? [d.letterGrade ? `Article Grade: ${d.letterGrade}` : null, lean].filter(Boolean)
  : [d.verdict ? `Verdict: ${VERDICT_LABELS[d.verdict]}` : null].filter(Boolean);
// The generated preview image (/og/<slug>.png) carries the grade + lean
// visually, so the title stays clean; the description keeps them as a backstop
// for the rare client that shows text but not the image.
const ogTitle = d.headline;
const ogImage = `/og/${post.id}.png`;
// Restricted readers (incl. crawlers) get a grade-free description so the
// grade/lean stays Premium; full-access requests keep the rich snippet.
// Keyed to fullAccess (not `locked`) so even the daily sample post keeps its
// grade out of <head> — the sample unlock lives only inside the marked
// data-sample-unlocked subtree.
const ogDescription = !access.fullAccess
  ? metaDescription(d.summary)
  : isBroadcast
    ? metaDescription(`${ogParts.join(" · ")} · Factuality ${d.factualityScore}/100. ${d.summary}`)
    : metaDescription(`${ogParts.join(" · ")}. ${d.summary}`);

// NewsArticle structured data (grade-free — body text is public; grade is gated).
const published = d.publishedAt.toISOString();
const modified = successors.length
  ? successors[successors.length - 1]!.data.publishedAt.toISOString()
  : published;
const origin = (Astro.site ?? new URL("https://cladfacts.com")).origin;
const newsLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: d.headline,
  description: metaDescription(d.summary, 300),
  image: [new URL(ogImage, Astro.site ?? "https://cladfacts.com").href],
  datePublished: published,
  dateModified: modified,
  mainEntityOfPage: { "@type": "WebPage", "@id": shareUrl },
  // The report text is free for everyone (only the scoreboard is gated), so
  // this page never triggers paywalled-content treatment in Search.
  isAccessibleForFree: true,
  // Named editor for E-E-A-T; author.url resolves to the bio on /about/.
  author: { "@type": "Person", name: "Ben Cody", jobTitle: "Editor", url: `${origin}/about/#editor` },
  publisher: {
    "@type": "NewsMediaOrganization",
    name: "CladFacts",
    legalName: "CladFacts LLC",
    logo: { "@type": "ImageObject", url: new URL("/favicon.svg", Astro.site ?? "https://cladfacts.com").href },
  },
};

// ClaimReview structured data. keyMoments (claim/verdict/note) are already
// public page content, so nothing gated is exposed here — never add
// letterGrade/factualityScore/lean values or rationales to any LD block.
const claimAuthor = {
  "@type": "Organization",
  name: "CladFacts",
  legalName: "CladFacts LLC",
  url: origin,
};
const claimAppearance = {
  "@type": "CreativeWork",
  url: d.sourceUrl,
  name: d.sourceTitle ?? sourceHost,
};
const KEY_MOMENT_RATINGS: Record<string, number> = {
  verified: 5, "missing context": 3, disputed: 2, unsupported: 1,
};
const VERDICT_RATINGS: Record<string, number> = {
  true: 5, "mostly-true": 4, mixed: 3, "mostly-false": 2, false: 1,
};
const claimLds = isBroadcast
  ? d.keyMoments.map((m) => ({
      "@context": "https://schema.org",
      "@type": "ClaimReview",
      url: shareUrl,
      claimReviewed: m.claim,
      datePublished: published,
      author: claimAuthor,
      itemReviewed: { "@type": "Claim", appearance: claimAppearance },
      reviewRating: {
        "@type": "Rating",
        ratingValue: KEY_MOMENT_RATINGS[m.verdict],
        bestRating: 5,
        worstRating: 1,
        alternateName: m.verdict,
      },
    }))
  : d.verdict
    ? [{
        "@context": "https://schema.org",
        "@type": "ClaimReview",
        url: shareUrl,
        claimReviewed: d.headline,
        datePublished: published,
        author: claimAuthor,
        itemReviewed: { "@type": "Claim", appearance: claimAppearance },
        reviewRating: {
          "@type": "Rating",
          ...(d.verdict !== "unverified" ? { ratingValue: VERDICT_RATINGS[d.verdict] } : {}),
          bestRating: 5,
          worstRating: 1,
          alternateName: VERDICT_LABELS[d.verdict],
        },
      }]
    : [];

const { sources, background } = splitCitations(d.citations);

// Social-media sentiment (scanner-scored, KV-backed). Premium-gated like the
// grade/lean, so restricted readers never even trigger the KV read.
const sentiment = isBroadcast && !locked ? (await getSentiments(env.AGENTS))[post.id] ?? null : null;

// Topic chips link to their aggregated topic page when one exists. The
// aggregator clusters near-duplicate tags by similarity, so raw tags rarely
// slug-match directly — the primary (first) chip therefore falls back to the
// cluster this post was actually assigned to.
const topicAggs = aggregateTopics(all);
const topicPageSlugs = new Set(topicAggs.map((t) => t.slug));
const ownTopicSlug = topicAggs.find((t) => t.posts.some((q) => q.id === post.id))?.slug ?? null;
---
<BaseLayout
  title={`${d.headline} — Clad`}
  description={metaDescription(d.summary)}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogType="article"
  jsonLd={[newsLd, ...claimLds]}
>
  <meta slot="head" property="article:published_time" content={published} />
  <article class="post" data-sample-unlocked={isSample && !access.fullAccess ? "true" : undefined}>
    <div class="post__kicker">
      {locked ? (
        <span class="grade-lock" aria-label="Premium"><span aria-hidden="true">🔒</span> Grade — Premium</span>
      ) : isBroadcast ? (
        <LetterGrade grade={d.letterGrade!} />
      ) : (
        <Verdict verdict={d.verdict!} />
      )}
      {isSample && !access.fullAccess && (
        <span class="sample-badge small-caps" style="margin-left:.75rem">Today's free sample</span>
      )}
      {d.kicker && <span class="small-caps" style="margin-left:.75rem">{d.kicker}</span>}
    </div>
    <h1 class="post__headline">{d.headline}</h1>
    <div class="post__byline">
      <span>{dateline(d.publishedAt)}</span>
      <span>·</span>
      <span>{readMinutes} min read</span>
      <span>·</span>
      <span>
        Source:{" "}
        <a href={d.sourceUrl} rel="noopener noreferrer" target="_blank">
          {d.sourceTitle ?? sourceHost}
        </a>
      </span>
      {d.sourceTitle && (
        <>
          <span>·</span>
          <span><a href={`/outlets/${slugify(d.sourceTitle.trim())}/`}>All {d.sourceTitle} reports</a></span>
        </>
      )}
      <span>·</span>
      <span>Reviewed &amp; approved by <a href="/about/#editor">Ben Cody</a></span>
    </div>

    <div class="post__actions">
      <ShareBar url={shareUrl} title={`${d.headline} — Clad`} storyImage={`/og/story/${post.id}.png`} />
      <button
        type="button"
        class="save-btn"
        id="save-btn"
        data-slug={post.id}
        data-headline={d.headline}
        aria-pressed="false"
        hidden
      >
        <span class="save-btn__icon" aria-hidden="true">♡</span>
        <span class="save-btn__label">Save</span>
      </button>
    </div>

    {isBroadcast && (
      <details class="embed-grade">
        <summary class="small-caps">Embed this grade</summary>
        <p class="embed-grade__hint">
          Paste this on your site or blog — the badge links readers to the full report
          (grade values stay in the image, same policy as our share cards).
        </p>
        <img src={`/embed/${post.id}.svg`} width="320" height="112" alt={`CladFacts grade badge for: ${d.headline}`} loading="lazy" />
        <textarea class="embed-grade__code" rows="3" readonly onclick="this.select()">{`<a href="${shareUrl}"><img src="${new URL(`/embed/${post.id}.svg`, Astro.site ?? "https://cladfacts.com").href}" width="320" height="112" alt="CladFacts grade for this report"></a>`}</textarea>
      </details>
    )}

    {original && (
      <div class="correction-banner" role="note">
        <span class="correction-banner__label">Correction</span>
        This post corrects an earlier report:{" "}
        <a href={`/posts/${original.id}/`}>{original.data.headline}</a>{" "}
        ({shortDate(original.data.publishedAt)}).
      </div>
    )}
    {successors.length > 0 && (
      <div class="correction-banner" role="note">
        <span class="correction-banner__label">Corrected</span>
        {successors.length === 1 ? (
          <>
            A correction to this post has been issued:{" "}
            <a href={`/posts/${successors[0]!.id}/`}>{successors[0]!.data.headline}</a>{" "}
            ({shortDate(successors[0]!.data.publishedAt)}).
          </>
        ) : (
          <>
            Corrections to this post:
            <ul style="margin:.4rem 0 0;padding-left:1.25rem">
              {successors.map((s) => (
                <li>
                  <a href={`/posts/${s.id}/`}>{s.data.headline}</a>{" "}
                  ({shortDate(s.data.publishedAt)})
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
    )}

    {isBroadcast ? (
      <div class="report">
        {locked ? (
          <div class="report__locked">
            <p class="grade-lock-panel">
              <span aria-hidden="true">🔒</span> The <strong>letter grade</strong>, factuality score,
              <strong> political-lean</strong> rating, and <strong>social-media sentiment</strong> for this report unlock with a
              <a href="/register/"> free CladFacts account</a> — no card, no trial clock.
              Already have one? <a href={`/login/?next=/posts/${post.id}/`}>Sign in</a>.
              The full report below is free to read.
            </p>
          </div>
        ) : (
          <>
            <div class="report__scorecard">
              <div class="report__grade">
                <LetterGrade grade={d.letterGrade!} size="hero" />
                <span class="small-caps">Grade</span>
              </div>
              <div class="report__metrics">
                <FactualityBar score={d.factualityScore!} />
                {(d.leanScore != null || d.politicalLean) && (
                  <PoliticalLean score={d.leanScore} lean={d.politicalLean} size="header" />
                )}
                {sentiment && (
                  <SocialSentiment score={sentiment.score} volume={sentiment.volume} size="header" />
                )}
              </div>
            </div>
            {d.gradeRationale && (
              <p class="grade-rationale">
                <span class="small-caps">Why this grade:</span> {d.gradeRationale}
              </p>
            )}
            {d.leanRationale && (
              <p class="lean-rationale">
                <span class="small-caps">Why this lean:</span> {d.leanRationale}
              </p>
            )}
            {sentiment?.summary && (
              <p class="senti-rationale">
                <span class="small-caps">Social reaction:</span> {sentiment.summary}
              </p>
            )}
          </>
        )}

        {/* Flagging is every reader's right (About / How It Works promise it),
            not a Premium perk — any signed-in account can dispute a grade or
            lean; signed-out readers get a sign-in prompt. */}
        <details class="flag" data-post-id={post.id}>
          <summary class="flag__summary">Disagree with this grade or political lean?</summary>
          <div class="flag__body">
            {access.signedIn ? (
              <>
                <p class="flag__intro">
                  Tell us why. Your note is reprocessed through the same grading
                  logic; if the output is still off the report is removed, and if
                  it holds up it stays.
                </p>
                <fieldset class="flag__aspect">
                  <legend class="small-caps">What do you disagree with?</legend>
                  <label><input type="radio" name="aspect" value="grade" checked /> The grade</label>
                  <label><input type="radio" name="aspect" value="lean" /> The political lean</label>
                  <label><input type="radio" name="aspect" value="both" /> Both</label>
                </fieldset>
                <textarea
                  class="flag__comment"
                  rows="4"
                  maxlength="2000"
                  placeholder="Explain what you think is wrong and why — cite specifics if you can."
                ></textarea>
                <div class="flag__actions">
                  <button type="button" class="flag__submit">Submit for review</button>
                </div>
                <div class="flag__status" role="status"></div>
              </>
            ) : (
              <p class="flag__intro">
                Flagging is open to every reader with a free account.
                {" "}<a href={`/login/?next=/posts/${post.id}/`}>Sign in</a> or
                {" "}<a href="/register/">create one</a> to dispute this report.
              </p>
            )}
          </div>
        </details>

        {d.videoId && (
          <div
            class="video-embed video-facade"
            data-embed={embedUrl(d.videoId)}
            data-title={`Source video: ${d.headline}`}
          >
            {/* Click-to-load facade: no YouTube requests (or cookies) until the
                reader opts in — cheaper LCP and consistent with the privacy
                policy's YouTube-cookie caveat. */}
            <button type="button" class="video-facade__btn" aria-label={`Play source video: ${d.headline}`}>
              <img
                class="video-facade__thumb"
                src={`https://img.youtube.com/vi/${d.videoId}/hqdefault.jpg`}
                alt=""
                loading="lazy"
                decoding="async"
              />
              <span class="video-facade__play" aria-hidden="true">▶</span>
              <span class="video-facade__label">Play source video</span>
            </button>
          </div>
        )}

        {d.topics.length > 0 && (
          <div class="topics">
            <h2 class="small-caps">Topics in This Edition</h2>
            <div class="topics__tags">
              {d.topics.map((t, i) => {
                const direct = topicSlug(canonicalTopic(t));
                const ts = topicPageSlugs.has(direct) ? direct : i === 0 ? ownTopicSlug : null;
                return ts ? (
                  <a class="topic-tag" href={`/topics/${ts}/`}>{t}</a>
                ) : (
                  <span class="topic-tag">{t}</span>
                );
              })}
            </div>
          </div>
        )}

        <section class="report__section">
          <h2 class="small-caps">Summary</h2>
          {paragraphs(d.summary).map((p) => <p>{p}</p>)}
        </section>

        <section class="report__section">
          <h2 class="small-caps">Editorial Assessment</h2>
          {paragraphs(d.assessment!).map((p) => <p>{p}</p>)}
        </section>

        {d.keyMoments.length > 0 && <KeyMoments moments={d.keyMoments} />}

        {d.notableConcerns.length > 0 && (
          <section class="notable-concerns">
            <h2 class="small-caps">Notable Concerns</h2>
            <ul>
              {d.notableConcerns.map((c) => <li>{c}</li>)}
            </ul>
          </section>
        )}

        <div class="post__body report__body">
          <Content />
        </div>
      </div>
    ) : (
      <div class="post__body">
        <Content />
      </div>
    )}

    {sources.length > 0 && (
      <section class="sources">
        <h2>Sources Consulted</h2>
        <ol>
          {sources.map((c) => (
            <li>
              <a href={c.url} rel="noopener noreferrer" target="_blank">{c.title}</a>
            </li>
          ))}
        </ol>
      </section>
    )}
    {background.length > 0 && (
      <section class="sources sources--background">
        <h2>Background</h2>
        <ol>
          {background.map((c) => (
            <li>
              <a href={c.url} rel="noopener noreferrer" target="_blank">{c.title}</a>
            </li>
          ))}
        </ol>
      </section>
    )}

    {isBroadcast && access.fullAccess && (
      <section class="reactions" data-slug={post.id} data-can-comment={access.tier === "paid" ? "1" : "0"}>
        <h2 class="small-caps reactions__title">Reader Reactions</h2>
        <p class="reactions__tally" id="rx-tally" hidden></p>

        {access.tier === "paid" ? (
          <form class="rx-form" id="rx-form" onsubmit="return false">
            <p class="small-caps rx-form__label">Your reaction</p>
            <div class="rx-votes">
              <fieldset class="rx-vote">
                <legend>The grade</legend>
                <label><input type="radio" name="gradeVote" value="agree" /> Agree</label>
                <label><input type="radio" name="gradeVote" value="disagree" /> Disagree</label>
                <label><input type="radio" name="gradeVote" value="" checked /> No opinion</label>
              </fieldset>
              <fieldset class="rx-vote">
                <legend>The political lean</legend>
                <label><input type="radio" name="leanVote" value="agree" /> Agree</label>
                <label><input type="radio" name="leanVote" value="disagree" /> Disagree</label>
                <label><input type="radio" name="leanVote" value="" checked /> No opinion</label>
              </fieldset>
            </div>
            <textarea
              class="rx-form__body"
              rows="3"
              maxlength="2000"
              placeholder="Add your take on the grade or the lean — cite specifics if you can."
            ></textarea>
            <div class="rx-form__actions">
              <button type="button" class="rx-form__submit">Post reaction</button>
              <button type="button" class="rx-form__delete" hidden>Delete</button>
              <span class="rx-form__status" role="status"></span>
            </div>
          </form>
        ) : (
          <p class="rx-upsell">
            Posting a reaction is a <a href="/upgrade/">Premium</a> perk — free accounts
            can read every reaction; go Premium to add yours (and support the newsroom).
          </p>
        )}

        <ol class="reactions__list" id="rx-list"></ol>
      </section>
    )}

    <NewsletterSignup compact />
    <Disclaimer />
  </article>

  <script is:inline>
    (() => {
      const box = document.querySelector(".video-facade");
      if (!box) return;
      const btn = box.querySelector(".video-facade__btn");
      btn.addEventListener("click", () => {
        const iframe = document.createElement("iframe");
        const embed = box.getAttribute("data-embed") || "";
        iframe.src = embed + (embed.includes("?") ? "&" : "?") + "autoplay=1";
        iframe.title = box.getAttribute("data-title") || "Source video";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;
        iframe.referrerPolicy = "strict-origin-when-cross-origin";
        box.replaceChildren(iframe);
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const box = document.querySelector(".flag");
      if (!box) return;
      const postId = box.getAttribute("data-post-id");
      const btn = box.querySelector(".flag__submit");
      const comment = box.querySelector(".flag__comment");
      const status = box.querySelector(".flag__status");
      const setStatus = (kind, msg) => {
        status.className = `flag__status flag__status--${kind}`;
        status.textContent = msg;
      };
      btn.addEventListener("click", async () => {
        const aspect = (box.querySelector('input[name="aspect"]:checked') || {}).value;
        const text = comment.value.trim();
        if (text.length < 3) {
          setStatus("error", "Please add a comment.");
          return;
        }
        btn.disabled = true;
        setStatus("info", "Submitting…");
        try {
          const res = await fetch("/api/flag", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ postId, aspect, comment: text }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Could not submit");
          box.querySelector(".flag__body").innerHTML =
            '<p class="flag__thanks">Thanks — your note was sent to the editor.</p>';
        } catch (err) {
          setStatus("error", String(err.message || err));
          btn.disabled = false;
        }
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const btn = document.getElementById("save-btn");
      if (!btn) return;
      const slug = btn.getAttribute("data-slug");
      const headline = btn.getAttribute("data-headline") || slug;
      const label = btn.querySelector(".save-btn__label");
      const icon = btn.querySelector(".save-btn__icon");
      let signedIn = false;
      let saved = false;

      const paint = () => {
        btn.setAttribute("aria-pressed", saved ? "true" : "false");
        btn.classList.toggle("save-btn--on", saved);
        icon.textContent = saved ? "♥" : "♡";
        label.textContent = saved ? "Saved" : "Save";
      };

      // Determine sign-in + saved state, then reveal the button.
      fetch("/api/me/favorites", { headers: { Accept: "application/json" } })
        .then((res) => {
          if (res.status === 401) { signedIn = false; return null; }
          signedIn = true;
          return res.json().catch(() => null);
        })
        .then((data) => {
          if (data && Array.isArray(data.favorites)) {
            saved = data.favorites.some((f) => f.slug === slug);
          }
          paint();
        })
        .finally(() => { btn.hidden = false; });

      btn.addEventListener("click", async () => {
        if (!signedIn) {
          const next = encodeURIComponent(location.pathname);
          location.href = "/login/?next=" + next;
          return;
        }
        const next = !saved;
        btn.disabled = true;
        try {
          const res = await fetch("/api/me/favorites", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug, headline, favorite: next }),
          });
          if (!res.ok) throw new Error();
          saved = next;
          paint();
        } catch {
          /* leave state unchanged on failure */
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const root = document.querySelector(".reactions");
      if (!root) return;
      const slug = root.getAttribute("data-slug");
      const tallyEl = root.querySelector("#rx-tally");
      const listEl = root.querySelector("#rx-list");
      const form = root.querySelector("#rx-form");
      const ENDPOINT = "/api/comments";
      const qs = "?slug=" + encodeURIComponent(slug);

      const esc = (s) =>
        String(s).replace(/[&<>"]/g, (c) =>
          ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c])
        );
      const cap = (v) => v.charAt(0).toUpperCase() + v.slice(1);
      const pct = (a, b) => (a + b > 0 ? Math.round((a / (a + b)) * 100) : null);

      const renderTally = (t) => {
        if (!t || !t.total) { tallyEl.hidden = true; return; }
        const g = pct(t.gradeAgree, t.gradeDisagree);
        const l = pct(t.leanAgree, t.leanDisagree);
        const parts = [];
        if (g != null) parts.push("<strong>" + g + "%</strong> agree with the grade");
        if (l != null) parts.push("<strong>" + l + "%</strong> agree with the lean");
        const lede = parts.length ? parts.join(" · ") : "No grade or lean votes yet";
        tallyEl.innerHTML =
          lede + ' <span class="reactions__count">(' + t.total +
          " reader" + (t.total === 1 ? "" : "s") + ")</span>";
        tallyEl.hidden = false;
      };

      const badge = (label, v) =>
        v ? '<span class="rx-badge rx-badge--' + v + '">' + label + ": " + cap(v) + "</span>" : "";

      const renderList = (comments) => {
        if (!comments || !comments.length) {
          listEl.innerHTML = '<li class="reactions__empty">No reactions yet.</li>';
          return;
        }
        listEl.innerHTML = comments
          .map(
            (c) =>
              '<li class="rx' + (c.mine ? " rx--mine" : "") + '">' +
              '<div class="rx__head"><span class="rx__author">' + esc(c.authorName) + "</span>" +
              badge("Grade", c.gradeVote) + badge("Lean", c.leanVote) + "</div>" +
              (c.body ? '<p class="rx__body">' + esc(c.body) + "</p>" : "") +
              "</li>"
          )
          .join("");
      };

      // ---- form wiring (premium only; absent for trial) ----
      let prefill = () => {};
      if (form) {
        const submit = form.querySelector(".rx-form__submit");
        const del = form.querySelector(".rx-form__delete");
        const status = form.querySelector(".rx-form__status");
        const bodyEl = form.querySelector(".rx-form__body");
        const getVote = (name) =>
          (form.querySelector('input[name="' + name + '"]:checked') || {}).value || null;
        const setVote = (name, val) => {
          const el = form.querySelector('input[name="' + name + '"][value="' + (val || "") + '"]');
          if (el) el.checked = true;
        };

        prefill = (m) => {
          bodyEl.value = (m && m.body) || "";
          setVote("gradeVote", m && m.gradeVote);
          setVote("leanVote", m && m.leanVote);
          del.hidden = !m;
        };

        const refresh = async () => {
          const data = await fetch(ENDPOINT + qs, { headers: { Accept: "application/json" } })
            .then((r) => (r.ok ? r.json() : null))
            .catch(() => null);
          if (!data) return;
          renderTally(data.tally);
          renderList(data.comments);
        };

        submit.addEventListener("click", async () => {
          const body = bodyEl.value.trim();
          const gradeVote = getVote("gradeVote");
          const leanVote = getVote("leanVote");
          if (body.length < 1 && !gradeVote && !leanVote) {
            status.textContent = "Add a comment or pick a stance.";
            return;
          }
          submit.disabled = true;
          status.textContent = "Saving…";
          try {
            const res = await fetch(ENDPOINT, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ slug, body, gradeVote, leanVote }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(data.error || "Could not post");
            status.textContent = "Posted.";
            del.hidden = false;
            await refresh();
          } catch (err) {
            status.textContent = String(err.message || err);
          } finally {
            submit.disabled = false;
          }
        });

        del.addEventListener("click", async () => {
          del.disabled = true;
          status.textContent = "Removing…";
          try {
            const res = await fetch(ENDPOINT + qs, { method: "DELETE" });
            if (!res.ok) throw new Error();
            bodyEl.value = "";
            setVote("gradeVote", null);
            setVote("leanVote", null);
            del.hidden = true;
            status.textContent = "Removed.";
            await refresh();
          } catch {
            status.textContent = "Could not remove.";
          } finally {
            del.disabled = false;
          }
        });
      }

      // ---- initial load ----
      fetch(ENDPOINT + qs, { headers: { Accept: "application/json" } })
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          if (!data) return;
          renderTally(data.tally);
          renderList(data.comments);
          if (data.mine) prefill(data.mine);
        })
        .catch(() => {});
    })();
  </script>

  <style is:global>
    /* Global (not scoped): the comment list is injected via innerHTML, so
       Astro's scoped-style attribute would not reach those elements. */
    .reactions { margin: 2.5rem 0 0; padding-top: 1.5rem; border-top: 2px solid var(--ink); }
    .reactions__title { display: block; margin-bottom: 0.4rem; }
    .reactions__tally { font-size: 1rem; margin: 0.2rem 0 1.2rem; }
    .reactions__count { color: var(--muted-ink); font-size: 0.85em; }
    .rx-form { border: 1px solid var(--rule); padding: 1rem 1.1rem; margin-bottom: 1.5rem; background: rgba(0,0,0,0.015); }
    .rx-form__label { display: block; margin: 0 0 0.7rem; }
    .rx-votes { display: flex; flex-wrap: wrap; gap: 1rem 1.6rem; margin-bottom: 0.8rem; }
    .rx-vote { border: none; margin: 0; padding: 0; }
    .rx-vote legend { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-ink); padding: 0; margin-bottom: 0.3rem; }
    .rx-vote label { display: inline-flex; align-items: center; gap: 0.25rem; margin-right: 0.8rem; font-size: 0.9rem; cursor: pointer; }
    .rx-form__body { width: 100%; box-sizing: border-box; font: inherit; font-size: 0.95rem; padding: 0.6rem; border: 1px solid var(--rule); resize: vertical; background: var(--paper); }
    .rx-form__actions { display: flex; align-items: center; gap: 0.8rem; margin-top: 0.7rem; }
    .rx-form__submit { font: inherit; font-size: 0.85rem; letter-spacing: 0.05em; text-transform: uppercase; padding: 0.5rem 1.1rem; border: none; background: var(--accent, rgb(150, 30, 20)); color: #fff; cursor: pointer; }
    .rx-form__submit:disabled { opacity: 0.6; cursor: default; }
    .rx-form__delete { font: inherit; font-size: 0.8rem; background: none; border: none; color: var(--muted-ink); text-decoration: underline; cursor: pointer; }
    .rx-form__status { font-size: 0.85rem; color: var(--muted-ink); }
    .rx-upsell { font-size: 0.95rem; padding: 0.8rem 1rem; border: 1px dashed var(--rule); margin-bottom: 1.5rem; }
    .reactions__list { list-style: none; padding: 0; margin: 0; }
    .reactions__empty { color: var(--muted-ink); font-style: italic; }
    .rx { padding: 0.9rem 0; border-bottom: 1px solid var(--rule); }
    .rx--mine { background: var(--accent-soft, rgba(150,30,20,0.04)); margin: 0 -0.6rem; padding: 0.9rem 0.6rem; }
    .rx__head { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
    .rx__author { font-weight: 700; font-size: 0.95rem; }
    .rx-badge { font-size: 0.68rem; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.12rem 0.45rem; border: 1px solid; border-radius: 2px; }
    .rx-badge--agree { color: rgb(30,90,40); border-color: rgb(30,90,40); }
    .rx-badge--disagree { color: var(--accent, rgb(150, 30, 20)); border-color: var(--accent, rgb(150, 30, 20)); }
    .rx__body { margin: 0.2rem 0 0; font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap; }
  </style>
</BaseLayout>
