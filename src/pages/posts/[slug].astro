---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Verdict from "~/components/Verdict.astro";
import LetterGrade from "~/components/LetterGrade.astro";
import FactualityBar from "~/components/FactualityBar.astro";
import KeyMoments from "~/components/KeyMoments.astro";
import PoliticalLean from "~/components/PoliticalLean.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import ShareBar from "~/components/ShareBar.astro";
import { dateline, shortDate } from "~/lib/dateline";
import { embedUrl } from "~/lib/youtube";

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection("posts", (p) => !p.data.draft);
  return all.map((p) => {
    const original = p.data.correctionOf
      ? all.find((q) => q.id === p.data.correctionOf) ?? null
      : null;
    const successors = all
      .filter((q) => q.data.correctionOf === p.id)
      .sort((a, b) => a.data.publishedAt.valueOf() - b.data.publishedAt.valueOf());
    return {
      params: { slug: p.id },
      props: { post: p, original, successors },
    };
  });
}

const { post, original, successors } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const isBroadcast = d.type === "broadcast";
const sourceHost = (() => {
  try {
    return new URL(d.sourceUrl).hostname.replace(/^www\./, "");
  } catch {
    return d.sourceUrl;
  }
})();
const paragraphs = (text: string) =>
  text.split(/\n{2,}/).map((s) => s.trim()).filter(Boolean);
const shareUrl = new URL(`/posts/${post.id}/`, Astro.site ?? "https://cladfacts.com").href;

// Social-preview composition: surface grade + political lean alongside the
// headline so they show in the unfurl card (image + title) on every platform.
function leanLabel(score: number | null | undefined, lean: string | undefined): string | null {
  const enumScore: Record<string, number> = {
    left: -80, "center-left": -40, center: 0, "center-right": 40, right: 80, none: 0,
  };
  const s = typeof score === "number" ? score : lean ? enumScore[lean] ?? null : null;
  if (s === null) return null;
  return Math.abs(s) < 5 ? "Centered" : `${Math.abs(s)}% ${s > 0 ? "Right" : "Left"}-leaning`;
}
const VERDICT_LABELS: Record<string, string> = {
  true: "True", "mostly-true": "Mostly True", mixed: "Mixed",
  "mostly-false": "Mostly False", false: "False", unverified: "Unverified",
};
const lean = leanLabel(d.leanScore, d.politicalLean);
const ogParts = isBroadcast
  ? [d.letterGrade ? `Article Grade: ${d.letterGrade}` : null, lean].filter(Boolean)
  : [d.verdict ? `Verdict: ${VERDICT_LABELS[d.verdict]}` : null].filter(Boolean);
// The generated preview image (/og/<slug>.png) carries the grade + lean
// visually, so the title stays clean; the description keeps them as a backstop
// for the rare client that shows text but not the image.
const ogTitle = d.headline;
const ogImage = `/og/${post.id}.png`;
const ogDescription = isBroadcast
  ? `${ogParts.join(" · ")} · Factuality ${d.factualityScore}/100. ${d.summary}`.slice(0, 200)
  : `${ogParts.join(" · ")}. ${d.summary}`.slice(0, 200);
---
<BaseLayout
  title={`${d.headline} — Clad`}
  description={d.summary}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogType="article"
>
  <article class="post">
    <div class="post__kicker">
      {isBroadcast ? (
        <LetterGrade grade={d.letterGrade!} />
      ) : (
        <Verdict verdict={d.verdict!} />
      )}
      {d.kicker && <span class="small-caps" style="margin-left:.75rem">{d.kicker}</span>}
    </div>
    <h1 class="post__headline">{d.headline}</h1>
    <div class="post__byline">
      <span>{dateline(d.publishedAt)}</span>
      <span>·</span>
      <span>
        Source:{" "}
        <a href={d.sourceUrl} rel="noopener noreferrer" target="_blank">
          {d.sourceTitle ?? sourceHost}
        </a>
      </span>
    </div>

    <div class="post__actions">
      <ShareBar url={shareUrl} title={`${d.headline} — Clad`} />
      <button
        type="button"
        class="save-btn"
        id="save-btn"
        data-slug={post.id}
        data-headline={d.headline}
        aria-pressed="false"
        hidden
      >
        <span class="save-btn__icon" aria-hidden="true">♡</span>
        <span class="save-btn__label">Save</span>
      </button>
    </div>

    {original && (
      <div class="correction-banner" role="note">
        <span class="correction-banner__label">Correction</span>
        This post corrects an earlier report:{" "}
        <a href={`/posts/${original.id}/`}>{original.data.headline}</a>{" "}
        ({shortDate(original.data.publishedAt)}).
      </div>
    )}
    {successors.length > 0 && (
      <div class="correction-banner" role="note">
        <span class="correction-banner__label">Corrected</span>
        {successors.length === 1 ? (
          <>
            A correction to this post has been issued:{" "}
            <a href={`/posts/${successors[0]!.id}/`}>{successors[0]!.data.headline}</a>{" "}
            ({shortDate(successors[0]!.data.publishedAt)}).
          </>
        ) : (
          <>
            Corrections to this post:
            <ul style="margin:.4rem 0 0;padding-left:1.25rem">
              {successors.map((s) => (
                <li>
                  <a href={`/posts/${s.id}/`}>{s.data.headline}</a>{" "}
                  ({shortDate(s.data.publishedAt)})
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
    )}

    {isBroadcast ? (
      <div class="report">
        <div class="report__scorecard">
          <div class="report__grade">
            <LetterGrade grade={d.letterGrade!} size="hero" />
            <span class="small-caps">Grade</span>
          </div>
          <div class="report__metrics">
            <FactualityBar score={d.factualityScore!} />
            {(d.leanScore != null || d.politicalLean) && (
              <PoliticalLean score={d.leanScore} lean={d.politicalLean} size="header" />
            )}
          </div>
        </div>
        {d.gradeRationale && (
          <p class="grade-rationale">
            <span class="small-caps">Why this grade:</span> {d.gradeRationale}
          </p>
        )}
        {d.leanRationale && (
          <p class="lean-rationale">
            <span class="small-caps">Why this lean:</span> {d.leanRationale}
          </p>
        )}

        <details class="flag" data-post-id={post.id}>
          <summary class="flag__summary">Disagree with this grade or political lean?</summary>
          <div class="flag__body">
            <p class="flag__intro">
              Tell us why. Your note goes to the editor, who reviews every
              submission and may re-grade the report.
            </p>
            <fieldset class="flag__aspect">
              <legend class="small-caps">What do you disagree with?</legend>
              <label><input type="radio" name="aspect" value="grade" checked /> The grade</label>
              <label><input type="radio" name="aspect" value="lean" /> The political lean</label>
              <label><input type="radio" name="aspect" value="both" /> Both</label>
            </fieldset>
            <textarea
              class="flag__comment"
              rows="4"
              maxlength="2000"
              placeholder="Explain what you think is wrong and why — cite specifics if you can."
            ></textarea>
            <div class="flag__actions">
              <button type="button" class="flag__submit">Submit to editor</button>
            </div>
            <div class="flag__status" role="status"></div>
          </div>
        </details>

        {d.videoId && (
          <div class="video-embed">
            <iframe
              src={embedUrl(d.videoId)}
              title={`Source video: ${d.headline}`}
              loading="lazy"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"
            ></iframe>
          </div>
        )}

        {d.topics.length > 0 && (
          <div class="topics">
            <h2 class="small-caps">Topics in This Edition</h2>
            <div class="topics__tags">
              {d.topics.map((t) => <span class="topic-tag">{t}</span>)}
            </div>
          </div>
        )}

        <section class="report__section">
          <h2 class="small-caps">Summary</h2>
          {paragraphs(d.summary).map((p) => <p>{p}</p>)}
        </section>

        <section class="report__section">
          <h2 class="small-caps">Editorial Assessment</h2>
          {paragraphs(d.assessment!).map((p) => <p>{p}</p>)}
        </section>

        {d.keyMoments.length > 0 && <KeyMoments moments={d.keyMoments} />}

        {d.notableConcerns.length > 0 && (
          <section class="notable-concerns">
            <h2 class="small-caps">Notable Concerns</h2>
            <ul>
              {d.notableConcerns.map((c) => <li>{c}</li>)}
            </ul>
          </section>
        )}

        <div class="post__body report__body">
          <Content />
        </div>
      </div>
    ) : (
      <div class="post__body">
        <Content />
      </div>
    )}

    {d.citations.length > 0 && (
      <section class="sources">
        <h2>Sources Consulted</h2>
        <ol>
          {d.citations.map((c) => (
            <li>
              <a href={c.url} rel="noopener noreferrer" target="_blank">{c.title}</a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <Disclaimer />
  </article>

  <script is:inline>
    (() => {
      const box = document.querySelector(".flag");
      if (!box) return;
      const postId = box.getAttribute("data-post-id");
      const btn = box.querySelector(".flag__submit");
      const comment = box.querySelector(".flag__comment");
      const status = box.querySelector(".flag__status");
      const setStatus = (kind, msg) => {
        status.className = `flag__status flag__status--${kind}`;
        status.textContent = msg;
      };
      btn.addEventListener("click", async () => {
        const aspect = (box.querySelector('input[name="aspect"]:checked') || {}).value;
        const text = comment.value.trim();
        if (text.length < 3) {
          setStatus("error", "Please add a comment.");
          return;
        }
        btn.disabled = true;
        setStatus("info", "Submitting…");
        try {
          const res = await fetch("/api/flag", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ postId, aspect, comment: text }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Could not submit");
          box.querySelector(".flag__body").innerHTML =
            '<p class="flag__thanks">Thanks — your note was sent to the editor.</p>';
        } catch (err) {
          setStatus("error", String(err.message || err));
          btn.disabled = false;
        }
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const btn = document.getElementById("save-btn");
      if (!btn) return;
      const slug = btn.getAttribute("data-slug");
      const headline = btn.getAttribute("data-headline") || slug;
      const label = btn.querySelector(".save-btn__label");
      const icon = btn.querySelector(".save-btn__icon");
      let signedIn = false;
      let saved = false;

      const paint = () => {
        btn.setAttribute("aria-pressed", saved ? "true" : "false");
        btn.classList.toggle("save-btn--on", saved);
        icon.textContent = saved ? "♥" : "♡";
        label.textContent = saved ? "Saved" : "Save";
      };

      // Determine sign-in + saved state, then reveal the button.
      fetch("/api/me/favorites", { headers: { Accept: "application/json" } })
        .then((res) => {
          if (res.status === 401) { signedIn = false; return null; }
          signedIn = true;
          return res.json().catch(() => null);
        })
        .then((data) => {
          if (data && Array.isArray(data.favorites)) {
            saved = data.favorites.some((f) => f.slug === slug);
          }
          paint();
        })
        .finally(() => { btn.hidden = false; });

      btn.addEventListener("click", async () => {
        if (!signedIn) {
          const next = encodeURIComponent(location.pathname);
          location.href = "/login/?next=" + next;
          return;
        }
        const next = !saved;
        btn.disabled = true;
        try {
          const res = await fetch("/api/me/favorites", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug, headline, favorite: next }),
          });
          if (!res.ok) throw new Error();
          saved = next;
          paint();
        } catch {
          /* leave state unchanged on failure */
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</BaseLayout>
